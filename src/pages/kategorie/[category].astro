---
import { getCollection } from "astro:content";
import AffiliateLayout from "../../layouts/AffiliateLayout.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  const categories = [
    ...new Map(
      pages.map((page) => [
        page.data.category,
        {
          slug: page.data.category,
          label: page.data.categoryLabel,
        },
      ]),
    ).values(),
  ];

  return categories.map((category) => ({
    params: {
      category: category.slug,
    },
    props: {
      category,
    },
  }));
}

const { category } = Astro.props;

const pages = await getCollection("pages");

const categoryPages = pages.filter(
  (page) => page.data.category === category.slug,
);
---

<AffiliateLayout
  title={`${category.label} | Solar Ratgeber`}
  description={`Alle Ratgeber, Vergleiche und Empfehlungen zum Thema ${category.label}.`}
>
  <section class="hero">
    <h1>{category.label}</h1>
    <p>Alle Ratgeber, Vergleiche und Empfehlungen zu diesem Thema.</p>
  </section>

  <h2 class="section-title">
    Artikel zu {category.label}
  </h2>

  <div class="card-grid">
    {
      categoryPages.map((page) => (
        <a class="card" href={`/${page.data.slug}`}>
          <div class="card-category">{page.data.categoryLabel}</div>

          <h3>{page.data.title}</h3>

          <p>{page.data.description}</p>
        </a>
      ))
    }
  </div>
</AffiliateLayout>
