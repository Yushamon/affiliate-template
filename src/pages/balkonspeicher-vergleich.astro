---
import AffiliateLayout from "../layouts/AffiliateLayout.astro";
import ComparisonExperience from "../components/ComparisonExperience.astro";
import { products, type ProductKey } from "../data/products";
import { getScoredProducts } from "../data/productScoring";

const productKeys = getScoredProducts().map(({ key }) => key as ProductKey);
const leadProduct = products[productKeys[0]];
---

<AffiliateLayout
  title="Balkonspeicher Vergleich"
  description="Balkonspeicher vergleichen und passende Lösungen für unterschiedliche Haushalte finden."
  canonical="/balkonspeicher-vergleich"
>
  <main class="ranking-page">
    <section class="ranking-hero">
      <div class="ranking-hero-copy">
        <p class="ranking-eyebrow">Vergleich</p>
        <h1>Balkonspeicher im direkten Vergleich</h1>
        <p class="ranking-hero-intro">
          Kapazität, Erweiterbarkeit, App und Einsatzbereich auf einen Blick – damit du schneller das System findest, das wirklich zu deinem Haushalt passt.
        </p>

        <div class="ranking-trust" aria-label="Grundlage des Vergleichs">
          <span><strong>4</strong> Systeme verglichen</span>
          <span>Transparent bewertet</span>
          <span>Nach Einsatzbereich sortiert</span>
        </div>
      </div>

      <div class="ranking-hero-summary">
        <span>Stärkstes Gesamtpaket</span>
        <img src={leadProduct.image} alt={leadProduct.name} loading="eager" decoding="async" />
        <strong>{leadProduct.name}</strong>
        <a href={leadProduct.productUrl}>Testbericht ansehen</a>
      </div>
    </section>

    <ComparisonExperience
      productKeys={productKeys}
      recommendationTitle="Welcher Balkonspeicher passt zu dir?"
      recommendationText="Unsere Gesamtwahl bietet das ausgewogenste Paket. Für Einsteiger, Nachrüstung und preisbewusste Käufer können andere Systeme die passendere Entscheidung sein."
      tableTitle="Vier Systeme im direkten Vergleich"
      cardsTitle="Unsere Favoriten im Detail"
    />

    <section class="article comparison-advice">
      <h2>Worauf kommt es beim Vergleich an?</h2>
      <p>
        Entscheidend ist nicht nur die nominelle Kapazität. Ein guter Balkonspeicher muss zu deinem Solarüberschuss, dem vorhandenen Wechselrichter und deinem täglichen Verbrauch passen. App, Erweiterbarkeit und Garantie beeinflussen außerdem, wie gut das System langfristig funktioniert.
      </p>
    </section>
  </main>
</AffiliateLayout>
