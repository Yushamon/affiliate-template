---
import { getCollection, render } from "astro:content";
import AffiliateLayout from "../layouts/AffiliateLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import FAQ from "../components/FAQ.astro";
import RelatedArticles from "../components/RelatedArticles.astro";
import ProductBox from "../components/ProductBox.astro";
import ProductComparisonTable from "../components/ProductComparisonTable.astro";
import StorageCalculator from "../components/StorageCalculator.astro";
import EconomicCalculator from "../components/calculator/EconomicCalculator.astro";
import IntentCTA from "../components/IntentCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import InternalLinks from "../components/InternalLinks.astro";
import { recommendations } from "../data/recommendations";
import { internalLinks } from "../data/internalLinks";
import PremiumRenderer from "../components/content/PremiumRenderer.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => ({
    params: {
      slug: page.data.slug,
    },
    props: {
      page,
    },
  }));
}

const { page } = Astro.props;

const { Content, headings } = await render(page);

const allPages = await getCollection("pages");

const relatedPages = allPages
  .filter((candidate) => {
    if (candidate.data.slug === page.data.slug) {
      return false;
    }

    const commonTags = candidate.data.tags.filter((tag) =>
      page.data.tags.includes(tag)
    );

    return (
      candidate.data.category === page.data.category ||
      commonTags.length > 0
    );
  })
  .sort((a, b) => {
    const aMatches = a.data.tags.filter((tag) =>
      page.data.tags.includes(tag)
    ).length;

    const bMatches = b.data.tags.filter((tag) =>
      page.data.tags.includes(tag)
    ).length;

    return bMatches - aMatches;
  })
  .slice(0, 3);

const showStorageCalculator =
  page.data.slug === "balkonspeicher-groesse-berechnen";

const showEconomicCalculator =
  page.data.slug === "balkonspeicher-wirtschaftlichkeit" ||
  page.data.slug === "balkonspeicher-amortisation";

const recommendation = page.data.intent
  ? recommendations[page.data.intent]
  : null;

const topicKey =
  page.data.topic && page.data.topic in internalLinks
    ? page.data.topic
    : "allgemein";

const internalLinkSlugs =
  internalLinks[topicKey as keyof typeof internalLinks].filter(
    (slug) => slug !== page.data.slug
  );

const internalLinkPages = internalLinkSlugs
  .map((slug) =>
    allPages.find((candidate) => candidate.data.slug === slug)
  )
  .filter(Boolean)
  .slice(0, 4);
---

<AffiliateLayout
  title={page.data.title}
  description={page.data.description}
  canonical={`/${page.data.slug}`}
  ogImage={page.data.ogImage || page.data.heroImage}
  faq={page.data.faq}
>
  <Breadcrumbs
    categoryLabel={page.data.categoryLabel}
    title={page.data.title}
  />

  <section class="article-header">
    <div class="article-category">
      {page.data.categoryLabel}
    </div>

    <h1 class="article-title">
      {page.data.title}
    </h1>

    <p class="article-description">
      {page.data.description}
    </p>
  </section>

  {
    page.data.heroImage && (
      <section class="article-hero">
        <img
          src={page.data.heroImage}
          alt={page.data.title}
          class="article-hero-image"
        />
      </section>
    )
  }

  <article class="article">
    <TableOfContents headings={headings} />

    {
      showStorageCalculator && (
        <section id="rechner" class="calculator-section">
          <StorageCalculator />
        </section>
      )
    }
<PremiumRenderer blocks={page.data.premiumBlocks} />
    <Content />

    {
      showEconomicCalculator && (
        <section id="wirtschaftlichkeitsrechner" class="calculator-section">
          <EconomicCalculator />
        </section>
      )
    }

    {
      recommendation && (
        <ProductBox productKey={recommendation.recommendedProduct} />
      )
    }

    {
      recommendation && (
        <ProductComparisonTable
          productKeys={recommendation.comparisonProducts}
        />
      )
    }

    <InternalLinks pages={internalLinkPages} />

    {
      recommendation && (
        <IntentCTA
          title={recommendation.ctaTitle}
          text={recommendation.ctaText}
          url={recommendation.ctaUrl}
        />
      )
    }

    <FAQ items={page.data.faq} />
  </article>

  <RelatedArticles pages={relatedPages} />
</AffiliateLayout>