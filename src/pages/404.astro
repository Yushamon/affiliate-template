---
import AffiliateLayout from "../layouts/AffiliateLayout.astro";
---

<AffiliateLayout
  title="Seite nicht gefunden"
  description="Diese Seite konnte nicht gefunden werden."
  canonical="/404"
>
  <section class="article legal-page">
    <h1>
      Seite nicht gefunden
    </h1>

    <p>
      Die gesuchte Seite existiert nicht oder wurde verschoben.
    </p>

    <p>
      Du kannst zurück zur Startseite gehen oder direkt in den Balkonspeicher-Ratgeber einsteigen.
    </p>

    <p>
      <a href="/" class="premium-button premium-button-primary">
        Zur Startseite
      </a>
    </p>

    <p>
      <a href="/balkonspeicher">
        Zum Balkonspeicher Ratgeber
      </a>
    </p>
  </section>
</AffiliateLayout>