---
import AffiliateLayout from "../../layouts/AffiliateLayout.astro";
import ProductBox from "../../components/ProductBox.astro";
import RelatedArticles from "../../components/RelatedArticles.astro";
import { products, type ProductKey } from "../../data/products";
import { manufacturers } from "../../data/manufacturers";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  return Object.values(manufacturers).map((manufacturer) => ({
    params: {
      manufacturer: manufacturer.slug
    },
    props: {
      manufacturer
    }
  }));
}

const { manufacturer } = Astro.props;

const manufacturerProducts = Object.entries(products).filter(
  ([, product]) => product.manufacturer === manufacturer.slug
);

const pages = await getCollection("pages");

const manufacturerArticles = pages
  .filter((page) =>
    page.data.tags.includes(manufacturer.slug) ||
    page.data.slug.includes(manufacturer.slug)
  )
  .slice(0, 3);
---

<AffiliateLayout
  title={manufacturer.title}
  description={manufacturer.description}
  canonical={`/hersteller/${manufacturer.slug}`}
>
  <section class="manufacturer-hero">
    <div class="manufacturer-badge">
      Hersteller
    </div>

    <h1>
      {manufacturer.title}
    </h1>

    <p>
      {manufacturer.description}
    </p>
  </section>

  <section class="manufacturer-answer">
    <strong>
      Kurzantwort
    </strong>

    <p>
      {manufacturer.shortAnswer}
    </p>
  </section>

  <section class="manufacturer-content">
    <div>
      <h2>
        Warum {manufacturer.label}?
      </h2>

      <p>
        {manufacturer.intro}
      </p>
    </div>

    <div class="manufacturer-info-grid">
      <div class="manufacturer-info-card">
        <h3>
          Stärken
        </h3>

        <ul>
          {manufacturer.strengths.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="manufacturer-info-card">
        <h3>
          Geeignet für
        </h3>

        <ul>
          {manufacturer.suitableFor.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="manufacturer-products">
    <div class="manufacturer-section-header">
      <span>
        Produkte
      </span>

      <h2>
        Produkte von {manufacturer.label}
      </h2>
    </div>

    {
      manufacturerProducts.map(([key]) => (
        <ProductBox productKey={key as ProductKey} />
      ))
    }
  </section>

  <section class="manufacturer-alternatives">
    <div class="manufacturer-section-header">
      <span>
        Alternativen
      </span>

      <h2>
        Andere Hersteller vergleichen
      </h2>
    </div>

    <div class="manufacturer-alternative-grid">
      {manufacturer.alternatives.map((alternative) => (
        <a href={alternative.href} class="manufacturer-alternative-card">
          {alternative.label}
        </a>
      ))}
    </div>
  </section>

  {
    manufacturerArticles.length > 0 && (
      <RelatedArticles pages={manufacturerArticles} />
    )
  }
</AffiliateLayout>