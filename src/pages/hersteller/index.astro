---
import AffiliateLayout from "../../layouts/AffiliateLayout.astro";
import { manufacturers } from "../../data/manufacturers";
---

<AffiliateLayout
  title="Balkonspeicher Hersteller"
  description="EcoFlow, Anker, Zendure und Solakon im Überblick. Vergleiche bekannte Hersteller für Balkonspeicher und Balkonkraftwerke."
  canonical="/hersteller"
>
  <section class="manufacturer-hero">
    <div class="manufacturer-badge">
      Hersteller
    </div>

    <h1>
      Balkonspeicher Hersteller
    </h1>

    <p>
      EcoFlow, Anker, Zendure und Solakon gehören aktuell zu den wichtigsten Anbietern für Balkonspeicher. Hier findest du die Hersteller im Überblick.
    </p>
  </section>

  <section class="manufacturer-answer">
    <strong>
      Kurzantwort
    </strong>

    <p>
      Welcher Hersteller am besten passt, hängt vor allem davon ab, ob du ein einfaches Komplettsystem, maximale Erweiterbarkeit oder ein flexibles Nachrüstsystem suchst.
    </p>
  </section>

  <section class="home-section">
    <div class="home-section-header">
      <span>
        Übersicht
      </span>

      <h2>
        Hersteller vergleichen
      </h2>
    </div>

    <div class="home-manufacturer-grid-v2">
      {Object.values(manufacturers).map((manufacturer) => (
        <a
          href={`/hersteller/${manufacturer.slug}`}
          class="home-manufacturer-card-v2"
        >
          <div class="manufacturer-logo-placeholder">
            {manufacturer.label.slice(0, 1)}
          </div>

          <strong>
            {manufacturer.label}
          </strong>

          <p>
            {manufacturer.description}
          </p>
        </a>
      ))}
    </div>
  </section>
</AffiliateLayout>