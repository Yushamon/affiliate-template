---
import { getCollection } from "astro:content";
import AffiliateLayout from "../layouts/AffiliateLayout.astro";
import { site } from "../utils/site";

const pages = await getCollection("pages");

const featuredPages = pages.filter((page) => page.data.featured);
const latestPages = [...pages].slice(0, 6);

const categories = [
  ...new Map(
    pages.map((page) => [
      page.data.category,
      {
        slug: page.data.category,
        label: page.data.categoryLabel,
      },
    ]),
  ).values(),
];
---

<AffiliateLayout
  title={site.siteName}
  description={site.siteDescription}
  canonical="/"
>
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Balkonspeicher, Solarstrom und Eigenverbrauch</p>

      <h1>Balkonspeicher einfach verstehen, vergleichen und sinnvoll nutzen</h1>

      <p>
        Verständliche Ratgeber, Vergleiche und Empfehlungen rund um
        Balkonspeicher, Balkonkraftwerke und Solarstrom.
      </p>
    </div>
  </section>

  <h2 class="section-title">Beliebte Themen</h2>

  <div class="category-list">
    {
      categories.map((category) => (
        <a class="category-pill" href={`/kategorie/${category.slug}`}>
          {category.label}
        </a>
      ))
    }
  </div>

  {
    featuredPages.length > 0 && (
      <>
        <h2 class="section-title">Empfohlene Artikel</h2>

        <div class="card-grid">
          {featuredPages.map((page) => (
            <a class="card" href={`/${page.data.slug}`}>
              <div class="card-category">{page.data.categoryLabel}</div>

              <h3>{page.data.title}</h3>

              <p>{page.data.description}</p>
            </a>
          ))}
        </div>
      </>
    )
  }

  <h2 class="section-title">Neueste Artikel</h2>

  <div class="card-grid">
    {
      latestPages.map((page) => (
        <a class="card" href={`/${page.data.slug}`}>
          <div class="card-category">{page.data.categoryLabel}</div>

          <h3>{page.data.title}</h3>

          <p>{page.data.description}</p>
        </a>
      ))
    }
  </div>
</AffiliateLayout>
