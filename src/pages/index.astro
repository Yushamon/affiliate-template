---
import { getCollection } from "astro:content";
import AffiliateLayout from "../layouts/AffiliateLayout.astro";
import { site } from "../utils/site";

const pages = await getCollection("pages");

const featuredPages = pages.filter(
  (page) => page.data.featured
);

const latestPages = [...pages].slice(0, 6);

const categories = [
  ...new Map(
    pages.map((page) => [
      page.data.category,
      {
        slug: page.data.category,
        label: page.data.categoryLabel
      }
    ])
  ).values()
];
---

<AffiliateLayout
  title={site.siteName}
  description={site.siteDescription}
  canonical="/"
>

  <section class="home-hero">

    <div class="home-hero-content">

      <div class="hero-badge">
        Balkonspeicher · Balkonkraftwerke · Solarstrom
      </div>

      <h1>
        Balkonspeicher verständlich erklärt
      </h1>

      <p>
        Vergleiche, Erfahrungen und unabhängige Ratgeber rund um
        Balkonspeicher und Balkonkraftwerke.
      </p>

      <div class="hero-buttons">

        <a
          href="/beste-balkonspeicher"
          class="hero-button-primary"
        >
          Beste Balkonspeicher
        </a>

        <a
          href="/balkonspeicher-vergleich"
          class="hero-button-secondary"
        >
          Zum Vergleich
        </a>

      </div>

    </div>

  </section>

  <section class="home-featured">

    <div class="feature-card">
      <strong>
        15+
      </strong>

      <span>
        Ratgeber & Vergleiche
      </span>
    </div>

    <div class="feature-card">
      <strong>
        4
      </strong>

      <span>
        Hersteller im Vergleich
      </span>
    </div>

    <div class="feature-card">
      <strong>
        100%
      </strong>

      <span>
        Fokus auf Balkonspeicher
      </span>
    </div>

  </section>

  <h2 class="section-title">
    Beliebte Inhalte
  </h2>

  <div class="card-grid">

    <a
      class="card"
      href="/beste-balkonspeicher"
    >
      <div class="card-category">
        Vergleich
      </div>

      <h3>
        Beste Balkonspeicher
      </h3>

      <p>
        Die aktuell interessantesten Speicherlösungen im Überblick.
      </p>
    </a>

    <a
      class="card"
      href="/balkonspeicher-vergleich"
    >
      <div class="card-category">
        Vergleich
      </div>

      <h3>
        Balkonspeicher Vergleich
      </h3>

      <p>
        Direkter Vergleich der wichtigsten Systeme.
      </p>
    </a>

    <a
      class="card"
      href="/balkonspeicher"
    >
      <div class="card-category">
        Ratgeber
      </div>

      <h3>
        Balkonspeicher Hub
      </h3>

      <p>
        Alle wichtigen Themen rund um Speicher und Eigenverbrauch.
      </p>
    </a>

  </div>

  <h2 class="section-title">
    Kategorien
  </h2>

  <div class="category-list">

    {
      categories.map((category) => (
        <a
          class="category-pill"
          href={`/kategorie/${category.slug}`}
        >
          {category.label}
        </a>
      ))
    }

  </div>

  <h2 class="section-title">
    Empfohlene Artikel
  </h2>

  <div class="card-grid">

    {
      featuredPages.map((page) => (
        <a
          class="card"
          href={`/${page.data.slug}`}
        >

          <div class="card-category">
            {page.data.categoryLabel}
          </div>

          <h3>
            {page.data.title}
          </h3>

          <p>
            {page.data.description}
          </p>

        </a>
      ))
    }

  </div>

  <h2 class="section-title">
    Neueste Inhalte
  </h2>

  <div class="card-grid">

    {
      latestPages.map((page) => (
        <a
          class="card"
          href={`/${page.data.slug}`}
        >

          <div class="card-category">
            {page.data.categoryLabel}
          </div>

          <h3>
            {page.data.title}
          </h3>

          <p>
            {page.data.description}
          </p>

        </a>
      ))
    }

  </div>

</AffiliateLayout>