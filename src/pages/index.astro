---
import { getCollection } from "astro:content";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const pages = await getCollection("pages");

const featuredPages = pages.filter((page) => page.data.featured);

const latestPages = [...pages].slice(0, 6);

const categories = [
  ...new Map(
    pages.map((page) => [
      page.data.category,
      {
        slug: page.data.category,
        label: page.data.categoryLabel,
      },
    ]),
  ).values(),
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Solar Ratgeber</title>

    <meta
      name="description"
      content="Ratgeber, Vergleiche und Empfehlungen rund um Balkonkraftwerke, Speicher und Solarstrom."
    />
  </head>

  <body>
    <Header />

    <main class="container">
      <section class="hero">
        <h1>
          Smarte Solar-Ratgeber für Balkonkraftwerk, Speicher und Stromkosten
        </h1>

        <p>
          Verständliche Kaufberatungen, Vergleiche und Empfehlungen für mehr
          Unabhängigkeit vom Stromanbieter.
        </p>
      </section>

      <h2 class="section-title">Beliebte Themen</h2>

      <div class="category-list">
        {
          categories.map((category) => (
            <a class="category-pill" href={`/kategorie/${category.slug}`}>
              {category.label}
            </a>
          ))
        }
      </div>

      {
        featuredPages.length > 0 && (
          <>
            <h2 class="section-title">Empfohlene Artikel</h2>

            <div class="card-grid">
              {featuredPages.map((page) => (
                <a class="card" href={`/${page.data.slug}`}>
                  <div class="card-category">{page.data.categoryLabel}</div>

                  <h3>{page.data.title}</h3>

                  <p>{page.data.description}</p>
                </a>
              ))}
            </div>
          </>
        )
      }

      <h2 class="section-title">Neueste Artikel</h2>

      <div class="card-grid">
        {
          latestPages.map((page) => (
            <a class="card" href={`/${page.data.slug}`}>
              <div class="card-category">{page.data.categoryLabel}</div>

              <h3>{page.data.title}</h3>

              <p>{page.data.description}</p>
            </a>
          ))
        }
      </div>
    </main>
    <Footer />
  </body>
</html>
