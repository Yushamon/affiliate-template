---
import AffiliateLayout from "../../layouts/AffiliateLayout.astro";
import ProductReview from "../../components/product/ProductReview.astro";
import ProductBox from "../../components/ProductBox.astro";
import { products, type ProductKey } from "../../data/products";

export async function getStaticPaths() {
  return Object.keys(products).map((key) => ({
    params: {
      product: key
    },
    props: {
      productKey: key
    }
  }));
}

const { productKey } = Astro.props;

const product =
  products[productKey as ProductKey];

const manufacturerProducts =
  Object.entries(products).filter(
    ([key, item]) =>
      key !== productKey &&
      item.manufacturer === product.manufacturer
  );
---

<AffiliateLayout
  title={`${product.name} Erfahrungen`}
  description={`${product.name} im Testbericht. Vorteile, Nachteile, technische Daten, Einsatzbereiche und Alternativen.`}
  canonical={`/produkt/${productKey}`}
  ogImage={product.image}
>
  <ProductReview productKey={productKey as ProductKey} />

  <div class="manufacturer-link">
    <a href={`/hersteller/${product.manufacturer}`}>
      Weitere Informationen zu {product.manufacturerLabel} →
    </a>
  </div>

  {
    manufacturerProducts.length > 0 && (
      <>
        <h2 class="section-title">
          Weitere Produkte von {product.manufacturerLabel}
        </h2>

        <div class="card-grid">
          {
            manufacturerProducts.map(([key, item]) => (
              <a
                class="card"
                href={`/produkt/${key}`}
              >
                <div class="card-category">
                  {item.brand}
                </div>

                <h3>
                  {item.name}
                </h3>

                <p>
                  {item.recommendation}
                </p>
              </a>
            ))
          }
        </div>
      </>
    )
  }
</AffiliateLayout>