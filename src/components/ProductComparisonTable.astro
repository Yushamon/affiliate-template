---
import { products, type ProductKey } from "../data/products";

interface Props {
  productKeys: ProductKey[];
}

const { productKeys } = Astro.props;

const selectedProducts = productKeys
  .map((key) => products[key])
  .filter(Boolean);
---

{selectedProducts.length > 0 && (
  <section class="comparison-section">

    <div class="comparison-header">

      <h2>
        Balkonspeicher im Vergleich
      </h2>

      <p>
        Die wichtigsten Unterschiede der beliebtesten Systeme auf einen Blick.
      </p>

    </div>

    <div class="comparison-table-wrap">

      <table class="comparison-table">

        <thead>

          <tr>
            <th>Modell</th>
            <th>Kapazität</th>
            <th>Erweiterbar</th>
            <th>Bewertung</th>
          </tr>

        </thead>

        <tbody>

          {
            selectedProducts.map((product) => (
              <tr>

                <td>

                  <div class="comparison-product">

                    <strong>
                      {product.name}
                    </strong>

                    <span>
                      {product.brand}
                    </span>

                  </div>

                </td>

                <td>
                  {product.capacity}
                </td>

                <td>
                  {product.expandable}
                </td>

                <td>
                  ★ {product.rating}
                </td>

              </tr>
            ))
          }

        </tbody>

      </table>

    </div>

  </section>
)}