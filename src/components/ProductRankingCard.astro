---
import { products, type ProductKey } from "../data/products";
import { getScoreLabel } from "../data/productScoring";

interface Props {
  productKey: ProductKey;
  rank: number;
  score: number;
  positionLabel?: string;
}

const { productKey, rank, score, positionLabel = "Platz" } = Astro.props;
const product = products[productKey];

const hasAffiliate = Boolean(product.affiliateUrl?.trim());
const buttonHref = hasAffiliate ? product.affiliateUrl : product.productUrl;
const buttonLabel = hasAffiliate ? "Aktuellen Preis prüfen" : "Zum Testbericht";

const leadingListIcons = /^(?:\s*(?:✓|✔|✅|❌|✕|✖|✗|×|⚠️?|→))+\s*/u;
const stripLeadingIcon = (value: string) =>
  value.replace(leadingListIcons, "");

const highlights = product.highlights.slice(0, 3);
const specs = product.specs.slice(0, 3);
---

<article class="product-ranking-card">
  <div class="product-ranking-card-media">
    <div class="product-ranking-position" aria-label={`${positionLabel} ${rank}`}>
      <span>{positionLabel}</span>
      <strong>{rank}</strong>
    </div>

    <span class="product-ranking-badge">{product.badge}</span>

    <img
      src={product.image}
      alt={product.name}
      loading={rank === 1 ? "eager" : "lazy"}
      decoding="async"
    />
  </div>

  <div class="product-ranking-card-content">
    <div class="product-ranking-meta">
      <span>{product.brand}</span>
      <span class="product-ranking-rating">
        <span aria-hidden="true">★</span> {product.rating} / 5
      </span>
    </div>

    <div class="product-ranking-title-row">
      <div>
        <h2>{product.name}</h2>
        <p>{product.recommendation}</p>
      </div>

      <div class="product-ranking-score" aria-label={`Score ${score} von 100`}>
        <strong>{score}</strong>
        <span>{getScoreLabel(score)}</span>
      </div>
    </div>

    <div class="product-ranking-details">
      <div class="product-ranking-highlights">
        {highlights.map((highlight) => (
          <div>
            <span aria-hidden="true">✓</span>
            <span>{stripLeadingIcon(highlight)}</span>
          </div>
        ))}
      </div>

      <dl class="product-ranking-specs">
        {specs.map((spec) => (
          <div>
            <dt>{spec.label}</dt>
            <dd>{spec.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="product-ranking-actions">
      <a
        class="product-ranking-cta"
        href={buttonHref}
        rel={hasAffiliate ? "sponsored nofollow noopener" : undefined}
        target={hasAffiliate ? "_blank" : undefined}
      >
        {buttonLabel}
      </a>

      <a class="product-ranking-review-link" href={product.productUrl}>
        Testbericht lesen
      </a>
    </div>
  </div>
</article>
