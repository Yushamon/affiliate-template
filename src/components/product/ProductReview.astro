---
import ProductBox from "../ProductBox.astro";
import { products, type ProductKey } from "../../data/products";
import { productReviews } from "../../data/productReviews";

interface Props {
  productKey: ProductKey;
}

const { productKey } = Astro.props;

const product = products[productKey];
const review = productReviews[productKey] ?? (product
  ? {
      summary: product.review.summary,
      verdict: product.review.verdict,
      pros: product.pros,
      cons: product.cons,
      bestFor: product.bestFor,
      notFor: product.notFor,
      ratings: product.ratings
    }
  : null);

const legacySpecs = product
  ? [
      { label: "Hersteller", value: product.manufacturerLabel },
      { label: "Kategorie", value: product.category },
      { label: "Kapazität", value: product.capacity },
      { label: "Erweiterbar", value: product.expandable },
      { label: "Einsatzbereich", value: product.useCase },
      { label: "Bewertung", value: `${product.rating} / 5` }
    ]
  : [];

const specs = product?.specs?.length ? product.specs : legacySpecs;

const ratingLabels: Record<string, string> = {
  installation: "Installation",
  app: "App",
  flexibility: "Flexibilität",
  pricePerformance: "Preis-Leistung",
  expandability: "Erweiterbarkeit",
  battery: "Akku",
  cleaning: "Reinigung",
  noise: "Lautstärke",
  safety: "Sicherheit"
};

const getRatingLabel = (key: string) => {
  if (ratingLabels[key]) {
    return ratingLabels[key];
  }

  return key
    .replace(/([a-z0-9])([A-Z])/g, "$1 $2")
    .replace(/[-_]+/g, " ")
    .trim()
    .replace(/\b\w/g, (character) => character.toUpperCase());
};

const ratingEntries =
  review?.ratings &&
  typeof review.ratings === "object" &&
  !Array.isArray(review.ratings)
    ? Object.entries(review.ratings).filter(([, rating]) =>
        Number.isFinite(rating)
      )
    : [];

const stars = (rating: number) => {
  const normalizedRating = Math.max(0, Math.min(5, Math.round(rating)));

  return "★".repeat(normalizedRating) + "☆".repeat(5 - normalizedRating);
};

const leadingListIcons = /^(?:\s*(?:✓|✔|✅|❌|✕|✖|✗|×))+\s*/u;

const stripLeadingIcon = (value: string) =>
  value.replace(leadingListIcons, "");
---

{product && review && (
  <article class="product-review-v3">
    <section class="product-review-hero-v3">
      <div class="product-review-hero-copy">
        <div class="article-category">
          Testbericht
        </div>

        <h1>
          {product.name}
        </h1>

        <p>
          {review.summary}
        </p>

        <div class="product-review-rating">
          <strong>
            {product.rating} / 5
          </strong>

          <span>
            Unsere Bewertung
          </span>
        </div>
      </div>

      <div class="product-review-hero-image">
        <img src={product.image} alt={product.name} loading="eager" />
      </div>
    </section>

    <section class="product-verdict-v3">
      <span>
        Kurzfazit
      </span>

      <h2>
        {product.recommendation}
      </h2>

      <p>
        {review.verdict}
      </p>
    </section>

    {ratingEntries.length > 0 && (
      <section class="product-score-grid-v3">
        {ratingEntries.map(([key, rating]) => (
          <div>
            <strong>{getRatingLabel(key)}</strong>
            <span>{stars(rating)}</span>
          </div>
        ))}
      </section>
    )}

    <section class="product-review-grid-v3">
      <div class="product-review-card-v3">
        <h2>
          Vorteile
        </h2>

        <ul>
          {review.pros.map((item) => (
            <li>✓ {stripLeadingIcon(item)}</li>
          ))}
        </ul>
      </div>

      <div class="product-review-card-v3">
        <h2>
          Nachteile
        </h2>

        <ul>
          {review.cons.map((item) => (
            <li>× {stripLeadingIcon(item)}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="product-review-grid-v3">
      <div class="product-review-card-v3">
        <h2>
          Ideal für
        </h2>

        <ul>
          {review.bestFor.map((item) => (
            <li>✓ {stripLeadingIcon(item)}</li>
          ))}
        </ul>
      </div>

      <div class="product-review-card-v3">
        <h2>
          Weniger geeignet für
        </h2>

        <ul>
          {review.notFor.map((item) => (
            <li>× {stripLeadingIcon(item)}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="product-review-card-v3">
      <h2>
        Technische Daten
      </h2>

      <div class="product-review-specs-v3">
        {specs.map((spec) => (
          <div>
            <strong>{spec.label}</strong>
            <span>{spec.value}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="product-verdict-v3">
      <span>
        Unser Urteil
      </span>

      <h2>
        Lohnt sich {product.name}?
      </h2>

      <p>
        {review.verdict}
      </p>
    </section>

    <ProductBox
      productKey={productKey}
      currentProductKey={productKey}
    />
  </article>
)}
