---
import ProductBox from "../ProductBox.astro";
import { products, type ProductKey } from "../../data/products";
import { productReviews } from "../../data/productReviews";

interface Props {
  productKey: ProductKey;
}

const { productKey } = Astro.props;

const product = products[productKey];
const review = productReviews[productKey];

const stars = (rating: number) =>
  "★".repeat(rating) + "☆".repeat(5 - rating);
---

{product && review && (
  <article class="product-review-v3">
    <section class="product-review-hero-v3">
      <div class="product-review-hero-copy">
        <div class="article-category">
          Testbericht
        </div>

        <h1>
          {product.name}
        </h1>

        <p>
          {review.summary}
        </p>

        <div class="product-review-rating">
          <strong>
            {product.rating} / 5
          </strong>

          <span>
            Unsere Bewertung
          </span>
        </div>
      </div>

      <div class="product-review-hero-image">
        <img src={product.image} alt={product.name} loading="eager" />
      </div>
    </section>

    <section class="product-verdict-v3">
      <span>
        Kurzfazit
      </span>

      <h2>
        {product.recommendation}
      </h2>

      <p>
        {review.verdict}
      </p>
    </section>

    <section class="product-score-grid-v3">
      <div>
        <strong>Installation</strong>
        <span>{stars(review.ratings.installation)}</span>
      </div>

      <div>
        <strong>App</strong>
        <span>{stars(review.ratings.app)}</span>
      </div>

      <div>
        <strong>Flexibilität</strong>
        <span>{stars(review.ratings.flexibility)}</span>
      </div>

      <div>
        <strong>Preis-Leistung</strong>
        <span>{stars(review.ratings.pricePerformance)}</span>
      </div>

      <div>
        <strong>Erweiterbarkeit</strong>
        <span>{stars(review.ratings.expandability)}</span>
      </div>
    </section>

    <section class="product-review-grid-v3">
      <div class="product-review-card-v3">
        <h2>
          Vorteile
        </h2>

        <ul>
          {review.pros.map((item) => (
            <li>✓ {item}</li>
          ))}
        </ul>
      </div>

      <div class="product-review-card-v3">
        <h2>
          Nachteile
        </h2>

        <ul>
          {review.cons.map((item) => (
            <li>× {item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="product-review-grid-v3">
      <div class="product-review-card-v3">
        <h2>
          Ideal für
        </h2>

        <ul>
          {review.bestFor.map((item) => (
            <li>✓ {item}</li>
          ))}
        </ul>
      </div>

      <div class="product-review-card-v3">
        <h2>
          Weniger geeignet für
        </h2>

        <ul>
          {review.notFor.map((item) => (
            <li>× {item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="product-review-card-v3">
      <h2>
        Technische Daten
      </h2>

      <div class="product-review-specs-v3">
        <div>
          <strong>Hersteller</strong>
          <span>{product.manufacturerLabel}</span>
        </div>

        <div>
          <strong>Kategorie</strong>
          <span>{product.category}</span>
        </div>

        <div>
          <strong>Kapazität</strong>
          <span>{product.capacity}</span>
        </div>

        <div>
          <strong>Erweiterbar</strong>
          <span>{product.expandable}</span>
        </div>

        <div>
          <strong>Einsatzbereich</strong>
          <span>{product.useCase}</span>
        </div>

        <div>
          <strong>Bewertung</strong>
          <span>{product.rating} / 5</span>
        </div>
      </div>
    </section>

    <section class="product-verdict-v3">
      <span>
        Unser Urteil
      </span>

      <h2>
        Lohnt sich {product.name}?
      </h2>

      <p>
        {review.verdict}
      </p>
    </section>

    <ProductBox
      productKey={productKey}
      currentProductKey={productKey}
    />
  </article>
)}