---
import { products, type ProductKey } from "../../data/products";

type PremiumBlockType =
  | "answer"
  | "quickFacts"
  | "scenarios"
  | "decision"
  | "steps"
  | "products"
  | "checks"
  | "mistakes"
  | "expert"
  | "vde"
  | "recommendation"
  | "checklist";

type PremiumCard = {
  label?: string;
  title: string;
  text?: string;
  value?: string;
  href?: string;
  cta?: string;
  badge?: string;
  productKey?: ProductKey;
  items?: string[];
};

type PremiumBlock = {
  type: PremiumBlockType;
  eyebrow?: string;
  title?: string;
  text?: string;
  cards?: PremiumCard[];
  items?: string[];
  href?: string;
  cta?: string;
};

interface Props {
  blocks?: PremiumBlock[];
}

const { blocks = [] } = Astro.props;
---

{blocks.length > 0 && (
  <div class="premium-v2">
    {blocks.map((block) => (
      <section class={`premium-v2-block premium-v2-${block.type}`}>
        {(block.eyebrow || block.title || block.text) && (
          <div class="premium-v2-header">
            {block.eyebrow && <span>{block.eyebrow}</span>}
            {block.title && <h2>{block.title}</h2>}
            {block.text && <p>{block.text}</p>}
          </div>
        )}

        {block.cards && block.cards.length > 0 && (
          <div class="premium-v2-grid">
            {block.cards.map((card, index) => {
              const product = card.productKey ? products[card.productKey] : null;
              const href = card.href ?? product?.productUrl;

              return (
                <article class="premium-v2-card">
                  {card.label && <span class="premium-v2-label">{card.label}</span>}
                  {card.badge && <span class="premium-v2-badge">{card.badge}</span>}

                  {card.value && <strong class="premium-v2-value">{card.value}</strong>}

                  <h3>{product ? product.name : card.title}</h3>

                  {card.text && <p>{card.text}</p>}
                  {product && <p>{product.recommendation}</p>}

                  {card.items && (
                    <ul>
                      {card.items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  )}

                  {product && (
                    <ul>
                      {product.highlights.slice(0, 3).map((item) => (
                        <li>✓ {item}</li>
                      ))}
                    </ul>
                  )}

                  {href && (
                    <a href={href}>
                      {card.cta ?? block.cta ?? "Mehr erfahren"}
                    </a>
                  )}
                </article>
              );
            })}
          </div>
        )}

        {block.items && block.items.length > 0 && (
          <ul class="premium-v2-list">
            {block.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}

        {block.href && (
          <a class="premium-v2-button" href={block.href}>
            {block.cta ?? "Mehr erfahren"}
          </a>
        )}
      </section>
    ))}
  </div>
)}