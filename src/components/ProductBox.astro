---
import Button from "./ui/Button.astro";
import Badge from "./ui/Badge.astro";
import { products, type ProductKey } from "../data/products";

interface Props {
  productKey: ProductKey;
  currentProductKey?: ProductKey;
}

const {
  productKey,
  currentProductKey
} = Astro.props;

const product = products[productKey];

const isCurrentProduct =
  currentProductKey === productKey;

const hasAffiliate =
  Boolean(
    product?.affiliateUrl &&
    product.affiliateUrl.trim().length > 0
  );

const buttonHref = hasAffiliate
  ? product.affiliateUrl
  : product.productUrl;

const buttonLabel = hasAffiliate
  ? "Preis bei Amazon ansehen"
  : "Zum Testbericht";

const showButton =
  hasAffiliate || !isCurrentProduct;
---

{
product && (

<section class="product-box-v2">

<div class="product-box-image">

<Badge
label={product.badge}
/>

<img
src={product.image}
alt={product.name}
loading="lazy"
/>

</div>

<div class="product-box-content">

<div class="product-box-brand">

{product.brand}

</div>

<h2>

{product.name}

</h2>

<div class="product-box-rating">

★★★★★

<span>

{product.rating} / 5

</span>

</div>

<p class="product-box-text">

{product.recommendation}

</p>

<div class="product-box-highlights">

{
product.highlights.map(item=>(
<div>

✓ {item}

</div>
))
}

</div>

<div class="product-box-specs">

<div>

<strong>

Kapazität

</strong>

<span>

{product.capacity}

</span>

</div>

<div>

<strong>

Erweiterbar

</strong>

<span>

{product.expandable}

</span>

</div>

</div>

{

showButton && (

<Button
href={buttonHref}
label={buttonLabel}
/>

)

}

{

hasAffiliate && (

<p class="affiliate-note">

Als Amazon-Partner erhalten wir bei qualifizierten Verkäufen eine Provision.

</p>

)

}

</div>

</section>

)
}