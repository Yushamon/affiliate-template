---
import { products, type ProductKey } from "../data/products";

interface Props {
  productKey: ProductKey;
  currentProductKey?: ProductKey;
}

const { productKey, currentProductKey } = Astro.props;
const product = products[productKey];

const isCurrentProduct =
  currentProductKey === productKey;

const hasAffiliate =
  product?.affiliateUrl &&
  product.affiliateUrl.length > 0;

const buttonLabel = hasAffiliate
  ? "Preis prüfen"
  : "Testbericht lesen";

const buttonHref = hasAffiliate
  ? product.affiliateUrl
  : product.productUrl;

const showButton =
  !isCurrentProduct;
---

{product && (
  <section class="product-box">
    <div class="product-image-area">
      <div class="product-badge">
        🏆 {product.badge}
      </div>

      <img
        src={product.image}
        alt={product.name}
        class="product-image"
        loading="lazy"
      />
    </div>

    <div class="product-content">
      <div class="product-brand">
        {product.brand}
      </div>

      <h2>
        {product.name}
      </h2>

      <div class="product-rating">
        ★★★★★
        <span>{product.rating} / 5</span>
      </div>

      <p class="product-recommendation">
        {product.recommendation}
      </p>

      <ul class="product-highlights">
        {product.highlights.map((item) => (
          <li>✓ {item}</li>
        ))}
      </ul>

      <div class="product-specs">
        <div class="product-spec">
          <strong>Kapazität</strong>
          <span>{product.capacity}</span>
        </div>

        <div class="product-spec">
          <strong>Erweiterbar</strong>
          <span>{product.expandable}</span>
        </div>
      </div>

      {showButton && (
        <a
          href={buttonHref}
          class="product-button"
          target={hasAffiliate ? "_blank" : undefined}
          rel={hasAffiliate ? "nofollow sponsored" : undefined}
        >
          {buttonLabel}
        </a>
      )}
    </div>
  </section>
)}