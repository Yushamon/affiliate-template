---
import Accordion from "./ui/Accordion.astro";

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
}

const { items = [] } = Astro.props;
---

{items.length > 0 && (
  <section class="faq-section">
    <div class="ui-section-header">
      <span>FAQ</span>
      <h2>Häufige Fragen</h2>
    </div>

    <Accordion items={items} />
  </section>
)}