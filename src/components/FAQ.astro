---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
}

const { items = [] } = Astro.props;
---

{
  items.length > 0 && (
    <section class="faq-section">
      <h2>Häufige Fragen</h2>

      <div class="faq-list">
        {items.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  )
}
