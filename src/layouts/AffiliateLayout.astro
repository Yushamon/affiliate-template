---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../utils/site";
import { siteMeta } from "../data/siteMeta";

interface FAQItem {
  question: string;
  answer: string;
}

interface Author {
  name: string;
  role?: string;
  url?: string;
}

interface Props {
  title: string;
  description: string;
  seoTitle?: string;
  seoDescription?: string;
  canonical?: string;
  ogImage?: string;
  faq?: FAQItem[];
  author?: Author;
  publishedAt?: string;
  updatedAt?: string;
  categoryLabel?: string;
}

const {
  title,
  description,
  seoTitle,
  seoDescription,
  canonical = "/",
  ogImage,
  faq = [],
  author,
  publishedAt,
  updatedAt,
  categoryLabel
} = Astro.props;

const pageTitle = seoTitle ?? title;
const pageDescription = seoDescription ?? description;

const normalizedCanonical =
  canonical === "/"
    ? "/"
    : canonical.startsWith("/")
      ? canonical
      : `/${canonical}`;

const canonicalUrl = `${site.domain}${normalizedCanonical}`;

const imageUrl = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : `${site.domain}${ogImage}`
  : `${site.domain}/images/generated/home-hero.webp`;

const isHome = normalizedCanonical === "/";

const visibleAuthor = author ?? siteMeta.defaultAuthor;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.siteName,
  url: site.domain,
  logo: siteMeta.publisher.logo
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.siteName,
  url: site.domain,
  description: site.siteDescription,
  publisher: {
    "@type": "Organization",
    name: site.siteName,
    logo: {
      "@type": "ImageObject",
      url: siteMeta.publisher.logo
    }
  }
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  mainEntityOfPage: canonicalUrl,
  image: [imageUrl],
  inLanguage: "de-DE",
  author: {
    "@type": "Person",
    name: visibleAuthor.name,
    url: visibleAuthor.url ?? siteMeta.defaultAuthor.url
  },
  publisher: {
    "@type": "Organization",
    name: site.siteName,
    logo: {
      "@type": "ImageObject",
      url: siteMeta.publisher.logo
    }
  },
  datePublished: publishedAt ?? siteMeta.articleDefaults.publishedAt,
  dateModified:
    updatedAt ??
    publishedAt ??
    siteMeta.articleDefaults.updatedAt
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Startseite",
      item: site.domain
    },
    ...(categoryLabel
      ? [
          {
            "@type": "ListItem",
            position: 2,
            name: categoryLabel,
            item: `${site.domain}/balkonspeicher`
          },
          {
            "@type": "ListItem",
            position: 3,
            name: pageTitle,
            item: canonicalUrl
          }
        ]
      : [
          {
            "@type": "ListItem",
            position: 2,
            name: pageTitle,
            item: canonicalUrl
          }
        ])
  ]
};

const faqSchema =
  faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer
          }
        }))
      }
    : null;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{pageTitle}</title>

    <meta
      name="description"
      content={pageDescription}
    />

    <meta
      name="robots"
      content="index,follow"
    />

    <link
      rel="canonical"
      href={canonicalUrl}
    />

    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />

    <meta
      property="og:type"
      content={isHome ? "website" : "article"}
    />

    <meta
      property="og:title"
      content={pageTitle}
    />

    <meta
      property="og:description"
      content={pageDescription}
    />

    <meta
      property="og:url"
      content={canonicalUrl}
    />

    <meta
      property="og:site_name"
      content={site.siteName}
    />

    <meta
      property="og:image"
      content={imageUrl}
    />

    <meta
      name="twitter:card"
      content="summary_large_image"
    />

    <meta
      name="twitter:title"
      content={pageTitle}
    />

    <meta
      name="twitter:description"
      content={pageDescription}
    />

    <meta
      name="twitter:image"
      content={imageUrl}
    />

    {
      !isHome && publishedAt && (
        <meta
          property="article:published_time"
          content={publishedAt}
        />
      )
    }

    {
      !isHome && updatedAt && (
        <meta
          property="article:modified_time"
          content={updatedAt}
        />
      )
    }

    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />

    {
      !isHome && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(articleSchema)}
        />
      )
    }

    {
      !isHome && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbSchema)}
        />
      )
    }

    {
      faqSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(faqSchema)}
        />
      )
    }
  </head>

  <body>
    <Header />

    <main class="container">
      <slot />
    </main>

    <Footer />
  </body>
</html>