---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
}

const headings = Array.isArray(Astro.props.headings)
  ? Astro.props.headings
  : [];

const tocHeadings = headings.filter((heading) => heading.depth === 2);
const initiallyOpen = tocHeadings.length <= 6;
---

{
  tocHeadings.length > 0 && (
    <details class="pt-toc" open={initiallyOpen}>
      <summary class="pt-toc__summary">
        <span class="pt-toc__title">
          <span class="pt-toc__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20">
              <path d="M8 6h12M8 12h12M8 18h12M4 6h.01M4 12h.01M4 18h.01" />
            </svg>
          </span>
          <strong>Inhaltsverzeichnis</strong>
        </span>

        <span class="pt-toc__meta">
          {tocHeadings.length} Abschnitte
        </span>

        <span class="pt-toc__chevron" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20">
            <path d="m7 10 5 5 5-5" />
          </svg>
        </span>
      </summary>

      <ol class="pt-toc__list">
        {tocHeadings.map((heading, index) => (
          <li class="pt-toc__item">
            <a href={`#${heading.slug}`}>
              <span class="pt-toc__number">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span>{heading.text}</span>
            </a>
          </li>
        ))}
      </ol>
    </details>
  )
}

<style>
  .pt-toc {
    width: 100%;
    margin: 0 0 clamp(28px, 5vw, 48px);
    overflow: hidden;
    border: 1px solid var(--pt-theme-border, var(--border));
    border-radius: 22px;
    background: var(--pt-theme-surface, var(--surface));
    color: var(--pt-theme-text, var(--text));
    box-shadow: var(--pt-theme-shadow-sm, var(--shadow-soft));
  }

  .pt-toc__summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 14px;
    min-height: 76px;
    align-items: center;
    padding: 18px 22px;
    cursor: pointer;
    list-style: none;
    background: var(--pt-theme-surface, var(--surface));
    color: var(--pt-theme-text, var(--text));
    transition:
      background-color 160ms ease,
      color 160ms ease;
  }

  .pt-toc__summary::-webkit-details-marker {
    display: none;
  }

  .pt-toc__summary:hover {
    background: var(--pt-theme-surface-2, var(--surface-soft));
  }

  .pt-toc__title {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 12px;
    color: var(--pt-theme-text, var(--text));
  }

  .pt-toc__title strong {
    overflow: hidden;
    color: inherit;
    font-size: clamp(1rem, 2.8vw, 1.2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pt-toc__icon {
    display: inline-grid;
    width: 38px;
    height: 38px;
    flex: 0 0 38px;
    place-items: center;
    border-radius: 12px;
    background: var(--pt-theme-accent-soft, var(--primary-soft));
    color: var(--pt-theme-accent-text, var(--primary-dark));
  }

  .pt-toc__icon svg,
  .pt-toc__chevron svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .pt-toc__meta {
    color: var(--pt-theme-text-muted, var(--muted));
    font-size: 0.94rem;
    white-space: nowrap;
  }

  .pt-toc__chevron {
    display: inline-grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border-radius: 10px;
    color: var(--pt-theme-text-soft, var(--text));
    transition:
      background-color 160ms ease,
      transform 180ms ease;
  }

  .pt-toc[open] .pt-toc__chevron {
    transform: rotate(180deg);
  }

  .pt-toc__list {
    display: grid;
    gap: 2px;
    margin: 0;
    padding: 10px 14px 16px;
    border-top: 1px solid var(--pt-theme-divider, var(--border));
    list-style: none;
    background: var(--pt-theme-surface-2, var(--surface-soft));
  }

  .pt-toc__item {
    margin: 0;
    padding: 0;
  }

  .pt-toc__item a {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    padding: 11px 12px;
    border-radius: 12px;
    color: var(--pt-theme-text-soft, var(--text));
    line-height: 1.45;
    text-decoration: none;
  }

  .pt-toc__item a:hover,
  .pt-toc__item a:focus-visible {
    background: var(--pt-theme-surface-3, var(--bg-soft));
    color: var(--pt-theme-accent, var(--primary));
  }

  .pt-toc__number {
    padding-top: 0.05em;
    color: var(--pt-theme-text-muted, var(--muted));
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  @media (max-width: 620px) {
    .pt-toc {
      border-radius: 18px;
    }

    .pt-toc__summary {
      grid-template-columns: minmax(0, 1fr) auto;
      min-height: 68px;
      padding: 14px 16px;
    }

    .pt-toc__meta {
      display: none;
    }

    .pt-toc__icon {
      width: 34px;
      height: 34px;
      flex-basis: 34px;
    }

    .pt-toc__list {
      padding: 8px 8px 12px;
    }
  }
</style>
