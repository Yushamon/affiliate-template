---
import { getCollection, getEntry, render } from "astro:content";
import { getImage } from "astro:assets";
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import FAQ from "@affiliate-core/components/FAQ.astro";
import RelatedArticles from "@affiliate-core/components/RelatedArticles.astro";
import ConversionJourney from "../../components/ConversionJourney.astro";
import ComparisonShell from "@affiliate-core/components/comparison/ComparisonShell.astro";
import AutoLinkContent from "@affiliate-core/components/AutoLinkContent.astro";
import { buildComparisonViewModel } from "@app/domain/comparison/buildComparisonViewModel";
import {
  getComparisonBreadcrumbs,
  getRelatedContent
} from "@app/domain/content";
import {
  getInternalLinkDefinitions,
  getSourceContexts
} from "../../domain/content/internalLinks";

type Props = {
  comparisonId: string;
};

export async function getStaticPaths() {
  const comparisons = await getCollection("comparisons");

  return comparisons.map((entry) => ({
    params: {
      comparison: entry.data.slug
    },
    props: {
      comparisonId: entry.id
    } satisfies Props
  }));
}

const { comparisonId } = Astro.props as Props;
const entry = await getEntry("comparisons", comparisonId);

if (!entry) {
  throw new Error(
    `Vergleich "${comparisonId}" wurde nicht gefunden.`
  );
}

const comparison = entry.data;
const { Content } = await render(entry);

const [products, manufacturers, pages, comparisons] = await Promise.all([
  getCollection("products"),
  getCollection("manufacturers"),
  getCollection("pages"),
  getCollection("comparisons")
]);

const internalLinkDefinitions = getInternalLinkDefinitions({
  pages,
  products,
  comparisons,
  manufacturers
});
const sourceContexts = getSourceContexts(comparison);

const model = buildComparisonViewModel({
  comparison: entry,
  products,
  manufacturers
});

const optimizedOgImage = comparison.heroImage
  ? await getImage({
      src: comparison.heroImage.src,
      width: 1200,
      quality: "high"
    })
  : undefined;

const breadcrumbs = getComparisonBreadcrumbs(entry);

const relatedEntries = await getRelatedContent({
  currentSlug: comparison.slug,
  tags: comparison.related?.tags.length
    ? comparison.related.tags
    : comparison.tags,
  sections: comparison.hub?.sections ?? [],
  type: "comparison",
  exclude: comparison.related?.exclude ?? [],
  limit: comparison.related?.limit ?? 4
});

const relatedItems = relatedEntries.map((related) => ({
  href: related.href,
  label:
    related.type === "product"
      ? "Produkt"
      : related.type === "manufacturer"
        ? "Hersteller"
        : related.type === "comparison"
          ? "Vergleich"
          : "Ratgeber",
  title: related.hubTitle,
  text: related.hubDescription
}));
---

<ProjectLayout
  title={comparison.title}
  seoTitle={comparison.seo?.title ?? comparison.title}
  description={comparison.description}
  seoDescription={
    comparison.seo?.description ??
    comparison.description
  }
  canonical={
    comparison.seo?.canonical ??
    `/vergleiche/${comparison.slug}/`
  }
  noindex={comparison.seo?.noindex ?? false}
  ogImage={optimizedOgImage?.src}
  faq={comparison.faq}
  categoryLabel="Vergleiche"
  breadcrumbs={breadcrumbs}
  schemaType="webpage"
>
  <Breadcrumbs items={breadcrumbs} />

  <main class="comparison-detail">
    <ComparisonShell model={model} />

    <article class="comparison-content">
      <AutoLinkContent
        definitions={internalLinkDefinitions}
        sourcePath={`/vergleiche/${comparison.slug}/`}
        sourceGroup="comparison"
        sourceContexts={sourceContexts}
        maxLinksPerPage={6}
      >
        <Content />
      </AutoLinkContent>
    </article>

    <ConversionJourney
      title="Von der Vorauswahl zur passenden Entscheidung"
      intro="Nutze den Vergleich als Ausgangspunkt und vertiefe anschließend das Modell oder die Kriterien, die für deinen Alltag entscheidend sind."
      items={[
        {
          eyebrow: "Produkte",
          title: "Favoriten im Detail prüfen",
          text: "Öffne die Produkttests der Modelle, die bei deinen wichtigsten Kriterien vorne liegen.",
          href: "#vergleich",
          label: "Modelle vergleichen"
        },
        {
          eyebrow: "Kaufberatung",
          title: "Anforderungen genauer einordnen",
          text: "Prüfe Futterart, Tierzahl, Portionsgröße, App, Stromversorgung und Reinigungsaufwand.",
          href: "/smarte-futterautomaten/",
          label: "Kaufberatung lesen"
        },
        {
          eyebrow: "Praxis",
          title: "Betrieb und Reinigung vorbereiten",
          text: "Plane Einrichtung, Testportionen und regelmäßige Pflege schon vor dem Kauf.",
          href: "/futterautomat-richtig-reinigen/",
          label: "Praxisratgeber öffnen"
        }
      ]}
    />

    <RelatedArticles items={relatedItems} />

    {comparison.faq.length > 0 && (
      <FAQ items={comparison.faq} />
    )}
  </main>
</ProjectLayout>
