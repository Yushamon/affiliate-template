---
type Item = {
  eyebrow: string;
  title: string;
  text: string;
  href: string;
  label: string;
};

interface Props {
  title?: string;
  intro?: string;
  items: Item[];
}

const {
  title = "Passend weiterentscheiden",
  intro = "Nutze den nächsten Schritt, der zu deiner aktuellen Auswahl passt.",
  items
} = Astro.props;

const visibleItems = items.filter((item) => item?.href && item?.title && item?.label).slice(0, 2);
---

{visibleItems.length > 0 && (
  <section class="pt-next-steps" aria-labelledby="pt-next-steps-title">
    <header class="pt-next-steps__header">
      <p class="pt-next-steps__eyebrow">Nächster Schritt</p>
      <h2 id="pt-next-steps-title">{title}</h2>
      <p>{intro}</p>
    </header>

    <div class="pt-next-steps__grid">
      {visibleItems.map((item) => (
        <a class="pt-next-steps__card" href={item.href}>
          <span class="pt-next-steps__label">{item.eyebrow}</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <strong>{item.label}<span aria-hidden="true"> →</span></strong>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .pt-next-steps {
    width: min(100%, 1120px);
    margin: clamp(2.5rem, 6vw, 5rem) auto;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--border-color, rgba(15, 23, 42, 0.12));
    border-radius: 24px;
    background: var(--surface-color, #fff);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
  }
  .pt-next-steps__header { max-width: 760px; margin-bottom: 1.25rem; }
  .pt-next-steps__eyebrow, .pt-next-steps__label {
    margin: 0 0 0.45rem;
    color: var(--accent-color, #2e7d32);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pt-next-steps__header h2 { margin: 0; font-size: clamp(1.55rem, 3vw, 2.2rem); line-height: 1.15; }
  .pt-next-steps__header > p:last-child { margin: 0.7rem 0 0; color: var(--text-muted, #475569); }
  .pt-next-steps__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .pt-next-steps__card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    padding: clamp(1.1rem, 2.5vw, 1.5rem);
    border: 1px solid var(--border-color, rgba(15, 23, 42, 0.12));
    border-radius: 18px;
    background: var(--surface-subtle, rgba(248, 250, 252, 0.8));
    color: inherit;
    text-decoration: none;
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }
  .pt-next-steps__card:hover, .pt-next-steps__card:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent-color, #2e7d32);
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.09);
    outline: none;
  }
  .pt-next-steps__card h3 { margin: 0; font-size: clamp(1.05rem, 2vw, 1.25rem); line-height: 1.3; }
  .pt-next-steps__card p { margin: 0.7rem 0 1rem; color: var(--text-muted, #475569); line-height: 1.6; }
  .pt-next-steps__card strong { margin-top: auto; color: var(--accent-color, #2e7d32); }
  @media (max-width: 720px) {
    .pt-next-steps { border-radius: 20px; }
    .pt-next-steps__grid { grid-template-columns: 1fr; }
  }
  :global([data-theme="dark"]) .pt-next-steps,
  :global(html.dark) .pt-next-steps {
    --surface-color: #111827;
    --surface-subtle: rgba(30, 41, 59, 0.72);
    --text-muted: #cbd5e1;
    --border-color: rgba(148, 163, 184, 0.24);
  }
</style>

<style is:global>
  /* pfotentechnik-mobile-ux-hotfix-4.2 */
  @media (prefers-color-scheme: dark) {
    .pt-next-steps {
      --surface-color: #101f32;
      --surface-subtle: #16263c;
      --text-muted: #b8c4d3;
      --border-color: rgba(203, 213, 225, 0.16);
      --accent-color: #5ee19a;
      color: #f8fafc;
      box-shadow: 0 18px 44px rgba(0, 0, 0, 0.28);
    }

    .pt-next-steps__header h2,
    .pt-next-steps__card h3 {
      color: #f8fafc;
    }

    .pt-next-steps__card {
      color: #f8fafc;
    }
  }
</style>

<style is:global>
  /* money-pages-next-steps-4.3 */
  .pt-next-steps {
    --next-bg: linear-gradient(145deg, #0a4d3f 0%, #0b3e36 100%);
    --next-card: rgba(255, 255, 255, 0.08);
    --next-card-border: rgba(184, 239, 197, 0.24);
    --next-text: #f8fafc;
    --next-muted: #d7e4df;
    --next-accent: #63e6a3;

    color: var(--next-text);
    border-color: rgba(184, 239, 197, 0.2);
    background: var(--next-bg);
    box-shadow: 0 22px 60px rgba(4, 24, 20, 0.24);
  }

  .pt-next-steps__header h2,
  .pt-next-steps__card h3 {
    color: var(--next-text);
  }

  .pt-next-steps__header > p:last-child,
  .pt-next-steps__card p {
    color: var(--next-muted);
  }

  .pt-next-steps__eyebrow,
  .pt-next-steps__label,
  .pt-next-steps__card strong {
    color: var(--next-accent);
  }

  .pt-next-steps__card {
    border-color: var(--next-card-border);
    background: var(--next-card);
    color: var(--next-text);
    box-shadow: none;
  }

  .pt-next-steps__card:first-child {
    border-color: rgba(99, 230, 163, 0.6);
    background: linear-gradient(
      145deg,
      rgba(99, 230, 163, 0.15),
      rgba(255, 255, 255, 0.07)
    );
  }

  .pt-next-steps__card:hover,
  .pt-next-steps__card:focus-visible {
    border-color: var(--next-accent);
    box-shadow: 0 14px 34px rgba(3, 20, 16, 0.24);
  }

  @media (prefers-color-scheme: dark) {
    .pt-next-steps {
      --next-bg: linear-gradient(145deg, #0a4d3f 0%, #082f2a 100%);
      --next-card: rgba(15, 35, 47, 0.58);
      --next-card-border: rgba(99, 230, 163, 0.26);
      --next-text: #f8fafc;
      --next-muted: #d5e2dd;
      --next-accent: #63e6a3;
    }
  }

  @media (max-width: 720px) {
    .pt-next-steps {
      padding: 1.35rem;
    }

    .pt-next-steps__grid {
      gap: 0.85rem;
    }

    .pt-next-steps__card {
      padding: 1.2rem;
    }
  }
</style>

