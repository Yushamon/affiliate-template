---
interface Spec {
  label: string;
  value: string;
  context?: string;
  icon?: string;
}
interface Props { specs: Spec[]; }
const { specs } = Astro.props;
---

<section class="context-specs" aria-labelledby="context-specs-title">
  <h2 id="context-specs-title">Technische Daten mit Einordnung</h2>
  <div class="spec-list">
    {specs.map((spec) => (
      <article class="spec-row">
        {spec.icon && <span class="spec-icon" aria-hidden="true">{spec.icon}</span>}
        <div class="spec-main">
          <span>{spec.label}</span>
          <strong>{spec.value}</strong>
        </div>
        {spec.context && <p>{spec.context}</p>}
      </article>
    ))}
  </div>
</section>

<style>
  .context-specs {
    padding: clamp(18px, 3vw, 28px);
    border: 1px solid var(--ps2-border, #dce5e0);
    border-radius: 18px;
    background: var(--ps2-surface, #fff);
  }
  h2 { margin: 0 0 18px; font-size: clamp(1.2rem, 2vw, 1.5rem); }
  .spec-list { display: grid; gap: 1px; overflow: hidden; border: 1px solid var(--ps2-border, #dce5e0); border-radius: 14px; background: var(--ps2-border, #dce5e0); }
  .spec-row { display: grid; grid-template-columns: auto minmax(150px, .65fr) minmax(220px, 1.35fr); gap: 14px; align-items: center; padding: 15px 16px; background: var(--ps2-surface-soft, #f7faf8); }
  .spec-icon { display: grid; place-items: center; width: 34px; height: 34px; border-radius: 10px; background: color-mix(in srgb, var(--ps2-accent, #2e7d32) 12%, transparent); }
  .spec-main span { display: block; color: var(--ps2-muted, #637069); font-size: .8rem; }
  .spec-main strong { display: block; margin-top: 2px; }
  .spec-row p { margin: 0; color: var(--ps2-muted, #637069); }
  @media (max-width: 720px) {
    .spec-row { grid-template-columns: auto minmax(0,1fr); align-items: start; }
    .spec-row p { grid-column: 2; }
  }
  :global([data-theme="dark"]) .context-specs,
  :global(.dark) .context-specs {
    --ps2-surface: #171f1b;
    --ps2-surface-soft: #202a25;
    --ps2-border: #2c3932;
    --ps2-muted: #a0aea6;
    --ps2-accent: #79d5aa;
    color: #eff6f2;
  }
</style>
