---
import DecisionCard from "./DecisionCard.astro";
import QuickFacts from "./QuickFacts.astro";
import SuitabilityMatrix from "./SuitabilityMatrix.astro";
import ProsCons from "./ProsCons.astro";
import ContextSpecs from "./ContextSpecs.astro";
import AlternativesGrid from "./AlternativesGrid.astro";
import TrustBar from "./TrustBar.astro";

interface Props {
  product: any;
}

const { product } = Astro.props;
const data = product?.data ?? product ?? {};
const ps2 = data.productStandard2 ?? {};

const decision = ps2.decision ?? data.decision ?? null;
const facts = ps2.quickFacts ?? [];
const suitability = ps2.suitability ?? data.suitability ?? null;
const pros = ps2.pros ?? data.pros ?? [];
const cons = ps2.cons ?? data.cons ?? [];
const specs = ps2.contextSpecs ?? [];
const alternatives = ps2.alternatives ?? data.alternatives ?? [];
const trust = ps2.trust ?? null;

const hasDecision =
  decision &&
  ((Array.isArray(decision.goodFor) && decision.goodFor.length) ||
    (Array.isArray(decision.notFor) && decision.notFor.length));

const hasFacts = Array.isArray(facts) && facts.length > 0;
const hasSuitability =
  suitability &&
  typeof suitability === "object" &&
  Object.keys(suitability).length > 0;
const hasProsCons =
  (Array.isArray(pros) && pros.length > 0) ||
  (Array.isArray(cons) && cons.length > 0);
const hasSpecs = Array.isArray(specs) && specs.length > 0;
const hasAlternatives = Array.isArray(alternatives) && alternatives.length > 0;
const hasTrust = trust && typeof trust === "object";
---

<div class="product-standard-2" data-product-standard="2.0">
  {hasDecision && <DecisionCard decision={decision} />}
  {hasFacts && <QuickFacts facts={facts} />}
  {hasSuitability && <SuitabilityMatrix suitability={suitability} />}
  {hasProsCons && <ProsCons pros={pros} cons={cons} />}
  {hasSpecs && <ContextSpecs specs={specs} />}
  {hasAlternatives && <AlternativesGrid alternatives={alternatives} />}
  {hasTrust && <TrustBar trust={trust} />}
</div>

<style>
  .product-standard-2 {
    display: grid;
    gap: 20px;
    margin-block: 24px;
  }
</style>
