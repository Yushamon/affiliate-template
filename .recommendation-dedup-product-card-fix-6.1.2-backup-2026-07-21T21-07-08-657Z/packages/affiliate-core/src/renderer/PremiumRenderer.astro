---
import { stripLeadingIcon } from "../utils/content";
import OptimizedImage from "../components/OptimizedImage.astro";

type ProjectImageKey =
  | "hero" | "feature" | "inline" | "comparison" | "guide" | "faq"
  | "product" | "category" | "decision" | "calculator" | "manufacturer"
  | "feederHero" | "feederComparison" | "feederWetFood";

type PremiumProduct = {
  key: string;
  name: string;
  productUrl: string;
  badge?: string;
  recommendation: string;
  rating: number;
  highlights: string[];
  tags: string[];
  image?: {
    src: any;
    alt: string;
  };
};

type PremiumBlockType =
  | "answer"
  | "quickFacts"
  | "scenarios"
  | "decision"
  | "steps"
  | "products"
  | "checks"
  | "mistakes"
  | "expert"
  | "vde"
  | "recommendation"
  | "checklist";

type PremiumCard = {
  label?: string;
  title: string;
  text?: string;
  value?: string;
  href?: string;
  cta?: string;
  badge?: string;
  productKey?: string;
  items?: string[];
};

type PremiumBlock = {
  type: PremiumBlockType;
  eyebrow?: string;
  title?: string;
  text?: string;
  cards?: PremiumCard[];
  items?: string[];
  href?: string;
  cta?: string;
  productFilter?: string;
  productLimit?: number;
  image?: string;
  imageAlt?: string;
  imageKey?: ProjectImageKey;
};

interface Props {
  blocks?: PremiumBlock[];
  project?: string;
  heroImage?: string;
  products?: PremiumProduct[];
}

const {
  blocks = [],
  products = [],
  project
} = Astro.props;

const productByKey = new Map(products.map((product) => [product.key, product]));

const getBlockImageKey = (type: PremiumBlockType): ProjectImageKey | null => {
  if (
    type === "answer" ||
    type === "quickFacts" ||
    type === "expert" ||
    type === "vde"
  ) {
    return "feature";
  }

  if (
    type === "steps" ||
    type === "checks" ||
    type === "mistakes" ||
    type === "checklist"
  ) {
    return "inline";
  }

  if (type === "scenarios") {
    return "comparison";
  }

  if (type === "decision" || type === "recommendation") {
    return "decision";
  }

  if (type === "products") {
    return "product";
  }

  return null;
};

const getBlockIcon = (type: PremiumBlockType) => {
  const icons: Record<PremiumBlockType, string> = {
    answer: "✓",
    quickFacts: "i",
    scenarios: "↗",
    decision: "→",
    steps: "1",
    products: "▦",
    checks: "✓",
    mistakes: "!",
    expert: "i",
    vde: "i",
    recommendation: "✓",
    checklist: "✓"
  };

  return icons[type];
};
---

{blocks.length > 0 && (
  <div class:list={["premium-v3", { "premium-v3--pfotentechnik": project === "pfotentechnik" }]}>
    {blocks.map((block) => {
      const filteredProducts =
        block.type === "products" && block.productFilter
          ? products
              .filter((product) => product.tags.includes(block.productFilter!))
              .slice(0, block.productLimit ?? 4)
          : [];

      const hasCards = block.cards && block.cards.length > 0;
      const hasProducts = filteredProducts.length > 0;
      const hasList = block.items && block.items.length > 0;
      const isExplicitBlockImage = Boolean(block.image);
      const blockImage = block.image;
      const shouldRenderBlockImage = Boolean(blockImage) && isExplicitBlockImage;

      return (
        <section class={`premium-v3-block premium-v3-${block.type}`}>
          {(block.eyebrow || block.title || block.text) && (
            <div class="premium-v3-header">
              <div class="premium-v3-header-icon">
                {getBlockIcon(block.type)}
              </div>

              <div>
                {block.eyebrow && (
                  <span class="premium-v3-eyebrow">
                    {block.eyebrow}
                  </span>
                )}

                {block.title && <h2>{block.title}</h2>}

                {block.text && <p>{block.text}</p>}
              </div>
            </div>
          )}

          {shouldRenderBlockImage && (
            <figure class="premium-v3-image premium-v3-image-compact">
              <OptimizedImage
                src={blockImage}
                alt={block.imageAlt ?? block.title ?? block.eyebrow ?? "Ratgeber Illustration"}
                layout="constrained"
              />
            </figure>
          )}

          {hasProducts && (
            <div class="premium-v3-grid premium-v3-grid-products">
              {filteredProducts.map((product) => {
                const score = Math.max(
                  0,
                  Math.min(
                    100,
                    Math.round(
                      product.rating <= 5
                        ? product.rating * 20
                        : product.rating
                    )
                  )
                );

                return (
                  <a
                    class="premium-v3-card premium-v3-product-card premium-v3-card-link"
                    href={product.productUrl}
                  >
                    {product.image && (
                      <figure class="premium-v3-product-media">
                        <OptimizedImage
                          src={product.image.src}
                          alt={product.image.alt}
                          width={480}
                          height={300}
                          layout="constrained"
                          fit="contain"
                          position="center"
                          sizes="(max-width: 679px) 70vw, (max-width: 979px) 320px, 280px"
                        />
                      </figure>
                    )}

                    <div class="premium-v3-product-content">
                      <div class="premium-v3-product-meta">
                        <span class="premium-v3-label">
                          {product.badge}
                        </span>

                        <div
                          class="premium-v3-score"
                          aria-label={`Bewertung: ${score} von 100 Punkten`}
                        >
                          <strong>{score}</strong>
                          <span>/100</span>
                        </div>
                      </div>

                      <h3>{product.name}</h3>

                      <p class="premium-v3-product-summary">
                        {product.recommendation}
                      </p>

                      <ul class="premium-v3-product-highlights">
                        {product.highlights.slice(0, 3).map((item) => (
                          <li>
                            <span>{stripLeadingIcon(item)}</span>
                          </li>
                        ))}
                      </ul>

                      <span class="premium-v3-product-cta">
                        Produktdetails ansehen
                      </span>
                    </div>
                  </a>
                );
              })}
            </div>
          )}

          {hasCards && (
            <div class={`premium-v3-grid premium-v3-grid-${block.type}`}>
              {block.cards?.map((card, index) => {
                const product = card.productKey
                  ? productByKey.get(card.productKey)
                  : null;

                const href = card.href ?? product?.productUrl;

                const CardTag = href ? "a" : "article";

                return (
                  <CardTag
                    class={`premium-v3-card premium-v3-card-${index + 1}${href ? " premium-v3-card-link" : ""}`}
                    href={href}
                  >
                    {card.label && (
                      <span class="premium-v3-label">
                        {card.label}
                      </span>
                    )}

                    {card.badge && (
                      <span class="premium-v3-badge">
                        {card.badge}
                      </span>
                    )}

                    {card.value && (
                      <strong class="premium-v3-value">
                        {card.value}
                      </strong>
                    )}

                    <h3>{product ? product.name : card.title}</h3>

                    {card.text && <p>{card.text}</p>}

                    {product && <p>{product.recommendation}</p>}

                    {card.items && (
                      <ul>
                        {card.items.map((item) => (
                          <li><span>{stripLeadingIcon(item)}</span></li>
                        ))}
                      </ul>
                    )}

                    {product && (
                      <ul>
                        {product.highlights.slice(0, 3).map((item) => (
                          <li><span>{stripLeadingIcon(item)}</span></li>
                        ))}
                      </ul>
                    )}

                    {href && (
                      <span class="premium-v3-card-cta">
                        {card.cta ?? "Mehr ansehen"}
                      </span>
                    )}
                  </CardTag>
                );
              })}
            </div>
          )}

          {hasList && (
            <ul class="premium-v3-list">
              {block.items?.map((item) => (
                <li><span>{stripLeadingIcon(item)}</span></li>
              ))}
            </ul>
          )}

          {block.href && (
            <a class="premium-v3-button" href={block.href}>
              {block.cta ?? "Mehr erfahren"}
            </a>
          )}
        </section>
      );
    })}
  </div>
)}

<style>
  /* PfotenTechnik Editorial Design System 6.0 */
  .premium-v3--pfotentechnik {
    --ed-surface: #ffffff;
    --ed-soft: #f4f7f8;
    --ed-text: #0f172a;
    --ed-muted: #52626b;
    --ed-accent: #2e7d32;
    --ed-accent-soft: rgba(46, 125, 50, 0.1);
    --ed-border: rgba(15, 23, 42, 0.11);
    --ed-shadow: 0 18px 48px rgba(15, 23, 42, 0.08);

    display: grid;
    gap: clamp(68px, 13vw, 112px);
    margin-block: clamp(42px, 8vw, 78px);
  }

  .premium-v3--pfotentechnik,
  .premium-v3--pfotentechnik * {
    box-sizing: border-box;
  }

  .premium-v3--pfotentechnik .premium-v3-block {
    position: relative;
    min-width: 0;
    margin: 0;
  }

  .premium-v3--pfotentechnik .premium-v3-header {
    display: grid;
    grid-template-columns: 40px minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    margin-bottom: 24px;
  }

  .premium-v3--pfotentechnik .premium-v3-header-icon {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--ed-accent) 24%, transparent);
    border-radius: 13px;
    background: var(--ed-accent-soft);
    color: var(--ed-accent);
    font-weight: 900;
  }

  .premium-v3--pfotentechnik .premium-v3-header > div:last-child {
    min-width: 0;
  }

  .premium-v3--pfotentechnik .premium-v3-eyebrow,
  .premium-v3--pfotentechnik .premium-v3-label {
    color: var(--ed-accent);
    font-size: 0.73rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .premium-v3--pfotentechnik .premium-v3-eyebrow {
    display: block;
    margin: 2px 0 9px;
  }

  .premium-v3--pfotentechnik .premium-v3-header h2 {
    margin: 0;
    color: var(--ed-text);
    font-size: clamp(1.7rem, 7.6vw, 2.55rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .premium-v3--pfotentechnik .premium-v3-header p {
    max-width: 68ch;
    margin: 14px 0 0;
    color: var(--ed-muted);
    line-height: 1.7;
  }

  .premium-v3--pfotentechnik .premium-v3-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .premium-v3--pfotentechnik .premium-v3-card {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: 100%;
    padding: 22px;
    flex-direction: column;
    align-items: flex-start;
    overflow: hidden;
    border: 1px solid var(--ed-border);
    border-radius: 20px;
    background: var(--ed-surface);
    color: var(--ed-text);
    text-align: left;
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
  }

  .premium-v3--pfotentechnik .premium-v3-card-link {
    cursor: pointer;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .premium-v3--pfotentechnik .premium-v3-card h3 {
    margin: 0 0 11px;
    color: var(--ed-text);
    font-size: clamp(1.18rem, 5vw, 1.48rem);
    line-height: 1.2;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .premium-v3--pfotentechnik .premium-v3-card p {
    margin: 0 0 18px;
    color: var(--ed-muted);
    line-height: 1.62;
  }

  .premium-v3--pfotentechnik .premium-v3-card ul,
  .premium-v3--pfotentechnik .premium-v3-list {
    margin: 4px 0 20px;
    padding: 0;
    list-style: none;
  }

  .premium-v3--pfotentechnik .premium-v3-card li,
  .premium-v3--pfotentechnik .premium-v3-list li {
    position: relative;
    min-width: 0;
    color: var(--ed-muted);
    line-height: 1.55;
  }

  .premium-v3--pfotentechnik .premium-v3-card li > span,
  .premium-v3--pfotentechnik .premium-v3-list li > span {
    display: block;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  /* Spotlight */
  .premium-v3--pfotentechnik .premium-v3-answer {
    padding: clamp(27px, 7vw, 42px);
    overflow: hidden;
    border: 0;
    border-radius: 28px;
    background:
      radial-gradient(circle at 100% 0%, rgba(94, 225, 154, 0.2), transparent 43%),
      linear-gradient(145deg, #135c45, #0c3739);
    box-shadow: 0 24px 64px rgba(7, 37, 35, 0.22);
  }

  .premium-v3--pfotentechnik .premium-v3-answer .premium-v3-header {
    margin: 0;
  }

  .premium-v3--pfotentechnik .premium-v3-answer .premium-v3-header-icon {
    border-color: rgba(134, 239, 172, 0.28);
    background: rgba(134, 239, 172, 0.12);
    color: #86efac;
  }

  .premium-v3--pfotentechnik .premium-v3-answer .premium-v3-eyebrow {
    color: #86efac;
  }

  .premium-v3--pfotentechnik .premium-v3-answer h2 {
    color: #ffffff;
  }

  .premium-v3--pfotentechnik .premium-v3-answer .premium-v3-header p {
    color: rgba(239, 250, 246, 0.84);
  }

  .premium-v3--pfotentechnik .premium-v3-button {
    display: inline-flex;
    width: fit-content;
    min-height: 46px;
    margin-top: 22px;
    padding: 11px 18px;
    align-items: center;
    border-radius: 999px;
    background: var(--ed-accent);
    color: #ffffff;
    font-weight: 800;
    text-decoration: none;
  }

  .premium-v3--pfotentechnik .premium-v3-answer .premium-v3-button {
    margin-left: 52px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.1);
  }

  /* Quick Facts */
  .premium-v3--pfotentechnik .premium-v3-quickFacts .premium-v3-card {
    padding-top: 54px;
    background: linear-gradient(145deg, var(--ed-surface), var(--ed-soft));
  }

  .premium-v3--pfotentechnik .premium-v3-quickFacts .premium-v3-card::before {
    position: absolute;
    top: 17px;
    right: 18px;
    color: color-mix(in srgb, var(--ed-accent) 28%, transparent);
    font-size: 1.8rem;
    font-weight: 900;
  }

  .premium-v3-card-1::before { content: "01"; }
  .premium-v3-card-2::before { content: "02"; }
  .premium-v3-card-3::before { content: "03"; }
  .premium-v3-card-4::before { content: "04"; }
  .premium-v3-card-5::before { content: "05"; }
  .premium-v3-card-6::before { content: "06"; }

  .premium-v3--pfotentechnik .premium-v3-card-cta {
    display: inline-flex;
    margin-top: auto;
    padding-top: 7px;
    gap: 7px;
    color: var(--ed-accent);
    font-size: 0.91rem;
    font-weight: 800;
  }

  .premium-v3--pfotentechnik .premium-v3-card-cta::after {
    content: "→";
  }

  /* Szenarien */
  .premium-v3--pfotentechnik .premium-v3-scenarios .premium-v3-card {
    min-height: 245px;
    justify-content: flex-end;
    border: 0;
    background:
      linear-gradient(180deg, transparent, rgba(5, 23, 36, 0.96)),
      radial-gradient(circle at 80% 15%, rgba(94, 225, 154, 0.22), transparent 38%),
      #183044;
    box-shadow: 0 18px 46px rgba(7, 25, 39, 0.22);
  }

  .premium-v3--pfotentechnik .premium-v3-scenarios .premium-v3-label {
    color: #86efac;
  }

  .premium-v3--pfotentechnik .premium-v3-scenarios h3 {
    color: #ffffff;
  }

  .premium-v3--pfotentechnik .premium-v3-scenarios .premium-v3-card p {
    margin-bottom: 0;
    color: rgba(235, 244, 250, 0.78);
  }

  /* Entscheidung – Bugfix: jede Zeile besteht aus Nummer + genau einem Textwrapper */
  .premium-v3--pfotentechnik .premium-v3-decision {
    padding: 0;
    border: 0;
    background: transparent;
  }

  .premium-v3--pfotentechnik .premium-v3-decision .premium-v3-list {
    display: grid;
    gap: 0;
    margin: 0;
    counter-reset: decision-step;
  }

  .premium-v3--pfotentechnik .premium-v3-decision .premium-v3-list li {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 14px;
    margin: 0;
    padding: 18px 0;
    align-items: start;
    border-bottom: 1px solid var(--ed-border);
    color: var(--ed-text);
    font-weight: 720;
    counter-increment: decision-step;
  }

  .premium-v3--pfotentechnik .premium-v3-decision .premium-v3-list li:last-child {
    border-bottom: 0;
  }

  .premium-v3--pfotentechnik .premium-v3-decision .premium-v3-list li::before {
    content: counter(decision-step);
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: 13px;
    background: var(--ed-accent-soft);
    color: var(--ed-accent);
    font-weight: 900;
  }

  .premium-v3--pfotentechnik .premium-v3-decision .premium-v3-list li > span {
    padding-top: 7px;
    color: var(--ed-text);
    line-height: 1.45;
    overflow-wrap: normal;
    word-break: normal;
  }

  /* Qualitätsband */
  .premium-v3--pfotentechnik .premium-v3-checks {
    padding: 28px 22px;
    border-radius: 28px;
    background:
      radial-gradient(circle at 100% 10%, rgba(94, 225, 154, 0.2), transparent 38%),
      #10283b;
  }

  .premium-v3--pfotentechnik .premium-v3-checks h2 {
    color: #ffffff;
  }

  .premium-v3--pfotentechnik .premium-v3-checks .premium-v3-eyebrow {
    color: #86efac;
  }

  .premium-v3--pfotentechnik .premium-v3-checks .premium-v3-list {
    display: grid;
    gap: 10px;
    margin: 0;
  }

  .premium-v3--pfotentechnik .premium-v3-checks .premium-v3-list li {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: 10px;
    margin: 0;
    padding: 14px 15px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 15px;
    background: rgba(255, 255, 255, 0.055);
    color: rgba(240, 249, 255, 0.84);
  }

  .premium-v3--pfotentechnik .premium-v3-checks .premium-v3-list li::before {
    content: "✓";
    color: #86efac;
    font-weight: 900;
  }

  .premium-v3--pfotentechnik .premium-v3-checks .premium-v3-list li > span {
    color: inherit;
  }

  /* Produktkarten 6.0 */
  .premium-v3--pfotentechnik .premium-v3-grid-products {
    display: flex;
    width: calc(100% + 20px);
    margin-right: -20px;
    padding: 4px 20px 8px 0;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .premium-v3--pfotentechnik .premium-v3-grid-products::-webkit-scrollbar {
    display: none;
  }

  .premium-v3--pfotentechnik .premium-v3-product-card {
    width: min(86vw, 344px);
    min-width: min(86vw, 344px);
    padding: 0;
    scroll-snap-align: start;
    border-radius: 24px;
    background: var(--ed-surface);
  }

  .premium-v3--pfotentechnik .premium-v3-product-media {
    width: 100%;
    aspect-ratio: 4 / 3;
    margin: 0;
    overflow: hidden;
    background: #eef2f3;
  }

  .premium-v3--pfotentechnik .premium-v3-product-media picture,
  .premium-v3--pfotentechnik .premium-v3-product-media img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .premium-v3--pfotentechnik .premium-v3-product-media img {
    object-fit: contain;
    padding: 16px;
  }

  .premium-v3--pfotentechnik .premium-v3-product-content {
    display: flex;
    min-height: 390px;
    padding: 22px;
    flex-direction: column;
  }

  .premium-v3--pfotentechnik .premium-v3-product-meta {
    display: flex;
    margin-bottom: 16px;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .premium-v3--pfotentechnik .premium-v3-product-meta .premium-v3-label {
    display: inline-flex;
    margin: 7px 0 0;
  }

  .premium-v3--pfotentechnik .premium-v3-score {
    display: grid;
    width: 64px;
    height: 64px;
    flex: 0 0 64px;
    place-content: center;
    border: 1px solid color-mix(in srgb, var(--ed-accent) 28%, transparent);
    border-radius: 19px;
    background: var(--ed-accent-soft);
    color: var(--ed-accent);
    text-align: center;
  }

  .premium-v3--pfotentechnik .premium-v3-score strong {
    display: block;
    font-size: 1.42rem;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .premium-v3--pfotentechnik .premium-v3-score span {
    display: block;
    margin-top: 3px;
    font-size: 0.67rem;
    font-weight: 800;
  }

  .premium-v3--pfotentechnik .premium-v3-product-summary {
    font-size: 0.96rem;
  }

  .premium-v3--pfotentechnik .premium-v3-product-highlights {
    display: grid;
    gap: 10px;
    margin: 2px 0 22px;
  }

  .premium-v3--pfotentechnik .premium-v3-product-highlights li {
    display: grid;
