---
import { loadAdvisorContext } from "../../../lib/seo/data/advisor";
import { runAdvisor } from "../../../lib/seo/advisor/engine";
import { buildAdvisorPrompt } from "../../../lib/seo/advisor/prompt";
export const prerender=false;
const requestedPeriod=Astro.url.searchParams.get("period")??"7d";
const allowedPeriods=["24h","7d","28d","3m","6m","12m"];
const period=allowedPeriods.includes(requestedPeriod)?requestedPeriod:"7d";
const context=await loadAdvisorContext(period); const result=runAdvisor(context); const items=result.recommendations.map((item)=>({...item,prompt:buildAdvisorPrompt(item)}));
const labels:Record<string,string>={"24h":"24 Stunden","7d":"7 Tage","28d":"28 Tage","3m":"3 Monate","6m":"6 Monate","12m":"12 Monate"};
---
<html lang="de"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>SEO Advisor · PfotenTechnik</title><style>
:root{color-scheme:light dark;--bg:#f6f7f9;--surface:#fff;--muted-surface:#f1f3f5;--text:#17211b;--muted:#66736b;--border:#dfe5e1;--accent:#2e7d32;--danger:#b42318;--warning:#b54708} @media(prefers-color-scheme:dark){:root{--bg:#101411;--surface:#171d19;--muted-surface:#202722;--text:#f3f7f4;--muted:#a5b0a9;--border:#303a33;--accent:#79c77d;--danger:#ff8c82;--warning:#fdb86b}} *{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,system-ui,sans-serif}main{width:min(1180px,calc(100% - 32px));margin:auto;padding:40px 0 80px}.eyebrow{color:var(--accent);font-weight:800;text-transform:uppercase;letter-spacing:.08em;font-size:.76rem}h1{margin:8px 0 10px;font-size:clamp(2rem,5vw,3.7rem);line-height:1}.intro{max-width:760px;color:var(--muted);line-height:1.65}.periods{display:flex;gap:8px;flex-wrap:wrap;margin:28px 0}.periods a{color:inherit;text-decoration:none;padding:9px 13px;border:1px solid var(--border);border-radius:999px;background:var(--surface);font-weight:700}.periods a[aria-current=page]{background:var(--text);color:var(--bg)}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:30px}.stat,.card,.empty{background:var(--surface);border:1px solid var(--border);border-radius:20px}.stat{padding:18px}.stat strong{display:block;font-size:2rem}.stat span,.card p,.url{color:var(--muted)}.list{display:grid;gap:16px}.card{padding:22px}.card-head{display:flex;gap:14px;align-items:flex-start}.priority{display:grid;place-items:center;min-width:44px;height:44px;border-radius:14px;background:var(--muted-surface);font-weight:900}.priority-A{color:var(--danger)}.priority-B{color:var(--warning)}.priority-C{color:var(--accent)}.card h2{margin:0;font-size:1.2rem}.score{margin-left:auto;font-weight:900}.action{padding:14px 16px;border-left:4px solid var(--accent);background:var(--muted-surface);color:var(--text)!important}.meta,.buttons{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px}.meta span{padding:6px 10px;border:1px solid var(--border);border-radius:999px;font-size:.82rem;color:var(--muted)}button,.open-link{border:0;border-radius:12px;padding:10px 14px;background:var(--text);color:var(--bg);font:inherit;font-weight:800;text-decoration:none;cursor:pointer}.open-link{background:var(--muted-surface);color:var(--text);border:1px solid var(--border)}.empty{padding:32px}@media(max-width:760px){.stats{grid-template-columns:repeat(2,1fr)}main{width:calc(100% - 20px);padding-top:24px}}
</style></head><body><main><span class="eyebrow">SEO Advisor Platform 1.0.1</span><h1>Was heute den größten Effekt bringt</h1><p class="intro">Priorisierte Empfehlungen aus Search-Console-Daten und Content-Graph. Die Analyse läuft lokal ohne kostenpflichtige KI-API.</p><nav class="periods" aria-label="Zeitraum">{allowedPeriods.map((value)=><a href={`?period=${value}`} aria-current={value===period?"page":undefined}>{labels[value]}</a>)}</nav><section class="stats">{(["A","B","C","D"] as const).map((priority)=><article class="stat"><strong>{result.counts[priority]}</strong><span>Priorität {priority}</span></article>)}</section>{items.length===0?<section class="empty"><h2>Noch keine Empfehlungen</h2><p>Der Advisor wurde geladen, hat aber keine auswertbaren GSC-Seiten gefunden. Führe zuerst <code>npm run gsc:sync</code> aus.</p></section>:<section class="list">{items.map((item)=><article class="card"><div class="card-head"><span class={`priority priority-${item.priority}`}>{item.priority}</span><div><h2>{item.title}</h2>{item.url&&<p class="url">{item.url}</p>}</div><span class="score">{item.score}/100</span></div><p>{item.summary}</p><p><strong>Warum:</strong> {item.reason}</p><p class="action"><strong>Nächster Schritt:</strong> {item.action}</p><div class="meta"><span>{item.category}</span><span>Aufwand: {item.effort}</span><span>Vertrauen: {Math.round(item.confidence)} %</span></div><div class="buttons"><button type="button" class="copy-prompt" data-prompt={item.prompt}>ChatGPT-Prompt kopieren</button>{item.url&&<a class="open-link" href={item.url} target="_blank">Seite öffnen</a>}</div></article>)}</section>}</main><script>document.querySelectorAll(".copy-prompt").forEach((button)=>{button.addEventListener("click",async()=>{const prompt=button.getAttribute("data-prompt")??"";const original=button.textContent;try{await navigator.clipboard.writeText(prompt);button.textContent="Prompt kopiert";setTimeout(()=>button.textContent=original,1800);}catch{button.textContent="Kopieren fehlgeschlagen";}});});</script></body></html>
