---
import { getCollection, render } from "astro:content";
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import ProjectLayout from "../layouts/ProjectLayout.astro";
import ArticleMeta from "@affiliate-core/components/ArticleMeta.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import TableOfContents from "@affiliate-core/components/TableOfContents.astro";
import PremiumRenderer from "@affiliate-core/renderer/PremiumRenderer.astro";
import FAQ from "@affiliate-core/components/FAQ.astro";
import RelatedArticles from "@affiliate-core/components/RelatedArticles.astro";
import ConversionJourney from "../components/ConversionJourney.astro";
import OptimizedImage from "@affiliate-core/components/OptimizedImage.astro";
import AutoLinkContent from "@affiliate-core/components/AutoLinkContent.astro";
import { addAmazonTrackingId } from "@affiliate-core/affiliate";
import HealthBridge from "../components/HealthBridge.astro";
import AutoContentBlocks from "../components/AutoContentBlocks.astro";
import { projectConfig, siteMeta } from "../project.config";
import { assembleContentPage } from "../domain/contentPlatform";
import {
  getDecisionProductRecommendations,
  getDecisionRule,
} from "../domain/productDecision";
import { getPageBreadcrumbs, getRelatedContent } from "@app/domain/content";
import {
  getInternalLinkDefinitions,
  getSourceContexts
} from "../domain/content/internalLinks";
import defaultHero from "../assets/images/project/pfotentechnik/hero.webp";
import categoryImage from "../assets/images/project/pfotentechnik/category.webp";
import comparisonImage from "../assets/images/project/pfotentechnik/comparison.webp";
import faqImage from "../assets/images/project/pfotentechnik/faq.webp";
import featureImage from "../assets/images/project/pfotentechnik/feature.webp";
import feederComparisonImage from "../assets/images/project/pfotentechnik/feeder-comparison.webp";
import feederHeroImage from "../assets/images/project/pfotentechnik/feeder-hero.webp";
import feederWetFoodImage from "../assets/images/project/pfotentechnik/feeder-wet-food.webp";
import guideImage from "../assets/images/project/pfotentechnik/guide.webp";
import inlineImage from "../assets/images/project/pfotentechnik/inline.webp";
import productImage from "../assets/images/project/pfotentechnik/product.webp";
import { toEditorialScore } from "@affiliate-core/utils/editorialScore";
export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);
const [pages, comparisons, manufacturers] = await Promise.all([
  getCollection("pages"),
  getCollection("comparisons"),
  getCollection("manufacturers")
]);
const breadcrumbs = getPageBreadcrumbs(page);
const products = await getCollection("products");
const internalLinkDefinitions = getInternalLinkDefinitions({
  pages,
  products,
  comparisons,
  manufacturers
});
const sourceContexts = getSourceContexts(page.data);
const assembledPage = assembleContentPage(page.data);
const productBySlug = new Map(
  products.map((product) => [product.data.slug, product]),
);
const premiumProducts = products.map((product) => ({
  key: product.data.slug,
  name: product.data.title,
  productUrl: `/produkt/${product.data.slug}/`,
  badge: product.data.manufacturer.name,
  recommendation: product.data.recommendation,
  rating: product.data.rating,
  highlights: product.data.strengths,
  tags: product.data.tags,
}));

const author = page.data.author ?? siteMeta.defaultAuthor;
const publishedAt =
  page.data.publishedAt ?? siteMeta.articleDefaults.publishedAt;
const updatedAt =
  page.data.updatedAt ??
  page.data.publishedAt ??
  siteMeta.articleDefaults.updatedAt;
const projectKey = page.data.project ?? "pfotentechnik";
const fallbackImages: Record<string, ImageMetadata> = {
  hero: defaultHero,
  category: categoryImage,
  comparison: comparisonImage,
  faq: faqImage,
  feature: featureImage,
  feederComparison: feederComparisonImage,
  feederHero: feederHeroImage,
  feederWetFood: feederWetFoodImage,
  guide: guideImage,
  inline: inlineImage,
  product: productImage,
};
const fallbackHero =
  fallbackImages[page.data.heroImageKey ?? "hero"] ?? defaultHero;
const heroImage = page.data.heroImage ?? {
  src: fallbackHero,
  alt: page.data.title,
};
const ogImage = page.data.ogImage ?? heroImage;
const optimizedOgImage = await getImage({
  src: ogImage.src,
  width: 1200,
  quality: "high",
});
const decisionRecommendations = assembledPage.decisionKey
  ? getDecisionProductRecommendations(assembledPage.decisionKey, products)
  : [];

const decisionRule = assembledPage.decisionKey
  ? getDecisionRule(assembledPage.decisionKey)
  : undefined;

const decisionProducts = decisionRecommendations
  .map(({ key }) => key)
  .filter((key) => productBySlug.has(key));

const topDecisionRecommendation = decisionRecommendations[0];
const topDecisionProduct = topDecisionRecommendation
  ? productBySlug.get(topDecisionRecommendation.key)
  : undefined;

const decisionIntro =
  page.data.decisionIntro ??
  "Basierend auf unseren Bewertungskriterien ist dies aktuell die passendste Empfehlung für diesen Anwendungsfall.";

const decisionThemeColor = assembledPage.themeColor;
const comparisonProducts =
  decisionProducts.length > 0
    ? decisionProducts
    : assembledPage.comparisonProducts.filter((key) =>
        productBySlug.has(key),
      );

const comparisonExperienceConfig =
  page.data.comparisonRecommendation ??
  (decisionProducts.length > 0
    ? {
        title: "Unsere Produktempfehlungen",
        text: "Diese Auswahl wird aus den hinterlegten Produkteigenschaften, Use Cases und Bewertungskriterien abgeleitet.",
        tableTitle: "Empfehlungen im direkten Vergleich",
        cardsTitle: "Die passenden Modelle im Detail",
        criteria: [
          "Portionierung",
          "Zuverlässigkeit",
          "Reinigung",
          "Sicherheit",
          "Preis-Leistung",
        ],
      }
    : null);
const comparisonProductEntries = comparisonProducts
  .map((slug) => productBySlug.get(slug))
  .filter((product): product is (typeof products)[number] => Boolean(product));

const recommendationJourney = page.data.recommendationJourney;
const isMoneyPage =
  recommendationJourney?.mode === "filtered" ||
  page.data.contentPlatform?.intent === "buying-guide" ||
  page.data.contentPlatform?.intent === "comparison-support";

const matchesRecommendationJourney = (product: (typeof products)[number]) => {
  if (!recommendationJourney || recommendationJourney.mode === "off") return true;
  const filters = product.data.comparisonFilters;
  const animalMatches = recommendationJourney.animal
    ? (filters?.animal ?? []).includes(recommendationJourney.animal)
    : true;
  const sizeMatches = recommendationJourney.petSize
    ? (filters?.petSize ?? []).includes(recommendationJourney.petSize)
    : true;
  return animalMatches && sizeMatches;
};

const journeyProducts = comparisonProductEntries
  .filter(matchesRecommendationJourney)
  .sort((a, b) =>
    (b.data.score ?? toEditorialScore(b.data.rating, 5)) -
    (a.data.score ?? toEditorialScore(a.data.rating, 5))
  );

const journeyTopProduct = journeyProducts[0];
const journeyFallbackProduct = comparisonProductEntries
  .slice()
  .sort((a, b) =>
    (b.data.score ?? toEditorialScore(b.data.rating, 5)) -
    (a.data.score ?? toEditorialScore(a.data.rating, 5))
  )[0];
const journeyRecommendedProduct =
  journeyTopProduct ?? journeyFallbackProduct;
const journeyHasExactMatch = Boolean(journeyTopProduct);

const journeyComparisonHref = recommendationJourney
  ? `${recommendationJourney.comparisonHref}${
      recommendationJourney.comparisonHref.includes("?") ? "&" : "?"
    }${[
      recommendationJourney.animal
        ? `filter-tier=${recommendationJourney.animal === "dog" ? "hund" : "katze"}`
        : "",
      recommendationJourney.petSize
        ? `filter-tiergroesse=${
            recommendationJourney.petSize === "small"
              ? "klein"
              : recommendationJourney.petSize === "medium"
                ? "mittel"
                : "gross"
          }`
        : ""
    ].filter(Boolean).join("&")}#direktvergleich`
  : undefined;

const closingProduct = assembledPage.closingCta
  ? productBySlug.get(assembledPage.closingCta.productKey)
  : undefined;

const getReadingTimeMinutes = (content: string) => {
  const plainText = content
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/<[^>]+>/g, " ")
    .replace(/[{}[\]()*_#>\-|]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  if (!plainText) {
    return 1;
  }

  const wordCount = plainText.split(" ").filter(Boolean).length;

  return Math.max(1, Math.ceil(wordCount / 200));
};

const readingTimeMinutes = getReadingTimeMinutes(page.body ?? "");

const relatedEntries = await getRelatedContent({
  currentSlug: page.data.slug,
  title: page.data.title,
  description: page.data.description,
  tags: page.data.related?.tags.length
    ? page.data.related.tags
    : page.data.tags,
  sections: page.data.hub?.sections ?? [],
  type: page.data.type,
  exclude: page.data.related?.exclude ?? [],
  limit: page.data.related?.limit ?? 3,
});

const relatedItems = relatedEntries.map((entry) => ({
  href: entry.href,
  label:
    entry.type === "product"
      ? "Produkt"
      : entry.type === "manufacturer"
        ? "Hersteller"
        : entry.type === "comparison"
          ? "Vergleich"
          : "Ratgeber",
  title: entry.hubTitle,
  text: entry.hubDescription,
}));
---

<ProjectLayout
  title={page.data.title}
  description={page.data.description}
  seoTitle={page.data.seo?.title ?? page.data.seoTitle}
  seoDescription={page.data.seo?.description ?? page.data.seoDescription}
  canonical={
    page.data.seo?.canonical ??
    `/${page.data.slug}/`
  }
  noindex={page.data.seo?.noindex ?? false}
  ogImage={optimizedOgImage.src}
  faq={assembledPage.faq}
  author={author}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  categoryLabel={assembledPage.categoryLabel}
  breadcrumbs={breadcrumbs}
>
  <Breadcrumbs items={breadcrumbs} />

  <header class="article-header">
    <span class="article-category">{assembledPage.categoryLabel}</span>
    <h1 class="article-title">{page.data.title}</h1>
    <p class="article-description">{page.data.description}</p>
    <ArticleMeta
      author={author}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      readingTimeMinutes={readingTimeMinutes}
    />
  </header>

  <figure class="article-hero">
    <OptimizedImage
      src={heroImage.src}
      alt={heroImage.alt ?? page.data.title}
      class="article-hero-image"
      layout="full-width"
      priority
    />
  </figure>

  <article class="article">
    <TableOfContents headings={headings} />

    <AutoContentBlocks
      page={assembledPage}
      products={products}
    />

    {
      isMoneyPage && journeyComparisonHref && (
        <nav
          class="money-page-intent-entry"
          aria-label="Direkteinstieg"
          data-feature="money-page-intent-entry-4.1"
        >
          <div>
            <p>Schon kaufbereit?</p>
            <h2>Direkt vergleichen oder erst Kriterien prüfen?</h2>
          </div>
          <div class="money-page-intent-actions">
            <a class="money-page-intent-primary" href={journeyComparisonHref}>
              Zum Vergleich
            </a>
            <a class="money-page-intent-secondary" href="#kaufberatung">
              Kriterien prüfen
            </a>
          </div>
        </nav>
      )
    }

    {
      topDecisionRecommendation && topDecisionProduct && (
        <section
          class={`decision-top-recommendation decision-top-recommendation-${decisionThemeColor}`}
        >
          <div class="ranking-section-header">
            <p class="ranking-eyebrow">Top-Empfehlung</p>
            <h2>Unser Favorit für diese Auswahl</h2>
            <p>{decisionIntro}</p>
          </div>

          <a
            class="decision-product-card"
            href={`/produkt/${topDecisionProduct.data.slug}/`}
          >
            <OptimizedImage
              src={
                topDecisionProduct.data.images.thumbnail?.src ??
                topDecisionProduct.data.images.hero.src
              }
              alt={
                topDecisionProduct.data.images.thumbnail?.alt ??
                topDecisionProduct.data.images.hero.alt
              }
              width={480}
              height={360}
              layout="constrained"
            />
            <div>
              <p>
                {topDecisionProduct.data.manufacturer.name} ·{" "}
                {topDecisionRecommendation.score} Punkte
              </p>
              <h3>{topDecisionProduct.data.title}</h3>
              <p>{topDecisionProduct.data.recommendation}</p>
              <strong>Produkt ansehen</strong>
            </div>
          </a>
        </section>
      )
    }
    <AutoLinkContent
      definitions={internalLinkDefinitions}
      sourcePath={`/${page.data.slug}/`}
      sourceGroup="knowledge"
      sourceContexts={sourceContexts}
      maxLinksPerPage={5}
    >
      <PremiumRenderer
        blocks={page.data.premiumBlocks as any}
        project={projectKey}
        products={premiumProducts}
      />
    </AutoLinkContent>
    {
      !recommendationJourney && comparisonProducts.length > 1 && (
        <div class="decision-comparison-intro">
          <h2>Weitere passende Empfehlungen</h2>
          <p>
            Neben unserer Top-Empfehlung können – je nach Budget, Ausstattung
            und persönlichen Anforderungen – auch diese Modelle interessant
            sein.
          </p>
        </div>
      )
    }
    {
      !recommendationJourney && comparisonProductEntries.length > 0 && comparisonExperienceConfig && (
        <section class="decision-template-section">
          <h2>{comparisonExperienceConfig.title}</h2>
          <p>{comparisonExperienceConfig.text}</p>
          <div class="decision-template-grid">
            {comparisonProductEntries.map((product) => (
              <a
                class="decision-template-card"
                href={`/produkt/${product.data.slug}/`}
              >
                <h3>{product.data.title}</h3>
                <p>{product.data.recommendation}</p>
                <p>
                  <strong>{toEditorialScore(product.data.rating, 5)}</strong>
                </p>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      decisionRule?.summary && decisionRule.summary.length > 0 && (
        <section class="decision-template-section decision-template-summary">
          <h2>30 Sekunden Zusammenfassung</h2>
          <ul>
            {decisionRule.summary.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      (decisionRule?.suitableFor || decisionRule?.notSuitableFor) && (
        <section class="decision-template-section decision-template-fit">
          <h2>Für wen ist diese Auswahl geeignet?</h2>
          <div class="decision-template-grid">
            {decisionRule.suitableFor &&
              decisionRule.suitableFor.length > 0 && (
                <div class="decision-template-card decision-template-card-positive">
                  <h3>Geeignet für</h3>
                  <ul>
                    {decisionRule.suitableFor.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              )}

            {decisionRule.notSuitableFor &&
              decisionRule.notSuitableFor.length > 0 && (
                <div class="decision-template-card decision-template-card-negative">
                  <h3>Eher nicht geeignet für</h3>
                  <ul>
                    {decisionRule.notSuitableFor.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              )}
          </div>
        </section>
      )
    }

    {
      decisionRule?.checklist && decisionRule.checklist.length > 0 && (
        <section class="decision-template-section decision-template-checklist">
          <h2>Kauf-Checkliste</h2>
          <ul>
            {decisionRule.checklist.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      decisionRule?.commonMistakes &&
        decisionRule.commonMistakes.length > 0 && (
          <section class="decision-template-section decision-template-mistakes">
            <h2>Typische Fehler beim Kauf</h2>
            <ul>
              {decisionRule.commonMistakes.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>
        )
    }

    {
      decisionRule?.alternatives && decisionRule.alternatives.length > 0 && (
        <section class="decision-template-section decision-template-alternatives">
          <h2>Alternativen</h2>
          <div class="decision-template-grid">
            {decisionRule.alternatives.map((item) => (
              <article class="decision-template-card">
                <h3>{item.label}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      decisionRule?.decisionTree && decisionRule.decisionTree.length > 0 && (
        <section class="decision-template-section decision-template-tree">
          <h2>Entscheidungsbaum</h2>
          <ul>
            {decisionRule.decisionTree.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    <div id="kaufberatung" class="money-page-guide-anchor" aria-hidden="true"></div>
    <AutoLinkContent
      definitions={internalLinkDefinitions}
      sourcePath={`/${page.data.slug}/`}
      sourceGroup="knowledge"
      sourceContexts={sourceContexts}
      maxLinksPerPage={7}
    >
      <Content />
    </AutoLinkContent>

    {
      recommendationJourney && (
        <section class="recommendation-journey-state">
          {
            journeyRecommendedProduct ? (
              <>
                <div class="ranking-section-header">
                  <p class="ranking-eyebrow">
                    {journeyHasExactMatch ? "Top-Empfehlung" : "Beste verfügbare Option"}
                  </p>
                  <h2>
                    {journeyHasExactMatch
                      ? "Die passendste dokumentierte Auswahl"
                      : "Dieses Modell kommt den Anforderungen am nächsten"}
                  </h2>
                  <p>
                    {journeyHasExactMatch
                      ? "Dieses Modell erfüllt die hinterlegten Eignungsfilter."
                      : recommendationJourney.emptyText}
                  </p>
                </div>
                <a
                  class="decision-product-card"
                  href={`/produkt/${journeyRecommendedProduct.data.slug}/`}
                >
                  <OptimizedImage
                    src={
                      journeyRecommendedProduct.data.images.thumbnail?.src ??
                      journeyRecommendedProduct.data.images.hero.src
                    }
                    alt={
                      journeyRecommendedProduct.data.images.thumbnail?.alt ??
                      journeyRecommendedProduct.data.images.hero.alt
                    }
                    width={480}
                    height={360}
                    layout="constrained"
                  />
                  <div>
                    <p>
                      {journeyRecommendedProduct.data.manufacturer.name} ·{" "}
                      {journeyRecommendedProduct.data.score ??
                        toEditorialScore(journeyRecommendedProduct.data.rating, 5)} Punkte
                    </p>
                    <h3>{journeyRecommendedProduct.data.title}</h3>
                    <p>{journeyRecommendedProduct.data.recommendation}</p>
                    <strong>Produkt ansehen</strong>
                  </div>
                </a>
              </>
            ) : (
              <div class="recommendation-journey-empty">
                <p class="ranking-eyebrow">Redaktionelle Einordnung</p>
                <h2>{recommendationJourney.emptyTitle}</h2>
                <p>{recommendationJourney.emptyText}</p>
              </div>
            )
          }
          {
            journeyComparisonHref && (
              <a class="recommendation-journey-comparison" href={journeyComparisonHref}>
                <span>Passende Modelle vergleichen</span>
                <strong>Zum Vergleich</strong>
              </a>
            )
          }
        </section>
      )
    }

    {
      decisionRule?.sources && decisionRule.sources.length > 0 && (
        <section class="decision-template-section decision-template-sources">
          <h2>Fachquellen</h2>
          <ul>
            {decisionRule.sources.map((source) => (
              <li>
                <a href={source.href} rel="noopener noreferrer" target="_blank">
                  {source.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
    {page.data.healthBridge && <HealthBridge {...page.data.healthBridge} />}
    {
      !isMoneyPage && assembledPage.closingCta && closingProduct && (
        <section class="pt-money-cta" aria-labelledby="pt-money-cta-title">
          <div>
            <span>{closingProduct.data.manufacturer.name}</span>
            <h2 id="pt-money-cta-title">{assembledPage.closingCta.title}</h2>
            <p>{assembledPage.closingCta.text}</p>
          </div>
          <div class="pt-money-cta-actions">
            {closingProduct.data.affiliate && (
              <a
                class="pt-money-cta-primary"
                href={addAmazonTrackingId(
                  closingProduct.data.affiliate.url,
                  projectConfig.affiliate.amazon.trackingId,
                )}
                rel={closingProduct.data.affiliate.rel}
                target={closingProduct.data.affiliate.target}
              >
                {assembledPage.closingCta.primaryLabel}
              </a>
            )}
            <a
              class="pt-money-cta-secondary"
              href={assembledPage.closingCta.secondaryHref}
            >
              {assembledPage.closingCta.secondaryLabel}
            </a>
          </div>
        </section>
      )
    }
    <FAQ items={assembledPage.faq} />
  </article>

{!isMoneyPage && (
  <ConversionJourney
    title="Was jetzt sinnvoll ist"
    intro="Vertiefe das Thema oder gehe gezielt zur passenden Produkt- und Vergleichsebene weiter."
    items={[
      {
        eyebrow: "Orientierung",
        title: "Passende Kaufberatung öffnen",
        text: "Nutze die zentrale Übersicht, um Anforderungen und Gerätetypen strukturiert einzuordnen.",
        href: "/smarte-futterautomaten/",
        label: "Zur Kaufberatung"
      },
      {
        eyebrow: "Vergleich",
        title: "Geeignete Modelle gegenüberstellen",
        text: "Vergleiche Funktionen und Einsatzbereiche, statt nur einzelne Produktversprechen zu betrachten.",
        href: "/vergleiche/",
        label: "Zu den Vergleichen"
      },
      {
        eyebrow: "Praxis",
        title: "Technik sicher im Alltag nutzen",
        text: "Prüfe Reinigung, Kontrollroutinen und Grenzen automatisierter Fütterung.",
        href: "/futterautomat-richtig-reinigen/",
        label: "Praxiswissen lesen"
      }
    ]}
  />
)}

  <RelatedArticles items={relatedItems} />
</ProjectLayout>

<style>
  .decision-comparison-intro,
  .decision-template-section {
    margin: 52px 0;
  }
  .decision-comparison-intro {
    max-width: 820px;
  }
  .decision-comparison-intro h2,
  .decision-template-section > h2 {
    margin: 0 0 14px;
    font-size: clamp(30px, 4vw, 46px);
    line-height: 1.08;
    letter-spacing: -0.045em;
  }
  .decision-comparison-intro p,
  .decision-template-section > p {
    max-width: 820px;
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.7;
  }
  .decision-template-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .decision-template-card {
    display: block;
    min-width: 0;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 22px;
    color: inherit;
    background: #fff;
    text-decoration: none;
    box-shadow: 0 12px 34px rgba(20, 32, 26, 0.05);
  }
  a.decision-template-card {
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  a.decision-template-card:hover {
    border-color: rgba(22, 163, 74, 0.28);
    transform: translateY(-2px);
    box-shadow: 0 16px 42px rgba(20, 32, 26, 0.09);
  }
  .decision-template-card h3 {
    margin: 0 0 12px;
    color: var(--text);
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.035em;
  }
