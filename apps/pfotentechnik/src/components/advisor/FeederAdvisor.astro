---
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
---
<section class:list={["pt-advisor", { "pt-advisor--compact": compact }]} data-feeder-advisor>
  <div class="pt-advisor__intro">
    <span class="pt-advisor__eyebrow">Futterautomaten-Berater</span>
    <h2>Welcher Futterautomat passt zu deinem Alltag?</h2>
    <p>Beantworte fünf kurze Fragen. Du erhältst eine passende Gerätekategorie und den sinnvollsten nächsten Schritt.</p>
  </div>
  <form class="pt-advisor__form">
    <fieldset><legend>1. Für welches Tier suchst du?</legend><label><input type="radio" name="animal" value="cat" required /> Katze</label><label><input type="radio" name="animal" value="dog" /> Hund</label><label><input type="radio" name="animal" value="multi" /> Mehrere Tiere</label></fieldset>
    <fieldset><legend>2. Welche Futterart soll ausgegeben werden?</legend><label><input type="radio" name="food" value="dry" required /> Trockenfutter</label><label><input type="radio" name="food" value="wet" /> Nassfutter</label><label><input type="radio" name="food" value="both" /> Beides</label></fieldset>
    <fieldset><legend>3. Was ist dir besonders wichtig?</legend><label><input type="radio" name="priority" value="reliable" required /> Zuverlässige Zeitpläne</label><label><input type="radio" name="priority" value="camera" /> Kamera und Fernkontrolle</label><label><input type="radio" name="priority" value="access" /> Individuelle Tiererkennung</label></fieldset>
    <fieldset><legend>4. Wie möchtest du das Gerät steuern?</legend><label><input type="radio" name="control" value="local" required /> Direkt am Gerät</label><label><input type="radio" name="control" value="app" /> Per App</label><label><input type="radio" name="control" value="either" /> Beides ist in Ordnung</label></fieldset>
    <fieldset><legend>5. Wie groß sind die üblichen Portionen?</legend><label><input type="radio" name="portion" value="small" required /> Klein</label><label><input type="radio" name="portion" value="medium" /> Mittel</label><label><input type="radio" name="portion" value="large" /> Groß</label></fieldset>
    <div class="pt-advisor__actions"><button type="submit">Empfehlung anzeigen</button><button type="reset" class="pt-advisor__reset">Zurücksetzen</button></div>
  </form>
  <div class="pt-advisor__result" hidden aria-live="polite"><span class="pt-advisor__result-label">Deine passende Kategorie</span><h3 data-advisor-title></h3><p data-advisor-text></p><ul data-advisor-reasons></ul><a data-advisor-link href="/vergleiche/beste-futterautomaten-fuer-katzen/">Passenden Vergleich öffnen</a><p class="pt-advisor__note">Der Berater grenzt geeignete Gerätetypen ein. Modellangaben, Futtergröße, Portionsbereich und Sicherheit solltest du vor dem Kauf immer einzeln prüfen.</p></div>
</section>
<script>
  document.querySelectorAll("[data-feeder-advisor]").forEach((advisor) => {
    if (!(advisor instanceof HTMLElement) || advisor.dataset.ready === "true") return;
    advisor.dataset.ready = "true";
    const form=advisor.querySelector("form"), result=advisor.querySelector(".pt-advisor__result"), title=advisor.querySelector("[data-advisor-title]"), text=advisor.querySelector("[data-advisor-text]"), reasons=advisor.querySelector("[data-advisor-reasons]"), link=advisor.querySelector("[data-advisor-link]");
    if (!(form instanceof HTMLFormElement) || !(result instanceof HTMLElement) || !(title instanceof HTMLElement) || !(text instanceof HTMLElement) || !(reasons instanceof HTMLElement) || !(link instanceof HTMLAnchorElement)) return;
    const recommendation=(v)=>{const animal=v.get("animal"),food=v.get("food"),priority=v.get("priority"),control=v.get("control"),portion=v.get("portion");
      if(food==="wet"||food==="both")return{title:"Portionsautomat für Nassfutter",text:"Für Nassfutter brauchst du geschlossene Einzelfächer statt eines klassischen Vorratsautomaten.",reasons:["Futter bleibt portionsweise getrennt","Standzeit und Kühlung lassen sich besser kontrollieren","Ein Vorratsbehälter mit Förderschnecke ist dafür ungeeignet"],href:animal==="dog"?"/vergleiche/beste-futterautomaten-fuer-hunde/":"/vergleiche/beste-futterautomaten-fuer-katzen/"};
      if(priority==="access"||animal==="multi")return{title:"Zugangskontrollierter Futterautomat",text:"Bei mehreren Tieren ist entscheidend, welches Tier tatsächlich Zugang zur Portion erhält.",reasons:["Hilft bei unterschiedlichen Rationen","Reduziert Futterdiebstahl zwischen Tieren","Tiererkennung ist wichtiger als ein Doppelnapf"],href:animal==="dog"?"/vergleiche/beste-futterautomaten-fuer-hunde/":"/vergleiche/beste-futterautomaten-fuer-katzen/"};
      if(priority==="camera")return{title:"App-Futterautomat mit Kamera",text:"Eine Kamera ist sinnvoll, wenn du Futterplatz und Geräteausgabe aus der Ferne kontrollieren möchtest.",reasons:["Fernkontrolle des Futterplatzes","Benachrichtigungen und manuelle Ausgabe per App","Datenschutz und mögliche Abokosten mitprüfen"],href:animal==="dog"?"/vergleiche/beste-futterautomaten-fuer-hunde/":"/vergleiche/beste-futterautomaten-fuer-katzen/"};
      if(portion==="large"||animal==="dog")return{title:"Standfester Vorratsautomat mit großem Portionsbereich",text:"Für Hunde und größere Rationen sind Mechanik, Napfgröße und Verriegelung wichtiger als Zusatzfunktionen.",reasons:["Großer nutzbarer Portionsbereich","Standfeste und sicher verschlossene Konstruktion","Auslass und Krokettengröße müssen zusammenpassen"],href:"/vergleiche/beste-futterautomaten-fuer-hunde/"};
      return{title:control==="local"?"Einfacher Vorratsautomat mit lokaler Steuerung":"App-gesteuerter Trockenfutterautomat",text:control==="local"?"Ein lokal programmierbares Modell ist passend, wenn zuverlässige Zeitpläne ohne Cloud im Vordergrund stehen.":"Ein App-Modell ist passend, wenn du Zeitpläne flexibel ändern und Meldungen erhalten möchtest.",reasons:["Geeignet für planbare Trockenfutterportionen","Portionsgewicht mit dem eigenen Futter nachwiegen","Batterie-Backup und lokale Zeitplanspeicherung prüfen"],href:animal==="dog"?"/vergleiche/beste-futterautomaten-fuer-hunde/":"/vergleiche/beste-futterautomaten-fuer-katzen/"};};
    form.addEventListener("submit",e=>{e.preventDefault();if(!form.reportValidity())return;const item=recommendation(new FormData(form));title.textContent=item.title;text.textContent=item.text;reasons.replaceChildren(...item.reasons.map(r=>{const li=document.createElement("li");li.textContent=r;return li;}));link.href=item.href;result.hidden=false;result.scrollIntoView({behavior:"smooth",block:"nearest"});});
    form.addEventListener("reset",()=>{result.hidden=true;});
  });
</script>
<style>
.pt-advisor{margin:48px 0;padding:clamp(22px,4vw,42px);border:1px solid rgba(15,23,42,.1);border-radius:28px;background:linear-gradient(145deg,#f6faf6,#fff);color:#0f172a}.pt-advisor__intro{max-width:760px;margin-bottom:28px}.pt-advisor__eyebrow,.pt-advisor__result-label{color:#2e7d32;font-size:.78rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.pt-advisor h2{margin:8px 0 12px;font-size:clamp(1.65rem,4vw,2.6rem);line-height:1.12}.pt-advisor__intro p{margin:0;color:#475569;line-height:1.65}.pt-advisor__form{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}.pt-advisor fieldset{min-width:0;margin:0;padding:18px;border:1px solid rgba(15,23,42,.1);border-radius:18px;background:#fff}.pt-advisor legend{padding:0 6px;font-weight:800}.pt-advisor label{display:flex;align-items:center;gap:10px;margin-top:11px;color:#334155;cursor:pointer}.pt-advisor input{width:18px;height:18px;accent-color:#2e7d32}.pt-advisor__actions{display:flex;flex-wrap:wrap;gap:12px;align-items:center;grid-column:1/-1}.pt-advisor button,.pt-advisor__result>a{display:inline-flex;justify-content:center;align-items:center;min-height:48px;padding:12px 20px;border:0;border-radius:999px;background:#2e7d32;color:#fff;font:inherit;font-weight:800;text-decoration:none;cursor:pointer}.pt-advisor .pt-advisor__reset{background:#e2e8f0;color:#0f172a}.pt-advisor__result{margin-top:26px;padding:24px;border-radius:20px;background:#fff;border:2px solid rgba(46,125,50,.24)}.pt-advisor__result h3{margin:7px 0 10px;font-size:clamp(1.35rem,3vw,1.9rem)}.pt-advisor__result p,.pt-advisor__result li{color:#475569;line-height:1.6}.pt-advisor__result ul{padding-left:20px;margin-bottom:20px}.pt-advisor__note{margin:16px 0 0;font-size:.88rem}@media(max-width:760px){.pt-advisor{margin:32px 0;border-radius:22px}.pt-advisor__form{grid-template-columns:1fr}}
</style>
