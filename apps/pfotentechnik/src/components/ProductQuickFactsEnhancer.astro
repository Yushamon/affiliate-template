---
interface Props {
  rootSelector?: string;
}

const { rootSelector = "main" } = Astro.props;
---

<div class="quick-facts-enhancer-marker" aria-hidden="true"></div>

<script is:inline define:vars={{ rootSelector }}>
  (() => {
    const PRIMARY_LABELS = new Set([
      "geeignet für",
      "einsatz",
      "kapazität"
    ]);

    const ICONS = {
      "geeignet für": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8.5 11.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Zm7 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM2.5 20c0-3.1 2.7-5.5 6-5.5s6 2.4 6 5.5m0 0c0-2.5 2.1-4.5 4.8-4.5 1 0 1.8.2 2.7.7"/>
        </svg>`,
      "einsatz": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 10.5 12 4l8 6.5V20H4v-9.5Zm5 9.5v-6h6v6"/>
        </svg>`,
      "kapazität": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 4h10l1 4v11H6V8l1-4Zm-1 4h12M9 4V2h6v2"/>
        </svg>`,
      "modell": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Zm0 0v18m8-13.5-8 4.5-8-4.5"/>
        </svg>`,
      "futterart": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 15c0 3 3.6 5 8 5s8-2 8-5H4Zm1-3h14l1 3H4l1-3Zm4-3c0-1 .8-2 1.8-2 .8 0 1.2.4 1.7 1 .5-.8 1.1-1.5 2.2-1.5 1.3 0 2.3 1 2.3 2.5"/>
        </svg>`,
      "krockettengröße": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="7" cy="7" r="2"/>
          <circle cx="15.5" cy="6.5" r="1.5"/>
          <circle cx="11.5" cy="13" r="2.5"/>
          <circle cx="18" cy="16.5" r="2"/>
          <circle cx="5" cy="17" r="1.5"/>
        </svg>`,
      "portionseinheit": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 4h11l2 5-2 11H7L5 4Zm11 2h3v5h-2M8 8h6M9 12h4"/>
        </svg>`,
      "maximale portionszahl": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 5h12v15H6V5Zm3-2v4m6-4v4M6 9h12M9 13h2m2 0h2m-6 3h2m2 0h2"/>
        </svg>`,
      "portionsgewicht": `
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 20h12l-1.5-11h-9L6 20Zm3-11a3 3 0 0 1 6 0m-5 5h4"/>
        </svg>`
    };

    const normalize = (value) =>
      (value || "")
        .trim()
        .toLocaleLowerCase("de")
        .replace(/\s+/g, " ");

    const directText = (element) =>
      Array.from(element.childNodes)
        .filter((node) => node.nodeType === Node.TEXT_NODE)
        .map((node) => node.textContent || "")
        .join(" ")
        .trim();

    const findHeading = (root) =>
      Array.from(root.querySelectorAll("h2, h3"))
        .find((heading) =>
          normalize(heading.textContent).includes("das wichtigste in kürze")
        );

    const findSection = (heading) => {
      let current = heading.parentElement;
      while (current && current !== document.body) {
        const candidates = current.querySelectorAll(
          ":scope > div, :scope > ul, :scope > section"
        );
        if (candidates.length >= 1 && current.textContent.length > 40) {
          return current;
        }
        current = current.parentElement;
      }
      return heading.parentElement;
    };

    const looksLikeFactCard = (element) => {
      const text = (element.textContent || "").trim();
      if (!text || text.length > 520) return false;

      const childCount = element.children.length;
      const hasShortLabel = Array.from(element.querySelectorAll("span, p, dt, small"))
        .some((child) => {
          const value = (child.textContent || "").trim();
          return value.length > 0 && value.length <= 36;
        });

      return childCount >= 1 && hasShortLabel;
    };

    const getCards = (section) => {
      const explicit = Array.from(section.querySelectorAll(
        "[class*='quick-fact'], [class*='quickFact'], [class*='fact-card'], [class*='spec-card']"
      )).filter(looksLikeFactCard);

      if (explicit.length >= 3) return explicit;

      const all = Array.from(section.querySelectorAll("div, li"))
        .filter(looksLikeFactCard)
        .filter((element) => {
          const nested = Array.from(element.querySelectorAll(":scope > div, :scope > li"))
            .filter(looksLikeFactCard);
          return nested.length === 0;
        });

      return all.slice(0, 12);
    };

    const getLabelElement = (card) => {
      const candidates = Array.from(card.querySelectorAll("span, p, dt, small, div"));
      return candidates.find((element) => {
        const text = (element.textContent || "").trim();
        return text.length > 0 && text.length <= 36;
      }) || null;
    };

    const enhance = () => {
      const root = document.querySelector(rootSelector) || document.body;
      const heading = findHeading(root);
      if (!heading) return;

      const section = findSection(heading);
      if (!section || section.dataset.quickFactsEnhanced === "true") return;

      const cards = getCards(section);
      if (cards.length < 3) return;

      section.dataset.quickFactsEnhanced = "true";
      section.classList.add("quick-facts-enhanced");

      const primary = document.createElement("div");
      primary.className = "quick-facts-primary";

      const secondary = document.createElement("div");
      secondary.className = "quick-facts-secondary";

      let primaryCount = 0;
      let secondaryCount = 0;

      for (const card of cards) {
        const labelElement = getLabelElement(card);
        const label = normalize(labelElement?.textContent);

        card.classList.add("quick-facts-card");
        card.dataset.factLabel = label;

        // Alte generische Diamant-Icons ersetzen.
        const oldIcon = Array.from(card.querySelectorAll("span, div"))
          .find((element) => {
            const value = (element.textContent || "").trim();
            return value === "◆" || value === "♦" || value === "●";
          });

        let icon = card.querySelector(".quick-facts-icon");
        if (!icon) {
          icon = document.createElement("span");
          icon.className = "quick-facts-icon";
          icon.innerHTML = ICONS[label] || `
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 3 21 12 12 21 3 12 12 3Z"/>
            </svg>`;
          card.prepend(icon);
        }

        if (oldIcon && oldIcon !== icon) oldIcon.remove();

        if (PRIMARY_LABELS.has(label)) {
          card.classList.add("quick-facts-card--primary");
          primary.appendChild(card);
          primaryCount += 1;
        } else {
          card.classList.add("quick-facts-card--secondary");
          secondary.appendChild(card);
          secondaryCount += 1;
        }
      }

      const originalContainers = new Set(
        cards
          .map((card) => card.parentElement)
          .filter(Boolean)
      );

      const anchor = cards[0];
      anchor.parentElement?.insertBefore(primary, anchor);
      primary.after(secondary);

      for (const container of originalContainers) {
        if (
          container &&
          container !== primary &&
          container !== secondary &&
          container.children.length === 0
        ) {
          container.remove();
        }
      }

      if (!primaryCount) primary.remove();
      if (!secondaryCount) secondary.remove();
    };

    enhance();

    const observer = new MutationObserver(() => enhance());
    observer.observe(document.documentElement, {
      childList: true,
      subtree: true
    });

    window.addEventListener("load", enhance, { once: true });
  })();
</script>

<style is:global>
  .quick-facts-enhanced {
    --qf-border: color-mix(in srgb, var(--color-border, #cbd5e1) 88%, transparent);
    --qf-surface: color-mix(in srgb, var(--color-surface, #fff) 96%, transparent);
    --qf-soft: color-mix(in srgb, var(--color-primary, #16a34a) 8%, var(--qf-surface));
  }

  .quick-facts-primary,
  .quick-facts-secondary {
    display: grid;
    gap: 14px;
    width: 100%;
  }

  .quick-facts-primary {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 0 0 14px;
  }

  .quick-facts-secondary {
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .quick-facts-card {
    position: relative;
    display: grid !important;
    grid-template-columns: 42px minmax(0, 1fr) !important;
    grid-template-rows: auto 1fr;
    column-gap: 12px;
    align-items: start !important;
    min-width: 0 !important;
    height: auto !important;
    min-height: 126px !important;
    padding: 16px !important;
    overflow: visible !important;
    border: 1px solid var(--qf-border) !important;
    border-radius: 16px !important;
    background: var(--qf-surface) !important;
  }

  .quick-facts-card--primary {
    min-height: 150px !important;
    background:
      linear-gradient(145deg, var(--qf-soft), var(--qf-surface)) !important;
  }

  .quick-facts-icon {
    grid-column: 1;
    grid-row: 1 / span 2;
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--color-primary, #16a34a) 10%, transparent);
    color: var(--color-primary, #15803d);
  }

  .quick-facts-icon svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .quick-facts-card > :not(.quick-facts-icon) {
    grid-column: 2;
    min-width: 0;
  }

  .quick-facts-card :is(p, dd, strong, span, div) {
    max-width: none !important;
    overflow: visible !important;
    text-overflow: clip !important;
    white-space: normal !important;
    overflow-wrap: anywhere;
    -webkit-line-clamp: unset !important;
    line-clamp: unset !important;
  }

  .quick-facts-card [data-long-product-fact="true"],
  .quick-facts-card[data-long-product-fact="true"] {
    overflow: visible !important;
  }

  .quick-facts-card--primary :is(strong, dd, p:last-child) {
    line-height: 1.42;
  }

  /* Auch Tabellen und technische Daten dürfen Eignungstexte vollständig zeigen. */
  .product-renderer :is(
    [class*="technical"],
    [class*="spec"],
    table,
    dl
  ) :is(td, dd, p, strong, span) {
    -webkit-line-clamp: unset !important;
    line-clamp: unset !important;
    overflow: visible !important;
    text-overflow: clip !important;
    white-space: normal !important;
  }

  @media (max-width: 980px) {
    .quick-facts-primary {
      grid-template-columns: 1fr;
    }

    .quick-facts-secondary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .quick-facts-card--primary {
      min-height: 0 !important;
    }
  }

  @media (max-width: 620px) {
    .quick-facts-primary,
    .quick-facts-secondary {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .quick-facts-card {
      min-height: 0 !important;
      padding: 14px !important;
      border-radius: 14px !important;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .quick-facts-card {
      transition:
        border-color 160ms ease,
        transform 160ms ease,
        box-shadow 160ms ease;
    }

    .quick-facts-card:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 28px rgb(15 23 42 / 0.07);
    }
  }

  :global(html.dark) .quick-facts-enhanced,
  :global([data-theme="dark"]) .quick-facts-enhanced {
    --qf-border: rgb(71 85 105 / 0.72);
    --qf-surface: rgb(15 23 42 / 0.86);
    --qf-soft: rgb(20 83 45 / 0.22);
  }
</style>
