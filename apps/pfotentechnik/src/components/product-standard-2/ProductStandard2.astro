---
import DecisionCard from "./DecisionCard.astro";
import QuickFacts from "./QuickFacts.astro";
import TrustBar from "./TrustBar.astro";

const { product } = Astro.props;
const data = product?.data ?? product ?? {};
const ps2 = data.productStandard2 ?? {};
const decision = ps2.decision ?? data.decision ?? null;
const facts = Array.isArray(ps2.quickFacts) ? ps2.quickFacts : [];
const trust = ps2.trust ?? null;

const hasDecision = decision && (
  (Array.isArray(decision.goodFor) && decision.goodFor.length > 0) ||
  (Array.isArray(decision.notFor) && decision.notFor.length > 0)
);
---

<div class="product-standard-2" data-product-standard="2.0">
  {hasDecision && <DecisionCard decision={decision} />}
  {facts.length > 0 && <QuickFacts facts={facts} />}
  {trust && <TrustBar trust={trust} />}
</div>

<style>
  .product-standard-2 { display: grid; gap: 20px; margin-block: 24px; }
</style>
