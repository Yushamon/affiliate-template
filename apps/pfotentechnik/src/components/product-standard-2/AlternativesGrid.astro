---
interface Alternative {
  title: string;
  slug?: string;
  url?: string;
  image?: string;
  reason?: string;
  badge?: string;
}
interface Props { alternatives: Alternative[]; }
const { alternatives } = Astro.props;
const normalized = alternatives
  .filter((item) => item && item.title)
  .map((item) => ({
    ...item,
    href: item.url ?? (item.slug ? `/produkt/${item.slug}/` : undefined)
  }));
---

{normalized.length > 0 && (
  <section class="alternatives" aria-labelledby="alternatives-title">
    <div class="head">
      <div>
        <p>Alternativen</p>
        <h2 id="alternatives-title">Diese Produkte könnten besser passen</h2>
      </div>
    </div>
    <div class="alternatives-grid">
      {normalized.map((item) => (
        <article class="alternative-card">
          {item.image && <img src={item.image} alt="" loading="lazy" decoding="async" />}
          <div>
            {item.badge && <span class="badge">{item.badge}</span>}
            <h3>{item.title}</h3>
            {item.reason && <p>{item.reason}</p>}
            {item.href && <a href={item.href}>Alternative ansehen</a>}
          </div>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .alternatives {
    padding: clamp(18px, 3vw, 28px);
    border: 1px solid var(--ps2-border, #dce5e0);
    border-radius: 18px;
    background: var(--ps2-surface, #fff);
  }
  .head p { margin: 0 0 4px; color: var(--ps2-accent, #2e7d32); font-size: .75rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  h2 { margin: 0 0 18px; font-size: clamp(1.2rem, 2vw, 1.5rem); }
  .alternatives-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .alternative-card { overflow: hidden; border: 1px solid var(--ps2-border, #dce5e0); border-radius: 14px; background: var(--ps2-surface-soft, #f7faf8); }
  .alternative-card img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; background: #fff; }
  .alternative-card > div { padding: 16px; }
  .badge { display: inline-flex; margin-bottom: 8px; padding: 4px 8px; border-radius: 999px; background: color-mix(in srgb, var(--ps2-accent, #2e7d32) 12%, transparent); color: var(--ps2-accent, #2e7d32); font-size: .72rem; font-weight: 800; }
  h3 { margin: 0 0 8px; font-size: 1rem; }
  .alternative-card p { margin: 0 0 12px; color: var(--ps2-muted, #637069); }
  .alternative-card a { color: var(--ps2-accent, #2e7d32); font-weight: 750; text-decoration: none; }
  :global([data-theme="dark"]) .alternatives,
  :global(.dark) .alternatives {
    --ps2-surface: #171f1b;
    --ps2-surface-soft: #202a25;
    --ps2-border: #2c3932;
    --ps2-muted: #a0aea6;
    --ps2-accent: #79d5aa;
    color: #eff6f2;
  }
</style>
