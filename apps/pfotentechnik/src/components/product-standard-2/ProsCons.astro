---
interface Props {
  pros?: string[];
  cons?: string[];
}
const { pros = [], cons = [] } = Astro.props;
---

<section class="pros-cons" aria-labelledby="pros-cons-title">
  <h2 id="pros-cons-title">Warum wir dieses Produkt empfehlen</h2>
  <div class="pros-cons-grid">
    {pros.length > 0 && (
      <article class="panel panel--pros">
        <h3>Stärken</h3>
        <ul>{pros.map((item) => <li><span aria-hidden="true">✓</span>{item}</li>)}</ul>
      </article>
    )}
    {cons.length > 0 && (
      <article class="panel panel--cons">
        <h3>Schwächen</h3>
        <ul>{cons.map((item) => <li><span aria-hidden="true">×</span>{item}</li>)}</ul>
      </article>
    )}
  </div>
</section>

<style>
  .pros-cons {
    padding: clamp(18px, 3vw, 28px);
    border: 1px solid var(--ps2-border, #dce5e0);
    border-radius: 18px;
    background: var(--ps2-surface, #fff);
  }
  h2 { margin: 0 0 18px; font-size: clamp(1.2rem, 2vw, 1.5rem); }
  .pros-cons-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
  .panel { padding: 18px; border-radius: 14px; border: 1px solid transparent; }
  .panel--pros { background: color-mix(in srgb, #2e7d32 9%, var(--ps2-surface, #fff)); border-color: color-mix(in srgb, #2e7d32 24%, transparent); }
  .panel--cons { background: color-mix(in srgb, #dc2626 8%, var(--ps2-surface, #fff)); border-color: color-mix(in srgb, #dc2626 22%, transparent); }
  h3 { margin: 0 0 12px; font-size: 1rem; }
  ul { display: grid; gap: 9px; margin: 0; padding: 0; list-style: none; }
  li { display: grid; grid-template-columns: 22px minmax(0, 1fr); gap: 8px; }
  .panel--pros li span { color: #2e7d32; font-weight: 800; }
  .panel--cons li span { color: #dc2626; font-weight: 800; }
  @media (max-width: 720px) { .pros-cons-grid { grid-template-columns: 1fr; } }
  :global([data-theme="dark"]) .pros-cons,
  :global(.dark) .pros-cons {
    --ps2-surface: #171f1b;
    --ps2-border: #2c3932;
    color: #eff6f2;
  }
</style>
