---
const { facts = [] } = Astro.props;
---

<section class="quick-facts" aria-labelledby="quick-facts-title">
  <h2 id="quick-facts-title">Quick Facts</h2>
  <div class="facts-grid">
    {facts.map((fact) => (
      <article class="fact-card">
        {fact.icon && <span class="fact-icon" aria-hidden="true">{fact.icon}</span>}
        <span class="fact-label">{fact.label}</span>
        <strong>{fact.value}</strong>
        {fact.note && <small>{fact.note}</small>}
      </article>
    ))}
  </div>
</section>

<style>
  .quick-facts {
    padding: clamp(18px, 3vw, 28px);
    border: 1px solid var(--ps2-border, #dce5e0);
    border-radius: 18px;
    background: var(--ps2-surface, #fff);
    color: var(--ps2-text, #15211b);
  }
  .quick-facts h2 { margin: 0 0 18px; font-size: clamp(1.2rem, 2vw, 1.5rem); }
  .facts-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(130px,1fr)); gap: 12px; }
  .fact-card { min-width: 0; padding: 16px; border: 1px solid var(--ps2-border, #dce5e0); border-radius: 14px; background: var(--ps2-soft, #f7faf8); }
  .fact-icon { display: grid; place-items: center; width: 34px; height: 34px; margin-bottom: 10px; border-radius: 10px; background: color-mix(in srgb, #2e7d32 12%, transparent); }
  .fact-label, .fact-card small { display: block; color: var(--ps2-muted, #637069); }
  .fact-card strong { display: block; margin-top: 4px; font-size: 1rem; }
  .fact-card small { margin-top: 5px; line-height: 1.35; }
  :global([data-theme="dark"]) .quick-facts,
  :global(.dark) .quick-facts {
    --ps2-surface: #171f1b;
    --ps2-soft: #202a25;
    --ps2-border: #2c3932;
    --ps2-muted: #a0aea6;
    --ps2-text: #eff6f2;
  }
</style>
