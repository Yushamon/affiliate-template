---
interface Props {
  product: any;
  reviewProduct: any;
  alternativeRecommendations?: any[];
  debug?: boolean;
}

const {
  product,
  reviewProduct,
  alternativeRecommendations = []
} = Astro.props;

const source = product?.data ?? product ?? {};
const value = reviewProduct ?? {};

const list = <T,>(input: T[] | null | undefined): T[] =>
  Array.isArray(input) ? input : [];

const asText = (input: unknown, fallback = ""): string => {
  if (typeof input === "string") return input.trim();
  if (typeof input === "number") return String(input);
  if (input && typeof input === "object") {
    const candidate =
      (input as any).label ??
      (input as any).name ??
      (input as any).title ??
      (input as any).value;
    return candidate == null ? fallback : String(candidate).trim();
  }
  return fallback;
};

const imageUrl = (input: any): string => {
  if (!input) return "";
  if (typeof input === "string") return input;
  if (typeof input.src === "string") return input.src;
  if (input.src && typeof input.src.src === "string") return input.src.src;
  if (typeof input.url === "string") return input.url;
  return "";
};

const name = asText(value.name ?? source.title, "Produkt");
const manufacturer = asText(
  value.manufacturerLabel ??
  source.manufacturer?.name ??
  source.manufacturer
);
const category = asText(
  value.category ??
  source.category?.label ??
  source.category
);
const recommendation = asText(
  value.recommendation ??
  source.recommendation ??
  source.description
);
const description = asText(source.description ?? recommendation);

const rating = Number(value.rating ?? source.rating ?? 0);
const editorialScore = Number(value.score ?? source.score ?? 0);
const ratingCount = Number(
  source.ratingCount ??
  source.reviewCount ??
  source.ratingsCount ??
  0
);

const rawHero =
  value.images?.hero ??
  source.images?.hero ??
  source.heroImage ??
  source.image;

const galleryEntries = [
  rawHero,
  ...list<any>(value.images?.gallery ?? source.images?.gallery)
];

const gallery = galleryEntries
  .map((entry: any, index: number) => ({
    src: imageUrl(entry),
    alt:
      asText(entry?.alt) ||
      (index === 0 ? name : `${name} – Ansicht ${index + 1}`),
    caption: asText(entry?.caption)
  }))
  .filter((entry: any, index: number, entries: any[]) =>
    entry.src &&
    entries.findIndex((candidate) => candidate.src === entry.src) === index
  );

const hero = gallery[0];

const pros = list<string>(
  value.pros ??
  source.strengths ??
  source.pros
).filter(Boolean);

const cons = list<string>(
  value.cons ??
  source.weaknesses ??
  source.cons
).filter(Boolean);

const bestFor = list<string>(
  value.bestFor ??
  source.decision?.bestFor ??
  source.decision?.goodFor
).filter(Boolean);

const notFor = list<string>(
  value.notFor ??
  source.decision?.attention ??
  source.decision?.notFor
).filter(Boolean);

const rawSpecs =
  value.specs ??
  source.specs ??
  source.specifications ??
  {};

const specEntries = Array.isArray(rawSpecs)
  ? rawSpecs
      .map((item: any) => ({
        label: asText(item?.label ?? item?.name ?? item?.title),
        value: asText(item?.value ?? item?.text ?? item?.description)
      }))
      .filter((item: any) => item.label && item.value)
  : Object.entries(rawSpecs ?? {})
      .map(([label, specValue]) => ({
        label,
        value: asText(specValue)
      }))
      .filter((item) => item.value);

const explicitQuickFacts = list<any>(
  source.productStandard2?.quickFacts ??
  source.quickFacts ??
  source.highlights
);

const quickFacts = (
  explicitQuickFacts.length
    ? explicitQuickFacts.map((fact: any) => ({
        label: asText(fact?.label ?? fact?.title ?? fact?.name, "Merkmal"),
        value: asText(fact?.value ?? fact?.text ?? fact?.description ?? fact),
        note: asText(fact?.note)
      }))
    : [
        value.capacity
          ? { label: "Kapazität", value: asText(value.capacity), note: "" }
          : null,
        value.useCase
          ? { label: "Einsatz", value: asText(value.useCase), note: "" }
          : null,
        ...specEntries.slice(0, 6)
      ]
).filter(Boolean).filter((fact: any) => fact.label && fact.value).slice(0, 8);

const review = value.review ?? source.review ?? {};
const reviewText = asText(
  review?.summary ??
  review?.verdict ??
  review?.text ??
  review?.body ??
  recommendation
);

const packageContents = list<any>(
  source.packageContents ??
  source.included ??
  source.scopeOfDelivery ??
  source.delivery
)
  .map((item) => asText(item))
  .filter(Boolean);

const faq = list<any>(
  source.productStandard2?.faq ??
  source.faq ??
  review?.faq
)
  .map((item: any) => ({
    question: asText(item?.question ?? item?.title),
    answer: asText(item?.answer ?? item?.text)
  }))
  .filter((item: any) => item.question && item.answer);

const affiliate = value.affiliate ?? source.affiliate ?? {};
const conversion = value.conversion ?? source.conversion ?? {};

const affiliateUrl = asText(
  affiliate.url ??
  conversion.url ??
  conversion.primaryUrl ??
  source.productUrl
);

const ctaLabel = asText(
  affiliate.label ??
  conversion.label ??
  conversion.ctaLabel ??
  conversion.primaryLabel,
  "Preis prüfen"
);

const price = asText(
  conversion.price ??
  conversion.currentPrice ??
  affiliate.price ??
  source.price
);

const priceNote = asText(
  conversion.priceNote ??
  conversion.note ??
  affiliate.note,
  "Preis und Verfügbarkeit können sich ändern."
);

const trust = source.editorial ?? source.trust ?? {};
const updatedAt = asText(
  trust.lastVerifiedAt ??
  source.updatedAt ??
  source.publishedAt
);

const testStatus = asText(
  source.testStatus ??
  trust.assessmentType ??
  trust.testStatus,
  "Redaktionelle Einordnung"
);

const alternatives = list<any>(alternativeRecommendations)
  .map((item: any) => {
    const entry = item?.product?.data ?? item?.data ?? item?.product ?? item;
    const slug =
      asText(entry?.slug ?? item?.slug);
    return {
      title: asText(entry?.title ?? entry?.name ?? item?.title, "Alternative"),
      href: asText(
        item?.href ??
        item?.url ??
        entry?.productUrl,
        slug ? `/produkt/${slug}/` : "#"
      ),
      image: imageUrl(
        entry?.images?.thumbnail ??
        entry?.images?.hero ??
        entry?.image ??
        item?.image
      ),
      reason: asText(
        item?.reason ??
        item?.description ??
        entry?.recommendation ??
        entry?.description
      ),
      score: Number(entry?.score ?? item?.score ?? 0)
    };
  })
  .filter((item: any) => item.title)
  .slice(0, 3);

const scoreLabel =
  editorialScore >= 9 ? "Hervorragend" :
  editorialScore >= 8 ? "Sehr gut" :
  editorialScore >= 7 ? "Gut" :
  editorialScore > 0 ? "Solide" :
  "Redaktionell eingeordnet";

const starWidth = `${Math.max(0, Math.min(100, (rating / 5) * 100))}%`;
---

<section class="native-product" data-product-engine="3.0">
  <header class="native-product__intro">
    <div class="native-product__badges">
      {category && <span class="native-product__badge">{category}</span>}
      {manufacturer && <span class="native-product__badge native-product__badge--soft">{manufacturer}</span>}
    </div>

    <h1>{name}</h1>

    {description && <p class="native-product__lead">{description}</p>}

    <div class="native-product__ratings" aria-label="Produktbewertung">
      {rating > 0 && (
        <div class="native-product__stars" aria-label={`${rating} von 5 Sternen`}>
          <span aria-hidden="true">★★★★★</span>
          <span class="native-product__stars-fill" style={`width:${starWidth}`} aria-hidden="true">★★★★★</span>
        </div>
      )}

      {rating > 0 && <strong>{rating.toLocaleString("de-DE", { maximumFractionDigits: 1 })}</strong>}
      {ratingCount > 0 && <span>({ratingCount.toLocaleString("de-DE")})</span>}

      {editorialScore > 0 && (
        <span class="native-product__score">
          {editorialScore.toLocaleString("de-DE", { maximumFractionDigits: 1 })}
          <small>/10</small>
        </span>
      )}

      <span class="native-product__score-label">{scoreLabel}</span>
    </div>
  </header>

  <div class="native-product__commerce">
    <section class="native-gallery" data-native-gallery>
      {hero ? (
        <>
          <div class="native-gallery__stage">
            {gallery.map((image: any, index: number) => (
              <figure
                class:list={[
                  "native-gallery__slide",
                  { "is-active": index === 0 }
                ]}
                data-gallery-slide={index}
              >
                <img
                  src={image.src}
                  alt={image.alt}
                  width="1200"
                  height="900"
                  loading={index === 0 ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                />
                {image.caption && <figcaption>{image.caption}</figcaption>}
              </figure>
            ))}

            {gallery.length > 1 && (
              <>
                <button class="native-gallery__nav native-gallery__nav--prev" type="button" data-gallery-prev aria-label="Vorheriges Bild">‹</button>
                <button class="native-gallery__nav native-gallery__nav--next" type="button" data-gallery-next aria-label="Nächstes Bild">›</button>
                <span class="native-gallery__counter" data-gallery-counter>1/{gallery.length}</span>
              </>
            )}
          </div>

          {gallery.length > 1 && (
            <div class="native-gallery__thumbs" aria-label="Produktbilder">
              {gallery.map((image: any, index: number) => (
                <button
                  class:list={[
                    "native-gallery__thumb",
                    { "is-active": index === 0 }
                  ]}
                  type="button"
                  data-gallery-thumb={index}
                  aria-label={`Bild ${index + 1} anzeigen`}
                >
                  <img src={image.src} alt="" width="160" height="120" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </>
      ) : (
        <div class="native-gallery__fallback">
          <span>Produktbild folgt</span>
        </div>
      )}
    </section>

    <aside class="native-buybox" aria-label="Kaufoptionen">
      {editorialScore > 0 && (
        <div class="native-buybox__score">
          <strong>{editorialScore.toLocaleString("de-DE", { maximumFractionDigits: 1 })}</strong>
          <span>/10</span>
          <small>{scoreLabel}</small>
        </div>
      )}

      {price && (
        <div class="native-buybox__price">
          <span>Aktueller Preis</span>
          <strong>{price}</strong>
        </div>
      )}

      {affiliateUrl ? (
        <a class="native-buybox__primary" href={affiliateUrl} rel="nofollow sponsored noopener" target="_blank">
          {ctaLabel}
          <span aria-hidden="true">→</span>
        </a>
      ) : (
        <span class="native-buybox__primary native-buybox__primary--disabled">Preis derzeit nicht verlinkt</span>
      )}

      <a class="native-buybox__secondary" href="#alternativen">
        Alternativen vergleichen
      </a>

      <p class="native-buybox__note">{priceNote}</p>

      <dl class="native-buybox__meta">
        {manufacturer && <div><dt>Hersteller</dt><dd>{manufacturer}</dd></div>}
        {category && <div><dt>Kategorie</dt><dd>{category}</dd></div>}
        {testStatus && <div><dt>Status</dt><dd>{testStatus}</dd></div>}
        {updatedAt && <div><dt>Aktualisiert</dt><dd>{updatedAt}</dd></div>}
      </dl>
    </aside>
  </div>

  {quickFacts.length > 0 && (
    <section class="native-panel native-quickfacts" aria-labelledby="native-quickfacts-title">
      <h2 id="native-quickfacts-title">Das Wichtigste in Kürze</h2>
      <div class="native-quickfacts__grid">
        {quickFacts.map((fact: any) => (
          <article>
            <span class="native-quickfacts__icon" aria-hidden="true">◆</span>
            <div>
              <small>{fact.label}</small>
              <strong>{fact.value}</strong>
              {fact.note && <span>{fact.note}</span>}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  {(bestFor.length > 0 || notFor.length > 0) && (
    <section class="native-panel native-decision" aria-labelledby="native-decision-title">
      <h2 id="native-decision-title">Passt {name} zu dir?</h2>
      <div class="native-decision__grid">
        {bestFor.length > 0 && (
          <article class="native-decision__card native-decision__card--yes">
            <h3>Passt gut, wenn …</h3>
            <ul>
              {bestFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        )}

        {notFor.length > 0 && (
          <article class="native-decision__card native-decision__card--no">
            <h3>Weniger geeignet, wenn …</h3>
            <ul>
              {notFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        )}
      </div>
    </section>
  )}

  <section class="native-summary-grid">
    {pros.length > 0 && (
      <article class="native-panel native-list-card native-list-card--positive">
        <h2>Vorteile</h2>
        <ul>{pros.map((item) => <li>{item}</li>)}</ul>
      </article>
    )}

    {cons.length > 0 && (
      <article class="native-panel native-list-card native-list-card--negative">
        <h2>Nachteile</h2>
        <ul>{cons.map((item) => <li>{item}</li>)}</ul>
      </article>
    )}

    {(reviewText || recommendation) && (
      <article class="native-panel native-recommendation">
        <span>Unsere Empfehlung</span>
        <h2>Redaktionelles Urteil</h2>
        <p>{reviewText || recommendation}</p>
        {recommendation && reviewText !== recommendation && (
          <strong>{recommendation}</strong>
        )}
      </article>
    )}
  </section>

  {(specEntries.length > 0 || packageContents.length > 0) && (
    <section class="native-detail-grid">
      {specEntries.length > 0 && (
        <article class="native-panel native-specs">
          <h2>Technische Daten</h2>
          <dl>
            {specEntries.map((spec) => (
              <div>
                <dt>{spec.label}</dt>
                <dd>{spec.value}</dd>
              </div>
            ))}
          </dl>
        </article>
      )}

      {packageContents.length > 0 && (
        <article class="native-panel native-package">
          <h2>Lieferumfang</h2>
          <ul>{packageContents.map((item) => <li>{item}</li>)}</ul>
        </article>
      )}
    </section>
  )}

  {(alternatives.length > 0 || faq.length > 0) && (
    <section class="native-bottom-grid">
      {alternatives.length > 0 && (
        <article class="native-panel native-alternatives" id="alternativen">
          <h2>Alternativen zu {name}</h2>
          <div class="native-alternatives__grid">
            {alternatives.map((item) => (
              <a href={item.href}>
                {item.image && <img src={item.image} alt="" width="180" height="135" loading="lazy" />}
                <div>
                  <strong>{item.title}</strong>
                  {item.score > 0 && <span>{item.score.toLocaleString("de-DE", { maximumFractionDigits: 1 })}/10</span>}
                  {item.reason && <p>{item.reason}</p>}
                </div>
              </a>
            ))}
          </div>
        </article>
      )}

      {faq.length > 0 && (
        <article class="native-panel native-faq">
          <h2>Häufige Fragen</h2>
          <div>
            {faq.map((item) => (
              <details>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </article>
      )}
    </section>
  )}

  <section class="native-trustbar" aria-label="Transparenz und Vertrauen">
    <div>
      <span aria-hidden="true">✓</span>
      <p><small>Prüfstatus</small><strong>{testStatus}</strong></p>
    </div>
    <div>
      <span aria-hidden="true">↻</span>
      <p><small>Zuletzt geprüft</small><strong>{updatedAt || "laufend aktualisiert"}</strong></p>
    </div>
    <div>
      <span aria-hidden="true">§</span>
      <p><small>Bewertung</small><strong>Nach einheitlichen Kriterien</strong></p>
    </div>
  </section>

  {affiliateUrl && (
    <div class="native-mobile-buybar">
      <div>
        {price && <strong>{price}</strong>}
        <span>{name}</span>
      </div>
      <a href={affiliateUrl} rel="nofollow sponsored noopener" target="_blank">{ctaLabel}</a>
    </div>
  )}
</section>

<script>
  document.querySelectorAll("[data-native-gallery]").forEach((gallery) => {
    const slides = Array.from(gallery.querySelectorAll("[data-gallery-slide]"));
    const thumbs = Array.from(gallery.querySelectorAll("[data-gallery-thumb]"));
    const previous = gallery.querySelector("[data-gallery-prev]");
    const next = gallery.querySelector("[data-gallery-next]");
    const counter = gallery.querySelector("[data-gallery-counter]");
    let active = 0;

    const show = (index) => {
      if (!slides.length) return;
      active = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle("is-active", slideIndex === active);
      });
      thumbs.forEach((thumb, thumbIndex) => {
        thumb.classList.toggle("is-active", thumbIndex === active);
      });
      if (counter) counter.textContent = `${active + 1}/${slides.length}`;
    };

    previous?.addEventListener("click", () => show(active - 1));
    next?.addEventListener("click", () => show(active + 1));
    thumbs.forEach((thumb, index) => {
      thumb.addEventListener("click", () => show(index));
    });

    let startX = null;
    gallery.addEventListener("touchstart", (event) => {
      startX = event.touches[0]?.clientX ?? null;
    }, { passive: true });

    gallery.addEventListener("touchend", (event) => {
      if (startX == null) return;
      const endX = event.changedTouches[0]?.clientX ?? startX;
      const delta = endX - startX;
      if (Math.abs(delta) > 45) show(active + (delta < 0 ? 1 : -1));
      startX = null;
    }, { passive: true });
  });
</script>

<style>
  .native-product {
    --np-bg: #ffffff;
    --np-surface: #ffffff;
    --np-surface-soft: #f7f9fc;
    --np-surface-strong: #eef3f8;
    --np-text: #111827;
    --np-muted: #64748b;
    --np-border: #dbe3ec;
    --np-green: #16a34a;
    --np-green-dark: #087333;
    --np-green-soft: #ecfdf3;
    --np-red: #dc2626;
    --np-red-soft: #fff1f2;
    --np-amber: #f59e0b;
    --np-shadow: 0 18px 48px rgba(15, 23, 42, .08);
    display: grid;
    gap: clamp(18px, 3vw, 28px);
    color: var(--np-text);
  }

  :global(html[data-theme="dark"]) .native-product,
  :global(.dark) .native-product,
  :global([data-theme="dark"]) .native-product {
    --np-bg: #071523;
    --np-surface: #0e2032;
    --np-surface-soft: #12273c;
    --np-surface-strong: #183049;
    --np-text: #f8fafc;
    --np-muted: #b9c6d6;
    --np-border: #294158;
    --np-green: #52d889;
    --np-green-dark: #3ec678;
    --np-green-soft: rgba(34, 197, 94, .12);
    --np-red: #ff7272;
    --np-red-soft: rgba(239, 68, 68, .11);
    --np-amber: #fbbf24;
    --np-shadow: none;
  }

  .native-product * {
    box-sizing: border-box;
  }

  .native-product__intro {
    display: grid;
    gap: 10px;
  }

  .native-product__badges,
  .native-product__ratings {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 9px;
  }

  .native-product__badge {
    display: inline-flex;
    padding: 5px 9px;
    border-radius: 7px;
    background: var(--np-green);
    color: #fff;
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .02em;
    text-transform: uppercase;
  }

  .native-product__badge--soft {
    background: var(--np-green-soft);
    color: var(--np-green-dark);
  }

  .native-product h1 {
    margin: 0;
    max-width: 820px;
    color: var(--np-text);
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.03;
    letter-spacing: -.035em;
  }

  .native-product__lead {
    max-width: 760px;
    margin: 0;
    color: var(--np-muted);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.65;
  }

  .native-product__ratings {
    color: var(--np-muted);
    font-size: .9rem;
  }

  .native-product__stars {
    position: relative;
    display: inline-block;
    color: #cbd5e1;
    letter-spacing: 2px;
  }

  .native-product__stars-fill {
    position: absolute;
    inset: 0 auto 0 0;
    overflow: hidden;
    color: var(--np-amber);
    white-space: nowrap;
  }

  .native-product__score {
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    padding: 4px 9px;
    border-radius: 8px;
    background: var(--np-green);
    color: #fff;
    font-weight: 900;
  }

  .native-product__score small {
    font-size: .65rem;
  }

  .native-product__score-label {
    font-size: .78rem;
  }

  .native-product__commerce {
    display: grid;
    gap: 18px;
  }

  .native-gallery__stage,
  .native-gallery__fallback {
    position: relative;
    min-height: 290px;
    overflow: hidden;
    border: 1px solid var(--np-border);
    border-radius: 20px;
    background: var(--np-surface-soft);
  }

  .native-gallery__slide {
    display: none;
    width: 100%;
    height: 100%;
    margin: 0;
  }

  .native-gallery__slide.is-active {
    display: block;
  }

  .native-gallery__slide img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
    background: var(--np-surface-soft);
  }

  .native-gallery__slide figcaption {
    position: absolute;
    inset: auto 14px 14px;
    padding: 7px 10px;
    border-radius: 9px;
    background: rgba(0, 0, 0, .68);
    color: white;
    font-size: .75rem;
  }

  .native-gallery__fallback {
    display: grid;
    place-items: center;
    color: var(--np-muted);
  }

  .native-gallery__nav {
    position: absolute;
    top: 50%;
    z-index: 3;
    display: grid;
    width: 42px;
    height: 50px;
    place-items: center;
    border: 0;
    background: rgba(15, 23, 42, .72);
    color: white;
    font-size: 2rem;
    cursor: pointer;
    transform: translateY(-50%);
  }

  .native-gallery__nav--prev {
    left: 0;
    border-radius: 0 12px 12px 0;
  }

  .native-gallery__nav--next {
    right: 0;
    border-radius: 12px 0 0 12px;
  }

  .native-gallery__counter {
    position: absolute;
    right: 14px;
    bottom: 14px;
    z-index: 3;
    padding: 6px 9px;
    border-radius: 999px;
    background: rgba(15, 23, 42, .78);
    color: white;
    font-size: .75rem;
    font-weight: 800;
  }

  .native-gallery__thumbs {
