---
export interface Metric {
  label: string;
  value: string;
}

export interface Fact {
  label: string;
  value: string;
}

export interface Props {
  title: string;
  description: string;
  imageSrc: string;
  imageAlt: string;
  badge?: string;
  rating?: number;
  verdictTitle?: string;
  verdictText?: string;
  tags?: string[];
  metrics?: Metric[];
  highlights?: string[];
  facts?: Fact[];
  priceUrl?: string;
  priceLabel?: string;
}

const {
  title,
  description,
  imageSrc,
  imageAlt,
  badge = "Unsere Empfehlung",
  rating = 4.6,
  verdictTitle = "Sehr gut",
  verdictText = description,
  tags = [],
  metrics = [],
  highlights = [],
  facts = [],
  priceUrl = "#preisvergleich",
  priceLabel = "Zum Preisvergleich",
} = Astro.props;

const score = Math.max(0, Math.min(5, rating));
const ratingWidth = `${(score / 5) * 100}%`;
---

<section class="pt-product-hero" aria-labelledby="product-title">
  <div class="pt-product-hero__media">
    <img
      src={imageSrc}
      alt={imageAlt}
      width="1200"
      height="900"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    {badge && <span class="pt-product-hero__badge">{badge}</span>}
  </div>

  <div class="pt-product-hero__body">
    <p class="pt-product-hero__eyebrow">Unsere Einschätzung</p>
    <h1 id="product-title">{title}</h1>
    <p class="pt-product-hero__description">{description}</p>

    {tags.length > 0 && (
      <ul class="pt-product-hero__tags" aria-label="Produkteigenschaften">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )}

    <section class="pt-verdict" aria-label="Unsere Einschätzung">
      <div class="pt-verdict__top">
        <div>
          <p class="pt-verdict__eyebrow">Unsere Einschätzung</p>
          <h2>{verdictTitle}</h2>
        </div>
        <strong>{score.toFixed(1).replace(".", ",")} / 5</strong>
      </div>

      <div
        class="pt-stars"
        style={`--rating-width:${ratingWidth}`}
        aria-label={`${score} von 5 Sternen`}
      >
        <span aria-hidden="true">★★★★★</span>
        <span aria-hidden="true">★★★★★</span>
      </div>

      <p>{verdictText}</p>
    </section>

    {metrics.length > 0 && (
      <dl class="pt-metrics">
        {metrics.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>
    )}

    <a class="pt-price-cta" href={priceUrl} rel="nofollow sponsored">
      <span>{priceLabel}</span>
      <span aria-hidden="true">›</span>
    </a>

    <p class="pt-price-note">Preise werden regelmäßig aktualisiert</p>

    {highlights.length > 0 && (
      <section class="pt-highlights">
        <h2>Das Wichtigste in Kürze</h2>
        <ul>
          {highlights.map((item) => (
            <li>
              <span class="pt-check" aria-hidden="true">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {facts.length > 0 && (
      <dl class="pt-facts">
        {facts.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>
    )}
  </div>
</section>
