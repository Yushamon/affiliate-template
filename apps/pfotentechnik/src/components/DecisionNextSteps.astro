---
import OptimizedImage from "@affiliate-core/components/OptimizedImage.astro";

type Item = {
  kind?: "product" | "comparison" | "guide" | "manufacturer";
  eyebrow: string;
  title: string;
  text?: string;
  href: string;
  label: string;
  image?: { src: any; alt?: string };
  score?: number;
  stat?: { value: string; label: string };
  highlights?: string[];
};

interface Props {
  title?: string;
  intro?: string;
  items: Item[];
}

const {
  title = "Deine nächsten Schritte",
  intro = "Direkt zum passenden Produkt oder alle geeigneten Modelle vergleichen.",
  items
} = Astro.props;

const visibleItems = items
  .filter((item) => item?.href && item?.title && item?.label)
  .slice(0, 2);
---

{visibleItems.length > 0 && (
  <section class="pt-next-steps" aria-labelledby="pt-next-steps-title" data-feature="recommendation-cards-2.0">
    <header class="pt-next-steps__header">
      <p class="pt-next-steps__eyebrow">Nächster Schritt</p>
      <h2 id="pt-next-steps-title">{title}</h2>
      <p>{intro}</p>
    </header>

    <div class="pt-next-steps__grid">
      {visibleItems.map((item) => {
        const kind = item.kind ?? "comparison";
        const highlights = (item.highlights ?? []).filter(Boolean).slice(0, 3);

        return (
          <a class:list={["pt-next-steps__card", `pt-next-steps__card--${kind}`]} href={item.href}>
            {item.image && (
              <div class="pt-next-steps__media">
                <OptimizedImage
                  src={item.image.src}
                  alt={item.image.alt ?? item.title}
                  width={360}
                  height={270}
                  layout="constrained"
                />
              </div>
            )}

            <div class="pt-next-steps__body">
              <div class="pt-next-steps__topline">
                <span class="pt-next-steps__label">{item.eyebrow}</span>
                {typeof item.score === "number" && (
                  <span class="pt-next-steps__score">
                    <strong>{Math.round(item.score)}</strong><small>/ 100</small>
                  </span>
                )}
                {typeof item.score !== "number" && item.stat && (
                  <span class="pt-next-steps__stat">
                    <strong>{item.stat.value}</strong><small>{item.stat.label}</small>
                  </span>
                )}
              </div>

              <h3>{item.title}</h3>

              {highlights.length > 0 ? (
                <ul class="pt-next-steps__highlights">
                  {highlights.map((highlight) => <li>{highlight}</li>)}
                </ul>
              ) : (
                item.text && <p>{item.text}</p>
              )}

              <strong class="pt-next-steps__cta">{item.label}<span aria-hidden="true">→</span></strong>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .pt-next-steps {
    --next-bg: linear-gradient(145deg, #0a4d3f 0%, #082f2a 100%);
    --next-card: rgba(255, 255, 255, 0.075);
    --next-border: rgba(184, 239, 197, 0.22);
    --next-text: #f8fafc;
    --next-muted: #d4e2dc;
    --next-accent: #63e6a3;
    width: min(100%, 1120px);
    margin: clamp(2.5rem, 6vw, 5rem) auto;
    padding: clamp(1.2rem, 3vw, 2rem);
    border: 1px solid rgba(184, 239, 197, 0.2);
    border-radius: 24px;
    color: var(--next-text);
    background: var(--next-bg);
    box-shadow: 0 22px 60px rgba(4, 24, 20, 0.25);
  }
  .pt-next-steps__header { max-width: 700px; margin-bottom: 1.25rem; }
  .pt-next-steps__eyebrow, .pt-next-steps__label {
    margin: 0; color: var(--next-accent); font-size: .75rem; font-weight: 850;
    letter-spacing: .09em; text-transform: uppercase;
  }
  .pt-next-steps__header h2 {
    margin: .45rem 0 0; color: var(--next-text);
    font-size: clamp(1.55rem, 3vw, 2.2rem); line-height: 1.12;
  }
  .pt-next-steps__header > p:last-child {
    max-width: 58ch; margin: .65rem 0 0; color: var(--next-muted); line-height: 1.55;
  }
  .pt-next-steps__grid {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem;
  }
  .pt-next-steps__card {
    display: grid; min-width: 0; overflow: hidden; border: 1px solid var(--next-border);
    border-radius: 20px; color: var(--next-text); background: var(--next-card);
    text-decoration: none; transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }
  .pt-next-steps__card--product {
    grid-template-columns: minmax(120px, 34%) minmax(0, 1fr);
    border-color: rgba(99, 230, 163, .58);
    background: linear-gradient(145deg, rgba(99,230,163,.15), rgba(255,255,255,.06));
  }
  .pt-next-steps__card:hover, .pt-next-steps__card:focus-visible {
    transform: translateY(-2px); border-color: var(--next-accent);
    box-shadow: 0 14px 34px rgba(3, 20, 16, .28); outline: none;
  }
  .pt-next-steps__media {
    min-height: 100%; padding: .8rem; background: rgba(255,255,255,.94);
  }
  .pt-next-steps__media :global(picture), .pt-next-steps__media :global(img) {
    display: block; width: 100%; height: 100%;
  }
  .pt-next-steps__media :global(img) { object-fit: contain; border-radius: 14px; }
  .pt-next-steps__body {
    display: flex; min-width: 0; flex-direction: column; padding: clamp(1.05rem, 2.5vw, 1.4rem);
  }
  .pt-next-steps__topline {
    display: flex; min-height: 2.3rem; align-items: flex-start; justify-content: space-between; gap: .75rem;
  }
  .pt-next-steps__score, .pt-next-steps__stat {
    display: inline-flex; flex: 0 0 auto; align-items: baseline; gap: .25rem; color: var(--next-accent);
  }
  .pt-next-steps__score strong, .pt-next-steps__stat strong { font-size: 1.35rem; line-height: 1; }
  .pt-next-steps__score small, .pt-next-steps__stat small {
    color: var(--next-muted); font-size: .67rem; font-weight: 700;
  }
  .pt-next-steps__stat { flex-direction: column; align-items: flex-end; gap: .1rem; }
  .pt-next-steps__card h3 {
    margin: .35rem 0 0; color: var(--next-text); font-size: clamp(1.08rem, 2.2vw, 1.35rem);
    line-height: 1.22; text-wrap: balance;
  }
  .pt-next-steps__card p {
    display: -webkit-box; margin: .7rem 0 1rem; overflow: hidden; color: var(--next-muted);
    line-height: 1.55; -webkit-box-orient: vertical; -webkit-line-clamp: 3;
  }
  .pt-next-steps__highlights {
    display: grid; gap: .45rem; margin: .85rem 0 1rem; padding: 0; list-style: none;
  }
  .pt-next-steps__highlights li {
    position: relative; margin: 0; padding-left: 1.25rem; color: var(--next-muted);
    font-size: .9rem; line-height: 1.35;
  }
  .pt-next-steps__highlights li::before {
    position: absolute; left: 0; color: var(--next-accent); font-weight: 900; content: "✓";
  }
  .pt-next-steps__cta {
    display: inline-flex; width: fit-content; margin-top: auto; align-items: center;
    gap: .45rem; color: var(--next-accent); font-size: .95rem;
  }
  .pt-next-steps__cta span { transition: transform 160ms ease; }
  .pt-next-steps__card:hover .pt-next-steps__cta span { transform: translateX(3px); }

  @media (max-width: 820px) {
    .pt-next-steps__grid { grid-template-columns: 1fr; }
    .pt-next-steps__card--product { grid-template-columns: 132px minmax(0, 1fr); }
  }
  @media (max-width: 520px) {
    .pt-next-steps { padding: 1.15rem; border-radius: 20px; }
    .pt-next-steps__header > p:last-child { font-size: .95rem; }
    .pt-next-steps__card--product { grid-template-columns: 104px minmax(0, 1fr); }
    .pt-next-steps__media { padding: .5rem; }
    .pt-next-steps__body { padding: 1rem; }
    .pt-next-steps__score strong, .pt-next-steps__stat strong { font-size: 1.12rem; }
    .pt-next-steps__highlights li:nth-child(3) { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pt-next-steps__card, .pt-next-steps__cta span { transition: none; }
  }
</style>

<style is:global>
  /* recommendation-cards-2.1 */
  .pt-next-steps[data-feature="recommendation-cards-2.0"] {
    --next-bg:
      radial-gradient(circle at top right, rgba(99, 230, 163, 0.11), transparent 36%),
      linear-gradient(145deg, #102239 0%, #0d1d31 100%);
    --next-card: linear-gradient(145deg, rgba(22, 43, 66, 0.98), rgba(18, 36, 57, 0.98));
    --next-border: rgba(148, 180, 202, 0.22);
    --next-text: #f8fafc;
    --next-muted: #c8d3de;
    --next-accent: #63e6a3;

    border-color: rgba(148, 180, 202, 0.2);
    background: var(--next-bg);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__card {
    border-color: var(--next-border);
    background: var(--next-card);
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__card--product {
    border-color: rgba(99, 230, 163, 0.44);
    background:
      linear-gradient(145deg, rgba(31, 75, 73, 0.72), rgba(20, 42, 61, 0.96));
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__highlights,
  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__highlights li {
    background: transparent !important;
    box-shadow: none !important;
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__highlights li {
    padding: 0 0 0 1.25rem !important;
    border: 0 !important;
    color: var(--next-muted) !important;
    font-weight: 650;
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__highlights li::before {
    content: "✓" !important;
    color: var(--next-accent) !important;
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__media {
    background: #f5f7f8;
  }

  @media (max-width: 520px) {
    .pt-next-steps[data-feature="recommendation-cards-2.0"] {
      padding: 1rem;
    }

    .pt-next-steps[data-feature="recommendation-cards-2.0"]
      .pt-next-steps__card--product {
      grid-template-columns: 96px minmax(0, 1fr);
    }

    .pt-next-steps[data-feature="recommendation-cards-2.0"]
      .pt-next-steps__highlights li {
      font-size: 0.84rem;
    }
  }

/* decision-next-steps-theme-4.1.2 */
  .pt-next-steps[data-feature="recommendation-cards-2.0"] {
    --next-bg:
      radial-gradient(
        circle at top right,
        color-mix(in srgb, var(--color-primary, #16813d) 10%, transparent),
        transparent 38%
      ),
      linear-gradient(
        145deg,
        var(--color-surface, #ffffff),
        var(--color-surface-soft, #f4f8f6)
      );
    --next-card: var(--color-surface, #ffffff);
    --next-border: var(--color-border, #dbe3df);
    --next-text: var(--color-text, #101828);
    --next-muted: var(--color-text-muted, #5f6f69);
    --next-accent: var(--color-primary, #16813d);

    border-color: var(--next-border);
    color: var(--next-text);
    background: var(--next-bg);
    box-shadow: 0 18px 48px rgba(16, 24, 40, .09);
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__card {
    border-color: var(--next-border);
    color: var(--next-text);
    background: var(--next-card);
    box-shadow: 0 8px 24px rgba(16, 24, 40, .045);
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__card--product {
    border-color: color-mix(
      in srgb,
      var(--next-accent) 34%,
      var(--next-border)
    );
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--next-accent) 8%, var(--next-card)),
        var(--next-card)
      );
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    :is(
      .pt-next-steps__header h2,
      .pt-next-steps__card h3,
      .pt-next-steps__score strong,
      .pt-next-steps__stat strong
    ) {
    color: var(--next-text);
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    :is(
      .pt-next-steps__header > p:last-child,
      .pt-next-steps__card p,
      .pt-next-steps__highlights li,
      .pt-next-steps__score small,
      .pt-next-steps__stat small
    ) {
    color: var(--next-muted) !important;
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    :is(
      .pt-next-steps__eyebrow,
      .pt-next-steps__label,
      .pt-next-steps__cta
    ) {
    color: var(--next-accent);
  }

  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__card:hover,
  .pt-next-steps[data-feature="recommendation-cards-2.0"]
    .pt-next-steps__card:focus-visible {
    border-color: var(--next-accent);
    box-shadow: 0 14px 34px rgba(16, 24, 40, .11);
  }

  html[data-theme="dark"]
    .pt-next-steps[data-feature="recommendation-cards-2.0"],
  html.dark
    .pt-next-steps[data-feature="recommendation-cards-2.0"],
  body.dark
    .pt-next-steps[data-feature="recommendation-cards-2.0"],
  [data-theme="dark"]
    .pt-next-steps[data-feature="recommendation-cards-2.0"] {
    --next-bg:
      radial-gradient(circle at top right, rgba(99, 230, 163, .11), transparent 36%),
      linear-gradient(145deg, #102239 0%, #0d1d31 100%);
    --next-card:
      linear-gradient(145deg, rgba(22, 43, 66, .98), rgba(18, 36, 57, .98));
    --next-border: rgba(148, 180, 202, .22);
    --next-text: #f8fafc;
    --next-muted: #c8d3de;
    --next-accent: #63e6a3;

    box-shadow: 0 18px 48px rgba(0, 0, 0, .22);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]):not(.light)
      .pt-next-steps[data-feature="recommendation-cards-2.0"] {
      --next-bg:
        radial-gradient(circle at top right, rgba(99, 230, 163, .11), transparent 36%),
        linear-gradient(145deg, #102239 0%, #0d1d31 100%);
      --next-card:
        linear-gradient(145deg, rgba(22, 43, 66, .98), rgba(18, 36, 57, .98));
      --next-border: rgba(148, 180, 202, .22);
      --next-text: #f8fafc;
      --next-muted: #c8d3de;
      --next-accent: #63e6a3;
    }
  }
/* end decision-next-steps-theme-4.1.2 */
</style>

