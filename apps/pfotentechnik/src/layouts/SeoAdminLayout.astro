---
interface Props {
  title: string;
  description: string;
  active?: "overview" | "cockpit" | "advisor" | "tasks" | "history" | "prompts";
}

const { title, description, active = "overview" } = Astro.props;
const nav = [
  ["overview", "/admin/seo/", "Übersicht"],
  ["cockpit", "/admin/seo/cockpit/", "Cockpit"],
  ["advisor", "/admin/seo/advisor/", "Co-Pilot"],
  ["tasks", "/admin/seo/tasks/", "Aufgaben"],
  ["history", "/admin/seo/history/", "Historie"],
  ["prompts", "/admin/seo/prompts/", "Prompts"],
] as const;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="color-scheme" content="light dark" />
    <title>{title} | PfotenTechnik SEO</title>
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color-scheme: light;
        --seo-bg: #f3f7f4;
        --seo-surface: #ffffff;
        --seo-surface-soft: #edf5ef;
        --seo-border: #d6e2da;
        --seo-text: #17211b;
        --seo-muted: #5d6d63;
        --seo-accent: #2e7d32;
        --seo-accent-strong: #1f6426;
        --seo-accent-soft: #e2f3e5;
        --seo-warning: #8a5a00;
        --seo-warning-soft: #fff4d8;
        --seo-danger: #a42b20;
        --seo-danger-soft: #fee9e7;
        --seo-focus: #4f46e5;
        --seo-shadow: 0 14px 38px rgba(31, 64, 39, .08);
      }
      html[data-theme="dark"] {
        color-scheme: dark;
        --seo-bg: #0d1410;
        --seo-surface: #151e18;
        --seo-surface-soft: #1b2920;
        --seo-border: #304137;
        --seo-text: #eef7f0;
        --seo-muted: #afbeb4;
        --seo-accent: #72d889;
        --seo-accent-strong: #8ee6a1;
        --seo-accent-soft: #183b23;
        --seo-warning: #ffd27a;
        --seo-warning-soft: #3b2d13;
        --seo-danger: #ffaaa2;
        --seo-danger-soft: #43201f;
        --seo-focus: #a5b4fc;
        --seo-shadow: none;
      }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--seo-bg); color: var(--seo-text); }
      a { color: var(--seo-accent-strong); }
      button, select, input, textarea { font: inherit; }
      button, select, input, textarea, a { outline-offset: 3px; }
      :focus-visible { outline: 3px solid var(--seo-focus); }
      .seo-shell { width: min(1320px, calc(100% - 28px)); margin: 0 auto; padding: 18px 0 64px; }
      .seo-topbar { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 18px; }
      .seo-brand { display: flex; align-items: center; gap: 10px; color: var(--seo-text); font-weight: 850; text-decoration: none; }
      .seo-brand-mark { display: grid; place-items: center; width: 36px; height: 36px; border-radius: 12px; background: var(--seo-accent); color: #08120a; }
      .seo-theme { min-height: 40px; border: 1px solid var(--seo-border); border-radius: 999px; padding: 8px 13px; background: var(--seo-surface); color: var(--seo-text); cursor: pointer; }
      .seo-nav { display: flex; gap: 6px; overflow-x: auto; padding: 5px; margin-bottom: 28px; border: 1px solid var(--seo-border); border-radius: 16px; background: var(--seo-surface); }
      .seo-nav a { flex: 0 0 auto; padding: 9px 13px; border-radius: 11px; color: var(--seo-muted); text-decoration: none; font-weight: 750; }
      .seo-nav a[aria-current="page"] { background: var(--seo-accent-soft); color: var(--seo-accent-strong); }
      .seo-page-header { display: flex; justify-content: space-between; align-items: end; gap: 24px; margin-bottom: 24px; }
      .seo-eyebrow { color: var(--seo-accent-strong); font-size: .78rem; font-weight: 850; letter-spacing: .09em; text-transform: uppercase; }
      .seo-page-header h1 { max-width: 900px; margin: 7px 0 9px; font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1; letter-spacing: -.035em; }
      .seo-page-header p { max-width: 780px; margin: 0; color: var(--seo-muted); line-height: 1.6; }
      .seo-card { border: 1px solid var(--seo-border); border-radius: 20px; background: var(--seo-surface); box-shadow: var(--seo-shadow); }
      .seo-muted { color: var(--seo-muted); }
      .seo-badge { display: inline-flex; align-items: center; min-height: 27px; padding: 4px 9px; border-radius: 999px; background: var(--seo-surface-soft); color: var(--seo-muted); font-size: .76rem; font-weight: 800; }
      .seo-badge[data-level="high"] { background: var(--seo-danger-soft); color: var(--seo-danger); }
      .seo-badge[data-level="medium"] { background: var(--seo-warning-soft); color: var(--seo-warning); }
      .seo-badge[data-level="low"] { background: var(--seo-accent-soft); color: var(--seo-accent-strong); }
      .seo-empty { padding: 18px; border: 1px dashed var(--seo-border); border-radius: 14px; color: var(--seo-muted); }
      @media (max-width: 680px) {
        .seo-shell { width: min(100% - 18px, 1320px); padding-top: 10px; }
        .seo-page-header { display: block; }
        .seo-page-header h1 { font-size: clamp(2rem, 12vw, 3rem); }
      }
      @media (prefers-color-scheme: dark) {
        html:not([data-theme="light"]) {
          color-scheme: dark;
          --seo-bg: #0d1410;
          --seo-surface: #151e18;
          --seo-surface-soft: #1b2920;
          --seo-border: #304137;
          --seo-text: #eef7f0;
          --seo-muted: #afbeb4;
          --seo-accent: #72d889;
          --seo-accent-strong: #8ee6a1;
          --seo-accent-soft: #183b23;
          --seo-warning: #ffd27a;
          --seo-warning-soft: #3b2d13;
          --seo-danger: #ffaaa2;
          --seo-danger-soft: #43201f;
          --seo-focus: #a5b4fc;
          --seo-shadow: none;
        }
      }
    </style>
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("pfotentechnik-seo-theme");
        if (saved === "light" || saved === "dark") document.documentElement.dataset.theme = saved;
      })();
    </script>
  </head>
  <body>
    <div class="seo-shell">
      <div class="seo-topbar">
        <a class="seo-brand" href="/admin/seo/"><span class="seo-brand-mark" aria-hidden="true">PT</span> SEO Workspace</a>
        <button class="seo-theme" type="button" data-theme-toggle aria-label="Farbschema wechseln">Theme wechseln</button>
      </div>
      <nav class="seo-nav" aria-label="SEO-Administration">
        {nav.map(([key, href, label]) => <a href={href} aria-current={active === key ? "page" : undefined}>{label}</a>)}
      </nav>
      <header class="seo-page-header">
        <div>
          <div class="seo-eyebrow">PfotenTechnik Redaktion</div>
          <h1>{title}</h1>
          <p>{description}</p>
        </div>
      </header>
      <slot />
    </div>
    <script is:inline>
      document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
        const current = document.documentElement.dataset.theme;
        const next = current === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("pfotentechnik-seo-theme", next);
      });
    </script>

<script is:inline data-pt-editorial-theme-advisor-7-2>
  (() => {
    const norm = (v = "") =>
      v.replace(/\s+/g, " ").trim().toLocaleLowerCase("de");

    const rgb = (value) => {
      const match = value?.match(
        /rgba?\(\s*([\d.]+)[,\s]+([\d.]+)[,\s]+([\d.]+)(?:[,\s/]+([\d.]+))?\s*\)/
      );
      return match
        ? {
            r: Number(match[1]),
            g: Number(match[2]),
            b: Number(match[3]),
            a: match[4] === undefined ? 1 : Number(match[4])
          }
        : null;
    };

    const channel = (v) => {
      const n = v / 255;
      return n <= 0.03928
        ? n / 12.92
        : ((n + 0.055) / 1.055) ** 2.4;
    };

    const lum = (c) =>
      c
        ? 0.2126 * channel(c.r) +
          0.7152 * channel(c.g) +
          0.0722 * channel(c.b)
        : null;

    const ratio = (a, b) => {
      const first = lum(a);
      const second = lum(b);
      if (first === null || second === null) return 21;
      return (Math.max(first, second) + 0.05) /
        (Math.min(first, second) + 0.05);
    };

    const background = (element) => {
      let current = element;
      while (current && current !== document.documentElement) {
        const color = rgb(getComputedStyle(current).backgroundColor);
        if (color && color.a > 0.08) return color;
        current = current.parentElement;
      }
      return rgb(getComputedStyle(document.body).backgroundColor);
    };

    const panelFor = (heading) => {
      let current = heading.parentElement;
      let fallback = null;

      for (let depth = 0; current && depth < 7; depth += 1) {
        if (
          current.matches?.(
            "section,article,aside,[class*='panel'],[class*='card'],[class*='method'],[class*='proof'],[class*='trust'],[class*='position']"
          )
        ) {
          fallback ||= current;
          const style = getComputedStyle(current);
          const radius = Number.parseFloat(style.borderRadius) || 0;
          const color = rgb(style.backgroundColor);
          if (radius >= 12 && color && color.a > 0.08) return current;
        }
        current = current.parentElement;
      }

      return fallback ||
        heading.closest("section,article,aside") ||
        heading.parentElement;
    };

    const classifyKnownPanels = () => {
      const rules = [
        ["empfehlungen brauchen eine überprüfbare grundlage", "pt-method-panel"],
        ["orientierung statt produktwerbung", "pt-proof-panel"],
        ["kein shop. keine herstellerplattform.", "pt-positioning-panel"],
        ["transparenz vor der produktauswahl", "pt-transparency-faq"]
      ];

      document
        .querySelectorAll("main h1,main h2,main h3,main h4")
        .forEach((heading) => {
          const text = norm(heading.textContent);
          const rule = rules.find(([phrase]) => text.includes(phrase));
          if (!rule) return;

          const panel = panelFor(heading);
          panel?.classList.add(rule[1]);

          if (rule[1] !== "pt-transparency-faq") {
            panel?.classList.add("pt-editorial-dark-panel");
          }
        });
    };

    const fixLowContrast = () => {
      document
        .querySelectorAll(
          "main section,main article,main aside,main details,main [class*='card'],main [class*='panel']"
        )
        .forEach((element) => {
          if (
            element.classList.contains("pt-editorial-dark-panel") ||
            element.classList.contains("pt-transparency-faq")
          ) return;

          const heading = element.querySelector(
            ":scope>h1,:scope>h2,:scope>h3,:scope>header h2,:scope>header h3"
          );
          const copy = element.querySelector(
            ":scope>p,:scope>div>p,:scope li"
          );
          if (!heading && !copy) return;

          const bg = background(element);
          const bgLum = lum(bg);
          if (bgLum === null) return;

          const headingColor = heading
            ? rgb(getComputedStyle(heading).color)
            : null;
          const copyColor = copy
            ? rgb(getComputedStyle(copy).color)
            : null;

          const bad =
            (headingColor && ratio(bg, headingColor) < 3.2) ||
            (copyColor && ratio(bg, copyColor) < 4.05);

          if (!bad) return;

          if (bgLum < 0.24) {
            element.classList.add("pt-auto-dark-panel");
          } else if (bgLum > 0.72) {
            element.classList.add("pt-auto-light-panel");
          }
        });
    };

    const configureAdvisor = () => {
      let section = document.querySelector(
        "#kaufberatung,.home41-decision"
      );

      if (!section) {
        const heading = [...document.querySelectorAll("main h1,main h2,main h3")]
          .find((element) =>
            norm(element.textContent).includes(
              "direkt zum passenden vergleich"
            )
          );
        section = heading?.closest("section,article,div");
      }

      if (section) section.id = "kaufberatung";

      document
        .querySelectorAll("header a,header button,nav a")
        .forEach((element) => {
          const text = norm(element.textContent);
          const href = norm(element.getAttribute?.("href") || "");
          const advisor =
            text.includes("berater") ||
            text.includes("kaufberatung") ||
            href.includes("berater") ||
            href.includes("advisor");

          if (!advisor) return;

          if (element.tagName === "A") {
            element.setAttribute("href", "/#kaufberatung");
          }

          const textNode = [...element.childNodes].find(
            (node) =>
              node.nodeType === Node.TEXT_NODE &&
              norm(node.textContent)
          );

          if (textNode) {
            textNode.textContent = "Kaufberatung";
          } else if (!element.querySelector("svg,img")) {
            element.textContent = "Kaufberatung";
          }

          element.classList.add("pt-nav-advisor-cta");
          element.setAttribute(
            "aria-label",
            "Kaufberatung für Futterautomaten, Trinkbrunnen und GPS-Tracker"
          );
          element.setAttribute(
            "title",
            "Kaufberatung für Futterautomaten, Trinkbrunnen und GPS-Tracker"
          );
        });

      if (location.hash === "#kaufberatung" && section) {
        requestAnimationFrame(() =>
          section.scrollIntoView({
            behavior: "smooth",
            block: "start"
          })
        );
      }
    };

    const apply = () => {
      classifyKnownPanels();
      fixLowContrast();
      configureAdvisor();
    };

    if (document.readyState === "loading") {
      document.addEventListener(
        "DOMContentLoaded",
        apply,
        { once: true }
      );
    } else {
      apply();
    }

    document.addEventListener("astro:page-load", apply);
    setTimeout(apply, 350);
  })();
</script>
</body>
</html>