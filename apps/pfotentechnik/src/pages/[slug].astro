---
import { getCollection, render } from "astro:content";
import ProjectLayout from "../layouts/ProjectLayout.astro";
import ArticleMeta from "@affiliate-core/components/ArticleMeta.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import TableOfContents from "@affiliate-core/components/TableOfContents.astro";
import PremiumRenderer from "@affiliate-core/renderer/PremiumRenderer.astro";
import FAQ from "@affiliate-core/components/FAQ.astro";
import RelatedArticles from "@affiliate-core/components/RelatedArticles.astro";
import AutoLinkContent from "@affiliate-core/components/AutoLinkContent.astro";
import ProductRankingCard from "@affiliate-core/components/ProductRankingCard.astro";
import { existsSync } from "node:fs";
import { join } from "node:path";
import { fileURLToPath } from "node:url";
import ComparisonExperience from "@affiliate-core/components/ComparisonExperience.astro";
import HealthBridge from "../components/HealthBridge.astro";
import MoneyPageCta from "../components/MoneyPageCta.astro";
import { projectConfig, siteMeta } from "../project.config";
import { DEFAULT_PROJECT, getProjectImage } from "../data/projectImages";
import { getSeoOverride } from "../data/seoOverrides";
import { products, type ProductKey } from "../data/products";
import {
  getDecisionProductRecommendations,
  getDecisionRule
} from "../data/decisionProducts";
import { internalLinkDefinitions } from "../data/internalLinks";
import {
  getPageBreadcrumbs,
  getRelatedContent
} from "@app/domain/content";
export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);
const breadcrumbs = getPageBreadcrumbs(page);

const author = page.data.author ?? siteMeta.defaultAuthor;
const publishedAt =
  page.data.publishedAt ?? siteMeta.articleDefaults.publishedAt;
const updatedAt =
  page.data.updatedAt ?? page.data.publishedAt ?? siteMeta.articleDefaults.updatedAt;
const projectKey = page.data.project ?? DEFAULT_PROJECT;
const publicDir = fileURLToPath(new URL("../../public", import.meta.url));

const localPublicImageExists = (imagePath?: string) => {
  if (!imagePath || imagePath.startsWith("http")) {
    return Boolean(imagePath);
  }

  return existsSync(join(publicDir, imagePath.replace(/^\//, "")));
};

const pageHeroImage = `/images/pages/${page.data.slug}/hero.webp`;
const heroTypeHeroImage = page.data.heroType
  ? `/images/pages/${page.data.heroType}/hero.webp`
  : undefined;
const configuredHeroImage = page.data.heroImage;
const fallbackHeroImage = getProjectImage(
  projectKey,
  page.data.heroImageKey ?? "hero"
);

const heroImage = localPublicImageExists(configuredHeroImage)
  ? configuredHeroImage
  : localPublicImageExists(pageHeroImage)
    ? pageHeroImage
    : localPublicImageExists(heroTypeHeroImage)
      ? heroTypeHeroImage
      : fallbackHeroImage;
const ogImage = page.data.ogImage ?? heroImage;
const seoOverride = getSeoOverride(page.data.slug);
const decisionRecommendations = page.data.decisionKey
  ? getDecisionProductRecommendations(page.data.decisionKey)
  : [];

const decisionRule = page.data.decisionKey
  ? getDecisionRule(page.data.decisionKey)
  : undefined;

const decisionProducts = decisionRecommendations
  .map(({ key }) => key)
  .filter((key): key is ProductKey => key in products);

const topDecisionRecommendation = decisionRecommendations[0];

const decisionIntro = page.data.decisionIntro ??
  "Basierend auf unseren Bewertungskriterien ist dies aktuell die passendste Empfehlung für diesen Anwendungsfall.";

const decisionThemeColor = page.data.themeColor ?? "teal";
const autoLinkSourceGroup = page.data.decisionKey

  ? "decision"

  : "knowledge";
  const autoLinkSourceContext =
  page.data.linkContext ??
  page.data.category;
const comparisonProducts = decisionProducts.length > 0
  ? decisionProducts
  : (page.data.comparisonProducts ?? [])
      .filter((key): key is ProductKey => key in products);

const comparisonExperienceConfig = page.data.comparisonRecommendation ?? (
  decisionProducts.length > 0
    ? {
        title: "Unsere Produktempfehlungen",
        text: "Diese Auswahl wird aus den hinterlegten Produkteigenschaften, Use Cases und Bewertungskriterien abgeleitet.",
        tableTitle: "Empfehlungen im direkten Vergleich",
        cardsTitle: "Die passenden Modelle im Detail",
        criteria: [
          "Portionierung",
          "Zuverlässigkeit",
          "Reinigung",
          "Sicherheit",
          "Preis-Leistung"
        ]
      }
    : null
);

const getReadingTimeMinutes = (content: string) => {
  const plainText = content
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/<[^>]+>/g, " ")
    .replace(/[{}[\]()*_#>\-|]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  if (!plainText) {
    return 1;
  }

  const wordCount = plainText.split(" ").filter(Boolean).length;

  return Math.max(1, Math.ceil(wordCount / 200));
};

const readingTimeMinutes = getReadingTimeMinutes(page.body ?? "");

const relatedEntries = await getRelatedContent({
  currentSlug: page.data.slug,
  tags: page.data.related?.tags.length
    ? page.data.related.tags
    : page.data.tags,
  sections: page.data.hub?.sections ?? [],
  type: page.data.type,
  exclude: page.data.related?.exclude ?? [],
  limit: page.data.related?.limit ?? 3
});

const relatedItems = relatedEntries.map((entry) => ({
  href: entry.href,
  label: entry.type === "product"
    ? "Produkt"
    : entry.type === "manufacturer"
      ? "Hersteller"
      : entry.type === "comparison"
        ? "Vergleich"
        : "Ratgeber",
  title: entry.hubTitle,
  text: entry.hubDescription
}));
---

<ProjectLayout
  title={page.data.title}
  description={page.data.description}
  seoTitle={seoOverride?.seoTitle ?? page.data.seoTitle}
  seoDescription={seoOverride?.seoDescription ?? page.data.seoDescription}
  canonical={`/${page.data.slug}`}
  ogImage={ogImage}
  faq={page.data.faq}
  author={author}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  categoryLabel={page.data.categoryLabel}
  breadcrumbs={breadcrumbs}
>
  <Breadcrumbs items={breadcrumbs} />

  <header class="article-header">
    <span class="article-category">{page.data.categoryLabel}</span>
    <h1 class="article-title">{page.data.title}</h1>
    <p class="article-description">{page.data.description}</p>
    <ArticleMeta
      author={author}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      readingTimeMinutes={readingTimeMinutes}
    />
  </header>

  <figure class="article-hero">
    <img
      src={heroImage}
      alt={page.data.title}
      class="article-hero-image"
      loading="eager"
      decoding="async"
    />
  </figure>

  <article class="article">
    <TableOfContents headings={headings} />
    {
      topDecisionRecommendation && (
        <section class={`decision-top-recommendation decision-top-recommendation-${decisionThemeColor}`}>
          <div class="ranking-section-header">
            <p class="ranking-eyebrow">Top-Empfehlung</p>
            <h2>Unser Favorit für diese Auswahl</h2>
            <p>{decisionIntro}</p>
          </div>

          <div class="product-ranking-list">
            <ProductRankingCard
              productKey={topDecisionRecommendation.key as ProductKey}
              rank={1}
              score={topDecisionRecommendation.score}
            />
          </div>
        </section>
      )
    }
    <PremiumRenderer
      blocks={page.data.premiumBlocks as any}
      project={projectKey}
      heroImage={heroImage}
    />
    {
      comparisonProducts.length > 1 && (
        <div class="decision-comparison-intro">
          <h2>Weitere passende Empfehlungen</h2>
          <p>
            Neben unserer Top-Empfehlung können – je nach Budget, Ausstattung und persönlichen Anforderungen – auch diese Modelle interessant sein.
          </p>
        </div>
      )
    }
    {
      comparisonProducts.length > 0 && comparisonExperienceConfig && (
        <ComparisonExperience
          productKeys={comparisonProducts}
          recommendationTitle={comparisonExperienceConfig.title}
          recommendationText={comparisonExperienceConfig.text}
          tableTitle={comparisonExperienceConfig.tableTitle}
          cardsTitle={comparisonExperienceConfig.cardsTitle}
          evaluationCriteria={comparisonExperienceConfig.criteria}
        />
      )
    }

    {
      decisionRule?.summary && decisionRule.summary.length > 0 && (
        <section class="decision-template-section decision-template-summary">
          <h2>30 Sekunden Zusammenfassung</h2>
          <ul>
            {decisionRule.summary.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      (decisionRule?.suitableFor || decisionRule?.notSuitableFor) && (
        <section class="decision-template-section decision-template-fit">
          <h2>Für wen ist diese Auswahl geeignet?</h2>
          <div class="decision-template-grid">
            {decisionRule.suitableFor && decisionRule.suitableFor.length > 0 && (
              <div class="decision-template-card decision-template-card-positive">
                <h3>Geeignet für</h3>
                <ul>
                  {decisionRule.suitableFor.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            )}

            {decisionRule.notSuitableFor && decisionRule.notSuitableFor.length > 0 && (
              <div class="decision-template-card decision-template-card-negative">
                <h3>Eher nicht geeignet für</h3>
                <ul>
                  {decisionRule.notSuitableFor.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </section>
      )
    }

    {
      decisionRule?.checklist && decisionRule.checklist.length > 0 && (
        <section class="decision-template-section decision-template-checklist">
          <h2>Kauf-Checkliste</h2>
          <ul>
            {decisionRule.checklist.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      decisionRule?.commonMistakes && decisionRule.commonMistakes.length > 0 && (
        <section class="decision-template-section decision-template-mistakes">
          <h2>Typische Fehler beim Kauf</h2>
          <ul>
            {decisionRule.commonMistakes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      decisionRule?.alternatives && decisionRule.alternatives.length > 0 && (
        <section class="decision-template-section decision-template-alternatives">
          <h2>Alternativen</h2>
          <div class="decision-template-grid">
            {decisionRule.alternatives.map((item) => (
              <article class="decision-template-card">
                <h3>{item.label}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      decisionRule?.decisionTree && decisionRule.decisionTree.length > 0 && (
        <section class="decision-template-section decision-template-tree">
          <h2>Entscheidungsbaum</h2>
          <ul>
            {decisionRule.decisionTree.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

<AutoLinkContent

  definitions={internalLinkDefinitions}

  sourcePath={`/${page.data.slug}/`}

  sourceGroup={autoLinkSourceGroup}

  sourceContext={autoLinkSourceContext}

  maxLinksPerPage={10}

>

  <Content />

</AutoLinkContent>

    {
      decisionRule?.sources && decisionRule.sources.length > 0 && (
        <section class="decision-template-section decision-template-sources">
          <h2>Fachquellen</h2>
          <ul>
            {decisionRule.sources.map((source) => (
              <li>
                <a href={source.href} rel="noopener noreferrer" target="_blank">
                  {source.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
    {
      page.data.healthBridge && (
        <HealthBridge {...page.data.healthBridge} />
      )
    }
    {
      page.data.closingCta &&
        page.data.closingCta.productKey in products && (
          <MoneyPageCta
            {...page.data.closingCta}
            productKey={page.data.closingCta.productKey as ProductKey}
          />
        )
    }
    <FAQ items={page.data.faq} />
  </article>

  <RelatedArticles items={relatedItems} />
</ProjectLayout>
