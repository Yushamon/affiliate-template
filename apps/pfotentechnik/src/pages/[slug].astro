---
import { getCollection, render } from "astro:content";
import ProjectLayout from "../layouts/ProjectLayout.astro";
import ArticleMeta from "@affiliate-core/components/ArticleMeta.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import TableOfContents from "@affiliate-core/components/TableOfContents.astro";
import PremiumRenderer from "@affiliate-core/renderer/PremiumRenderer.astro";
import FAQ from "@affiliate-core/components/FAQ.astro";
import RelatedArticles from "@affiliate-core/components/RelatedArticles.astro";
import ComparisonExperience from "@affiliate-core/components/ComparisonExperience.astro";
import HealthBridge from "../components/HealthBridge.astro";
import MoneyPageCta from "../components/MoneyPageCta.astro";
import { projectConfig, siteMeta } from "../project.config";
import { DEFAULT_PROJECT, getProjectImage } from "../data/projectImages";
import { getSeoOverride } from "../data/seoOverrides";
import { products, type ProductKey } from "../data/products";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);
const allPages = await getCollection("pages");

const author = page.data.author ?? siteMeta.defaultAuthor;
const publishedAt =
  page.data.publishedAt ?? siteMeta.articleDefaults.publishedAt;
const updatedAt =
  page.data.updatedAt ?? page.data.publishedAt ?? siteMeta.articleDefaults.updatedAt;
const projectKey = page.data.project ?? DEFAULT_PROJECT;
const heroImage = page.data.heroImage ?? getProjectImage(
  projectKey,
  page.data.heroImageKey ?? "hero"
);
const ogImage = page.data.ogImage ?? heroImage;
const seoOverride = getSeoOverride(page.data.slug);
const comparisonProducts = (page.data.comparisonProducts ?? [])
  .filter((key): key is ProductKey => key in products);

const getReadingTimeMinutes = (content: string) => {
  const plainText = content
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/<[^>]+>/g, " ")
    .replace(/[{}[\]()*_#>\-|]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  if (!plainText) {
    return 1;
  }

  const wordCount = plainText.split(" ").filter(Boolean).length;

  return Math.max(1, Math.ceil(wordCount / 200));
};

const readingTimeMinutes = getReadingTimeMinutes(page.body ?? "");

const relatedPages = allPages
  .filter((candidate) => {
    if (candidate.data.slug === page.data.slug) return false;

    const commonTags = candidate.data.tags.filter((tag) =>
      page.data.tags.includes(tag)
    );

    return candidate.data.category === page.data.category || commonTags.length > 0;
  })
  .slice(0, 3);
---

<ProjectLayout
  title={page.data.title}
  description={page.data.description}
  seoTitle={seoOverride?.seoTitle ?? page.data.seoTitle}
  seoDescription={seoOverride?.seoDescription ?? page.data.seoDescription}
  canonical={`/${page.data.slug}`}
  ogImage={ogImage}
  faq={page.data.faq}
  author={author}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  categoryLabel={page.data.categoryLabel}
>
  <Breadcrumbs
    categoryLabel={page.data.categoryLabel}
    title={page.data.title}
    categoryHref={page.data.categoryPath ?? projectConfig.categoryPath}
  />

  <header class="article-header">
    <span class="article-category">{page.data.categoryLabel}</span>
    <h1 class="article-title">{page.data.title}</h1>
    <p class="article-description">{page.data.description}</p>
    <ArticleMeta
      author={author}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      readingTimeMinutes={readingTimeMinutes}
    />
  </header>

  <figure class="article-hero">
    <img
      src={heroImage}
      alt={page.data.title}
      class="article-hero-image"
      loading="eager"
      decoding="async"
    />
  </figure>

  <article class="article">
    <TableOfContents headings={headings} />
    <PremiumRenderer
      blocks={page.data.premiumBlocks as any}
      project={projectKey}
      heroImage={heroImage}
    />
    {
      comparisonProducts.length > 0 && page.data.comparisonRecommendation && (
        <ComparisonExperience
          productKeys={comparisonProducts}
          recommendationTitle={page.data.comparisonRecommendation.title}
          recommendationText={page.data.comparisonRecommendation.text}
          tableTitle={page.data.comparisonRecommendation.tableTitle}
          cardsTitle={page.data.comparisonRecommendation.cardsTitle}
          evaluationCriteria={page.data.comparisonRecommendation.criteria}
        />
      )
    }
    <Content />
    {
      page.data.healthBridge && (
        <HealthBridge {...page.data.healthBridge} />
      )
    }
    {
      page.data.closingCta &&
        page.data.closingCta.productKey in products && (
          <MoneyPageCta
            {...page.data.closingCta}
            productKey={page.data.closingCta.productKey as ProductKey}
          />
        )
    }
    <FAQ items={page.data.faq} />
  </article>

  <RelatedArticles pages={relatedPages} />
</ProjectLayout>
