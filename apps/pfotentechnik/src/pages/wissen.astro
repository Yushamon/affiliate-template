---
import { getCollection } from "astro:content";
import ProjectLayout from "../layouts/ProjectLayout.astro";
import { getProjectImage } from "../data/projectImages";

const allPages = (await getCollection("pages"))
  .filter((page) => page.data.slug !== "wissen")
  .sort((a, b) =>
    (b.data.hubPriority ?? 0) - (a.data.hubPriority ?? 0) ||
    (b.data.updatedAt ?? "").localeCompare(a.data.updatedAt ?? "")
  );

const getPageUrl = (slug: string) => `/${slug}/`;

const hasTag = (page: (typeof allPages)[number], tags: string[]) => {
  const pageTags = page.data.tags ?? [];

  return tags.some((tag) => pageTags.includes(tag));
};

const includesSlug = (page: (typeof allPages)[number], fragments: string[]) =>
  fragments.some((fragment) => page.data.slug.includes(fragment));

const uniquePages = (pages: typeof allPages) => {
  const seen = new Set<string>();

  return pages.filter((page) => {
    if (seen.has(page.data.slug)) {
      return false;
    }

    seen.add(page.data.slug);

    return true;
  });
};

const featuredPages = uniquePages(
  allPages.filter((page) =>
    page.data.slug === "smarte-futterautomaten" ||
    page.data.slug === "futterautomat-hund" ||
    page.data.slug === "futterautomat-katze" ||
    page.data.slug === "beste-futterautomaten-fuer-welpen" ||
    page.data.slug === "beste-futterautomaten-fuer-berufstaetige" ||
    page.data.slug === "beste-futterautomaten-unter-100-euro"
  )
).slice(0, 6);

const clusters = [
  {
    title: "Ernährung & Fütterung",
    text: "Grundlagen, Routinen und praktische Entscheidungshilfen rund um Fütterung, Mahlzeiten und Portionskontrolle.",
    pages: uniquePages(
      allPages.filter((page) =>
        hasTag(page, ["futterautomat", "ernaehrung", "ernährung", "hund", "katze"]) ||
        includesSlug(page, ["futterautomat", "mahlzeiten", "ernaehrung", "ernahrung"])
      )
    )
  },
  {
    title: "Kaufberatung & Vergleiche",
    text: "Vergleichsseiten für konkrete Anwendungsfälle, Budgets und Alltagssituationen.",
    pages: uniquePages(
      allPages.filter((page) =>
        page.data.category === "vergleich" ||
        hasTag(page, ["vergleich", "kaufberatung"]) ||
        includesSlug(page, ["beste-", "vergleich", "unter-100", "unter-200"])
      )
    )
  },
  {
    title: "Alltag & Probleme",
    text: "Ratgeber für konkrete Alltagssituationen wie Beruf, Urlaub, mehrere Tiere oder schlingendes Fressen.",
    pages: uniquePages(
      allPages.filter((page) =>
        includesSlug(page, ["urlaub", "berufstaetige", "mehrtier", "schlingen", "uebergewicht", "ohne-wlan", "akku"])
      )
    )
  },
  {
    title: "Produkte & Hersteller",
    text: "Produktseiten, Markenprofile und Modellübersichten für smarte Haustiertechnik.",
    pages: uniquePages(
      allPages.filter((page) =>
        page.data.slug.startsWith("produkt/") ||
        page.data.slug.startsWith("hersteller/") ||
        hasTag(page, ["produkt", "hersteller"])
      )
    )
  }
].map((cluster) => ({
  ...cluster,
  pages: cluster.pages.slice(0, 12)
}));

const allHubPages = uniquePages(
  clusters.flatMap((cluster) => cluster.pages)
).slice(0, 24);
---

<ProjectLayout
  title="Wissen"
  description="Ratgeber, Vergleiche und Kaufberatung rund um smarte Haustiertechnik für Hunde und Katzen."
  canonical="/wissen/"
  ogImage={getProjectImage("pfotentechnik", "guide")}
  schemaType="article"
  includeBreadcrumbSchema={true}
>
  <main class="pt-knowledge-hub">
    <section class="pt-knowledge-hero">
      <div>
        <p class="pt-eyebrow">Wissen</p>
        <h1>Ratgeber für moderne Tierhaltung</h1>
        <p>
          Praxiswissen, Kaufberatung und unabhängige Vergleiche rund um smarte Haustiertechnik für Hunde und Katzen.
        </p>
      </div>

      <div class="pt-knowledge-hero-card">
        <span>{allPages.length}</span>
        <strong>Ratgeber, Vergleiche und Produktseiten</strong>
        <p>Der Wissensbereich wächst automatisch mit neuen Inhalten.</p>

        {
          import.meta.env.DEV && (
            <details style="margin-top:16px;font-size:12px;">
              <summary>Debug</summary>
              <ul>
                {allPages.map((page) => (
                  <li>
                    {page.data.slug} | {page.data.category ?? "-"} | {(page.data.tags ?? []).join(", ")}
                  </li>
                ))}
              </ul>
            </details>
          )
        }
      </div>
    </section>

    {featuredPages.length > 0 && (
      <section class="pt-knowledge-section" aria-labelledby="featured-guides-title">
        <div class="pt-section-header">
          <p class="pt-eyebrow">Empfohlen</p>
          <h2 id="featured-guides-title">Der beste Einstieg</h2>
          <p>Diese Seiten helfen dir, schnell die wichtigsten Themen und Produktempfehlungen zu finden.</p>
        </div>

        <div class="pt-knowledge-featured-grid">
          {featuredPages.map((page) => (
            <a class="pt-knowledge-featured-card" href={getPageUrl(page.data.slug)}>
              <span>{page.data.categoryLabel ?? page.data.category ?? "Ratgeber"}</span>
              <h3>{page.data.title}</h3>
              <p>{page.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="pt-knowledge-section" aria-labelledby="knowledge-clusters-title">
      <div class="pt-section-header">
        <p class="pt-eyebrow">Themen</p>
        <h2 id="knowledge-clusters-title">Wissen nach Themen</h2>
        <p>Unsere Inhalte sind nach Suchintention und Alltagssituation gebündelt.</p>
      </div>

      <div class="pt-knowledge-cluster-grid">
        {clusters.filter((cluster) => cluster.pages.length > 0).map((cluster) => (
          <section class="pt-knowledge-cluster-card">
            <div class="pt-knowledge-cluster-head">
              <span>{cluster.pages.length}</span>
              <div>
                <h3>{cluster.title}</h3>
                <p>{cluster.text}</p>
              </div>
            </div>

            <div class="pt-knowledge-link-list">
              {cluster.pages.map((page) => (
                <a href={getPageUrl(page.data.slug)}>
                  <strong>{page.data.title}</strong>
                  <span>{page.data.description}</span>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    {allHubPages.length > 0 && (
      <section class="pt-knowledge-section" aria-labelledby="all-guides-title">
        <div class="pt-section-header">
          <p class="pt-eyebrow">Alle Inhalte</p>
          <h2 id="all-guides-title">Aktuelle Ratgeber und Vergleiche</h2>
          <p>Alle zentralen Inhalte aus dem PfotenTechnik-Wissensbereich auf einen Blick.</p>
        </div>

        <div class="pt-knowledge-list-grid">
          {allHubPages.map((page) => (
            <a class="pt-knowledge-list-card" href={getPageUrl(page.data.slug)}>
              <span>{page.data.categoryLabel ?? page.data.category ?? "Wissen"}</span>
              <h3>{page.data.title}</h3>
              <p>{page.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</ProjectLayout>

<style>
  .pt-knowledge-hub {
    display: grid;
    gap: clamp(42px, 7vw, 90px);
    padding: clamp(36px, 6vw, 76px) 0 clamp(70px, 9vw, 120px);
  }

  .pt-knowledge-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
    gap: 28px;
    align-items: stretch;
    padding: clamp(28px, 5vw, 58px);
    border: 1px solid rgba(20, 32, 26, 0.08);
    border-radius: 34px;
    background: linear-gradient(135deg, rgba(20, 184, 166, 0.12), rgba(255, 255, 255, 0.96));
    box-shadow: 0 24px 70px rgba(20, 32, 26, 0.08);
  }

  .pt-knowledge-hero h1 {
    max-width: 820px;
    margin: 0;
    color: var(--text);
    font-size: clamp(42px, 7vw, 82px);
    line-height: 0.96;
    letter-spacing: -0.07em;
  }

  .pt-knowledge-hero p {
    max-width: 720px;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 23px);
    line-height: 1.55;
  }

  .pt-knowledge-hero-card {
    display: grid;
    align-content: center;
    gap: 12px;
    padding: 28px;
    border-radius: 28px;
    background: #ffffff;
    box-shadow: inset 0 0 0 1px rgba(20, 32, 26, 0.08);
  }

  .pt-knowledge-hero-card span {
    color: var(--primary-dark);
    font-size: 54px;
    font-weight: 950;
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .pt-knowledge-hero-card strong {
    color: var(--text);
    font-size: 22px;
    line-height: 1.2;
  }

  .pt-knowledge-hero-card p {
    margin: 0;
    font-size: 16px;
  }

  .pt-knowledge-section {
    display: grid;
    gap: 24px;
  }

  .pt-knowledge-featured-grid,
  .pt-knowledge-list-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .pt-knowledge-featured-card,
  .pt-knowledge-list-card,
  .pt-knowledge-link-list a {
    color: inherit;
    text-decoration: none;
  }

  .pt-knowledge-featured-card,
  .pt-knowledge-list-card,
  .pt-knowledge-cluster-card {
    border: 1px solid rgba(20, 32, 26, 0.08);
    border-radius: 26px;
    background: #ffffff;
    box-shadow: 0 14px 38px rgba(20, 32, 26, 0.045);
  }

  .pt-knowledge-featured-card,
  .pt-knowledge-list-card {
    display: grid;
    gap: 10px;
    padding: 24px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .pt-knowledge-featured-card:hover,
  .pt-knowledge-list-card:hover,
  .pt-knowledge-link-list a:hover {
    border-color: rgba(22, 163, 74, 0.24);
    box-shadow: 0 18px 46px rgba(20, 32, 26, 0.075);
    transform: translateY(-2px);
  }

  .pt-knowledge-featured-card span,
  .pt-knowledge-list-card span {
    width: fit-content;
    padding: 7px 11px;
    border-radius: 999px;
    background: rgba(20, 184, 166, 0.1);
    color: var(--primary-dark);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pt-knowledge-featured-card h3,
  .pt-knowledge-list-card h3,
  .pt-knowledge-cluster-card h3 {
    margin: 0;
    color: var(--text);
    font-size: 22px;
    line-height: 1.16;
    letter-spacing: -0.035em;
  }

  .pt-knowledge-featured-card p,
  .pt-knowledge-list-card p,
  .pt-knowledge-cluster-card p,
  .pt-knowledge-link-list span {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .pt-knowledge-cluster-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .pt-knowledge-cluster-card {
    display: grid;
    gap: 20px;
    padding: 26px;
  }

  .pt-knowledge-cluster-head {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 16px;
    align-items: start;
  }

  .pt-knowledge-cluster-head > span {
    display: inline-grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 16px;
    background: rgba(20, 184, 166, 0.12);
    color: var(--primary-dark);
    font-weight: 950;
  }

  .pt-knowledge-link-list {
    display: grid;
    gap: 10px;
  }

  .pt-knowledge-link-list a {
    display: grid;
    gap: 4px;
    padding: 15px;
    border: 1px solid rgba(20, 32, 26, 0.08);
    border-radius: 18px;
    background: rgba(248, 250, 248, 0.8);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .pt-knowledge-link-list strong {
    color: var(--text);
    line-height: 1.25;
  }

  @media (max-width: 900px) {
    .pt-knowledge-hero,
    .pt-knowledge-featured-grid,
    .pt-knowledge-list-grid,
    .pt-knowledge-cluster-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .pt-knowledge-hub {
      padding-top: 24px;
    }

    .pt-knowledge-hero {
      padding: 24px;
      border-radius: 26px;
    }

    .pt-knowledge-featured-card,
    .pt-knowledge-list-card,
    .pt-knowledge-cluster-card {
      border-radius: 22px;
      padding: 20px;
    }
  }
</style>