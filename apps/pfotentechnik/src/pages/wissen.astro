---
import ProjectLayout from "../layouts/ProjectLayout.astro";
import { getContentByHub } from "@app/domain/content";

const knowledgePages = await getContentByHub("wissen");
const featuredPages = knowledgePages.filter((page) => page.featured).slice(0, 6);
const remainingPages = knowledgePages.filter(
  (page) => !featuredPages.some((featured) => featured.href === page.href)
);
---

<ProjectLayout
  title="Wissen"
  description="Ratgeber, Vergleiche und Kaufberatung rund um smarte Haustiertechnik für Hunde und Katzen."
  canonical="/wissen/"
  schemaType="article"
  includeBreadcrumbSchema={true}
>
  <main class="pt-knowledge-hub">
    <section class="pt-knowledge-hero">
      <div>
        <p class="pt-eyebrow">Wissen</p>
        <h1>Ratgeber für moderne Tierhaltung</h1>
        <p>
          Praxiswissen, Kaufberatung und unabhängige Vergleiche rund um
          smarte Haustiertechnik für Hunde und Katzen.
        </p>
      </div>

      <div class="pt-knowledge-hero-card">
        <span>{knowledgePages.length}</span>
        <strong>veröffentlichte Inhalte</strong>
        <p>Neue Markdown-Seiten werden automatisch ergänzt.</p>
      </div>
    </section>

    {featuredPages.length > 0 && (
      <section class="pt-knowledge-section">
        <header>
          <p class="pt-eyebrow">Empfohlen</p>
          <h2>Der beste Einstieg</h2>
        </header>

        <div class="pt-knowledge-grid">
          {featuredPages.map((page) => (
            <a class="pt-knowledge-card featured" href={page.href}>
              <span>{page.icon ?? "📖"}</span>
              <h3>{page.hubTitle}</h3>
              <p>{page.hubDescription}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="pt-knowledge-section">
      <header>
        <p class="pt-eyebrow">Alle Inhalte</p>
        <h2>Ratgeber und Entscheidungshilfen</h2>
        <p>Alle Inhalte stammen direkt aus der Content Registry.</p>
      </header>

      <div class="pt-knowledge-grid">
        {(featuredPages.length > 0 ? remainingPages : knowledgePages).map((page) => (
          <a class="pt-knowledge-card" href={page.href}>
            <span>{page.icon ?? "📖"}</span>
            <h3>{page.hubTitle}</h3>
            <p>{page.hubDescription}</p>
            <strong>Weiterlesen <span aria-hidden="true">→</span></strong>
          </a>
        ))}
      </div>
    </section>
  </main>
</ProjectLayout>

<style>
  .pt-knowledge-hub { display: grid; gap: clamp(42px, 7vw, 90px); padding: clamp(36px, 6vw, 76px) 0 clamp(70px, 9vw, 120px); }
  .pt-knowledge-hero { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 360px); gap: 28px; padding: clamp(28px, 5vw, 58px); border: 1px solid rgba(20, 32, 26, 0.08); border-radius: 34px; background: linear-gradient(135deg, rgba(20, 184, 166, 0.12), rgba(255, 255, 255, 0.96)); box-shadow: 0 24px 70px rgba(20, 32, 26, 0.08); }
  .pt-knowledge-hero h1 { max-width: 820px; margin: 0; color: var(--text); font-size: clamp(42px, 7vw, 82px); line-height: 0.96; letter-spacing: -0.07em; }
  .pt-knowledge-hero > div > p:last-child { max-width: 720px; color: var(--muted); font-size: clamp(18px, 2vw, 23px); line-height: 1.55; }
  .pt-eyebrow { margin: 0 0 10px; color: var(--primary-dark); font-size: 12px; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; }
  .pt-knowledge-hero-card { display: grid; align-content: center; gap: 12px; padding: 28px; border-radius: 28px; background: #fff; box-shadow: inset 0 0 0 1px rgba(20, 32, 26, 0.08); }
  .pt-knowledge-hero-card > span { color: var(--primary-dark); font-size: 54px; font-weight: 950; line-height: 1; }
  .pt-knowledge-hero-card p { margin: 0; color: var(--muted); }
  .pt-knowledge-section { display: grid; gap: 24px; }
  .pt-knowledge-section header { max-width: 760px; }
  .pt-knowledge-section h2 { margin: 0; color: var(--text); font-size: clamp(32px, 5vw, 54px); letter-spacing: -0.05em; }
  .pt-knowledge-section header > p:last-child { color: var(--muted); }
  .pt-knowledge-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; }
  .pt-knowledge-card { display: grid; gap: 10px; padding: 24px; border: 1px solid rgba(20, 32, 26, 0.08); border-radius: 26px; background: #fff; box-shadow: 0 14px 38px rgba(20, 32, 26, 0.045); color: inherit; text-decoration: none; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .pt-knowledge-card:hover { transform: translateY(-2px); box-shadow: 0 18px 46px rgba(20, 32, 26, 0.075); }
  .pt-knowledge-card > span { font-size: 28px; }
  .pt-knowledge-card h3 { margin: 0; color: var(--text); font-size: 22px; line-height: 1.16; letter-spacing: -0.035em; }
  .pt-knowledge-card p { margin: 0; color: var(--muted); line-height: 1.55; }
  .pt-knowledge-card strong { margin-top: auto; padding-top: 8px; color: var(--primary-dark); }
  .pt-knowledge-card.featured { background: linear-gradient(145deg, rgba(20, 184, 166, 0.08), #fff 50%); }
  @media (max-width: 900px) { .pt-knowledge-hero, .pt-knowledge-grid { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .pt-knowledge-hero { padding: 24px; border-radius: 26px; } .pt-knowledge-card { padding: 20px; border-radius: 22px; } }
</style>
