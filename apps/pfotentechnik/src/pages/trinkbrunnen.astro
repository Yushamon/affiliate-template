---
import { getCollection } from "astro:content";
import ProjectLayout from "../layouts/ProjectLayout.astro";
import OptimizedImage from "@affiliate-core/components/OptimizedImage.astro";

const products = (await getCollection("products"))
  .filter((product) => product.data.category.key === "trinkbrunnen")
  .sort((a, b) =>
    Number(b.data.hub?.featured ?? false) - Number(a.data.hub?.featured ?? false) ||
    (a.data.hub?.order ?? 100) - (b.data.hub?.order ?? 100) ||
    (b.data.score ?? b.data.rating * 20) - (a.data.score ?? a.data.rating * 20)
  );

const catProducts = products.filter((product) => !product.data.tags.includes("hunde") || product.data.tags.includes("katzen"));
const dogProducts = products.filter((product) => product.data.tags.includes("hunde"));
---

<ProjectLayout
  title="Trinkbrunnen für Katzen und Hunde"
  seoTitle="Die besten Trinkbrunnen für Katzen und Hunde"
  description="Trinkbrunnen nach Tierart, Kapazität, Material, Reinigung, Lautstärke, Akku und App verständlich vergleichen."
  canonical="/trinkbrunnen/"
>
  <main class="fountain-hub">
    <header class="fountain-hero">
      <p>Trinkbrunnen im Vergleich</p>
      <h1>Welcher Trinkbrunnen passt zu deinem Tier?</h1>
      <div class="fountain-hero-copy">
        <p>Entscheidend sind nicht möglichst viele Smart-Funktionen, sondern eine tiergerechte Trinkfläche, leiser Betrieb, gut erreichbare Bauteile und eine Reinigung, die im Alltag wirklich durchgehalten wird.</p>
        <strong>{products.length} aktuelle Modelle eingeordnet</strong>
      </div>
      <nav aria-label="Trinkbrunnen-Auswahl">
        <a href="#katzen">Für Katzen</a>
        <a href="#hunde">Für Hunde</a>
        <a href="#auswahl">Auswahlkriterien</a>
      </nav>
    </header>

    <section id="auswahl" class="fountain-advice">
      <article><span>01</span><h2>Kapazität</h2><p>Ein größerer Tank spart Nachfüllen, verlängert aber nicht automatisch die hygienische Standzeit des Wassers.</p></article>
      <article><span>02</span><h2>Reinigung</h2><p>Pumpe, Rotorraum und Auslauf müssen ohne Spezialwerkzeug erreichbar sein. UVC und Filter ersetzen das Reinigen nicht.</p></article>
      <article><span>03</span><h2>Betriebsart</h2><p>Akku schafft flexible Standorte. Dauerfluss wird häufig gut angenommen; Sensorbetrieb spart Energie, passt aber nicht zu jedem Tier.</p></article>
    </section>

    <section id="katzen" class="fountain-section">
      <header><p>Für Katzen</p><h2>Leise, zugänglich und gut zu reinigen</h2></header>
      <div class="fountain-grid">
        {catProducts.map((product) => (
          <a class="fountain-card" href={`/produkt/${product.data.slug}/`}>
            <figure><OptimizedImage src={product.data.images.thumbnail?.src ?? product.data.images.hero.src} alt={product.data.images.thumbnail?.alt ?? product.data.images.hero.alt} width={640} height={480} layout="constrained" /></figure>
            <div><span>{product.data.manufacturer.name} · {product.data.rating.toFixed(1)} / 5</span><h3>{product.data.title}</h3><p>{product.data.recommendation}</p><strong>Einordnung lesen →</strong></div>
          </a>
        ))}
      </div>
    </section>

    <section id="hunde" class="fountain-section">
      <header><p>Für Hunde</p><h2>Mehr Volumen und eine breite Trinkfläche</h2></header>
      <div class="fountain-grid">
        {dogProducts.map((product) => (
          <a class="fountain-card" href={`/produkt/${product.data.slug}/`}>
            <figure><OptimizedImage src={product.data.images.thumbnail?.src ?? product.data.images.hero.src} alt={product.data.images.thumbnail?.alt ?? product.data.images.hero.alt} width={640} height={480} layout="constrained" /></figure>
            <div><span>{product.data.manufacturer.name} · {product.data.rating.toFixed(1)} / 5</span><h3>{product.data.title}</h3><p>{product.data.recommendation}</p><strong>Einordnung lesen →</strong></div>
          </a>
        ))}
      </div>
    </section>

    <aside class="fountain-note"><h2>Wichtig für die Gesundheit</h2><p>Ein Trinkbrunnen kann Wasser attraktiver machen, ist aber kein Behandlungsgerät. Plötzlich deutlich mehr oder weniger Trinken, häufiges Urinieren, Schwäche oder Erbrechen sollten tierärztlich abgeklärt werden.</p></aside>
  </main>
</ProjectLayout>

<style>
  .fountain-hub{display:grid;gap:clamp(4rem,8vw,7rem)}
  .fountain-hero{max-width:1050px;padding:clamp(2rem,5vw,5rem) 0 0}
  .fountain-hero>p,.fountain-section header p{margin:0 0 .75rem;color:#18743b;font-size:.78rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase}
  .fountain-hero h1{max-width:900px;margin:0;font-size:clamp(3rem,8vw,6.5rem);line-height:.94;letter-spacing:-.065em}
  .fountain-hero-copy{display:grid;grid-template-columns:minmax(0,2fr) minmax(180px,1fr);gap:2rem;align-items:end;margin-top:2rem;padding-top:2rem;border-top:1px solid #dce5e3}
  .fountain-hero-copy p{max-width:700px;margin:0;color:#647579;font-size:1.15rem;line-height:1.75}
  .fountain-hero-copy strong{color:#0f5a2b}
  .fountain-hero nav{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:2rem}
  .fountain-hero nav a{padding:.7rem 1rem;border:1px solid #cfe0dc;border-radius:999px;color:#0f5a2b;font-weight:800;text-decoration:none}
  .fountain-advice{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem}
  .fountain-advice article{padding:1.5rem;border:1px solid #dce5e3;border-radius:1.4rem;background:#fff}
  .fountain-advice span{color:#18743b;font-weight:900}.fountain-advice h2{margin:.7rem 0;font-size:1.35rem}.fountain-advice p{margin:0;color:#647579;line-height:1.65}
  .fountain-section header{max-width:760px;margin-bottom:2rem}.fountain-section h2{margin:0;font-size:clamp(2.2rem,5vw,4rem);letter-spacing:-.05em}
  .fountain-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1.25rem}
  .fountain-card{display:grid;grid-template-columns:190px minmax(0,1fr);overflow:hidden;border:1px solid #dce5e3;border-radius:1.4rem;background:#fff;color:inherit;text-decoration:none;box-shadow:0 12px 30px rgba(13,48,43,.05)}
  .fountain-card figure{min-height:230px;margin:0;overflow:hidden;background:#f2f7f5}.fountain-card figure :global(img){width:100%;height:100%;object-fit:cover}
  .fountain-card>div{display:flex;flex-direction:column;padding:1.35rem}.fountain-card span{color:#18743b;font-size:.75rem;font-weight:900;text-transform:uppercase}.fountain-card h3{margin:.55rem 0;font-size:1.45rem;line-height:1.1}.fountain-card p{margin:0;color:#647579;line-height:1.55}.fountain-card strong{margin-top:auto;padding-top:1rem;color:#0f5a2b}
  .fountain-note{padding:clamp(1.5rem,4vw,3rem);border-radius:1.7rem;background:linear-gradient(135deg,#eefaf6,#fff)}.fountain-note h2{margin-top:0}.fountain-note p{max-width:800px;margin-bottom:0;color:#526568;line-height:1.75}
  @media(max-width:900px){.fountain-grid{grid-template-columns:1fr}}
  @media(max-width:650px){.fountain-hero-copy,.fountain-advice{grid-template-columns:1fr}.fountain-card{grid-template-columns:1fr}.fountain-card figure{aspect-ratio:4/3;min-height:0}.fountain-hub{gap:4rem}}
</style>
