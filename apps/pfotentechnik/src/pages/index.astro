---
import { getCollection } from "astro:content";
import ProjectLayout from "../layouts/ProjectLayout.astro";
import { projectConfig } from "../project.config";

const { home } = projectConfig;
const products = await getCollection("products");
const manufacturers = (await getCollection("manufacturers"))
  .sort((a, b) =>
    Number(b.data.hub?.featured ?? false) - Number(a.data.hub?.featured ?? false) ||
    (a.data.hub?.order ?? 100) - (b.data.hub?.order ?? 100) ||
    a.data.name.localeCompare(b.data.name, "de")
  )
  .slice(0, 4);
const availableCategories = home.categories.items.filter((category) =>
  "productCategory" in category
    ? products.some((product) =>
        product.data.category.key === category.productCategory ||
        product.data.category.path?.includes(category.productCategory)
      )
    : "productUseCase" in category
      ? products.some((product) =>
          product.data.useCase === category.productUseCase ||
          product.data.tags.includes(category.productUseCase)
        )
      : false
);
const featuredProducts = products
  .sort((a, b) =>
    Number(b.data.hub?.featured ?? false) - Number(a.data.hub?.featured ?? false) ||
    (a.data.hub?.order ?? 100) - (b.data.hub?.order ?? 100) ||
    (b.data.score ?? b.data.rating * 20) - (a.data.score ?? a.data.rating * 20)
  )
  .slice(0, 3);
const pages = (await getCollection("pages"))
  .sort((a, b) =>
    (b.data.hubPriority ?? 0) - (a.data.hubPriority ?? 0) ||
    (b.data.updatedAt ?? "").localeCompare(a.data.updatedAt ?? "")
  )
  .slice(0, 3);
---

<ProjectLayout
  title={home.seo.title}
  description={home.seo.description}
  canonical="/"
  ogImage="/images/project/pfotentechnik/feeder-hero.webp"
  publishedAt={home.seo.publishedAt}
  updatedAt={home.seo.updatedAt}
  schemaType="article"
  includeBreadcrumbSchema={true}
>
  <div class="pt-home">
    <section class="pt-hero" aria-labelledby="pt-hero-title">
      <div class="pt-hero-copy">
        <p class="pt-eyebrow">{home.hero.eyebrow}</p>
        <h1 id="pt-hero-title">{home.hero.title}</h1>
        <p class="pt-hero-text">{home.hero.text}</p>

        <div class="pt-hero-actions">
          <a class="pt-button pt-button-primary" href={home.hero.primaryAction.href}>
            {home.hero.primaryAction.label}
          </a>
          <a class="pt-button pt-button-secondary" href={home.hero.secondaryAction.href}>
            {home.hero.secondaryAction.label}
          </a>
        </div>

        <ul class="pt-signal-list" aria-label={home.hero.eyebrow}>
          {home.hero.signals.map((signal) => <li>{signal}</li>)}
        </ul>
      </div>

      <figure class="pt-hero-media">
        <img
          src="/images/project/pfotentechnik/feeder-hero.webp"
          alt={home.hero.imageAlt}
          width="1728"
          height="960"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <span class="pt-image-accent" aria-hidden="true"></span>
      </figure>
    </section>

    <section class="pt-section pt-categories" aria-labelledby="pt-categories-title">
      <header class="pt-section-header">
        <p class="pt-eyebrow">{home.categories.eyebrow}</p>
        <h2 id="pt-categories-title">{home.categories.title}</h2>
        <p>{home.categories.text}</p>
      </header>

      <div class="pt-category-grid">
        {availableCategories.map((category) => (
          <a class="pt-category-card" id={category.anchor} href={category.href}>
            <span class="pt-card-index">{category.code}</span>
            <h3>{category.title}</h3>
            <p>{category.text}</p>
            <span class="pt-card-line" aria-hidden="true"></span>
          </a>
        ))}
      </div>
    </section>

    <section class="pt-section pt-categories" id="hersteller" aria-labelledby="pt-manufacturers-title">
      <header class="pt-section-header">
        <p class="pt-eyebrow">{home.manufacturers.eyebrow}</p>
        <h2 id="pt-manufacturers-title">{home.manufacturers.title}</h2>
        <p>{home.manufacturers.text}</p>
      </header>
      <div class="pt-category-grid">
        {manufacturers.map((manufacturer, index) => (
          <a class="pt-category-card" href={`/hersteller/${manufacturer.data.slug}/`}>
            <span class="pt-card-index">{String(index + 1).padStart(2, "0")}</span>
            <h3>{manufacturer.data.name}</h3>
            <p>{manufacturer.data.description}</p>
            <span class="pt-card-line" aria-hidden="true"></span>
          </a>
        ))}
      </div>
    </section>

    <section
      class="pt-section pt-values"
      id="ueber-uns"
      aria-labelledby="pt-values-title"
    >
      <div class="pt-values-intro">
        <p class="pt-eyebrow">{home.values.eyebrow}</p>
        <h2 id="pt-values-title">{home.values.title}</h2>
        <p>{home.values.text}</p>
      </div>

      <div class="pt-value-grid">
        {home.values.items.map((item) => (
          <article class="pt-value-card">
            <span>{item.number}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section
      class="pt-section pt-guides"
      id="ratgeber"
      aria-labelledby="pt-guides-title"
    >
      <header class="pt-section-header">
        <p class="pt-eyebrow">{home.guides.eyebrow}</p>
        <h2 id="pt-guides-title">{home.guides.title}</h2>
        <p>{home.guides.text}</p>
      </header>

      <div class="pt-guide-grid">
        {pages.map((page) => (
          <a class="pt-guide-card" href={`/${page.data.slug}`}>
            <div class="pt-guide-image">
              <img
                src={page.data.heroImage ?? "/images/project/pfotentechnik/guide.webp"}
                alt=""
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="pt-guide-content">
              <span>{home.guides.cardLabel}</span>
              <h3>{page.data.title}</h3>
              <p>{page.data.description}</p>
              <strong>{home.guides.cardAction}</strong>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section
      class="pt-section pt-products"
      id="produkte"
      aria-labelledby="pt-products-title"
    >
      <span id="vergleiche" class="pt-anchor" aria-hidden="true"></span>
      <header class="pt-section-header">
        <p class="pt-eyebrow">{home.products.eyebrow}</p>
        <h2 id="pt-products-title">{home.products.title}</h2>
        <p>{home.products.text}</p>
      </header>

      <div class="pt-category-grid pt-home-ranking-list">
        {featuredProducts.map((product, index) => (
          <a class="pt-category-card" href={`/produkt/${product.data.slug}/`}>
            <span class="pt-card-index">{String(index + 1).padStart(2, "0")}</span>
            <img
              src={product.data.images.thumbnail?.src ?? product.data.images.hero.src}
              alt={product.data.images.thumbnail?.alt ?? product.data.images.hero.alt}
              loading="lazy"
              decoding="async"
            />
            <p class="pt-eyebrow">{product.data.manufacturer.name} · {product.data.rating.toFixed(1)} / 5</p>
            <h3>{product.data.title}</h3>
            <p>{product.data.recommendation}</p>
            <strong>Produkttest lesen</strong>
            <span class="pt-card-line" aria-hidden="true"></span>
          </a>
        ))}
      </div>
    </section>
  </div>
</ProjectLayout>
