---
import { getCollection, getEntry, render } from "astro:content";
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import FAQ from "@affiliate-core/components/FAQ.astro";
import RelatedArticles from "@affiliate-core/components/RelatedArticles.astro";
import {
  getComparisonBreadcrumbs,
  getRelatedContent
} from "@app/domain/content";

type Props = { comparisonId: string };

export async function getStaticPaths() {
  const comparisons = await getCollection("comparisons");
  return comparisons.map((entry) => ({
    params: { comparison: entry.data.slug },
    props: { comparisonId: entry.id } satisfies Props
  }));
}

const { comparisonId } = Astro.props as Props;
const entry = await getEntry("comparisons", comparisonId);
if (!entry) throw new Error(`Vergleich "${comparisonId}" wurde nicht gefunden.`);

const comparison = entry.data;
const { Content } = await render(entry);
const products = await getCollection("products");
const manufacturers = await getCollection("manufacturers");
const productBySlug = new Map(products.map((product) => [product.data.slug, product]));
const manufacturerBySlug = new Map(manufacturers.map((manufacturer) => [manufacturer.data.slug, manufacturer]));
const winnerSlug = comparison.recommendation.winnerSlug;
const winnerItem = winnerSlug
  ? comparison.items.find((item) => item.slug === winnerSlug)
  : undefined;
const winnerProduct = winnerItem?.type === "product"
  ? products.find((product) => product.data.slug === winnerSlug)
  : undefined;
const winnerManufacturer = winnerItem?.type === "manufacturer"
  ? manufacturers.find((manufacturer) => manufacturer.data.slug === winnerSlug)
  : undefined;
const winnerHref = winnerItem?.type === "manufacturer"
  ? `/hersteller/${winnerSlug}/`
  : `/produkt/${winnerSlug}/`;
const winnerImage = winnerProduct?.data.images.hero
  ?? winnerManufacturer?.data.images.hero;
const winnerRating = winnerProduct?.data.rating
  ?? winnerManufacturer?.data.rating;
const normalizeKey = (value: string) => value
  .toLocaleLowerCase("de")
  .replaceAll("ä", "ae")
  .replaceAll("ö", "oe")
  .replaceAll("ü", "ue")
  .replaceAll("ß", "ss")
  .replace(/[^a-z0-9]/g, "");
const getCriterionValue = (productSlug: string, criterionKey: string, criterionLabel: string) => {
  const product = productBySlug.get(productSlug);
  if (!product) return "–";

  const normalizedCandidates = new Set([
    normalizeKey(criterionKey),
    normalizeKey(criterionLabel)
  ]);
  const spec = product.data.specs.find((item) =>
    normalizedCandidates.has(normalizeKey(item.label))
  );

  if (spec) {
    return typeof spec.value === "boolean"
      ? spec.value ? "Ja" : "Nein"
      : String(spec.value);
  }

  const rating = Object.entries(product.data.ratings).find(([key]) =>
    normalizedCandidates.has(normalizeKey(key))
  )?.[1];

  return typeof rating === "number" ? `${rating.toFixed(1)} / 5` : "–";
};
const breadcrumbs =
  getComparisonBreadcrumbs(entry);

const relatedEntries = await getRelatedContent({
  currentSlug: comparison.slug,
  tags: comparison.related?.tags.length
    ? comparison.related.tags
    : comparison.tags,
  sections: comparison.hub?.sections ?? [],
  type: "comparison",
  exclude: comparison.related?.exclude ?? [],
  limit: comparison.related?.limit ?? 4
});

const relatedItems = relatedEntries.map((related) => ({
  href: related.href,
  label: related.type === "product"
    ? "Produkt"
    : related.type === "manufacturer"
      ? "Hersteller"
      : related.type === "comparison"
        ? "Vergleich"
        : "Ratgeber",
  title: related.hubTitle,
  text: related.hubDescription
}));
---

<ProjectLayout
  title={comparison.title}
  seoTitle={comparison.seo?.title ?? comparison.title}
  description={comparison.description}
  seoDescription={comparison.seo?.description ?? comparison.description}
  canonical={comparison.seo?.canonical ?? `/vergleiche/${comparison.slug}/`}
  faq={comparison.faq}
  categoryLabel="Vergleiche"
  breadcrumbs={breadcrumbs}
  schemaType="article"
>
  <Breadcrumbs items={breadcrumbs} />

  <main class="comparison-detail">
    <header class="comparison-hero">
      <span>{comparison.icon ?? "↔"} Vergleich</span>
      <h1>{comparison.title}</h1>
      <p>{comparison.description}</p>
    </header>

    {winnerItem && (
      <section class="comparison-winner" aria-labelledby="comparison-winner-title">
        {winnerImage && (
          <img
            src={winnerImage.src}
            alt={winnerImage.alt ?? winnerItem.label ?? "Top-Empfehlung"}
            loading="eager"
            decoding="async"
          />
        )}
        <div>
          <span>Top-Empfehlung</span>
          <h2 id="comparison-winner-title">{winnerItem.label ?? winnerItem.slug}</h2>
          <p>{winnerItem.recommendation ?? comparison.recommendation.text}</p>
          {winnerRating && <strong>{winnerRating.toFixed(1)} / 5</strong>}
          <a href={winnerHref}>Ausführlichen Test lesen</a>
        </div>
      </section>
    )}

    <section>
      <h2>{comparison.cardsTitle ?? "Verglichene Produkte"}</h2>
      <div class="comparison-items">
        {comparison.items.map((item) => {
          const product = item.type === "product"
            ? productBySlug.get(item.slug)
            : undefined;
          const manufacturer = item.type === "manufacturer"
            ? manufacturerBySlug.get(item.slug)
            : undefined;
          const image = product?.data.images.thumbnail
            ?? product?.data.images.hero
            ?? manufacturer?.data.images.logo
            ?? manufacturer?.data.images.hero;
          const title = product?.data.title
            ?? manufacturer?.data.name
            ?? item.label
            ?? item.slug;
          const recommendation = product?.data.recommendation
            ?? manufacturer?.data.recommendation
            ?? item.recommendation;
          const rating = product?.data.rating
            ?? manufacturer?.data.rating;
          const href = item.type === "manufacturer"
            ? `/hersteller/${item.slug}/`
            : `/produkt/${item.slug}/`;

          return (
            <a href={href}>
              {image && (
                <img
                  src={image.src}
                  alt={image.alt ?? title}
                  loading="lazy"
                  decoding="async"
                />
              )}
              <span>
                {item.slug === winnerSlug
                  ? "Top-Empfehlung"
                  : item.type === "product"
                    ? product?.data.manufacturer.name ?? "Produkt"
                    : "Hersteller"}
              </span>
              <h3>{title}</h3>
              {recommendation && <p>{recommendation}</p>}
              {rating && <strong>{rating.toFixed(1)} / 5</strong>}
            </a>
          );
        })}
      </div>
    </section>

    {comparison.criteria.length > 0 && (
      <section>
        <h2>{comparison.tableTitle ?? "Vergleichskriterien"}</h2>
        <div class="comparison-table-wrap">
          <table class="comparison-table">
            <thead>
              <tr>
                <th scope="col">Kriterium</th>
                {comparison.items.map((item) => (
                  <th scope="col">{productBySlug.get(item.slug)?.data.title ?? item.label ?? item.slug}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {comparison.criteria.map((criterion) => (
                <tr>
                  <th scope="row">
                    {criterion.label}
                    {criterion.description && <small>{criterion.description}</small>}
                  </th>
                  {comparison.items.map((item) => (
                    <td>{getCriterionValue(item.slug, criterion.key, criterion.label)}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <section class="comparison-result">
      <span>Unsere Empfehlung</span>
      <h2>{comparison.recommendation.title}</h2>
      <p>{comparison.recommendation.text}</p>
    </section>

    <article class="comparison-content"><Content /></article>
    <RelatedArticles items={relatedItems} />
    {comparison.faq.length > 0 && <FAQ items={comparison.faq} />}
  </main>
</ProjectLayout>

<style>
  .comparison-detail { display: grid; gap: 3.5rem; padding-bottom: 5rem; }
  .comparison-hero { padding: clamp(2rem, 6vw, 5rem); border: 1px solid #dce5e3; border-radius: 1.75rem; background: linear-gradient(145deg, #fff, #f5f9f6); text-align: center; }
  .comparison-hero span, .comparison-result > span, .comparison-items span { color: #18743b; font-size: .75rem; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
  .comparison-hero h1 { max-width: 18ch; margin: .7rem auto 1rem; font-size: clamp(2.6rem, 6vw, 5rem); line-height: 1; letter-spacing: -.05em; }
  .comparison-hero p { max-width: 65ch; margin: 0 auto; color: #647579; line-height: 1.7; }
  .comparison-items { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
  .comparison-items a { display: flex; flex-direction: column; min-width: 0; padding: 1.4rem; border: 1px solid #dce5e3; border-radius: 1rem; color: inherit; background: #fff; text-decoration: none; box-shadow: 0 10px 30px rgba(20, 32, 26, .04); }
  .comparison-items img { width: 100%; aspect-ratio: 4 / 3; margin-bottom: 1rem; border-radius: .8rem; object-fit: contain; background: #f8faf9; }
  .comparison-items h3 { margin: .5rem 0; }
  .comparison-items p, .comparison-result p { color: #647579; line-height: 1.6; }
  .comparison-items strong { margin-top: auto; padding-top: .8rem; color: #18743b; }
  .comparison-table-wrap { width: 100%; overflow-x: auto; border: 1px solid #dce5e3; border-radius: 1rem; background: #fff; }
  .comparison-table { width: 100%; min-width: 760px; border-collapse: collapse; }
  .comparison-table th, .comparison-table td { padding: 1rem; border-bottom: 1px solid #e7eeec; text-align: left; vertical-align: top; }
  .comparison-table thead th { color: #0d302b; background: #f2f8f4; font-size: .78rem; line-height: 1.35; }
  .comparison-table tbody th { min-width: 150px; color: #0d302b; }
  .comparison-table tbody td { min-width: 130px; color: #647579; font-size: .92rem; line-height: 1.5; }
  .comparison-table small { display: block; margin-top: .35rem; color: #647579; font-weight: 400; line-height: 1.4; }
  .comparison-table tbody tr:last-child th, .comparison-table tbody tr:last-child td { border-bottom: 0; }
  .comparison-result { padding: 2rem; border-radius: 1.2rem; background: rgba(24, 116, 59, .08); }
  .comparison-winner { display: grid; grid-template-columns: minmax(220px, .8fr) minmax(0, 1.2fr); gap: clamp(1.5rem, 4vw, 3rem); align-items: center; padding: clamp(1.4rem, 4vw, 2.5rem); border: 1px solid rgba(24, 116, 59, .24); border-radius: 1.5rem; background: linear-gradient(145deg, #fff, #eff9f1); box-shadow: 0 18px 48px rgba(20, 32, 26, .08); }
  .comparison-winner img { width: 100%; aspect-ratio: 4 / 3; border-radius: 1.1rem; object-fit: contain; background: #fff; }
  .comparison-winner span { color: #18743b; font-size: .75rem; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
  .comparison-winner h2 { margin: .55rem 0 .8rem; font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.05; letter-spacing: -.04em; }
  .comparison-winner p { color: #647579; line-height: 1.65; }
  .comparison-winner strong { display: block; margin: 1rem 0; color: #18743b; font-size: 1.1rem; }
  .comparison-winner a { display: inline-flex; padding: .85rem 1.2rem; border-radius: 999px; color: #fff; background: #18743b; font-weight: 900; text-decoration: none; }
  .comparison-content { max-width: 780px; line-height: 1.75; }
  @media(max-width: 800px) { .comparison-items, .comparison-winner { grid-template-columns: 1fr; } .comparison-winner { padding: 1.2rem; } .comparison-table th, .comparison-table td { padding: .8rem; } }
</style>
