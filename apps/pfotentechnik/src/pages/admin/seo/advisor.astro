---
import SeoAdminLayout from "../../../layouts/SeoAdminLayout.astro";
import { loadSeoDashboard } from "../../../lib/seo/loadDashboard";
import { buildSeoAdvisor } from "../../../lib/seo/advisor";
import { loadAdvisorContent } from "../../../lib/seo/advisor/loadContent";
import {
  buildProductImagePrompts,
  buildProductMarkdownPrompt,
  loadProductIntelligence,
} from "../../../lib/seo/advisor/productIntelligence";

const payload = loadSeoDashboard();
const { documents, graph } = await loadAdvisorContent();
const results = Object.fromEntries(
  Object.entries(payload.ranges).map(([key, range]) => [key, buildSeoAdvisor({ payload, range, documents, graph })]),
);
const defaultResult = results[payload.defaultRange] ?? Object.values(results)[0];
const productIntelligence = await loadProductIntelligence();
const productDiscoveries = productIntelligence.discoveries.map((product) => ({
  ...product,
  markdownPrompt: buildProductMarkdownPrompt(product),
  imagePrompts: buildProductImagePrompts(product),
}));
const clientPayload = JSON.stringify({
  defaultRange: payload.defaultRange,
  generatedAt: payload.generatedAt,
  property: payload.property,
  source: payload.source,
  diagnostics: payload.diagnostics,
  results,
  productIntelligence: { ...productIntelligence, discoveries: productDiscoveries },
}).replace(/</g, "\\u003c").replace(/\u2028/g, "\\u2028").replace(/\u2029/g, "\\u2029");
const formatNumber = (value: number) => new Intl.NumberFormat("de-DE").format(value);
---
<SeoAdminLayout
  title="SEO Co-Pilot"
  description="Tägliche Prioritäten, konservative Szenarien und Product Intelligence aus Search-Daten, Content Graph und validierten Astro-Collections."
  active="advisor"
>
  {defaultResult ? (
    <>
      <section class="status-grid" aria-label="Datenstatus">
        <article class="seo-card status-main">
          <div>
            <span class="seo-badge" data-level={defaultResult.dataConfidence === "gering" ? "medium" : "low"}>Datenvertrauen: {defaultResult.dataConfidence}</span>
            <h2 id="active-period">{defaultResult.range.label}</h2>
            <p id="active-dates">{defaultResult.range.startDate} bis {defaultResult.range.endDate}</p>
          </div>
          <p id="data-notice">{defaultResult.dataNotice}</p>
        </article>
        <article class="seo-card generated-card">
          <span>Generiert am</span>
          <strong>{payload.generatedAt ? new Date(payload.generatedAt).toLocaleString("de-DE") : "Nicht verfügbar"}</strong>
          <small>{payload.property || "Keine Property-Angabe"}</small>
        </article>
      </section>

      <div class="range-toolbar" role="group" aria-label="Zeitraum auswählen">
        {Object.entries(results).map(([key, result]) => (
          <button type="button" class:list={["range-button", { active: key === payload.defaultRange }]} data-range={key} aria-pressed={key === payload.defaultRange ? "true" : "false"}>
            {result.range.label}
          </button>
        ))}
      </div>

      <section class="metric-grid" id="metric-grid" aria-label="Kennzahlen">
        {[
          ["Klicks", formatNumber(defaultResult.range.metrics.current.clicks)],
          ["Impressionen", formatNumber(defaultResult.range.metrics.current.impressions)],
          ["CTR", `${defaultResult.range.metrics.current.ctr.toFixed(2)} %`],
          ["Position", defaultResult.range.metrics.current.position.toFixed(1)],
          ["Seiten", formatNumber(defaultResult.range.pages.length)],
          ["Queries", formatNumber(defaultResult.range.queries.length)],
          ["Trendtage", formatNumber(defaultResult.range.trend.length)],
          ["Empfehlungen", formatNumber(defaultResult.range.recommendations.length)],
        ].map(([label, value]) => <article class="seo-card metric"><span>{label}</span><strong>{value}</strong></article>)}
      </section>

      <section class="traffic-win seo-card" aria-labelledby="traffic-win-title">
        <div class="section-heading">
          <div><span class="seo-eyebrow">Fokus</span><h2 id="traffic-win-title">Größter Traffic-Gewinn heute</h2></div>
          <span class="score-pill" id="traffic-win-score">{defaultResult.trafficWin?.score ?? 0}/100</span>
        </div>
        <div id="traffic-win-content">
          {defaultResult.trafficWin ? (
            <>
              <h3>{defaultResult.trafficWin.title}</h3>
              <p class="target">{defaultResult.trafficWin.url ?? defaultResult.trafficWin.query}</p>
              <p>{defaultResult.trafficWin.rationale}</p>
              <p><strong>Empfohlene Änderung:</strong> {defaultResult.trafficWin.nextAction}</p>
              <p><strong>Erwarteter Effekt:</strong> {defaultResult.trafficWin.expectedBenefit}</p>
            </>
          ) : <div class="seo-empty">Keine belastbare Empfehlung für diesen Zeitraum.</div>}
        </div>
      </section>

      <section class="advisor-section" aria-labelledby="today-title">
        <div class="section-heading"><div><span class="seo-eyebrow">Priorisiert</span><h2 id="today-title">Heute erledigen – Top 5</h2></div></div>
        <div class="task-list" id="top-tasks">
          {defaultResult.topTasks.map((task, index) => (
            <article class="seo-card task-card">
              <div class="task-rank">{index + 1}</div>
              <div><span class="seo-badge">{task.category}</span><h3>{task.title}</h3><p class="target">{task.url ?? task.query}</p><p>{task.rationale}</p></div>
            </article>
          ))}
        </div>
      </section>

      <section class="analysis-grid intelligence-row" aria-label="Priorität und Forecast">
        <article class="seo-card analysis-card">
          <div class="section-heading"><div><span class="seo-eyebrow">Niedriger Aufwand</span><h2>Quick Wins</h2></div></div>
          <div id="quick-win-list"></div>
        </article>
        <article class="seo-card analysis-card">
          <div class="section-heading"><div><span class="seo-eyebrow">Konservatives Szenario</span><h2>Forecast</h2></div></div>
          <p class="disclaimer">Szenarien auf Basis vorhandener Impressionen – keine Traffic- oder Ranking-Versprechen.</p>
          <div id="forecast-list"></div>
        </article>
      </section>

      <section class="advisor-section" aria-labelledby="opportunities-title">
        <div class="section-heading"><div><span class="seo-eyebrow">Arbeitsvorrat</span><h2 id="opportunities-title">Chancen nach Kategorie</h2></div></div>
        <div class="filter-grid" aria-label="Chancen filtern">
          <label>Kategorie<select id="filter-category"><option value="all">Alle</option><option value="ranking">Ranking</option><option value="ctr">CTR</option><option value="eeat">EEAT</option><option value="internal-link">Interne Links</option><option value="content-gap">Content Gap</option><option value="technical">Technik</option></select></label>
          <label>Priorität<select id="filter-priority"><option value="all">Alle</option><option value="high">Hoch</option><option value="medium">Mittel</option><option value="low">Niedrig</option></select></label>
          <label>Seitentyp<select id="filter-page-type"><option value="all">Alle</option><option value="Cornerstone">Cornerstone</option><option value="Vergleich">Vergleich</option><option value="Produkt">Produkt</option><option value="Hersteller">Hersteller</option><option value="Ratgeber">Ratgeber</option></select></label>
          <label>Status<select id="filter-status"><option value="all">Alle</option><option value="offen">Offen</option><option value="geplant">Geplant</option><option value="in-arbeit">In Arbeit</option><option value="erledigt">Erledigt</option><option value="verworfen">Verworfen</option></select></label>
        </div>
        <div class="opportunity-list" id="opportunities"></div>
      </section>

      <section class="analysis-grid">
        <article class="seo-card analysis-card"><div class="section-heading"><div><span class="seo-eyebrow">Internes Signal</span><h2>EEAT-Analyse</h2></div></div><p class="disclaimer">Interne Qualitätsbewertung – kein offizieller Google-Score.</p><div id="eeat-list"></div></article>
        <article class="seo-card analysis-card"><div class="section-heading"><div><span class="seo-eyebrow">Suchintention</span><h2>Content Gaps</h2></div></div><div id="gap-list"></div></article>
        <article class="seo-card analysis-card"><div class="section-heading"><div><span class="seo-eyebrow">Risikoanalyse</span><h2>Kannibalisierung</h2></div></div><div id="cannibal-list"></div></article>
        <article class="seo-card analysis-card"><div class="section-heading"><div><span class="seo-eyebrow">Content Graph</span><h2>Cornerstone-Links</h2></div></div><div id="link-list"></div></article>
        <article class="seo-card analysis-card"><div class="section-heading"><div><span class="seo-eyebrow">Cluster-Abdeckung</span><h2>Graph Gaps</h2></div></div><div id="graph-gap-list"></div></article>
        <article class="seo-card analysis-card"><div class="section-heading"><div><span class="seo-eyebrow">Funnel-Struktur</span><h2>Conversion Insights</h2></div></div><p class="disclaimer">Keine Interaktionsmessung: bewertet werden Search-Traffic und strukturelle CTA-/Linksignale.</p><div id="conversion-list"></div></article>
      </section>

      <section class="advisor-section" aria-labelledby="calendar-title">
        <div class="section-heading"><div><span class="seo-eyebrow">Redaktionsplanung</span><h2 id="calendar-title">Editorial Calendar</h2></div></div>
        <div class="intelligence-cards" id="calendar-list"></div>
      </section>

      <section class="advisor-section" aria-labelledby="products-title">
        <div class="section-heading">
          <div><span class="seo-eyebrow">Product Intelligence 1.0</span><h2 id="products-title">Produkte, Abdeckung und Datenqualität</h2></div>
          <span class="seo-badge">{productIntelligence.health.length} validierte Produkte</span>
        </div>
        <div class="product-summary">
          <article class="seo-card summary-tile"><strong>{productIntelligence.discoveries.length}</strong><span>Neue, in Herstellerdaten belegte Produktkandidaten</span></article>
          <article class="seo-card summary-tile"><strong>{productIntelligence.coverageGaps.length}</strong><span>Product Gaps</span></article>
          <article class="seo-card summary-tile"><strong>{productIntelligence.health.filter((item) => item.status === "gesund").length}</strong><span>Produkte mit Health ≥ 85</span></article>
        </div>
        <div class="product-grid">
          <article class="seo-card analysis-card">
            <div class="section-heading"><div><span class="seo-eyebrow">Hersteller-Collection</span><h2>Neue Produkte</h2></div></div>
            {productDiscoveries.length ? productDiscoveries.map((product) => (
              <div class="finding product-candidate">
                <h3>{product.name}</h3><p>{product.manufacturerName} · <code>{product.slug}</code></p>
                <p>{product.knownData.join(" · ")}</p>
                <div class="task-actions">
                  <button type="button" class="button secondary" data-product-action="product.draft.create" data-slug={product.slug} data-name={product.name}>Produkt erstellen</button>
                  <button type="button" class="button secondary" data-copy-product-prompt={product.slug}>Markdown Prompt</button>
                  <button type="button" class="button secondary" data-product-action="product.images.prompts" data-slug={product.slug} data-name={product.name}>Bilder erstellen</button>
                  <button type="button" class="button secondary" data-product-action="product.images.pack" data-slug={product.slug} data-name={product.name}>Bildpaket bauen</button>
                </div>
              </div>
            )) : <div class="seo-empty">Keine neue Produktdatei ist durch die vorhandenen Hersteller-Produktlisten belegt. Es wird kein Dummy-Produkt vorgeschlagen.</div>}
          </article>
          <article class="seo-card analysis-card">
            <div class="section-heading"><div><span class="seo-eyebrow">Coverage</span><h2>Product Gaps</h2></div></div>
            {productIntelligence.coverageGaps.slice(0, 16).map((gap) => <div class="finding"><span class="seo-badge">{gap.kind}</span><h3>{gap.title}</h3><p>{gap.evidence}</p><p>{gap.recommendation}</p></div>)}
            {!productIntelligence.coverageGaps.length && <div class="seo-empty">Keine strukturelle Produktlücke erkannt.</div>}
          </article>
        </div>
        <article class="seo-card health-card">
          <div class="section-heading"><div><span class="seo-eyebrow">Schema · Bilder · Quellen · Links</span><h2>Product Health</h2></div></div>
          <div class="table-scroll"><table><thead><tr><th>Produkt</th><th>Hersteller</th><th>Kategorie</th><th>Score</th><th>Offen</th></tr></thead><tbody>
            {productIntelligence.health.map((product) => <tr><td><a href={`/produkt/${product.slug}/`}>{product.title}</a></td><td>{product.manufacturer}</td><td>{product.category}</td><td><span class="seo-badge" data-level={product.status === "kritisch" ? "high" : product.status === "prüfen" ? "medium" : "low"}>{product.score}/100</span></td><td>{product.gaps.join(", ") || "–"}</td></tr>)}
          </tbody></table></div>
        </article>
      </section>

      <section class="advisor-section learning-section" aria-labelledby="learning-title">
        <div class="section-heading"><div><span class="seo-eyebrow">Wirkungsmessung</span><h2 id="learning-title">Learning</h2></div></div>
        <article class="seo-card analysis-card">
          <p>Abgeschlossene Aufgaben erhalten einen lokalen Baseline-Snapshot und werden frühestens nach 14 Tagen mit neuen Search-Daten verglichen. Veränderungen gelten nur als zeitliche Assoziation; der Co-Pilot behauptet keine Kausalität.</p>
          <div id="learning-list" class="intelligence-cards"><div class="seo-empty">Verbinde den lokalen Admin-Service, um Abschluss-Snapshots zu laden.</div></div>
        </article>
      </section>

      <div class="action-message seo-card" id="copilot-action-message" aria-live="polite">One-Click-Aktionen benötigen den lokalen Admin-Service auf Port 4178.</div>

      <details class="seo-card raw-details">
        <summary>Rohdaten und Diagnose</summary>
        <div id="diagnostics"></div>
        <h3>Seiten</h3><div class="table-scroll"><table><thead><tr><th>URL</th><th>Klicks</th><th>Impr.</th><th>CTR</th><th>Position</th></tr></thead><tbody id="raw-pages"></tbody></table></div>
        <h3>Queries</h3><div class="table-scroll"><table><thead><tr><th>Query</th><th>Klicks</th><th>Impr.</th><th>CTR</th><th>Position</th></tr></thead><tbody id="raw-queries"></tbody></table></div>
        <h3>Trend</h3><div class="table-scroll"><table><thead><tr><th>Datum</th><th>Klicks</th><th>Impr.</th><th>CTR</th><th>Position</th></tr></thead><tbody id="raw-trend"></tbody></table></div>
        <h3>Vorhandene GSC-Empfehlungen</h3><div id="raw-recommendations"></div>
      </details>

      <div class="export-bar seo-card"><div><strong>Aufgaben lokal verwalten</strong><p>Status und Notizen werden nur in diesem Browser gespeichert.</p></div><button type="button" class="button secondary" id="export-tasks">Aufgaben als JSON exportieren</button></div>
    </>
  ) : (
    <section class="seo-card fatal-state"><h2>Keine nutzbaren SEO-Daten</h2><p>Prüfe die Diagnose in den GSC-Datendateien. Es werden keine Ersatzwerte angezeigt.</p></section>
  )}

  <script type="application/json" id="advisor-data" set:html={clientPayload}></script>
</SeoAdminLayout>

<style>
  .status-grid { display: grid; grid-template-columns: 1fr 300px; gap: 16px; }
  .status-main, .generated-card { padding: 20px; }
  .status-main { display: grid; grid-template-columns: minmax(220px, .7fr) 1fr; gap: 28px; align-items: center; }
  .status-main h2 { margin: 9px 0 4px; font-size: 1.35rem; }
  .status-main p { margin: 0; color: var(--seo-muted); line-height: 1.55; }
  .generated-card { display: grid; gap: 7px; align-content: center; }
  .generated-card span, .generated-card small { color: var(--seo-muted); }
  .generated-card strong { overflow-wrap: anywhere; }
  .range-toolbar { display: flex; gap: 8px; overflow-x: auto; padding: 18px 0 14px; }
  .range-button, .button { min-height: 42px; border: 1px solid var(--seo-border); border-radius: 999px; padding: 9px 14px; background: var(--seo-surface); color: var(--seo-text); font-weight: 800; cursor: pointer; }
  .range-button { flex: 0 0 auto; }
  .range-button.active { border-color: var(--seo-accent); background: var(--seo-accent); color: #071309; }
  .metric-grid { display: grid; grid-template-columns: repeat(8, minmax(0, 1fr)); gap: 10px; }
  .metric { min-width: 0; padding: 15px; }
  .metric span { display: block; color: var(--seo-muted); font-size: .78rem; }
  .metric strong { display: block; margin-top: 6px; font-size: clamp(1.2rem, 2vw, 1.65rem); }
  .traffic-win { margin-top: 22px; padding: clamp(20px, 4vw, 34px); border-color: color-mix(in srgb, var(--seo-accent) 45%, var(--seo-border)); background: linear-gradient(135deg, var(--seo-surface), var(--seo-accent-soft)); }
  .section-heading { display: flex; justify-content: space-between; gap: 16px; align-items: start; }
  .section-heading h2 { margin: 5px 0 14px; font-size: clamp(1.35rem, 3vw, 2rem); }
  .score-pill { flex: 0 0 auto; padding: 8px 12px; border-radius: 999px; background: var(--seo-accent); color: #071309; font-weight: 900; }
  .traffic-win h3 { margin: 4px 0 6px; font-size: 1.25rem; }
  .traffic-win p { max-width: 920px; color: var(--seo-muted); line-height: 1.6; }
  .target { color: var(--seo-accent-strong) !important; font-weight: 780; overflow-wrap: anywhere; }
  .advisor-section { margin-top: 34px; }
  .task-list, .opportunity-list { display: grid; gap: 12px; }
  .task-card { position: relative; display: grid; grid-template-columns: 44px 1fr; gap: 15px; padding: 20px; }
  .task-rank { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 13px; background: var(--seo-accent-soft); color: var(--seo-accent-strong); font-size: 1.2rem; font-weight: 900; }
  .task-card h3, .opportunity h3 { margin: 8px 0 4px; }
  .task-card p, .opportunity p { margin: 6px 0; color: var(--seo-muted); line-height: 1.55; }
  .task-meta, .opportunity-meta, .task-actions { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin-top: 12px; }
  .task-steps { margin: 12px 0 0; padding-left: 20px; color: var(--seo-muted); line-height: 1.55; }
  .button { background: var(--seo-accent); color: #071309; border-color: var(--seo-accent); }
  .button.secondary { background: var(--seo-surface); color: var(--seo-text); border-color: var(--seo-border); }
  .task-status { min-height: 42px; border: 1px solid var(--seo-border); border-radius: 10px; padding: 8px 10px; background: var(--seo-surface); color: var(--seo-text); }
  .filter-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 14px; }
  .filter-grid label { display: grid; gap: 5px; color: var(--seo-muted); font-size: .78rem; font-weight: 800; }
  .filter-grid select { min-width: 0; min-height: 43px; border: 1px solid var(--seo-border); border-radius: 11px; padding: 8px 10px; background: var(--seo-surface); color: var(--seo-text); }
  .opportunity { padding: 18px; }
  .analysis-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 34px; }
  .analysis-card { padding: 20px; min-width: 0; }
  .intelligence-row { margin-top: 34px; }
  .intelligence-cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
  .mini-card { padding: 16px; }
  .mini-card h3 { margin: 10px 0 5px; font-size: 1rem; }
  .mini-card p { margin: 5px 0; color: var(--seo-muted); line-height: 1.5; }
  .product-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-bottom: 16px; }
  .summary-tile { display: grid; gap: 6px; padding: 18px; }
  .summary-tile strong { font-size: 2rem; color: var(--seo-accent-strong); }
  .summary-tile span { color: var(--seo-muted); line-height: 1.4; }
  .product-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
  .health-card { margin-top: 16px; padding: 20px; }
  .health-card table td:first-child a { font-weight: 780; }
  .product-candidate code { overflow-wrap: anywhere; }
  .learning-section .analysis-card > p { max-width: 900px; color: var(--seo-muted); line-height: 1.6; }
  .action-message { margin-top: 22px; padding: 14px 18px; color: var(--seo-muted); }
  .action-message[data-state="success"] { background: var(--seo-accent-soft); color: var(--seo-accent-strong); }
  .action-message[data-state="error"] { background: var(--seo-danger-soft); color: var(--seo-danger); }
  .disclaimer { margin-top: -6px; padding: 9px 11px; border-radius: 10px; background: var(--seo-warning-soft); color: var(--seo-warning); font-size: .86rem; }
  .finding { padding: 13px 0; border-top: 1px solid var(--seo-border); }
  .finding:first-child { border-top: 0; }
  .finding h3 { margin: 0 0 6px; font-size: 1rem; overflow-wrap: anywhere; }
  .finding p { margin: 5px 0; color: var(--seo-muted); font-size: .9rem; line-height: 1.5; }
  .finding ul { margin: 7px 0 0; padding-left: 18px; color: var(--seo-muted); font-size: .88rem; }
  .raw-details { margin-top: 28px; padding: 18px; }
  .raw-details summary { cursor: pointer; font-weight: 850; }
  .raw-details h3 { margin-top: 24px; }
  .table-scroll { overflow-x: auto; }
  table { width: 100%; min-width: 660px; border-collapse: collapse; font-size: .86rem; }
  th, td { padding: 9px; border-bottom: 1px solid var(--seo-border); text-align: right; }
  th:first-child, td:first-child { text-align: left; max-width: 520px; overflow-wrap: anywhere; }
  .diagnostic { margin-top: 10px; padding: 10px; border-radius: 10px; background: var(--seo-surface-soft); color: var(--seo-muted); }
  .export-bar { display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-top: 16px; padding: 18px; }
  .export-bar p { margin: 4px 0 0; color: var(--seo-muted); }
  .fatal-state { padding: 24px; }
  @media (max-width: 1050px) { .metric-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 900px) { .intelligence-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 800px) { .status-grid, .analysis-grid, .product-grid { grid-template-columns: 1fr; } .status-main { grid-template-columns: 1fr; gap: 12px; } .filter-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .product-summary, .intelligence-cards { grid-template-columns: 1fr; } }
  @media (max-width: 520px) { .metric-grid { grid-template-columns: repeat(2, 1fr); } .filter-grid { grid-template-columns: 1fr; } .task-card { grid-template-columns: 36px 1fr; padding: 15px; } .task-rank { width: 34px; height: 34px; } .export-bar { align-items: stretch; flex-direction: column; } .button { width: 100%; } }
</style>

<script>
  const dataElement = document.getElementById("advisor-data");
  const advisorData = dataElement ? JSON.parse(dataElement.textContent || "{}") : { results: {} };
  const number = new Intl.NumberFormat("de-DE");
  const taskStoreKey = "pfotentechnik-seo-advisor-tasks-v1";
  let activeRange = localStorage.getItem("pfotentechnik-seo-advisor-range") || advisorData.defaultRange || Object.keys(advisorData.results)[0];

  const element = (tag, className, text) => {
    const node = document.createElement(tag);
    if (className) node.className = className;
    if (text !== undefined) node.textContent = String(text);
    return node;
  };

  const getTasks = () => {
    try { return JSON.parse(localStorage.getItem(taskStoreKey) || "{}"); }
    catch { return {}; }
  };

  const taskStatus = (id) => getTasks()[id]?.status || "offen";
  const statusLabel = (status) => ({ offen: "Offen", geplant: "Geplant", "in-arbeit": "In Arbeit", erledigt: "Erledigt", verworfen: "Verworfen" }[status] || status);

  const persistTask = (task, status, note = "") => {
    const tasks = getTasks();
    const now = new Date().toISOString();
    const previous = tasks[task.id];
    const history = Array.isArray(previous?.history) ? [...previous.history] : [];
    if (!previous || previous.status !== status) history.push({ at: now, from: previous?.status || null, to: status });
    tasks[task.id] = {
      id: task.id, title: task.title, type: task.category, url: task.url || "", query: task.query || "",
      score: task.score, createdAt: previous?.createdAt || now, updatedAt: now, status, note: note || previous?.note || "",
      dataBasis: task.dataBasis, prompt: task.prompt, codexPrompt: task.codexPrompt || "", history,
    };
    localStorage.setItem(taskStoreKey, JSON.stringify(tasks));
  };

  const copyText = async (text, button) => {
    try {
      await navigator.clipboard.writeText(text);
      const original = button.textContent;
      button.textContent = "Kopiert";
      setTimeout(() => { button.textContent = original; }, 1400);
    } catch {
      const area = element("textarea"); area.value = text; area.style.position = "fixed"; area.style.opacity = "0";
      document.body.append(area); area.select(); document.execCommand("copy"); area.remove();
    }
  };

  const adminServiceUrl = "http://127.0.0.1:4178";
  const actionMessage = document.getElementById("copilot-action-message");
  const setActionMessage = (text, level = "info") => {
    if (!actionMessage) return;
    actionMessage.textContent = text;
    actionMessage.dataset.state = level;
  };
  const adminApi = async (path, options = {}) => {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), options.timeout || 5000);
    try {
      const response = await fetch(`${adminServiceUrl}${path}`, { ...options, signal: controller.signal, headers: { "content-type": "application/json", ...(options.headers || {}) } });
      const body = await response.json().catch(() => ({}));
      if (!response.ok) throw body.error || { message: `HTTP ${response.status}` };
      return body;
    } finally { clearTimeout(timer); }
  };
  const runAdminAction = async (action, payload, button) => {
    const original = button?.textContent;
    if (button) { button.disabled = true; button.textContent = "Läuft …"; }
    try {
      const queued = await adminApi("/api/admin/search/actions", { method: "POST", body: JSON.stringify({ action, payload }) });
      for (let attempt = 0; attempt < 360; attempt += 1) {
        const current = await adminApi(`/api/admin/search/actions/${encodeURIComponent(queued.id)}`);
        setActionMessage(current.progress?.message || `${action}: ${current.status}`);
        if (current.status === "succeeded") { setActionMessage(`${action} erfolgreich abgeschlossen.`, "success"); return current; }
        if (current.status === "failed") throw current.error || { message: "Aktion fehlgeschlagen." };
        await new Promise((resolve) => setTimeout(resolve, 500));
      }
      throw { message: "Zeitlimit der Statusabfrage überschritten." };
    } catch (error) {
      setActionMessage(`${error?.message || "Lokaler Admin-Service nicht erreichbar."}${error?.nextAction ? ` ${error.nextAction}` : ""}`, "error");
      return null;
    } finally {
      if (button) { button.disabled = false; button.textContent = original; }
    }
  };

  const renderLearning = async () => {
    const container = document.getElementById("learning-list");
    if (!container) return;
    try {
      const status = await adminApi("/api/admin/search/status", { timeout: 1800 });
      const completions = status?.copilot?.completions || [];
      const result = advisorData.results[activeRange];
      container.replaceChildren(...completions.slice().reverse().map((completion) => {
        const card = element("article", "seo-card mini-card");
        const reviewReady = Date.parse(completion.reviewAfter) <= Date.now();
        const current = result?.range?.pages?.find((row) => row.normalizedPath === completion.url);
        let assessment = `Nachmessung ab ${new Date(completion.reviewAfter).toLocaleDateString("de-DE")}.`;
        let adjusted = completion.baselineConfidence || 0;
        if (reviewReady && current) {
          const clickDelta = current.clicks - completion.baseline.clicks;
          const positionImproved = current.position > 0 && current.position < completion.baseline.position;
          const associatedImprovement = clickDelta > 0 || positionImproved;
          adjusted = Math.max(0.25, Math.min(0.95, adjusted + (associatedImprovement ? 0.05 : -0.03)));
          assessment = `${associatedImprovement ? "Positive" : "Keine positive"} zeitliche Assoziation: Klicks ${clickDelta >= 0 ? "+" : ""}${clickDelta}, Position ${completion.baseline.position.toFixed(1)} → ${current.position.toFixed(1)}.`;
        }
        card.append(badge(reviewReady ? "Nachmessung fällig" : "Wartefenster", reviewReady ? "medium" : "low"), element("h3", "", completion.title || completion.id), element("p", "target", completion.url || completion.query || ""), element("p", "", assessment), element("p", "", `Angepasste Confidence ${Math.round(adjusted * 100)} % · Keine Kausalitätsaussage.`));
        return card;
      }));
      if (!completions.length) container.append(element("div", "seo-empty", "Noch keine Aufgabe über die sichere Admin-Action abgeschlossen."));
    } catch {
      container.replaceChildren(element("div", "seo-empty", "Lokaler Admin-Service nicht verbunden. Starte npm run seo:admin."));
    }
  };

  const badge = (text, level) => {
    const node = element("span", "seo-badge", text);
    if (level) node.dataset.level = level;
    return node;
  };

  const makeTaskCard = (task, rank) => {
    const card = element("article", "seo-card task-card");
    card.append(element("div", "task-rank", rank));
    const content = element("div");
    const labels = element("div", "task-meta");
    labels.append(badge(task.category), badge(`Priorität ${task.priority}`, task.priority), badge(`Score ${task.score}/100`));
    if (task.lowData) labels.append(badge("Geringe Datenbasis", "medium"));
    content.append(labels, element("h3", "", task.title), element("p", "target", task.url || task.query || "Keine eindeutige Zielseite"));
    content.append(element("p", "", task.rationale));
    const meta = element("div", "task-meta");
    meta.append(badge(`Nutzen ${task.expectedBenefit}`), badge(`Aufwand ${task.effort}`), badge(`Confidence ${Math.round(task.confidence * 100)} %`), badge(task.pageType));
    content.append(meta);
    const steps = element("ol", "task-steps"); task.steps.forEach((step) => steps.append(element("li", "", step))); content.append(steps);
    const actions = element("div", "task-actions");
    const prompt = element("button", "button secondary", "ChatGPT-Prompt kopieren"); prompt.type = "button"; prompt.addEventListener("click", () => copyText(task.prompt, prompt)); actions.append(prompt);
    if (task.codexPrompt) { const codex = element("button", "button secondary", "Codex-Prompt kopieren"); codex.type = "button"; codex.addEventListener("click", () => copyText(task.codexPrompt, codex)); actions.append(codex); }
    [["optimization", "Optimierung"], ["faq", "FAQ"], ["internal-links", "Interne Links"], ["meta", "Meta"], ["schema", "Schema prüfen"]].forEach(([kind, label]) => {
      const action = element("button", "button secondary", label); action.type = "button";
      action.addEventListener("click", async () => {
        const completed = await runAdminAction("copilot.prompt", { kind, task }, action);
        if (completed?.result?.prompt) await copyText(completed.result.prompt, action);
      });
      actions.append(action);
    });
    const complete = element("button", "button", "Task abschließen"); complete.type = "button";
    complete.addEventListener("click", async () => {
      persistTask(task, "erledigt");
      await runAdminAction("copilot.task.complete", { task }, complete);
      renderTopTasks(advisorData.results[activeRange]); renderOpportunities();
    });
    actions.append(complete);
    const select = element("select", "task-status"); select.setAttribute("aria-label", `Status für ${task.title}`);
    ["offen", "geplant", "in-arbeit", "erledigt", "verworfen"].forEach((status) => { const option = element("option", "", statusLabel(status)); option.value = status; select.append(option); });
    select.value = taskStatus(task.id); select.addEventListener("change", () => { persistTask(task, select.value); renderOpportunities(); }); actions.append(select);
    content.append(actions); card.append(content); return card;
  };

  const renderMetrics = (range) => {
    const values = [["Klicks", number.format(range.metrics.current.clicks)], ["Impressionen", number.format(range.metrics.current.impressions)], ["CTR", `${range.metrics.current.ctr.toFixed(2)} %`], ["Position", range.metrics.current.position.toFixed(1)], ["Seiten", range.pages.length], ["Queries", range.queries.length], ["Trendtage", range.trend.length], ["Empfehlungen", range.recommendations.length]];
    const grid = document.getElementById("metric-grid"); if (!grid) return; grid.replaceChildren(...values.map(([label, value]) => { const card = element("article", "seo-card metric"); card.append(element("span", "", label), element("strong", "", value)); return card; }));
  };

  const renderTrafficWin = (result) => {
    const container = document.getElementById("traffic-win-content"); const score = document.getElementById("traffic-win-score"); if (!container || !score) return;
    container.replaceChildren(); const task = result.trafficWin; score.textContent = `${task?.score || 0}/100`;
    if (!task) { container.append(element("div", "seo-empty", "Keine belastbare Empfehlung für diesen Zeitraum.")); return; }
    container.append(element("h3", "", task.title), element("p", "target", task.url || task.query || ""), element("p", "", task.rationale));
    const action = element("p"); action.append(element("strong", "", "Empfohlene Änderung: "), document.createTextNode(task.nextAction)); container.append(action);
    const effect = element("p"); effect.append(element("strong", "", "Erwarteter Effekt: "), document.createTextNode(task.expectedBenefit)); container.append(effect);
  };

  const renderTopTasks = (result) => {
    const container = document.getElementById("top-tasks"); if (!container) return;
    container.replaceChildren(...result.topTasks.map((task, index) => makeTaskCard(task, index + 1)));
    if (!result.topTasks.length) container.append(element("div", "seo-empty", "Keine Aufgabe überschreitet die konservativen Datenschwellen."));
  };

  function renderOpportunities() {
    const result = advisorData.results[activeRange]; const container = document.getElementById("opportunities"); if (!result || !container) return;
    const filters = { category: document.getElementById("filter-category")?.value || "all", priority: document.getElementById("filter-priority")?.value || "all", pageType: document.getElementById("filter-page-type")?.value || "all", status: document.getElementById("filter-status")?.value || "all" };
    const filtered = result.opportunities.filter((item) => (filters.category === "all" || item.category === filters.category) && (filters.priority === "all" || item.priority === filters.priority) && (filters.pageType === "all" || item.pageType === filters.pageType) && (filters.status === "all" || taskStatus(item.id) === filters.status));
    container.replaceChildren(...filtered.slice(0, 30).map((item) => {
      const card = element("article", "seo-card opportunity");
      const labels = element("div", "opportunity-meta"); labels.append(badge(item.category), badge(`Priorität ${item.priority}`, item.priority), badge(`${item.score}/100`), badge(statusLabel(taskStatus(item.id))));
      card.append(labels, element("h3", "", item.title), element("p", "target", item.url || item.query || ""), element("p", "", item.rationale));
      const action = element("p"); action.append(element("strong", "", "Nächste Aktion: "), document.createTextNode(item.nextAction)); card.append(action);
      const buttons = element("div", "task-actions"); const prompt = element("button", "button secondary", "Prompt kopieren"); prompt.type = "button"; prompt.addEventListener("click", () => copyText(item.prompt, prompt)); buttons.append(prompt);
      if (item.codexPrompt) { const codex = element("button", "button secondary", "Codex-Prompt kopieren"); codex.type = "button"; codex.addEventListener("click", () => copyText(item.codexPrompt, codex)); buttons.append(codex); }
      card.append(buttons); return card;
    }));
    if (!filtered.length) container.append(element("div", "seo-empty", "Keine Chance entspricht den gewählten Filtern."));
  }

  const renderFindingList = (id, findings, renderer) => {
    const container = document.getElementById(id); if (!container) return; container.replaceChildren(...findings.map(renderer));
    if (!findings.length) container.append(element("div", "seo-empty", "Keine belastbare Auffälligkeit in den vorhandenen Daten."));
  };

  const renderAnalyses = (result) => {
    renderFindingList("eeat-list", result.eeat, (item) => { const node = element("div", "finding"); const head = element("div", "task-meta"); head.append(badge(`${item.score}/100`), badge(`Priorität ${item.priority}`, item.priority)); node.append(head, element("h3", "", item.route), element("p", "", item.recommendation), element("p", "", item.filePath)); if (item.missingSignals.length) { const list = element("ul"); item.missingSignals.slice(0, 4).forEach((signal) => list.append(element("li", "", signal))); node.append(list); } return node; });
    renderFindingList("gap-list", result.contentGaps, (item) => { const node = element("div", "finding"); const head = element("div", "task-meta"); head.append(badge(item.kind), badge(`${item.impressions} Impr.`), item.lowData ? badge("Geringe Datenbasis", "medium") : badge(item.matchStrength)); node.append(head, element("h3", "", item.query), element("p", "target", item.matchedRoute || "Keine passende Zielseite erkannt"), element("p", "", item.rationale), element("p", "", item.recommendation)); return node; });
    renderFindingList("cannibal-list", result.cannibalization, (item) => { const node = element("div", "finding"); const head = element("div", "task-meta"); head.append(badge(item.kind), badge(`Risiko ${item.risk}`, item.risk === "hoch" ? "high" : item.risk === "mittel" ? "medium" : "low")); node.append(head, element("h3", "", item.routes.join(" ↔ ")), element("p", "", item.evidence), element("p", "", item.recommendation)); return node; });
    renderFindingList("link-list", result.linkRecommendations, (item) => { const node = element("div", "finding"); const head = element("div", "task-meta"); head.append(badge(`Priorität ${item.priority}`, item.priority)); node.append(head, element("h3", "", `${item.sourceRoute} → ${item.targetRoute}`), element("p", "", `Anker: ${item.anchorText}`), element("p", "", item.context), element("p", "", item.rationale)); return node; });
    renderFindingList("graph-gap-list", result.graphGaps, (item) => { const node = element("div", "finding"); node.append(badge(item.kind, item.priority), element("h3", "", item.route || item.cluster || "Cluster"), element("p", "", item.evidence), element("p", "", item.recommendation)); return node; });
    renderFindingList("conversion-list", result.conversionInsights, (item) => { const node = element("div", "finding"); node.append(badge(`${item.impressions} Impr.`), badge(`Confidence ${Math.round(item.confidence * 100)} %`), element("h3", "", item.route), element("p", "", item.evidence), element("p", "", item.recommendation)); return node; });
  };

  const renderIntelligence = (result) => {
    renderFindingList("quick-win-list", result.quickWins, (item) => {
      const node = element("div", "finding"); node.append(badge(`${item.score}/100`, item.priority), badge(`${item.estimatedMinutes} Min.`), element("h3", "", item.title), element("p", "target", item.url || item.query || ""), element("p", "", item.nextAction)); return node;
    });
    renderFindingList("forecast-list", result.topTasks, (item) => {
      const node = element("div", "finding"); const forecast = item.forecast;
      node.append(element("h3", "", item.url || item.query || item.title), element("p", "", `CTR-Potenzial +${forecast.ctrPotential.toFixed(2)} PP · Positionsszenario ${forecast.positionPotential || "–"} · Klickpotenzial +${forecast.clickPotential} · Trafficpotenzial +${forecast.trafficPotential.toFixed(2)} %`), element("p", "", `Confidence ${Math.round(forecast.confidence * 100)} % · ${forecast.dataBasis}`));
      const list = element("ul"); forecast.assumptions.forEach((assumption) => list.append(element("li", "", assumption))); node.append(list); return node;
    });
    const calendar = document.getElementById("calendar-list");
    if (calendar) {
      calendar.replaceChildren(...result.editorialCalendar.map((item) => {
        const card = element("article", "seo-card mini-card"); card.append(badge(item.due, item.priority), element("h3", "", item.title), element("p", "target", item.route), element("p", "", item.reason)); return card;
      }));
      if (!result.editorialCalendar.length) calendar.append(element("div", "seo-empty", "Keine fällige redaktionelle Prüfung erkannt."));
    }
  };

  const appendRows = (tbodyId, rows, firstKey) => {
    const body = document.getElementById(tbodyId); if (!body) return; body.replaceChildren(...rows.slice(0, 50).map((row) => { const tr = element("tr"); [row[firstKey], row.clicks, row.impressions, `${Number(row.ctr).toFixed(2)} %`, Number(row.position).toFixed(1)].forEach((value) => tr.append(element("td", "", value))); return tr; }));
  };

  const renderRaw = (result) => {
    appendRows("raw-pages", result.range.pages, "normalizedPath"); appendRows("raw-queries", result.range.queries, "query"); appendRows("raw-trend", result.range.trend, "date");
    const recs = document.getElementById("raw-recommendations"); if (recs) { recs.replaceChildren(...result.range.recommendations.map((item) => { const node = element("div", "finding"); node.append(element("h3", "", `${item.title}: ${item.page || item.query || "ohne Ziel"}`), element("p", "", item.reason), element("p", "", item.action)); return node; })); if (!result.range.recommendations.length) recs.append(element("div", "seo-empty", "Keine GSC-Regel-Empfehlung in diesem Zeitraum.")); }
    const diagnostics = document.getElementById("diagnostics"); if (diagnostics) { diagnostics.replaceChildren(...advisorData.diagnostics.map((item) => element("div", "diagnostic", `${item.level.toUpperCase()} · ${item.code}: ${item.message}`))); if (!advisorData.diagnostics.length) diagnostics.append(element("div", "diagnostic", "Loader-Diagnose: keine Fehler oder Fallbacks.")); }
  };

  const render = (rangeKey) => {
    const result = advisorData.results[rangeKey]; if (!result) return; activeRange = rangeKey; localStorage.setItem("pfotentechnik-seo-advisor-range", rangeKey);
    document.querySelectorAll("[data-range]").forEach((button) => { const active = button.dataset.range === rangeKey; button.classList.toggle("active", active); button.setAttribute("aria-pressed", String(active)); });
    document.getElementById("active-period").textContent = result.range.label;
    document.getElementById("active-dates").textContent = `${result.range.startDate || "Start unbekannt"} bis ${result.range.endDate || "Ende unbekannt"}`;
    document.getElementById("data-notice").textContent = result.dataNotice;
    renderMetrics(result.range); renderTrafficWin(result); renderTopTasks(result); renderOpportunities(); renderAnalyses(result); renderIntelligence(result); renderRaw(result); renderLearning();
  };

  document.querySelectorAll("[data-range]").forEach((button) => button.addEventListener("click", () => render(button.dataset.range)));
  ["filter-category", "filter-priority", "filter-page-type", "filter-status"].forEach((id) => document.getElementById(id)?.addEventListener("change", renderOpportunities));
  document.getElementById("export-tasks")?.addEventListener("click", () => { const blob = new Blob([JSON.stringify(Object.values(getTasks()), null, 2)], { type: "application/json" }); const url = URL.createObjectURL(blob); const anchor = element("a"); anchor.href = url; anchor.download = `pfotentechnik-seo-aufgaben-${new Date().toISOString().slice(0, 10)}.json`; anchor.click(); URL.revokeObjectURL(url); });
  document.querySelectorAll("[data-copy-product-prompt]").forEach((button) => button.addEventListener("click", () => {
    const product = advisorData.productIntelligence?.discoveries?.find((item) => item.slug === button.dataset.copyProductPrompt);
    if (product) copyText(product.markdownPrompt, button);
  }));
  document.querySelectorAll("[data-product-action]").forEach((button) => button.addEventListener("click", async () => {
    const product = advisorData.productIntelligence?.discoveries?.find((item) => item.slug === button.dataset.slug);
    const completed = await runAdminAction(button.dataset.productAction, { slug: button.dataset.slug, name: button.dataset.name, comparisonSuggestions: product?.comparisonSuggestions || [] }, button);
    if (completed?.result?.prompts) await copyText(completed.result.prompts.map((item) => `${item.role}\nZiel: ${item.target}\n${item.prompt}`).join("\n\n"), button);
  }));
  if (advisorData.results[activeRange]) render(activeRange);
</script>
