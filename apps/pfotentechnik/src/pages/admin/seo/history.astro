---
import SeoAdminLayout from "../../../layouts/SeoAdminLayout.astro";
import { loadSeoDashboard } from "../../../lib/seo/loadDashboard";
const payload = loadSeoDashboard();
---
<SeoAdminLayout title="SEO-Historie" description="Nachvollziehbare Snapshot-Basis ohne erfundene Entwicklungen. Mehrere Zeitfenster desselben Exports werden nicht als zeitliche Historie ausgegeben." active="history">
  <section class="seo-card history-notice"><span class="seo-badge" data-level="medium">Noch keine historische Vergleichsbasis</span><h2>Ein Snapshot, mehrere Zeitfenster</h2><p>Die vorhandenen 7d-, 28d-, 3m-, 6m- und 12m-Daten wurden gemeinsam am selben Zeitpunkt erzeugt. Daraus lassen sich Zeiträume vergleichen, aber keine neuen, verschwundenen oder im Score veränderten Advisor-Chancen zwischen zwei Snapshots belegen.</p></section>
  <section class="history-grid">{Object.values(payload.ranges).map((range)=><article class="seo-card snapshot"><span class="seo-badge">{range.label}</span><h2>{range.startDate} bis {range.endDate}</h2><dl><div><dt>Klicks</dt><dd>{range.metrics.current.clicks}</dd></div><div><dt>Impressionen</dt><dd>{range.metrics.current.impressions}</dd></div><div><dt>CTR</dt><dd>{range.metrics.current.ctr.toFixed(2)} %</dd></div><div><dt>Position</dt><dd>{range.metrics.current.position.toFixed(1)}</dd></div></dl></article>)}</section>
  <section class="seo-card task-history"><h2>Lokale Statusänderungen</h2><p>Diese Historie stammt ausschließlich aus den in diesem Browser gespeicherten Aufgaben.</p><div id="task-history-list"></div></section>
</SeoAdminLayout>
<style>.history-notice{padding:24px}.history-notice h2{margin:12px 0 8px}.history-notice p{max-width:900px;color:var(--seo-muted);line-height:1.6}.history-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:16px}.snapshot{padding:20px}.snapshot h2{font-size:1.05rem}.snapshot dl{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:16px 0 0}.snapshot dl div{padding:10px;border-radius:10px;background:var(--seo-surface-soft)}.snapshot dt{color:var(--seo-muted);font-size:.72rem}.snapshot dd{margin:4px 0 0;font-weight:850}.task-history{margin-top:16px;padding:20px}.task-history>p,.history-event p{color:var(--seo-muted)}.history-event{padding:12px 0;border-top:1px solid var(--seo-border)}.history-event h3{margin:0;font-size:1rem}.history-event p{margin:5px 0}@media(max-width:750px){.history-grid{grid-template-columns:1fr}}@media(max-width:450px){.snapshot dl{grid-template-columns:1fr 1fr}}</style>
<script>
  const storeKey="pfotentechnik-seo-advisor-tasks-v1";const labels={offen:"Offen",geplant:"Geplant","in-arbeit":"In Arbeit",erledigt:"Erledigt",verworfen:"Verworfen"};const container=document.getElementById("task-history-list");
  try{const tasks=Object.values(JSON.parse(localStorage.getItem(storeKey)||"{}"));const events=tasks.flatMap(task=>(Array.isArray(task.history)?task.history:[]).map(event=>({...event,title:task.title,url:task.url||task.query||""}))).sort((a,b)=>String(b.at).localeCompare(String(a.at)));events.forEach(event=>{const item=document.createElement("div");item.className="history-event";const title=document.createElement("h3");title.textContent=event.title;const meta=document.createElement("p");meta.textContent=`${new Date(event.at).toLocaleString("de-DE")} · ${event.from?labels[event.from]||event.from:"Neu"} → ${labels[event.to]||event.to}`;const route=document.createElement("p");route.textContent=event.url;item.append(title,meta,route);container?.append(item)});if(!events.length){const empty=document.createElement("div");empty.className="seo-empty";empty.textContent="Noch keine lokalen Statusänderungen gespeichert.";container?.append(empty)}}catch{const error=document.createElement("div");error.className="seo-empty";error.textContent="Lokale Aufgabenhistorie konnte nicht gelesen werden.";container?.append(error)}
</script>
