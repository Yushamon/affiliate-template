---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import FAQ from "@affiliate-core/components/FAQ.astro";
import ProductRankingCard from "@affiliate-core/components/ProductRankingCard.astro";
import { getCollection } from "astro:content";
import {
  products,
  type ProductKey
} from "../../data/products";

import {
  manufacturers,
  type Manufacturer
} from "../../data/manufacturers";

import {
  getWeightedProductScore
} from "../../data/productScoring";

export async function getStaticPaths() {
  const manufacturerEntries =
    await getCollection("manufacturers");

  const contentSlugs = new Set(
    manufacturerEntries.map(
      (entry) => entry.data.slug
    )
  );

  const contentManufacturers =
    manufacturerEntries.map((entry) => {
      const data = entry.data;

      return {
        key: data.key,
        name: data.name,
        slug: data.slug,
        description: data.description,
        website: data.website ?? "",
        focus: data.focus,
        productCategories:
          data.productCategories,
        strengths: data.strengths,
        limitations: data.weaknesses,
        rating: data.rating,
        productAreas:
          data.productAreas.map((name) => ({
            name,
            description: ""
          })),
        series:
          data.series.map((series) => ({
            name: series.name,
            suitableFor:
              series.suitableFor.join(", "),
            description:
              series.description ?? ""
          })),
        suitableFor: data.suitableFor,
        lessSuitableFor: data.attention,
        customerExperience:
          data.experience
            ? {
                summary:
                  data.experience.summary ??
                  data.summary,
                positives:
                  data.experience.positives,
                criticism:
                  data.experience.criticism,
                supportAssessment:
                  data.experience.support ?? ""
              }
            : undefined,
        alternatives:
          data.alternativeManufacturerSlugs,
        faq: data.faq,
        sources:
          data.sources
            .filter(
              (source) => Boolean(source.url)
            )
            .map((source) => ({
              label: source.label,
              url: source.url ?? ""
            })),
        products:
          data.productSlugs.filter(
            (slug): slug is ProductKey =>
              slug in products
          )
      } satisfies Manufacturer;
    });

  const legacyManufacturers =
    manufacturers.filter(
      (manufacturer) =>
        !contentSlugs.has(manufacturer.slug)
    );

  const resolvedManufacturers = [
    ...contentManufacturers,
    ...legacyManufacturers
  ];

  return resolvedManufacturers.map((manufacturer) => ({
    params: {
      manufacturer: manufacturer.slug
    },
    props: {
      manufacturer,
      manufacturerDirectory:
        resolvedManufacturers
    }
  }));
}

const {
  manufacturer,
  manufacturerDirectory
} = Astro.props as {
  manufacturer: Manufacturer;
  manufacturerDirectory: Manufacturer[];
};

const title =
  `${manufacturer.name}: Produkte, Erfahrungen und Empfehlungen`;

const description =
  `${manufacturer.name} im Markencheck: Produkte, Serien, ` +
  `Erfahrungen, Support, Stärken und passende Empfehlungen.`;

const faq =
  manufacturer.faq?.length
    ? manufacturer.faq
    : [
        {
          question:
            `Welche Produkte von ${manufacturer.name} sind im Katalog enthalten?`,
          answer:
            manufacturer.products.length > 0
              ? `Aktuell sind ${manufacturer.products.length} Produkte beziehungsweise Modellvarianten redaktionell eingeordnet.`
              : "Aktuell ist noch kein konkretes Produkt vollständig eingeordnet."
        },
        {
          question:
            `Worauf sollte man bei ${manufacturer.name} achten?`,
          answer:
            "Entscheidend sind Produktkategorie, Funktionsumfang, App-Kompatibilität, Ersatzteilversorgung und die regionale Verfügbarkeit."
        }
      ];

const comparisonLinks = [
  {
    href: "/beste-futterautomaten-fuer-katzen",
    label: "Beste Futterautomaten für Katzen"
  },
  {
    href: "/beste-futterautomaten-fuer-hunde",
    label: "Beste Futterautomaten für Hunde"
  },
  {
    href: "/beste-futterautomaten-ohne-wlan",
    label: "Futterautomaten ohne WLAN"
  },
  {
    href: "/beste-futterautomaten-fuer-zwei-katzen",
    label: "Futterautomaten für zwei Katzen"
  }
];

const alternativeManufacturers =
  (manufacturer.alternatives ?? [])
    .map((slug) =>
      manufacturerDirectory.find(
        (item) => item.slug === slug
      )
    )
    .filter(
      (item): item is Manufacturer =>
        Boolean(item)
    );

const ratingLabels = {
  innovation: "Innovation",
  quality: "Verarbeitung und Qualität",
  app: "App und Funktionen",
  support: "Support und Service",
  value: "Preis-Leistung"
};

const sortedProducts = [...manufacturer.products].sort(
  (a, b) =>
    getWeightedProductScore(b) -
    getWeightedProductScore(a)
);
type EditorialRecommendation = {
  productKey: ProductKey;
  eyebrow: string;
  title: string;
  description: string;
  icon: string;
};

const getProduct = (productKey: ProductKey) =>
  products[productKey];

const hasUseCase = (
  productKey: ProductKey,
  searchTerms: string[]
) => {
  const product = getProduct(productKey);

  const useCases = (product.useCases ?? []).map(
    (useCase) => useCase.toLowerCase()
  );

  return searchTerms.some((searchTerm) =>
    useCases.some((useCase) =>
      useCase.includes(searchTerm.toLowerCase())
    )
  );
};

const findBestProduct = (
  candidates: ProductKey[],
  exclude: ProductKey[] = []
) =>
  candidates.find(
    (productKey) => !exclude.includes(productKey)
  );

const overallProductKey =
  sortedProducts[0];

const wetFoodCandidates =
  sortedProducts.filter((productKey) =>
    hasUseCase(productKey, [
      "nassfutter",
      "wet-food",
      "wetfood"
    ])
  );

const multiPetCandidates =
  sortedProducts.filter((productKey) =>
    hasUseCase(productKey, [
      "mehrere-tiere",
      "mehrere-katzen",
      "mehrtier",
      "rfid",
      "futterneid"
    ])
  );

const valueCandidates =
  [...sortedProducts].sort((a, b) => {
    const valueA =
      getProduct(a).ranking?.value ?? 0;

    const valueB =
      getProduct(b).ranking?.value ?? 0;

    return valueB - valueA;
  });

const wetFoodProductKey =
  findBestProduct(
    wetFoodCandidates,
    overallProductKey ? [overallProductKey] : []
  );

const multiPetProductKey =
  findBestProduct(
    multiPetCandidates,
    [
      overallProductKey,
      wetFoodProductKey
    ].filter(Boolean) as ProductKey[]
  );

const valueProductKey =
  findBestProduct(
    valueCandidates,
    [
      overallProductKey,
      wetFoodProductKey,
      multiPetProductKey
    ].filter(Boolean) as ProductKey[]
  );

const editorialRecommendations =
  [
    wetFoodProductKey && {
      productKey: wetFoodProductKey,
      eyebrow: "Spezialempfehlung",
      title: "Für Nassfutter",
      description:
        "Die passendere Wahl, wenn deine Katze überwiegend Nassfutter erhält und vorbereitete Portionen zuverlässig bereitstehen sollen.",
      icon: "🥣"
    },
    multiPetProductKey && {
      productKey: multiPetProductKey,
      eyebrow: "Spezialempfehlung",
      title: "Für mehrere Katzen",
      description:
        "Besonders interessant für Mehrkatzenhaushalte, in denen getrennte Rationen oder ein kontrollierter Futterzugang wichtig sind.",
      icon: "🐈"
    },
    valueProductKey && {
      productKey: valueProductKey,
      eyebrow: "Preis-Leistungs-Tipp",
      title: "Bestes Preis-Leistungs-Verhältnis",
      description:
        "Eine ausgewogene Wahl für alle, die gute Alltagstauglichkeit und wichtige Funktionen zu einem angemessenen Preis suchen.",
      icon: "💰"
    }
  ].filter(
    (
      recommendation
    ): recommendation is EditorialRecommendation =>
      Boolean(recommendation)
  );
const heroImage =
  `/images/manufacturers/${manufacturer.slug}/hero.webp`;

const logoImage =
  `/images/manufacturers/${manufacturer.slug}/logo.webp`;

const ratingStars = (rating: number) => {
  const rounded = Math.max(
    0,
    Math.min(5, Math.round(rating))
  );

  return "★".repeat(rounded) +
    "☆".repeat(5 - rounded);
};
---

<ProjectLayout
  title={title}
  seoTitle={`${manufacturer.name}: Erfahrungen, Produkte und Empfehlungen`}
  description={description}
  seoDescription={description}
  canonical={`/hersteller/${manufacturer.slug}`}
  faq={faq}
  categoryLabel="Hersteller"
  schemaType="article"
>
  <Breadcrumbs
    categoryLabel="Hersteller"
    categoryHref="/smarte-futterautomaten"
    title={manufacturer.name}
  />

<header class="manufacturer-hero-v3">

  <div class="manufacturer-hero-grid">

    <!-- LEFT -->

    <div class="manufacturer-hero-content">

      <span class="manufacturer-eyebrow">
        Unsere Einschätzung
      </span>

      <h1 class="manufacturer-title">
        {manufacturer.name}
      </h1>

     <p class="manufacturer-subtitle">
  Hersteller für smarte Haustiertechnik
</p>

      {
        manufacturer.rating && (
          <div class="manufacturer-rating">

            <div class="manufacturer-stars">
              {ratingStars(manufacturer.rating)}
            </div>

            <div>

              <strong>
                {manufacturer.rating.toFixed(1)} / 5
              </strong>

              <p>
                Basierend auf Herstellerdaten,
                Fachtests und Käufererfahrungen.
              </p>

            </div>

          </div>
        )
      }

      <p class="manufacturer-summary">
        {manufacturer.description}
      </p>

      <a
        href="#produktempfehlungen"
        class="manufacturer-cta"
      >
        <span aria-hidden="true">
          ★
        </span>

        Unsere Empfehlungen

        <span aria-hidden="true">
          →
        </span>

      </a>

    </div>

    <!-- RIGHT -->

   <div
  class="manufacturer-hero-media"
  data-manufacturer-visual
>

    <img
  src={heroImage}
  alt={`Produkte von ${manufacturer.name}`}
  class="manufacturer-hero-image"
  loading="eager"
  decoding="async"
  data-manufacturer-hero-image
  data-logo-src={logoImage}
/>

<div
  class="manufacturer-hero-fallback"
  data-manufacturer-fallback
  hidden
>
  <span class="manufacturer-fallback-label">
    {manufacturer.name}
  </span>

  <strong>
    Smarte Haustiertechnik
  </strong>

  {manufacturer.rating && (
    <span>
      {ratingStars(manufacturer.rating)}
    </span>
  )}
</div>

      <div class="manufacturer-trust-badge">

        <span aria-hidden="true">
          ✓
        </span>

        <div>

          <strong>
            Redaktionell geprüft
          </strong>

          <small>
            Aktuelle Produktpalette
          </small>

        </div>

      </div>

<div class="manufacturer-stats">
  <div>
    <span>📦</span>

    <strong>
      {manufacturer.products.length}
    </strong>

    <small>
      Produkte
    </small>
  </div>

  <div>
    <span>🧩</span>

    <strong>
      {manufacturer.series?.length ?? 0}
    </strong>

    <small>
      Serien
    </small>
  </div>

  <div>
    <span>🗂️</span>

    <strong>
      {
        manufacturer.productAreas?.length ??
        manufacturer.productCategories.length
      }
    </strong>

    <small>
      Produktbereiche
    </small>
  </div>

  <div>
    <span>🎯</span>

    <strong>
      {manufacturer.focus.length}
    </strong>

    <small>
      Schwerpunkte
    </small>
  </div>

  <div>
    <span>🔎</span>

    <strong>
      {manufacturer.sources?.length ?? 0}
    </strong>

    <small>
      Quellen
    </small>
  </div>
</div>

    </div>

  </div>

  <div class="manufacturer-hero-bottom">

    {
     manufacturer.suitableFor?.length > 0 && (
        <section class="manufacturer-info-card">

          <header>

            <span>👥</span>

            <h2>
              Besonders geeignet für
            </h2>

          </header>

          <ul>

            {
              manufacturer.suitableFor
                .slice(0, 5)
                .map((item) => (

                  <li>

                    <span>
                      ✓
                    </span>

                    <strong>
                      {item}
                    </strong>

                  </li>

                ))
            }

          </ul>

        </section>
      )
    }

    {
      manufacturer.ratings && (
        <section class="manufacturer-info-card">

          <header>

            <span>⭐</span>

            <h2>
              Unsere Herstellerbewertung
            </h2>

          </header>

          <div class="manufacturer-rating-list">

            {
              Object.entries(manufacturer.ratings)
                .map(([key, value]) => (

                  <div class="manufacturer-rating-row">

                    <span>
                      {
                        ratingLabels[
                          key as keyof typeof ratingLabels
                        ]
                      }
                    </span>

                    <span class="manufacturer-rating-stars">
                      {ratingStars(value)}
                    </span>

                    <strong>
                      {value.toFixed(1)}
                    </strong>

                  </div>

                ))
            }

          </div>

        </section>
      )
    }

  </div>

</header>

<div
  class="manufacturer-divider"
  aria-hidden="true"
>
  <span></span>

  <strong>
    🐾
  </strong>

  <span></span>

</div>



  <article class="article manufacturer-hub">
<section
  id="produktempfehlungen"
  class="manufacturer-editors-choice"
>
  <header class="choice-header">
    <span class="choice-eyebrow">
      Redaktionelle Auswahl
    </span>

    <h2>
      Welches {manufacturer.name}-Modell passt zu dir?
    </h2>

    <p>
      Wir empfehlen nicht automatisch das teuerste Modell,
      sondern das Produkt, das am besten zum jeweiligen
      Einsatzzweck passt.
    </p>
  </header>

  {overallProductKey ? (
    <article class="editorial-featured-card">
      <div class="editorial-featured-copy">
        <span class="editorial-featured-badge">
          🏆 Beste Gesamtwahl
        </span>

        <h3>
          {getProduct(overallProductKey).name}
        </h3>

        <div class="editorial-featured-rating">
          <span aria-hidden="true">
            {ratingStars(
              getProduct(overallProductKey).rating
            )}
          </span>

          <strong>
            {
              getProduct(
                overallProductKey
              ).rating.toFixed(1)
            } / 5
          </strong>
        </div>

        <p class="editorial-featured-lead">
          Wenn du nur eine Empfehlung mitnehmen möchtest,
          ist dieses Modell innerhalb des aktuellen Sortiments
          unsere erste Wahl.
        </p>

        <p>
          {
            getProduct(overallProductKey)
              .recommendation
          }
        </p>

        {
          getProduct(
            overallProductKey
          ).highlights?.length > 0 && (
            <ul class="editorial-featured-highlights">
              {
                getProduct(
  overallProductKey
).highlights
  .slice(0, 3)
  .map((highlight) => {
    const cleanHighlight = highlight
      .replace(/^[✓✔☑]+\s*/, "")
      .trim();

    return (
      <li>
        <span aria-hidden="true">
          ✓
        </span>

        {cleanHighlight}
      </li>
    );
  })
              }
            </ul>
          )
        }

        <a
          class="editorial-product-link editorial-product-link-primary"
          href={
            getProduct(
              overallProductKey
            ).productUrl
          }
        >
          Zum vollständigen Test
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <a
        class="editorial-featured-image-link"
        href={
          getProduct(
            overallProductKey
          ).productUrl
        }
        aria-label={`${getProduct(overallProductKey).name} ansehen`}
      >
        <img
          src={
            getProduct(
              overallProductKey
            ).images.comparison ??
            getProduct(
              overallProductKey
            ).images.thumbnail ??
            getProduct(
              overallProductKey
            ).images.hero
          }
          alt={getProduct(overallProductKey).name}
          loading="lazy"
          decoding="async"
        />
      </a>
    </article>
  ) : (
    <div class="manufacturer-empty-state">
      <strong>
        Noch keine Kaufempfehlung verfügbar
      </strong>

      <p>
        Für diesen Hersteller ist aktuell noch kein
        vollständig bewertetes Produkt vorhanden.
      </p>
    </div>
  )}

  {editorialRecommendations.length > 0 && (
    <div class="editorial-special-grid">
      {editorialRecommendations.map(
        (recommendation) => {
          const product =
            getProduct(
              recommendation.productKey
            );

          return (
            <article class="editorial-special-card">
              <div class="editorial-special-heading">
                <span
                  class="editorial-special-icon"
                  aria-hidden="true"
                >
                  {recommendation.icon}
                </span>

                <div>
                  <span class="editorial-special-eyebrow">
                    {recommendation.eyebrow}
                  </span>

                  <h3>
                    {recommendation.title}
                  </h3>
                </div>
              </div>

              <p class="editorial-special-description">
                {recommendation.description}
              </p>

              <a
                class="editorial-special-product"
                href={product.productUrl}
              >
                <div class="editorial-special-image">
                  <img
                    src={
                      product.images.thumbnail ??
                      product.images.comparison ??
                      product.images.hero
                    }
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                </div>

                <div class="editorial-special-content">
                  <strong>
                    {product.name}
                  </strong>

                  <span class="editorial-special-stars">
                    {ratingStars(product.rating)}
                  </span>

                  <small>
                    {product.verdict}
                  </small>
                </div>
              </a>

              <a
                class="editorial-product-link"
                href={product.productUrl}
              >
                Ausführliche Bewertung lesen
                <span aria-hidden="true">→</span>
              </a>
            </article>
          );
        }
      )}
    </div>
  )}
</section>

<div
  class="manufacturer-divider"
  aria-hidden="true"
>

  <span></span>

  <strong>

    🐾

  </strong>

  <span></span>

</div>

<section>

  <header class="choice-header">

    <span class="choice-eyebrow">

      Vollständige Übersicht

    </span>

    <h2>

      Alle Produkte von {manufacturer.name}

    </h2>

    <p>

      Hier findest du alle aktuell
      eingeordneten Modelle dieses Herstellers.

    </p>

  </header>

  <div class="product-ranking-list">

    {
      sortedProducts.map(
        (productKey, index) => (

          <ProductRankingCard
            productKey={productKey}
            rank={index + 1}
            score={
              getWeightedProductScore(
                productKey
              )
            }
          />

        )
      )
    }

  </div>

</section>

    {manufacturer.series?.length > 0 && (
      <section>
        <h2>
          Produktserien im Überblick
        </h2>

        <div class="manufacturer-series-grid">
          {manufacturer.series.map((series) => (
            <article class="manufacturer-series-card">
              <span class="manufacturer-series-label">
                Produktserie
              </span>

              <h3>
                {series.name}
              </h3>

              <p class="manufacturer-series-suitable">
                {series.suitableFor}
              </p>

              <p>
                {series.description}
              </p>
            </article>
          ))}
        </div>
      </section>
    )}

    {manufacturer.customerExperience && (
      <section>
        <h2>
          Erfahrungen aus der Praxis
        </h2>

        <p class="manufacturer-section-intro">
          {
            manufacturer.customerExperience
              .summary
          }
        </p>

        <div class="manufacturer-experience-grid">
          <div class="manufacturer-experience-card positive">
            <span aria-hidden="true">👍</span>

            <h3>
              Häufig positiv genannt
            </h3>

            <ul>
              {
                manufacturer.customerExperience
                  .positives.map((item) => (
                    <li>{item}</li>
                  ))
              }
            </ul>
          </div>

          <div class="manufacturer-experience-card neutral">
            <span aria-hidden="true">⚠</span>

            <h3>
              Wiederkehrende Kritik
            </h3>

            <ul>
              {
                manufacturer.customerExperience
                  .criticism.map((item) => (
                    <li>{item}</li>
                  ))
              }
            </ul>
          </div>

          <div class="manufacturer-experience-card support">
            <span aria-hidden="true">☏</span>

            <h3>
              Support und Service
            </h3>

            <p>
              {
                manufacturer.customerExperience
                  .supportAssessment
              }
            </p>
          </div>
        </div>
      </section>
    )}

    {(
      manufacturer.suitableFor?.length ||
      manufacturer.lessSuitableFor?.length
    ) && (
      <section>
        <h2>
          Passt {manufacturer.name} zu mir?
        </h2>

        <div class="pros-cons-v3">
          {manufacturer.suitableFor?.length > 0 && (
            <div class="pros-box-v3">
              <h3>
                Besonders geeignet
              </h3>

              <ul>
                {manufacturer.suitableFor.map(
                  (item) => (
                    <li>{item}</li>
                  )
                )}
              </ul>
            </div>
          )}

          {manufacturer.lessSuitableFor?.length > 0 && (
            <div class="cons-box-v3">
              <h3>
                Darauf solltest du achten
              </h3>

              <ul>
                {manufacturer.lessSuitableFor.map(
                  (item) => (
                    <li>{item}</li>
                  )
                )}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    <section>
      <h2>
        Stärken und Schwächen
      </h2>

      <div class="pros-cons-v3">
        <div class="pros-box-v3">
          <h3>
            Stärken
          </h3>

          <ul>
            {manufacturer.strengths.map(
              (item) => (
                <li>{item}</li>
              )
            )}
          </ul>
        </div>

        <div class="cons-box-v3">
          <h3>
            Zu beachten
          </h3>

          <ul>
            {manufacturer.limitations.map(
              (item) => (
                <li>{item}</li>
              )
            )}
          </ul>
        </div>
      </div>
    </section>

    {manufacturer.productAreas?.length ? (
      <section>
        <h2>
          Produktbereiche
        </h2>

        <div class="manufacturer-area-grid">
          {manufacturer.productAreas.map((area) => (
            <article class="manufacturer-area-card">
              <h3>
                {area.name}
              </h3>

              <p>
                {area.description}
              </p>
            </article>
          ))}
        </div>
      </section>
    ) : (
      manufacturer.productCategories.length > 0 && (
        <section>
          <h2>
            Produktbereiche
          </h2>

          <ul>
