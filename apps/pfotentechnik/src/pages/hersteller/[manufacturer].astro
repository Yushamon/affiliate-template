---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import FAQ from "@affiliate-core/components/FAQ.astro";
import ProductRankingCard from "@affiliate-core/components/ProductRankingCard.astro";

import {
  manufacturers,
  type Manufacturer
} from "../../data/manufacturers";

import {
  getWeightedProductScore
} from "../../data/productScoring";

export function getStaticPaths() {
  return manufacturers.map((manufacturer) => ({
    params: {
      manufacturer: manufacturer.slug
    },
    props: {
      manufacturer
    }
  }));
}

const { manufacturer } = Astro.props as {
  manufacturer: Manufacturer;
};

const title =
  `${manufacturer.name}: Produkte, Erfahrungen und Empfehlungen`;

const description =
  `${manufacturer.name} im Markencheck: Produkte, Serien, ` +
  `Erfahrungen, Support, Stärken und passende Empfehlungen.`;

const faq =
  manufacturer.faq?.length
    ? manufacturer.faq
    : [
        {
          question:
            `Welche Produkte von ${manufacturer.name} sind im Katalog enthalten?`,
          answer:
            manufacturer.products.length > 0
              ? `Aktuell sind ${manufacturer.products.length} Produkte beziehungsweise Modellvarianten redaktionell eingeordnet.`
              : "Aktuell ist noch kein konkretes Produkt vollständig eingeordnet."
        },
        {
          question:
            `Worauf sollte man bei ${manufacturer.name} achten?`,
          answer:
            "Entscheidend sind Produktkategorie, Funktionsumfang, App-Kompatibilität, Ersatzteilversorgung und die Verfügbarkeit in Deutschland."
        }
      ];

const comparisonLinks = [
  {
    href: "/beste-futterautomaten-fuer-katzen",
    label: "Beste Futterautomaten für Katzen"
  },
  {
    href: "/beste-futterautomaten-fuer-hunde",
    label: "Beste Futterautomaten für Hunde"
  },
  {
    href: "/beste-futterautomaten-ohne-wlan",
    label: "Futterautomaten ohne WLAN"
  },
  {
    href: "/beste-futterautomaten-fuer-zwei-katzen",
    label: "Futterautomaten für zwei Katzen"
  }
];

const alternativeManufacturers =
  (manufacturer.alternatives ?? [])
    .map((slug) =>
      manufacturers.find(
        (item) => item.slug === slug
      )
    )
    .filter(
      (item): item is Manufacturer =>
        Boolean(item)
    );

const ratingLabels = {
  innovation: "Innovation",
  quality: "Verarbeitung und Qualität",
  app: "App und Funktionen",
  support: "Support und Service",
  value: "Preis-Leistung"
};

const sortedProducts = [...manufacturer.products].sort(
  (a, b) =>
    getWeightedProductScore(b) -
    getWeightedProductScore(a)
);

const heroImage =
  `/images/manufacturers/${manufacturer.slug}/hero.webp`;

const logoImage =
  `/images/manufacturers/${manufacturer.slug}/logo.webp`;

const primarySuitableFor =
  manufacturer.suitableFor?.slice(0, 5) ?? [];

const productCount =
  manufacturer.products.length;

const seriesCount =
  manufacturer.series?.length ?? 0;

const ratingStars = (rating: number) => {
  const rounded = Math.max(
    0,
    Math.min(5, Math.round(rating))
  );

  return "★".repeat(rounded) +
    "☆".repeat(5 - rounded);
};
---

<ProjectLayout
  title={title}
  seoTitle={`${manufacturer.name}: Erfahrungen, Produkte und Empfehlungen`}
  description={description}
  seoDescription={description}
  canonical={`/hersteller/${manufacturer.slug}`}
  faq={faq}
  categoryLabel="Hersteller"
  schemaType="article"
>
  <Breadcrumbs
    categoryLabel="Hersteller"
    categoryHref="/smarte-futterautomaten"
    title={manufacturer.name}
  />

  <header class="manufacturer-hero">
    <div class="manufacturer-hero-main">
      <div class="manufacturer-hero-content">
        <span class="manufacturer-hero-eyebrow">
          Unsere Einschätzung
        </span>

        <h1>
          {manufacturer.name}
        </h1>

        <p class="manufacturer-hero-subtitle">
          Hersteller für smarte Haustiertechnik
        </p>

        {manufacturer.rating && (
          <div class="manufacturer-hero-rating">
            <span
              class="manufacturer-hero-stars"
              aria-hidden="true"
            >
              {ratingStars(manufacturer.rating)}
            </span>

            <strong>
              {manufacturer.rating.toFixed(1)} / 5
            </strong>
          </div>
        )}

        <p class="manufacturer-hero-rating-note">
          Redaktionelle Einschätzung auf Basis von
          Herstellerdaten, Fachtests und wiederkehrenden
          Mustern aus Käufererfahrungen.
        </p>

        <p class="manufacturer-hero-summary">
          {manufacturer.description}
        </p>

        {sortedProducts.length > 0 && (
          <a
            class="manufacturer-hero-cta"
            href="#produktempfehlungen"
          >
            <span aria-hidden="true">★</span>
            Unsere Empfehlungen
            <span aria-hidden="true">→</span>
          </a>
        )}
      </div>

      <div
        class="manufacturer-hero-visual"
        data-manufacturer-visual
      >
        <img
          class="manufacturer-hero-image"
          src={heroImage}
          alt={`Produkte von ${manufacturer.name}`}
          loading="eager"
          decoding="async"
          data-manufacturer-hero-image
          data-logo-src={logoImage}
        />

        <div
          class="manufacturer-hero-fallback"
          data-manufacturer-fallback
          hidden
        >
          <span class="manufacturer-fallback-label">
            {manufacturer.name}
          </span>

          <strong>
            Smarte Haustiertechnik
          </strong>

          {manufacturer.rating && (
            <span>
              {ratingStars(manufacturer.rating)}
            </span>
          )}
        </div>

        <div class="manufacturer-hero-trust">
          <div>
            <span aria-hidden="true">⌖</span>
            <strong>Deutschland</strong>
            <small>verfügbar</small>
          </div>

          <div>
            <span aria-hidden="true">▯</span>
            <strong>Eigene App</strong>
            <small>modellabhängig</small>
          </div>

          <div>
            <span aria-hidden="true">◇</span>
            <strong>{productCount}</strong>
            <small>Produkte</small>
          </div>

          <div>
            <span aria-hidden="true">▱</span>
            <strong>{seriesCount}</strong>
            <small>Produktserien</small>
          </div>

          <div>
            <span aria-hidden="true">◉</span>
            <strong>Support</strong>
            <small>Deutschland</small>
          </div>
        </div>
      </div>
    </div>

    <div class="manufacturer-hero-details">
      {primarySuitableFor.length > 0 && (
        <section class="manufacturer-hero-card">
          <div class="manufacturer-card-heading">
            <span
              class="manufacturer-card-icon"
              aria-hidden="true"
            >
              ♟
            </span>

            <h2>
              Besonders geeignet für
            </h2>
          </div>

          <ul class="manufacturer-suitable-list">
            {primarySuitableFor.map((item) => (
              <li>
                <span aria-hidden="true">✓</span>
                <strong>{item}</strong>
              </li>
            ))}
          </ul>
        </section>
      )}

      {manufacturer.ratings && (
        <section class="manufacturer-hero-card">
          <div class="manufacturer-card-heading">
            <span
              class="manufacturer-card-icon"
              aria-hidden="true"
            >
              ★
            </span>

            <h2>
              Unsere Herstellerbewertung
            </h2>
          </div>

          <div class="manufacturer-rating-list">
            {Object.entries(
              manufacturer.ratings
            ).map(([key, value]) => (
              <div class="manufacturer-rating-row">
                <span>
                  {
                    ratingLabels[
                      key as keyof typeof ratingLabels
                    ]
                  }
                </span>

                <span
                  class="manufacturer-rating-stars"
                  aria-label={`${value.toFixed(1)} von 5`}
                >
                  {ratingStars(value)}
                </span>

                <strong>
                  {value.toFixed(1)}
                </strong>
              </div>
            ))}
          </div>

          <div class="manufacturer-rating-method">
            <span aria-hidden="true">✓</span>

            <p>
              Bewertet anhand von Herstellerangaben,
              Fachtests und wiederkehrenden
              Kundenerfahrungen.
            </p>
          </div>
        </section>
      )}
    </div>
  </header>

  <div
    class="manufacturer-section-divider"
    aria-hidden="true"
  >
    <span></span>
    <strong>🐾</strong>
    <span></span>
  </div>

  <article class="article manufacturer-hub">
    <section id="produktempfehlungen">
      <h2>
        Unsere Produktempfehlungen
      </h2>

      {sortedProducts.length > 0 ? (
        <div class="product-ranking-list">
          {sortedProducts.map(
            (productKey, index) => (
              <ProductRankingCard
                productKey={productKey}
                rank={index + 1}
                score={
                  getWeightedProductScore(
                    productKey
                  )
                }
              />
            )
          )}
        </div>
      ) : (
        <p>
          Für diesen Hersteller ist derzeit noch
          kein Produkt vollständig bewertet.
        </p>
      )}
    </section>

    {manufacturer.series?.length > 0 && (
      <section>
        <h2>
          Produktserien im Überblick
        </h2>

        <div class="manufacturer-series-grid">
          {manufacturer.series.map((series) => (
            <article class="manufacturer-series-card">
              <span class="manufacturer-series-label">
                Produktserie
              </span>

              <h3>
                {series.name}
              </h3>

              <p class="manufacturer-series-suitable">
                {series.suitableFor}
              </p>

              <p>
                {series.description}
              </p>
            </article>
          ))}
        </div>
      </section>
    )}

    {manufacturer.customerExperience && (
      <section>
        <h2>
          Erfahrungen aus der Praxis
        </h2>

        <p class="manufacturer-section-intro">
          {
            manufacturer.customerExperience
              .summary
          }
        </p>

        <div class="manufacturer-experience-grid">
          <div class="manufacturer-experience-card positive">
            <span aria-hidden="true">👍</span>

            <h3>
              Häufig positiv genannt
            </h3>

            <ul>
              {
                manufacturer.customerExperience
                  .positives.map((item) => (
                    <li>{item}</li>
                  ))
              }
            </ul>
          </div>

          <div class="manufacturer-experience-card neutral">
            <span aria-hidden="true">⚠</span>

            <h3>
              Wiederkehrende Kritik
            </h3>

            <ul>
              {
                manufacturer.customerExperience
                  .criticism.map((item) => (
                    <li>{item}</li>
                  ))
              }
            </ul>
          </div>

          <div class="manufacturer-experience-card support">
            <span aria-hidden="true">☏</span>

            <h3>
              Support und Service
            </h3>

            <p>
              {
                manufacturer.customerExperience
                  .supportAssessment
              }
            </p>
          </div>
        </div>
      </section>
    )}

    {(
      manufacturer.suitableFor?.length ||
      manufacturer.lessSuitableFor?.length
    ) && (
      <section>
        <h2>
          Passt {manufacturer.name} zu mir?
        </h2>

        <div class="pros-cons-v3">
          {manufacturer.suitableFor?.length > 0 && (
            <div class="pros-box-v3">
              <h3>
                Besonders geeignet
              </h3>

              <ul>
                {manufacturer.suitableFor.map(
                  (item) => (
                    <li>{item}</li>
                  )
                )}
              </ul>
            </div>
          )}

          {manufacturer.lessSuitableFor?.length > 0 && (
            <div class="cons-box-v3">
              <h3>
                Darauf solltest du achten
              </h3>

              <ul>
                {manufacturer.lessSuitableFor.map(
                  (item) => (
                    <li>{item}</li>
                  )
                )}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    <section>
      <h2>
        Stärken und Schwächen
      </h2>

      <div class="pros-cons-v3">
        <div class="pros-box-v3">
          <h3>
            Stärken
          </h3>

          <ul>
            {manufacturer.strengths.map(
              (item) => (
                <li>{item}</li>
              )
            )}
          </ul>
        </div>

        <div class="cons-box-v3">
          <h3>
            Zu beachten
          </h3>

          <ul>
            {manufacturer.limitations.map(
              (item) => (
                <li>{item}</li>
              )
            )}
          </ul>
        </div>
      </div>
    </section>

    {manufacturer.productAreas?.length ? (
      <section>
        <h2>
          Produktbereiche
        </h2>

        <div class="manufacturer-area-grid">
          {manufacturer.productAreas.map((area) => (
            <article class="manufacturer-area-card">
              <h3>
                {area.name}
              </h3>

              <p>
                {area.description}
              </p>
            </article>
          ))}
        </div>
      </section>
    ) : (
      manufacturer.productCategories.length > 0 && (
        <section>
          <h2>
            Produktbereiche
          </h2>

          <ul>
            {manufacturer.productCategories.map(
              (category) => (
                <li>{category}</li>
              )
            )}
          </ul>
        </section>
      )
    )}

    <section>
      <h2>
        Über {manufacturer.name}
      </h2>

      <p>
        {manufacturer.description}
      </p>

      {manufacturer.focus.length > 0 && (
        <>
          <h3>
            Schwerpunkte
          </h3>

          <ul>
            {manufacturer.focus.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </>
      )}

      {manufacturer.country && (
        <p>
          <strong>Markenbezug:</strong>{" "}
          {manufacturer.country}
        </p>
      )}

      <p>
        <a
          href={manufacturer.website}
          rel="noopener noreferrer"
          target="_blank"
        >
          Offizielle Herstellerseite
        </a>
      </p>
    </section>

    {alternativeManufacturers.length > 0 && (
      <section>
        <h2>
          Alternativen zu {manufacturer.name}
        </h2>

        <div class="manufacturer-alternative-grid">
          {alternativeManufacturers.map(
            (alternative) => (
              <a
                class="manufacturer-alternative-card"
                href={`/hersteller/${alternative.slug}`}
              >
                <strong>
                  {alternative.name}
                </strong>

                <span>
                  Herstellerprofil ansehen
                </span>
              </a>
            )
          )}
        </div>
      </section>
    )}

    <section>
      <h2>
        Vergleiche und Orientierung
      </h2>

      <ul>
        {comparisonLinks.map((link) => (
          <li>
            <a href={link.href}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="manufacturer-trust-section">
      <h2>
        So entsteht unsere Bewertung
      </h2>

      <div class="manufacturer-trust-grid">
        <div>
          <strong>Geprüfte Daten</strong>
          <span>
            Herstellerseiten und Handbücher
          </span>
        </div>

        <div>
          <strong>Erfahrungen</strong>
          <span>
            Wiederkehrende Nutzermuster
          </span>
        </div>

        <div>
          <strong>Unabhängige Einordnung</strong>
          <span>
            Transparent und redaktionell
          </span>
        </div>

        <div>
          <strong>Regelmäßige Aktualisierung</strong>
          <span>
            Produkte und Hersteller im Blick
          </span>
        </div>
      </div>
    </section>

    {manufacturer.sources?.length > 0 && (
      <details class="manufacturer-sources">
        <summary>
          Quellen und Datengrundlage anzeigen
        </summary>

        <p>
          Die Einschätzung basiert auf
          Herstellerinformationen,
          Supportangaben, Fachtests und
          wiederkehrenden Mustern aus
          öffentlichen Nutzerbewertungen.
        </p>

        <ul>
          {manufacturer.sources.map(
            (source) => (
              <li>
                <a
                  href={source.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  {source.label}
                </a>
              </li>
            )
          )}
        </ul>
      </details>
    )}

    <FAQ items={faq} />
  </article>
</ProjectLayout>

<script>
  const initializeManufacturerVisuals = () => {
    document
      .querySelectorAll<HTMLElement>(
        "[data-manufacturer-visual]"
      )
      .forEach((visual) => {
        if (
          visual.dataset.initialized === "true"
        ) {
          return;
        }

        const image =
          visual.querySelector<HTMLImageElement>(
            "[data-manufacturer-hero-image]"
          );

        const fallback =
          visual.querySelector<HTMLElement>(
            "[data-manufacturer-fallback]"
          );

        if (!image || !fallback) {
          return;
        }

        let logoAttempted = false;

        image.addEventListener("error", () => {
          const logoSrc =
            image.dataset.logoSrc;

          if (!logoAttempted && logoSrc) {
            logoAttempted = true;
            image.src = logoSrc;
            image.classList.add(
              "manufacturer-hero-logo"
            );
            return;
          }

          image.hidden = true;
          fallback.hidden = false;
        });

        visual.dataset.initialized = "true";
      });
  };

  initializeManufacturerVisuals();

  document.addEventListener(
    "astro:page-load",
    initializeManufacturerVisuals
  );
</script>

<style>
  .manufacturer-hero {
    margin: 1.5rem 0 2rem;
  }

  .manufacturer-hero-main {
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
    border: 1px solid
      var(--border-color, #dbe3e2);
    border-radius: 1.5rem;
    background:
      linear-gradient(
        135deg,
        #ffffff 0%,
        #f7faf8 62%,
        #f4efe8 100%
      );
    box-shadow:
      0 20px 50px rgba(15, 40, 35, 0.08);
  }

  .manufacturer-hero-content {
    padding: 1.5rem;
  }

  .manufacturer-hero-eyebrow {
    display: block;
    margin-bottom: 0.5rem;
    color:
      var(--manufacturer-accent, #18743b);
    font-weight: 800;
  }

  .manufacturer-hero h1 {
    margin: 0;
    font-size:
      clamp(3rem, 12vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .manufacturer-hero-subtitle {
    max-width: 22ch;
    margin: 1rem 0 0.75rem;
    color:
      var(--text-color, #102f2b);
    font-size:
      clamp(1.45rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.2;
  }

  .manufacturer-hero-rating {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
    margin: 1rem 0 0.25rem;
  }

  .manufacturer-hero-stars,
  .manufacturer-rating-stars {
    color:
      var(--manufacturer-accent, #18743b);
    letter-spacing: 0.1em;
  }

  .manufacturer-hero-rating-note {
    margin: 0 0 1rem;
    color:
      var(--text-muted, #657679);
    font-size: 0.88rem;
  }

  .manufacturer-hero-summary {
    max-width: 58ch;
    color:
      var(--text-muted, #5e7073);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .manufacturer-hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-height: 3.25rem;
    margin-top: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: 0.75rem;
    background:
      var(--manufacturer-accent, #18743b);
    color: #fff;
    font-weight: 800;
    text-decoration: none;
    box-shadow:
      0 10px 25px rgba(24, 116, 59, 0.2);
  }

  .manufacturer-hero-visual {
    position: relative;
    min-height: 22rem;
    background:
      linear-gradient(
        145deg,
        #f6f2ec,
        #ffffff
      );
  }

  .manufacturer-hero-image {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 22rem;
    object-fit: cover;
  }

  .manufacturer-hero-image.manufacturer-hero-logo {
    padding: 4rem;
    object-fit: contain;
  }

  .manufacturer-hero-fallback {
    display: grid;
    place-content: center;
    gap: 0.75rem;
    min-height: 22rem;
    padding: 2rem;
    text-align: center;
    background:
      radial-gradient(
        circle at top,
        rgba(24, 116, 59, 0.14),
        transparent 58%
      );
  }

  .manufacturer-hero-fallback[hidden] {
    display: none;
  }

  .manufacturer-fallback-label {
    color:
      var(--manufacturer-accent, #18743b);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .manufacturer-hero-fallback strong {
    font-size: 1.8rem;
  }

  .manufacturer-hero-fallback span:last-child {
    color:
      var(--manufacturer-accent, #18743b);
    font-size: 1.3rem;
  }

  .manufacturer-hero-trust {
    display: grid;
    grid-template-columns:
      repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(16px);
  }

  .manufacturer-hero-trust div {
    display: grid;
    justify-items: center;
    gap: 0.1rem;
    padding: 0.55rem;
    text-align: center;
  }

  .manufacturer-hero-trust div > span {
    color:
      var(--manufacturer-accent, #18743b);
    font-size: 1.2rem;
  }

  .manufacturer-hero-trust strong {
    font-size: 0.9rem;
  }

  .manufacturer-hero-trust small {
    color:
      var(--text-muted, #657679);
    font-size: 0.72rem;
  }

  .manufacturer-hero-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }

  .manufacturer-hero-card {
    padding: 1.25rem;
    border: 1px solid
      var(--border-color, #dbe3e2);
    border-radius: 1.25rem;
    background: #fff;
    box-shadow:
      0 12px 30px rgba(15, 40, 35, 0.06);
  }

  .manufacturer-card-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .manufacturer-card-heading h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .manufacturer-card-icon {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.65rem;
    background:
