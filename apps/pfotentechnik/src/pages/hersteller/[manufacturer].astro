---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import FAQ from "@affiliate-core/components/FAQ.astro";
import ProductRankingCard from "@affiliate-core/components/ProductRankingCard.astro";

import {
  manufacturers,
  type Manufacturer
} from "../../data/manufacturers";

import {
  getWeightedProductScore
} from "../../data/productScoring";

export function getStaticPaths() {
  return manufacturers.map((manufacturer) => ({
    params: {
      manufacturer: manufacturer.slug
    },
    props: {
      manufacturer
    }
  }));
}

const { manufacturer } = Astro.props as {
  manufacturer: Manufacturer;
};

const title =
  `${manufacturer.name}: Produkte, Erfahrungen und Empfehlungen`;

const description =
  `${manufacturer.name} im Markencheck: Produkte, Serien, ` +
  `Erfahrungen, Support, Stärken und passende Empfehlungen.`;

const faq =
  manufacturer.faq?.length
    ? manufacturer.faq
    : [
        {
          question:
            `Welche Produkte von ${manufacturer.name} sind im Katalog enthalten?`,
          answer:
            manufacturer.products.length > 0
              ? `Aktuell sind ${manufacturer.products.length} Produkte beziehungsweise Modellvarianten redaktionell eingeordnet.`
              : "Aktuell ist noch kein konkretes Produkt vollständig eingeordnet."
        },
        {
          question:
            `Worauf sollte man bei ${manufacturer.name} achten?`,
          answer:
            "Entscheidend sind Produktkategorie, Funktionsumfang, App-Kompatibilität, Ersatzteilversorgung und die Verfügbarkeit in Deutschland."
        }
      ];

const comparisonLinks = [
  {
    href: "/beste-futterautomaten-fuer-katzen",
    label: "Beste Futterautomaten für Katzen"
  },
  {
    href: "/beste-futterautomaten-fuer-hunde",
    label: "Beste Futterautomaten für Hunde"
  },
  {
    href: "/beste-futterautomaten-ohne-wlan",
    label: "Futterautomaten ohne WLAN"
  },
  {
    href: "/beste-futterautomaten-fuer-zwei-katzen",
    label: "Futterautomaten für zwei Katzen"
  }
];

const alternativeManufacturers =
  (manufacturer.alternatives ?? [])
    .map((slug) =>
      manufacturers.find(
        (item) => item.slug === slug
      )
    )
    .filter(
      (item): item is Manufacturer =>
        Boolean(item)
    );

const ratingLabels = {
  innovation: "Innovation",
  quality: "Verarbeitung und Qualität",
  app: "App und Funktionen",
  support: "Support und Service",
  value: "Preis-Leistung"
};

const sortedProducts = [...manufacturer.products].sort(
  (a, b) =>
    getWeightedProductScore(b) -
    getWeightedProductScore(a)
);
const recommendationLabels = [
  {
    badge: "Top-Empfehlung",
    icon: "🏆",
    title: "Unsere erste Wahl",
    description:
      "Das aktuell am stärksten bewertete Modell dieses Herstellers."
  },
  {
    badge: "Starke Alternative",
    icon: "⭐",
    title: "Sehr gute Alternative",
    description:
      "Eine überzeugende Alternative mit einem ausgewogenen Gesamtpaket."
  },
  {
    badge: "Empfehlenswert",
    icon: "✓",
    title: "Ebenfalls empfehlenswert",
    description:
      "Ein interessantes Modell für Nutzer mit abweichenden Anforderungen."
  },
  {
    badge: "Weitere Wahl",
    icon: "◇",
    title: "Weitere starke Wahl",
    description:
      "Eine zusätzliche Option innerhalb des aktuellen Produktsortiments."
  }
];

const featuredProducts = sortedProducts
  .slice(0, 4)
  .map((productKey, index) => ({
    productKey,
    ...recommendationLabels[index]
  }));
const heroImage =
  `/images/manufacturers/${manufacturer.slug}/hero.webp`;

const logoImage =
  `/images/manufacturers/${manufacturer.slug}/logo.webp`;

const primarySuitableFor =
  manufacturer.suitableFor?.slice(0, 5) ?? [];

const productCount =
  manufacturer.products.length;

const seriesCount =
  manufacturer.series?.length ?? 0;

const ratingStars = (rating: number) => {
  const rounded = Math.max(
    0,
    Math.min(5, Math.round(rating))
  );

  return "★".repeat(rounded) +
    "☆".repeat(5 - rounded);
};
---

<ProjectLayout
  title={title}
  seoTitle={`${manufacturer.name}: Erfahrungen, Produkte und Empfehlungen`}
  description={description}
  seoDescription={description}
  canonical={`/hersteller/${manufacturer.slug}`}
  faq={faq}
  categoryLabel="Hersteller"
  schemaType="article"
>
  <Breadcrumbs
    categoryLabel="Hersteller"
    categoryHref="/smarte-futterautomaten"
    title={manufacturer.name}
  />

<header class="manufacturer-hero-v3">

  <div class="manufacturer-hero-grid">

    <!-- LEFT -->

    <div class="manufacturer-hero-content">

      <span class="manufacturer-eyebrow">
        Unsere Einschätzung
      </span>

      <h1 class="manufacturer-title">
        {manufacturer.name}
      </h1>

      <p class="manufacturer-subtitle">
        Premium-Hersteller für smarte Haustiertechnik
      </p>

      {
        manufacturer.rating && (
          <div class="manufacturer-rating">

            <div class="manufacturer-stars">
              {ratingStars(manufacturer.rating)}
            </div>

            <div>

              <strong>
                {manufacturer.rating.toFixed(1)} / 5
              </strong>

              <p>
                Basierend auf Herstellerdaten,
                Fachtests und Käufererfahrungen.
              </p>

            </div>

          </div>
        )
      }

      <p class="manufacturer-summary">
        {manufacturer.description}
      </p>

      <a
        href="#produktempfehlungen"
        class="manufacturer-cta"
      >
        <span aria-hidden="true">
          ★
        </span>

        Unsere Empfehlungen

        <span aria-hidden="true">
          →
        </span>

      </a>

    </div>

    <!-- RIGHT -->

    <div class="manufacturer-hero-media">

      <img
        src={`/images/manufacturers/${manufacturer.slug}/hero.webp`}
        alt={manufacturer.name}
        class="manufacturer-hero-image"
        loading="eager"
        decoding="async"
      />

      <div class="manufacturer-trust-badge">

        <span aria-hidden="true">
          ✓
        </span>

        <div>

          <strong>
            Redaktionell geprüft
          </strong>

          <small>
            Aktuelle Produktpalette
          </small>

        </div>

      </div>

      <div class="manufacturer-stats">

        <div>

          <span>📍</span>

          <strong>
            Deutschland
          </strong>

          <small>
            verfügbar
          </small>

        </div>

        <div>

          <span>📱</span>

          <strong>
            Eigene App
          </strong>

          <small>
            modellabhängig
          </small>

        </div>

        <div>

          <span>📦</span>

          <strong>
            {manufacturer.products.length}
          </strong>

          <small>
            Produkte
          </small>

        </div>

        <div>

          <span>🧩</span>

          <strong>
            {manufacturer.series?.length ?? 0}
          </strong>

          <small>
            Serien
          </small>

        </div>

        <div>

          <span>🛠️</span>

          <strong>
            Support
          </strong>

          <small>
            Deutschland
          </small>

        </div>

      </div>

    </div>

  </div>

  <div class="manufacturer-hero-bottom">

    {
      manufacturer.suitableFor && (
        <section class="manufacturer-info-card">

          <header>

            <span>👥</span>

            <h2>
              Besonders geeignet für
            </h2>

          </header>

          <ul>

            {
              manufacturer.suitableFor
                .slice(0, 5)
                .map((item) => (

                  <li>

                    <span>
                      ✓
                    </span>

                    <strong>
                      {item}
                    </strong>

                  </li>

                ))
            }

          </ul>

        </section>
      )
    }

    {
      manufacturer.ratings && (
        <section class="manufacturer-info-card">

          <header>

            <span>⭐</span>

            <h2>
              Unsere Herstellerbewertung
            </h2>

          </header>

          <div class="manufacturer-rating-list">

            {
              Object.entries(manufacturer.ratings)
                .map(([key, value]) => (

                  <div class="manufacturer-rating-row">

                    <span>
                      {
                        ratingLabels[
                          key as keyof typeof ratingLabels
                        ]
                      }
                    </span>

                    <span class="manufacturer-rating-stars">
                      {ratingStars(value)}
                    </span>

                    <strong>
                      {value.toFixed(1)}
                    </strong>

                  </div>

                ))
            }

          </div>

        </section>
      )
    }

  </div>

</header>

<div
  class="manufacturer-divider"
  aria-hidden="true"
>
  <span></span>

  <strong>
    🐾
  </strong>

  <span></span>

</div>



  <article class="article manufacturer-hub">
   <section
  id="produktempfehlungen"
  class="manufacturer-recommendations"
>
  <div class="manufacturer-recommendations-header">
    <span class="manufacturer-recommendations-eyebrow">
      Redaktionelle Auswahl
    </span>

    <h2>
      Unsere Kaufempfehlungen
    </h2>

    <p>
      Nicht jedes Modell eignet sich für jeden Haushalt.
      Diese Produkte schneiden innerhalb des aktuellen
      Sortiments besonders gut ab und bieten je nach
      Anforderungen unterschiedliche Vorteile.
    </p>
  </div>

  {featuredProducts.length > 0 ? (
    <div class="manufacturer-choice-grid">
      {featuredProducts.map(
        (recommendation, index) => (
          <article
            class:list={[
              "manufacturer-choice-card",
              {
                "manufacturer-choice-card-featured":
                  index === 0
              }
            ]}
          >
            <div class="manufacturer-choice-heading">
              <span
                class="manufacturer-choice-icon"
                aria-hidden="true"
              >
                {recommendation.icon}
              </span>

              <div>
                <span class="manufacturer-choice-badge">
                  {recommendation.badge}
                </span>

                <h3>
                  {recommendation.title}
                </h3>
              </div>
            </div>

            <p class="manufacturer-choice-description">
              {recommendation.description}
            </p>

            <ProductRankingCard
              productKey={recommendation.productKey}
              rank={index + 1}
              score={
                getWeightedProductScore(
                  recommendation.productKey
                )
              }
            />
          </article>
        )
      )}
    </div>
  ) : (
    <div class="manufacturer-empty-state">
      <strong>
        Noch keine Kaufempfehlung verfügbar
      </strong>

      <p>
        Für diesen Hersteller ist derzeit noch kein
        Produkt vollständig bewertet.
      </p>
    </div>
  )}

  {sortedProducts.length > featuredProducts.length && (
    <>
      <div
        class="manufacturer-products-divider"
        aria-hidden="true"
      >
        <span></span>
        <strong>🐾</strong>
        <span></span>
      </div>

      <div class="manufacturer-all-products-header">
        <span>
          Vollständige Übersicht
        </span>

        <h2>
          Alle Produkte von {manufacturer.name}
        </h2>

        <p>
          Hier findest du alle aktuell eingeordneten
          Produkte und Modellvarianten dieses Herstellers.
        </p>
      </div>

      <div class="product-ranking-list">
        {sortedProducts.map(
          (productKey, index) => (
            <ProductRankingCard
              productKey={productKey}
              rank={index + 1}
              score={
                getWeightedProductScore(
                  productKey
                )
              }
            />
          )
        )}
      </div>
    </>
  )}
</section>

    {manufacturer.series?.length > 0 && (
      <section>
        <h2>
          Produktserien im Überblick
        </h2>

        <div class="manufacturer-series-grid">
          {manufacturer.series.map((series) => (
            <article class="manufacturer-series-card">
              <span class="manufacturer-series-label">
                Produktserie
              </span>

              <h3>
                {series.name}
              </h3>

              <p class="manufacturer-series-suitable">
                {series.suitableFor}
              </p>

              <p>
                {series.description}
              </p>
            </article>
          ))}
        </div>
      </section>
    )}

    {manufacturer.customerExperience && (
      <section>
        <h2>
          Erfahrungen aus der Praxis
        </h2>

        <p class="manufacturer-section-intro">
          {
            manufacturer.customerExperience
              .summary
          }
        </p>

        <div class="manufacturer-experience-grid">
          <div class="manufacturer-experience-card positive">
            <span aria-hidden="true">👍</span>

            <h3>
              Häufig positiv genannt
            </h3>

            <ul>
              {
                manufacturer.customerExperience
                  .positives.map((item) => (
                    <li>{item}</li>
                  ))
              }
            </ul>
          </div>

          <div class="manufacturer-experience-card neutral">
            <span aria-hidden="true">⚠</span>

            <h3>
              Wiederkehrende Kritik
            </h3>

            <ul>
              {
                manufacturer.customerExperience
                  .criticism.map((item) => (
                    <li>{item}</li>
                  ))
              }
            </ul>
          </div>

          <div class="manufacturer-experience-card support">
            <span aria-hidden="true">☏</span>

            <h3>
              Support und Service
            </h3>

            <p>
              {
                manufacturer.customerExperience
                  .supportAssessment
              }
            </p>
          </div>
        </div>
      </section>
    )}

    {(
      manufacturer.suitableFor?.length ||
      manufacturer.lessSuitableFor?.length
    ) && (
      <section>
        <h2>
          Passt {manufacturer.name} zu mir?
        </h2>

        <div class="pros-cons-v3">
          {manufacturer.suitableFor?.length > 0 && (
            <div class="pros-box-v3">
              <h3>
                Besonders geeignet
              </h3>

              <ul>
                {manufacturer.suitableFor.map(
                  (item) => (
                    <li>{item}</li>
                  )
                )}
              </ul>
            </div>
          )}

          {manufacturer.lessSuitableFor?.length > 0 && (
            <div class="cons-box-v3">
              <h3>
                Darauf solltest du achten
              </h3>

              <ul>
                {manufacturer.lessSuitableFor.map(
                  (item) => (
                    <li>{item}</li>
                  )
                )}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    <section>
      <h2>
        Stärken und Schwächen
      </h2>

      <div class="pros-cons-v3">
        <div class="pros-box-v3">
          <h3>
            Stärken
          </h3>

          <ul>
            {manufacturer.strengths.map(
              (item) => (
                <li>{item}</li>
              )
            )}
          </ul>
        </div>

        <div class="cons-box-v3">
          <h3>
            Zu beachten
          </h3>

          <ul>
            {manufacturer.limitations.map(
              (item) => (
                <li>{item}</li>
              )
            )}
          </ul>
        </div>
      </div>
    </section>

    {manufacturer.productAreas?.length ? (
      <section>
        <h2>
          Produktbereiche
        </h2>

        <div class="manufacturer-area-grid">
          {manufacturer.productAreas.map((area) => (
            <article class="manufacturer-area-card">
              <h3>
                {area.name}
              </h3>

              <p>
                {area.description}
              </p>
            </article>
          ))}
        </div>
      </section>
    ) : (
      manufacturer.productCategories.length > 0 && (
        <section>
          <h2>
            Produktbereiche
          </h2>

          <ul>
            {manufacturer.productCategories.map(
              (category) => (
                <li>{category}</li>
              )
            )}
          </ul>
        </section>
      )
    )}

    <section>
      <h2>
        Über {manufacturer.name}
      </h2>

      <p>
        {manufacturer.description}
      </p>

      {manufacturer.focus.length > 0 && (
        <>
          <h3>
            Schwerpunkte
          </h3>

          <ul>
            {manufacturer.focus.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </>
      )}

      {manufacturer.country && (
        <p>
          <strong>Markenbezug:</strong>{" "}
          {manufacturer.country}
        </p>
      )}

      <p>
        <a
          href={manufacturer.website}
          rel="noopener noreferrer"
          target="_blank"
        >
          Offizielle Herstellerseite
        </a>
      </p>
    </section>

    {alternativeManufacturers.length > 0 && (
      <section>
        <h2>
          Alternativen zu {manufacturer.name}
        </h2>

        <div class="manufacturer-alternative-grid">
          {alternativeManufacturers.map(
            (alternative) => (
              <a
                class="manufacturer-alternative-card"
                href={`/hersteller/${alternative.slug}`}
              >
                <strong>
                  {alternative.name}
                </strong>

                <span>
                  Herstellerprofil ansehen
                </span>
              </a>
            )
          )}
        </div>
      </section>
    )}

    <section>
      <h2>
        Vergleiche und Orientierung
      </h2>

      <ul>
        {comparisonLinks.map((link) => (
          <li>
            <a href={link.href}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="manufacturer-trust-section">
      <h2>
        So entsteht unsere Bewertung
      </h2>

      <div class="manufacturer-trust-grid">
        <div>
          <strong>Geprüfte Daten</strong>
          <span>
            Herstellerseiten und Handbücher
          </span>
        </div>

        <div>
          <strong>Erfahrungen</strong>
          <span>
            Wiederkehrende Nutzermuster
          </span>
        </div>

        <div>
          <strong>Unabhängige Einordnung</strong>
          <span>
            Transparent und redaktionell
          </span>
        </div>

        <div>
          <strong>Regelmäßige Aktualisierung</strong>
          <span>
            Produkte und Hersteller im Blick
          </span>
        </div>
      </div>
    </section>

    {manufacturer.sources?.length > 0 && (
      <details class="manufacturer-sources">
        <summary>
          Quellen und Datengrundlage anzeigen
        </summary>

        <p>
          Die Einschätzung basiert auf
          Herstellerinformationen,
          Supportangaben, Fachtests und
          wiederkehrenden Mustern aus
          öffentlichen Nutzerbewertungen.
        </p>

        <ul>
          {manufacturer.sources.map(
            (source) => (
              <li>
                <a
                  href={source.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  {source.label}
                </a>
              </li>
            )
          )}
        </ul>
      </details>
    )}

    <FAQ items={faq} />
  </article>
</ProjectLayout>

<script>
  const initializeManufacturerVisuals = () => {
    document
      .querySelectorAll<HTMLElement>(
        "[data-manufacturer-visual]"
      )
      .forEach((visual) => {
        if (
          visual.dataset.initialized === "true"
        ) {
          return;
        }

        const image =
          visual.querySelector<HTMLImageElement>(
            "[data-manufacturer-hero-image]"
          );

        const fallback =
          visual.querySelector<HTMLElement>(
            "[data-manufacturer-fallback]"
          );

        if (!image || !fallback) {
          return;
        }

        let logoAttempted = false;

        image.addEventListener("error", () => {
          const logoSrc =
            image.dataset.logoSrc;

          if (!logoAttempted && logoSrc) {
            logoAttempted = true;
            image.src = logoSrc;
            image.classList.add(
              "manufacturer-hero-logo"
            );
            return;
          }

          image.hidden = true;
          fallback.hidden = false;
        });

        visual.dataset.initialized = "true";
      });
  };

  initializeManufacturerVisuals();

  document.addEventListener(
    "astro:page-load",
    initializeManufacturerVisuals
  );
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .manufacturer-hero-v3,
  .manufacturer-hub,
  .manufacturer-divider {
    --manufacturer-accent: #18743b;
    --manufacturer-accent-dark: #0f5a2b;
    --manufacturer-accent-soft: rgba(24, 116, 59, 0.09);
    --manufacturer-text: #0d302b;
    --manufacturer-muted: #647579;
    --manufacturer-border: #dce5e3;
    --manufacturer-surface: #ffffff;
    box-sizing: border-box;
  }

  .manufacturer-hero-v3 *,
  .manufacturer-hub *,
  .manufacturer-divider * {
    box-sizing: border-box;
  }

  /* Hero Container */

  .manufacturer-hero-v3 {
    position: relative;
    left: 50%;
    width: min(1500px, calc(100vw - 32px));
    margin: 2rem 0 2.5rem;
    transform: translateX(-50%);
  }

  /* Hero Hauptbereich */

  .manufacturer-hero-grid {
    display: grid;
    grid-template-columns:
      minmax(0, 44fr)
      minmax(0, 56fr);
    min-height: 620px;
    overflow: hidden;
    border: 1px solid var(--manufacturer-border);
    border-radius: 28px;
    background:
      linear-gradient(
        135deg,
        #ffffff 0%,
        #f8faf9 55%,
        #f3ede5 100%
      );
    box-shadow:
      0 22px 55px rgba(13, 48, 43, 0.1);
  }

  /* Linke Hero Spalte */

  .manufacturer-hero-content {
    display: flex;
    min-width: 0;
    padding: clamp(36px, 4vw, 64px);
    flex-direction: column;
    justify-content: center;
  }

  .manufacturer-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 14px;
    color: var(--manufacturer-accent);
    font-size: 0.96rem;
    font-weight: 800;
  }

  .manufacturer-title {
    margin: 0;
    color: var(--manufacturer-text);
    font-size: clamp(4rem, 6.4vw, 7rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.055em;
  }

  .manufacturer-subtitle {
    max-width: 18ch;
    margin: 24px 0 0;
    color: var(--manufacturer-text);
    font-size: clamp(1.65rem, 2.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.025em;
  }

  .manufacturer-rating {
    display: flex;
    margin-top: 22px;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  .manufacturer-rating > div:last-child {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .manufacturer-rating strong {
    color: var(--manufacturer-text);
    font-size: 1.08rem;
  }

  .manufacturer-rating p {
    max-width: 48ch;
    margin: 0;
