---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";
import FeederAdvisor from "../../components/advisor/FeederAdvisor.astro";
const breadcrumbs=[{label:"Startseite",href:"/"},{label:"Futterautomaten-Berater",href:"/berater/futterautomat/"}];
---
<ProjectLayout title="Futterautomaten-Berater" seoTitle="Futterautomaten-Berater: passenden Gerätetyp finden" description="Interaktive Auswahlhilfe für Futterautomaten nach Tier, Futterart, Portionsgröße, Steuerung und gewünschter Ausstattung." canonical="/berater/futterautomat/" categoryLabel="Berater" breadcrumbs={breadcrumbs} schemaType="webpage"><Breadcrumbs items={breadcrumbs}/><main class="advisor-page"><header><span>Interaktive Auswahlhilfe</span><h1>Futterautomaten-Berater</h1><p>Der Berater empfiehlt keine Marke auf Zuruf. Er grenzt zuerst die technisch passende Geräteklasse ein – damit du anschließend nur Modelle vergleichst, die zu deinem Tier und deiner Fütterung passen.</p></header><FeederAdvisor/></main></ProjectLayout>
<style>.advisor-page{width:min(1120px,calc(100% - 32px));margin:0 auto;padding:24px 0 72px}.advisor-page>header{max-width:820px;margin:20px 0 24px}.advisor-page>header span{color:#2e7d32;font-weight:800;text-transform:uppercase;letter-spacing:.08em;font-size:.78rem}.advisor-page h1{margin:8px 0 14px;font-size:clamp(2.2rem,6vw,4.5rem);line-height:1}.advisor-page>header p{color:#475569;font-size:1.08rem;line-height:1.7}</style>
