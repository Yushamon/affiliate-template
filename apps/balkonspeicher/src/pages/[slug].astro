---
import { getCollection, render } from "astro:content";

import AffiliateLayout from "@affiliate-core/layouts/AffiliateLayout.astro";
import ArticleMeta from "@affiliate-core/components/ArticleMeta.astro";
import TableOfContents from "@affiliate-core/components/TableOfContents.astro";
import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";

import PremiumRenderer from "@affiliate-core/renderer/PremiumRenderer.astro";
import ComparisonExperience from "@affiliate-core/components/ComparisonExperience.astro";
import DecisionBox from "@affiliate-core/components/DecisionBox.astro";

import StorageCalculator from "../components/StorageCalculator.astro";
import EconomicCalculator from "../components/calculator/EconomicCalculator.astro";

import ProductBox from "@affiliate-core/components/ProductBox.astro";
import ProductComparisonTable from "@affiliate-core/components/ProductComparisonTable.astro";

import NextStepCTA from "@affiliate-core/components/NextStepCTA.astro";
import InternalLinks from "@affiliate-core/components/InternalLinks.astro";
import IntentCTA from "@affiliate-core/components/IntentCTA.astro";

import FAQ from "@affiliate-core/components/FAQ.astro";
import RelatedArticles from "@affiliate-core/components/RelatedArticles.astro";

import { siteMeta } from "../data/siteMeta";
import { recommendations } from "../data/recommendations";
import { internalLinks } from "../data/internalLinks";
import { getNextStep } from "../data/nextSteps";
import { getSeoOverride } from "../data/seoOverrides";
import { DEFAULT_PROJECT, getProjectImage } from "../data/projectImages";
import { products, type ProductKey } from "../data/products";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => ({
    params: {
      slug: page.data.slug
    },
    props: {
      page
    }
  }));
}

const { page } = Astro.props;

const { Content, headings } = await render(page);

const allPages = await getCollection("pages");

const author = page.data.author ?? siteMeta.defaultAuthor;

const publishedAt =
  page.data.publishedAt ?? siteMeta.articleDefaults.publishedAt;

const updatedAt =
  page.data.updatedAt ?? page.data.publishedAt ?? siteMeta.articleDefaults.updatedAt;

const seoOverride = getSeoOverride(page.data.slug);

const seoTitle =
  seoOverride?.seoTitle ?? page.data.seoTitle;

const seoDescription =
  seoOverride?.seoDescription ?? page.data.seoDescription;

const projectKey =
  page.data.project ?? DEFAULT_PROJECT;

const heroImage =
  page.data.heroImage ?? getProjectImage(projectKey, "hero");

const ogImage =
  page.data.ogImage ?? heroImage;

const relatedPages = allPages
  .filter((candidate) => {
    if (candidate.data.slug === page.data.slug) {
      return false;
    }

    const commonTags = candidate.data.tags.filter((tag) =>
      page.data.tags.includes(tag)
    );

    return candidate.data.category === page.data.category || commonTags.length > 0;
  })
  .sort((a, b) => {
    const aMatches = a.data.tags.filter((tag) =>
      page.data.tags.includes(tag)
    ).length;

    const bMatches = b.data.tags.filter((tag) =>
      page.data.tags.includes(tag)
    ).length;

    return bMatches - aMatches;
  })
  .slice(0, 3);

const showStorageCalculator =
  page.data.slug === "balkonspeicher-groesse-berechnen";

const showEconomicCalculator =
  page.data.slug === "balkonspeicher-wirtschaftlichkeit" ||
  page.data.slug === "balkonspeicher-amortisation";

const recommendation = page.data.intent && page.data.intent in recommendations
  ? recommendations[page.data.intent as keyof typeof recommendations]
  : null;

const topicKey =
  page.data.topic && page.data.topic in internalLinks
    ? page.data.topic
    : "allgemein";

const internalLinkSlugs = internalLinks[
  topicKey as keyof typeof internalLinks
].filter((slug) => slug !== page.data.slug);

const internalLinkPages = internalLinkSlugs
  .flatMap((slug) => {
    const page = allPages.find((candidate) => candidate.data.slug === slug);
    return page ? [page] : [];
  })
  .slice(0, 4);

const nextStep = getNextStep(page);

const showDecisionBox = [
  "vergleich",
  "produkt",
  "speicher",
  "nachruesten"
].includes(page.data.intent ?? "");

const comparisonProducts = (page.data.comparisonProducts ?? [])
  .filter((key): key is ProductKey => key in products);
---

<AffiliateLayout
  title={page.data.title}
  description={page.data.description}
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  canonical={`/${page.data.slug}`}
  ogImage={ogImage}
  faq={page.data.faq}
  author={author}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  categoryLabel={page.data.categoryLabel}
>
  <Breadcrumbs
    categoryLabel={page.data.categoryLabel}
    title={page.data.title}
  />

  <section class="article-header">
    <div class="article-category">
      {page.data.categoryLabel}
    </div>

    <h1 class="article-title">
      {page.data.title}
    </h1>

    <p class="article-description">
      {page.data.description}
    </p>

    <ArticleMeta
      author={author}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
    />
  </section>

  {
    heroImage && (
      <section class="article-hero">
        <img
          src={heroImage}
          alt={page.data.title}
          class="article-hero-image"
          loading="eager"
          decoding="async"
        />
      </section>
    )
  }

  {
    comparisonProducts.length > 0 && page.data.comparisonRecommendation && (
      <ComparisonExperience
        productKeys={comparisonProducts}
        recommendationTitle={page.data.comparisonRecommendation.title}
        recommendationText={page.data.comparisonRecommendation.text}
        tableTitle={page.data.comparisonRecommendation.tableTitle}
        cardsTitle={page.data.comparisonRecommendation.cardsTitle}
      />
    )
  }

  <article class="article">
    <TableOfContents headings={headings} />

    {
      showStorageCalculator && (
        <section id="rechner" class="calculator-section">
          <StorageCalculator />
        </section>
      )
    }

    <PremiumRenderer
      blocks={page.data.premiumBlocks as any}
      project={projectKey}
      heroImage={heroImage}
    />

    {
      showDecisionBox && comparisonProducts.length === 0 && (
        <DecisionBox />
      )
    }

    <Content />

    {
      showEconomicCalculator && (
        <section
          id="wirtschaftlichkeitsrechner"
          class="calculator-section"
        >
          <EconomicCalculator />
        </section>
      )
    }

    {
      recommendation && (
        <>
          <ProductBox
            productKey={recommendation.recommendedProduct as "ecoflow-stream-ultra" | "anker-solix-solarbank-3-pro" | "zendure-solarflow" | "solakon-one"}
          />

          <ProductComparisonTable
            productKeys={recommendation.comparisonProducts}
          />
        </>
      )
    }

    {
      nextStep && (
        <NextStepCTA
          title={nextStep.title}
          text={nextStep.text}
          href={nextStep.href}
          button={nextStep.button}
        />
      )
    }

    <InternalLinks pages={internalLinkPages} />

    {
      recommendation && (
        <IntentCTA
          title={recommendation.ctaTitle}
          text={recommendation.ctaText}
          url={recommendation.ctaUrl}
        />
      )
    }

    <FAQ items={page.data.faq} />
  </article>

  <RelatedArticles pages={relatedPages} />
</AffiliateLayout>
