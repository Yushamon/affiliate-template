---
interface CTA {
  label: string;
  href: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  primaryCta: CTA;
  secondaryCta: CTA;
  image: string;
  imageAlt: string;
}

const {
  badge,
  title,
  description,
  primaryCta,
  secondaryCta,
  image,
  imageAlt
} = Astro.props;
---

<section class="home-premium-hero">
  <div class="home-premium-copy">
    <div class="home-premium-badge">
      {badge}
    </div>

    <h1>
      {title}
    </h1>

    <p>
      {description}
    </p>
  </div>

  <div class="home-premium-image">
    <img src={image} alt={imageAlt} loading="eager" />
  </div>

  <div class="home-premium-actions">
    <a href={primaryCta.href} class="premium-button premium-button-primary">
      {primaryCta.label}
    </a>

    <a href={secondaryCta.href} class="premium-button premium-button-secondary">
      {secondaryCta.label}
    </a>
  </div>
</section>