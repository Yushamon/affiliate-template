---
import payload from "../../../data/seo/gsc-dashboard-ranges.json";
const json = JSON.stringify(payload).replace(/</g, "\\u003c");
---
<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<meta name="robots" content="noindex,nofollow" />
<title>SEO Cockpit | PfotenTechnik</title>
<style>
:root{color-scheme:light dark;font-family:Inter,system-ui,sans-serif;--bg:#f4f6f8;--card:#fff;--border:#dce5df;--text:#17211b;--muted:#66736b;--accent:#2e7d32}
*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text)}main{width:min(1280px,calc(100% - 28px));margin:auto;padding:28px 0 60px}
header{display:flex;justify-content:space-between;gap:20px;align-items:end}h1{margin:3px 0;font-size:clamp(2rem,4vw,3rem)}h2{font-size:1.15rem}
.muted{color:var(--muted)}.toolbar{display:flex;gap:8px;flex-wrap:wrap;margin:22px 0}.range{padding:10px 14px;border:1px solid var(--border);border-radius:999px;background:var(--card);color:var(--text);font-weight:700;cursor:pointer}.range.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.notice{display:none;padding:11px 14px;border-radius:12px;background:#fff3d8;color:#805300;margin-bottom:16px}.notice.show{display:block}.grid{display:grid;gap:16px}.metrics{grid-template-columns:repeat(4,1fr);margin-bottom:16px}.columns{grid-template-columns:repeat(2,1fr)}
.card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:18px}.metric strong{display:block;font-size:1.8rem;margin:6px 0}.positive{color:#2e7d32}.negative{color:#b42318}.list{display:grid;gap:10px}.item{padding:12px;border:1px solid var(--border);border-radius:13px}.item strong{display:block;overflow-wrap:anywhere}.meta{font-size:.86rem;color:var(--muted);margin-top:5px}
table{width:100%;border-collapse:collapse;font-size:.9rem}th,td{padding:9px;border-bottom:1px solid var(--border);text-align:right}th:first-child,td:first-child{text-align:left}.scroll{overflow:auto}
@media(max-width:850px){.metrics,.columns{grid-template-columns:1fr 1fr}}@media(max-width:560px){.metrics,.columns{grid-template-columns:1fr}header{display:block}}
@media(prefers-color-scheme:dark){:root{--bg:#101512;--card:#171e19;--border:#2b352e;--text:#edf4ef;--muted:#aebbb2}.notice{background:#382b14;color:#ffd88b}}
</style>
</head>
<body>
<main>
<header>
<div><div class="muted">Google Search Console</div><h1>SEO Cockpit</h1><div id="period" class="muted"></div></div>
<div class="muted">Synchronisiert: {new Date(payload.generatedAt).toLocaleString("de-DE")}</div>
</header>

<div class="toolbar">
<button class="range" data-range="24h">24 Stunden</button>
<button class="range active" data-range="7d">7 Tage</button>
<button class="range" data-range="28d">28 Tage</button>
<button class="range" data-range="3m">3 Monate</button>
<button class="range" data-range="6m">6 Monate</button>
<button class="range" data-range="12m">12 Monate</button>
</div>

<div id="notice" class="notice">Aktuelle GSC-Daten sind noch nicht vollständig verarbeitet und können sich nachträglich ändern.</div>
<section id="metrics" class="grid metrics"></section>
<section class="grid columns">
<article class="card"><h2>🚀 Quick Wins</h2><div id="quick" class="list"></div></article>
<article class="card"><h2>📉 Schwache CTR</h2><div id="ctr" class="list"></div></article>
<article class="card"><h2>🔎 Suchbegriffe</h2><div class="scroll"><table><thead><tr><th>Suchanfrage</th><th>Impr.</th><th>Klicks</th><th>Pos.</th></tr></thead><tbody id="queries"></tbody></table></div></article>
<article class="card"><h2>🤖 Empfehlungen</h2><div id="recs" class="list"></div></article>
</section>
</main>

<script type="application/json" id="seo-data" set:html={json}></script>
<script>
const payload=JSON.parse(document.getElementById("seo-data").textContent);
const number=new Intl.NumberFormat("de-DE");
const clean=(url)=>url?.replace("https://www.pfotentechnik.de","")||"/";
const card=(title,meta)=>'<div class="item"><strong>'+title+'</strong><div class="meta">'+meta+'</div></div>';
function render(key){
 const data=payload.ranges[key];
 document.querySelectorAll(".range").forEach((button)=>button.classList.toggle("active",button.dataset.range===key));
 document.getElementById("notice").classList.toggle("show",Boolean(data.partial));
 document.getElementById("period").textContent=data.label+" · Vergleich: "+data.comparisonStartDate+" bis "+data.comparisonEndDate;
 const m=data.metrics.current,c=data.metrics.change;
 const metrics=[
  ["Klicks",number.format(m.clicks),c.clicks+" %"],
  ["Impressionen",number.format(m.impressions),c.impressions+" %"],
  ["CTR",m.ctr.toFixed(2)+" %",(c.ctr>=0?"+":"")+c.ctr.toFixed(2)+" Pp."],
  ["Position",m.position.toFixed(1),(c.position>=0?"+":"")+c.position.toFixed(1)]
 ];
 document.getElementById("metrics").innerHTML=metrics.map(([label,value,delta])=>'<article class="card metric"><div class="muted">'+label+'</div><strong>'+value+'</strong><div class="'+(delta.startsWith("-")?"negative":"positive")+'">'+delta+'</div></article>').join("");
 const quick=data.pages.filter((r)=>r.position>=8&&r.position<=20&&r.impressions>=20).slice(0,20);
 document.getElementById("quick").innerHTML=quick.map((r)=>card(clean(r.page),number.format(r.impressions)+" Impressionen · Position "+r.position.toFixed(1)+" · CTR "+r.ctr.toFixed(2)+" %")).join("")||card("Keine Quick Wins","Für diesen Zeitraum wurden keine passenden Seiten gefunden.");
 const weak=data.pages.filter((r)=>r.impressions>=20&&r.ctr<2.5).slice(0,20);
 document.getElementById("ctr").innerHTML=weak.map((r)=>card(clean(r.page),number.format(r.impressions)+" Impressionen · CTR "+r.ctr.toFixed(2)+" % · Position "+r.position.toFixed(1))).join("")||card("Keine auffälligen Seiten","Für diesen Zeitraum liegt keine Seite unter dem Schwellenwert.");
 document.getElementById("queries").innerHTML=data.queries.slice(0,30).map((r)=>"<tr><td>"+r.query+"</td><td>"+number.format(r.impressions)+"</td><td>"+number.format(r.clicks)+"</td><td>"+r.position.toFixed(1)+"</td></tr>").join("");
 document.getElementById("recs").innerHTML=(data.recommendations||[]).slice(0,20).map((r)=>card(r.title+": "+clean(r.page),r.reason+" · "+r.action)).join("")||card("Keine dringende Empfehlung","Für diesen Zeitraum gibt es aktuell keinen Regel-Treffer.");
 localStorage.setItem("seo-cockpit-range",key);
}
document.querySelectorAll(".range").forEach((button)=>button.addEventListener("click",()=>render(button.dataset.range)));
const saved=localStorage.getItem("seo-cockpit-range");
render(payload.ranges[saved]?saved:(payload.defaultRange||"7d"));
</script>
</body>
</html>
