---
import OptimizedImage from "@affiliate-core/components/OptimizedImage.astro";
import type { CollectionEntry } from "astro:content";
import type { AssembledContentPage } from "../domain/contentPlatform";

interface Props {
  page: AssembledContentPage;
  products: CollectionEntry<"products">[];
  hideRecommendationBlocks?: boolean;
}

const {
  page,
  products,
  hideRecommendationBlocks = false
} = Astro.props as Props;
const productBySlug = new Map(
  products.map((product) => [product.data.slug, product])
);
const selectedProducts = page.comparisonProducts
  .map((slug) => productBySlug.get(slug))
  .filter(
    (product): product is CollectionEntry<"products"> =>
      Boolean(product)
  );
const hasBlock = (
  block: AssembledContentPage["blocks"][number]
) => page.blocks.includes(block);
---

{hasBlock("summary") && page.summary.length > 0 && (
  <section class="cp-auto-block cp-auto-summary">
    <header>
      <span>Auf einen Blick</span>
      <h2>Das Wichtigste in Kürze</h2>
    </header>
    <ul>{page.summary.map((item) => <li>{item}</li>)}</ul>
  </section>
)}

{!hideRecommendationBlocks && hasBlock("recommendation") && selectedProducts.length > 0 && (
  <section class="cp-auto-block">
    <header>
      <span>Passende Modelle</span>
      <h2>Redaktionell eingeordnete Empfehlungen</h2>
      <p>
        Die Auswahl stammt aus den hinterlegten Produktdaten.
        Es werden keine Modelle allein durch Textgenerierung ergänzt.
      </p>
    </header>
    <div class="cp-product-grid">
      {selectedProducts.slice(0, 3).map((product) => (
        <a class="cp-product-card" href={`/produkt/${product.data.slug}/`}>
          <OptimizedImage
            src={product.data.images.thumbnail?.src ?? product.data.images.hero.src}
            alt={product.data.images.thumbnail?.alt ?? product.data.images.hero.alt}
            width={480}
            height={360}
            layout="constrained"
          />
          <div>
            <small>{product.data.manufacturer.name}</small>
            <h3>{product.data.title}</h3>
            <p>{product.data.recommendation}</p>
            <strong>Produkttest lesen →</strong>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

{!hideRecommendationBlocks && hasBlock("comparison") && selectedProducts.length > 1 && (
  <section class="cp-auto-block">
    <header>
      <span>Direkter Überblick</span>
      <h2>Empfehlungen kompakt vergleichen</h2>
    </header>
    <div class="cp-table-wrap">
      <table>
        <thead>
          <tr>
            <th>Modell</th>
            <th>Bewertung</th>
            <th>Geeignet für</th>
            <th>Preisklasse</th>
          </tr>
        </thead>
        <tbody>
          {selectedProducts.map((product) => (
            <tr>
              <th><a href={`/produkt/${product.data.slug}/`}>{product.data.title}</a></th>
              <td>{product.data.rating.toFixed(1).replace(".", ",")} / 5</td>
              <td>{product.data.decision.bestFor[0] ?? product.data.useCase ?? "siehe Produkttest"}</td>
              <td>{product.data.priceCategory ?? "nicht eingeordnet"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}

{hasBlock("fit") && (page.suitableFor.length > 0 || page.notSuitableFor.length > 0) && (
  <section class="cp-auto-block">
    <header>
      <span>Einordnung</span>
      <h2>Passt diese Auswahl zu dir?</h2>
    </header>
    <div class="cp-fit-grid">
      {page.suitableFor.length > 0 && (
        <article>
          <h3>Geeignet für</h3>
          <ul>{page.suitableFor.map((item) => <li>{item}</li>)}</ul>
        </article>
      )}
      {page.notSuitableFor.length > 0 && (
        <article>
          <h3>Eher nicht geeignet für</h3>
          <ul>{page.notSuitableFor.map((item) => <li>{item}</li>)}</ul>
        </article>
      )}
    </div>
  </section>
)}

{hasBlock("checklist") && page.checklist.length > 0 && (
  <section class="cp-auto-block cp-auto-list">
    <header><span>Prüfen</span><h2>Kurze Checkliste</h2></header>
    <ol>{page.checklist.map((item) => <li>{item}</li>)}</ol>
  </section>
)}

{hasBlock("mistakes") && page.mistakes.length > 0 && (
  <section class="cp-auto-block cp-auto-list">
    <header><span>Vermeiden</span><h2>Typische Fehler</h2></header>
    <ul>{page.mistakes.map((item) => <li>{item}</li>)}</ul>
  </section>
)}

<style>
  .cp-auto-block { margin: 52px 0; }
  .cp-auto-block > header { max-width: 780px; margin-bottom: 22px; }
  .cp-auto-block > header > span {
    display: block; margin-bottom: 7px; color: #2e7d32;
    font-size: .78rem; font-weight: 800; letter-spacing: .08em;
    text-transform: uppercase;
  }
  .cp-auto-block h2 {
    margin: 0 0 10px; font-size: clamp(1.65rem, 3vw, 2.35rem);
    line-height: 1.12;
  }
  .cp-auto-block header p { margin: 0; color: #475569; line-height: 1.65; }
  .cp-auto-summary, .cp-auto-list {
    padding: clamp(22px, 4vw, 34px); border: 1px solid rgba(15,23,42,.1);
    border-radius: 24px; background: #f8fafc;
  }
  .cp-auto-block ul, .cp-auto-block ol { margin: 0; padding-left: 1.25rem; }
  .cp-auto-block li + li { margin-top: 10px; }
  .cp-product-grid, .cp-fit-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }
  .cp-product-card, .cp-fit-grid article {
    border: 1px solid rgba(15,23,42,.1); border-radius: 20px;
    background: #fff; overflow: hidden;
  }
  .cp-product-card { color: inherit; text-decoration: none; }
  .cp-product-card > div, .cp-fit-grid article { padding: 20px; }
  .cp-product-card h3, .cp-fit-grid h3 { margin: 5px 0 10px; }
  .cp-product-card p { color: #475569; line-height: 1.55; }
  .cp-product-card strong { color: #2e7d32; }
  .cp-table-wrap {
    overflow-x: auto; border: 1px solid rgba(15,23,42,.1);
    border-radius: 20px;
  }
  .cp-table-wrap table {
    width: 100%; min-width: 680px; border-collapse: collapse; background: #fff;
  }
  .cp-table-wrap th, .cp-table-wrap td {
    padding: 15px 16px; border-bottom: 1px solid rgba(15,23,42,.08);
    text-align: left; vertical-align: top;
  }
  .cp-table-wrap thead th { background: #f8fafc; font-size: .82rem; color: #475569; }
</style>
