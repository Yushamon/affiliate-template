---
import { getSeoDashboardData } from "../../lib/seo-dashboard/data";
const data=await getSeoDashboardData();
const pl={high:"Hoch",medium:"Mittel",low:"Hinweis"} as const;
const sl={ok:"OK",warning:"Warnung",error:"Fehler",pending:"Ausstehend"} as const;
---
<!doctype html><html lang="de"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><meta name="robots" content="noindex,nofollow"><title>SEO Dashboard | {data.site.name}</title><script is:inline>const t=localStorage.getItem("seo-theme");if(t==="dark"||(!t&&matchMedia("(prefers-color-scheme:dark)").matches))document.documentElement.dataset.theme="dark";</script></head>
<body><div class="shell"><aside><div class="brand"><b>PT</b><span><strong>SEO Dashboard</strong><small>{data.site.name}</small></span></div><nav><a href="#overview">Übersicht</a><a href="#recommendations">Empfehlungen</a><a href="#pages">Seiten</a><a href="#technical">Technisches SEO</a><a href="#reports">Reports</a><a href="#settings">Einstellungen</a></nav><footer>Foundation 1.0<br><a href="/" target="_blank">Website öffnen ↗</a></footer></aside>
<main><header><div><p class="eye">Arbeitscockpit</p><h1>SEO heute im Blick</h1><p>Stand: {new Date(data.generatedAt).toLocaleString("de-DE")}</p></div><div class="actions"><input id="search" type="search" placeholder="Seite suchen …"><button id="theme" aria-label="Darstellung wechseln">◐</button></div></header>
<section id="overview"><div class="heading"><div><p class="eye">Übersicht</p><h2>Die wichtigsten Signale</h2></div></div><div class="kpis">{data.kpis.map(k=><article class="card kpi"><span>{k.label}</span><strong>{k.value}</strong><small>{k.detail}</small></article>)}</div></section>
<section id="recommendations"><div class="heading"><div><p class="eye">Heute tun</p><h2>Priorisierte Empfehlungen</h2></div><small>{data.recommendations.length} Aufgaben</small></div><div class="recs">{data.recommendations.map(r=><article class="card rec searchable" data-search={`${r.title} ${r.url||""} ${r.reason}`.toLowerCase()}><div class={`priority ${r.priority}`}>{pl[r.priority]}</div><div class="content"><div class="title"><h3>{r.title}</h3>{r.url&&<a href={r.url} target="_blank">Seite öffnen ↗</a>}</div><p>{r.reason}</p><ul>{r.actions.map(a=><li>{a}</li>)}</ul>{r.potential&&<b class="potential">{r.potential}</b>}</div></article>)}</div></section>
<section id="pages"><div class="heading"><div><p class="eye">Seiten</p><h2>Leistungsübersicht</h2></div><small>{data.pages.length} Seiten</small></div><div class="card table">{data.pages.length?<div class="scroll"><table><thead><tr><th>Seite</th><th>Klicks</th><th>Impressionen</th><th>CTR</th><th>Position</th><th>Status</th></tr></thead><tbody>{data.pages.map(p=><tr class="searchable" data-search={`${p.title} ${p.url}`.toLowerCase()}><td><a href={p.url} target="_blank"><b>{p.title}</b><small>{p.url}</small></a></td><td>{p.clicks?.toLocaleString("de-DE")??"–"}</td><td>{p.impressions?.toLocaleString("de-DE")??"–"}</td><td>{p.ctr!==undefined?`${p.ctr.toFixed(1)} %`:"–"}</td><td>{p.position?.toFixed(1)??"–"}</td><td><i class={`status ${p.status}`}>{sl[p.status]}</i></td></tr>)}</tbody></table></div>:<div class="empty"><b>Noch keine Seitendaten</b><p>Nach <code>npm run gsc:audit</code> erscheinen hier echte Werte.</p></div>}</div></section>
<section id="technical"><div class="heading"><div><p class="eye">Technisches SEO</p><h2>Datenquellen und Status</h2></div></div><div class="grid">{data.connectors.map(c=><article class="card statuscard"><div><h3>{c.label}</h3><i class={`status ${c.status}`}>{sl[c.status]}</i></div><p>{c.message}</p></article>)}</div></section>
<section id="reports"><div class="heading"><div><p class="eye">Reports</p><h2>Vorhandene Auswertungen</h2></div></div><div class="card reports">{data.reports.length?data.reports.map(r=><div class="report"><span><b>{r.name}</b><small>{r.path}</small></span><em>{r.kind.toUpperCase()}</em><time>{r.updated?new Date(r.updated).toLocaleString("de-DE"):"–"}</time></div>):<div class="empty"><b>Noch keine Reports gefunden</b><p>Quelle: <code>apps/pfotentechnik/reports</code></p></div>}</div></section>
<section id="settings"><div class="heading"><div><p class="eye">Einstellungen</p><h2>Konfiguration</h2></div></div><div class="grid"><article class="card pad"><h3>Website</h3><p>{data.site.name}<br>{data.site.url}</p></article><article class="card pad"><h3>Nächster Schritt</h3><p>Dashboard 1.1 bindet Bing und IndexNow über standardisierte JSON-Reports an.</p></article></div></section>
</main></div><script is:inline>const q=document.querySelector("#search");q?.addEventListener("input",()=>{const s=q.value.trim().toLowerCase();document.querySelectorAll(".searchable").forEach(e=>e.hidden=!!s&&!(e.dataset.search||"").includes(s))});document.querySelector("#theme")?.addEventListener("click",()=>{const d=document.documentElement.dataset.theme==="dark";if(d)delete document.documentElement.dataset.theme;else document.documentElement.dataset.theme="dark";localStorage.setItem("seo-theme",d?"light":"dark")});</script></body></html>
<style is:global>
:root{color-scheme:light;--bg:#f5f7f6;--card:#fff;--soft:#eef4f1;--text:#15211b;--muted:#647169;--line:#dce5e0;--accent:#216e4e;--warn:#9a6700;--danger:#b42318;--shadow:0 8px 30px #182d230f}:root[data-theme=dark]{color-scheme:dark;--bg:#0f1512;--card:#171f1b;--soft:#202a25;--text:#eff6f2;--muted:#a0aea6;--line:#2c3932;--accent:#79d5aa;--warn:#f5c451;--danger:#ff8a80;--shadow:none}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--bg);color:var(--text);font:15px/1.5 Inter,system-ui,sans-serif}.shell{display:grid;grid-template-columns:245px 1fr;min-height:100vh}aside{position:sticky;top:0;height:100vh;background:var(--card);border-right:1px solid var(--line);padding:24px 18px;display:flex;flex-direction:column}.brand{display:flex;gap:12px;align-items:center;margin-bottom:24px}.brand>b{display:grid;place-items:center;width:40px;height:40px;border-radius:12px;background:var(--accent);color:var(--card)}.brand strong,.brand small{display:block}.brand small,header>div>p:last-child,.heading>small{color:var(--muted)}nav{display:grid;gap:5px}nav a{padding:10px 12px;border-radius:10px;text-decoration:none;color:var(--muted);font-weight:700}nav a:hover{background:var(--soft);color:var(--accent)}aside footer{margin-top:auto;padding-top:16px;border-top:1px solid var(--line);color:var(--muted);font-size:12px}aside footer a{color:var(--accent)}main{min-width:0;padding:32px clamp(18px,4vw,58px) 80px}header{display:flex;justify-content:space-between;align-items:center;gap:24px;margin-bottom:44px}h1{font-size:clamp(30px,4vw,48px);letter-spacing:-.045em;margin:0}h2{font-size:clamp(22px,2.2vw,29px);letter-spacing:-.025em;margin:0}h3,p{margin-top:0}.eye{color:var(--accent);font-size:12px;font-weight:800;letter-spacing:.11em;text-transform:uppercase;margin-bottom:5px}.actions{display:flex;gap:9px}.actions input,.actions button{border:1px solid var(--line);border-radius:12px;background:var(--card);color:var(--text);padding:11px 14px;font:inherit}.actions input{min-width:min(320px,40vw)}.actions button{width:44px}section{margin-bottom:54px}.heading{display:flex;justify-content:space-between;align-items:end;margin-bottom:18px}.card{background:var(--card);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow)}.kpis{display:grid;grid-template-columns:repeat(6,minmax(125px,1fr));gap:12px}.kpi{padding:18px}.kpi span,.kpi small{display:block;color:var(--muted)}.kpi strong{display:block;font-size:clamp(22px,2.5vw,32px);margin:7px 0}.recs{display:grid;gap:12px}.rec{display:grid;grid-template-columns:82px 1fr;overflow:hidden}.priority{padding:22px 12px;text-align:center;font-size:12px;font-weight:850;text-transform:uppercase}.priority.high{background:#fee4e2;color:var(--danger)}.priority.medium{background:#fff3c4;color:var(--warn)}.priority.low{background:var(--soft);color:var(--accent)}.content{padding:20px 22px}.title{display:flex;justify-content:space-between;gap:16px}.title a{color:var(--accent);font-size:13px;font-weight:750}.content p{color:var(--muted)}.potential{display:inline-block;margin-top:10px;color:var(--accent)}.table{overflow:hidden}.scroll{overflow:auto}table{width:100%;border-collapse:collapse;min-width:760px}th,td{padding:14px 16px;border-bottom:1px solid var(--line);text-align:left}th{background:var(--soft);color:var(--muted);font-size:12px;text-transform:uppercase}td a{text-decoration:none}td small,.report small{display:block;color:var(--muted);max-width:330px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.statuscard,.pad{padding:20px}.statuscard>div{display:flex;justify-content:space-between}.statuscard p,.pad p{color:var(--muted);margin-bottom:0}.status{display:inline-flex;padding:4px 9px;border-radius:99px;font-size:11px;font-style:normal;font-weight:800;background:var(--soft);color:var(--muted)}.status.ok{color:var(--accent)}.status.warning{color:var(--warn)}.status.error{color:var(--danger)}.report{display:grid;grid-template-columns:1fr 90px 180px;gap:20px;padding:14px 18px;border-bottom:1px solid var(--line)}.report:last-child{border:0}.report em,.report time{color:var(--muted);font-size:12px;font-style:normal}.empty{text-align:center;padding:30px;color:var(--muted)}.empty>b{color:var(--text)}code{background:var(--soft);padding:3px 7px;border-radius:6px}[hidden]{display:none!important}@media(max-width:1100px){.kpis{grid-template-columns:repeat(3,1fr)}}@media(max-width:760px){.shell{display:block}aside{position:static;height:auto;border-right:0;border-bottom:1px solid var(--line);padding:14px 16px}.brand{margin-bottom:10px}nav{display:flex;overflow:auto}nav a{white-space:nowrap}aside footer{display:none}main{padding:24px 16px 60px}header{align-items:stretch;flex-direction:column}.actions input{min-width:0;width:100%}.actions{width:100%}.actions input{flex:1}.kpis{grid-template-columns:repeat(2,1fr)}.rec{grid-template-columns:1fr}.priority{text-align:left;padding:8px 12px}.title{display:block}.grid{grid-template-columns:1fr}.report{grid-template-columns:1fr auto}.report time{grid-column:1/-1}}
</style>