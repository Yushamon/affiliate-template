---
import Badge from "./ui/Badge.astro";
import { products, type ProductKey } from "@app/data/products";
import {
  getScoreLabel,
  getWeightedProductScore
} from "@app/data/productScoring";
import { stripLeadingIcon } from "../utils/content";
import { getPrimaryAffiliateLink } from "../affiliate/affiliateEngine";
import { projectConfig } from "@app/project.config";
import { DEFAULT_PROJECT, getProjectImage } from "@app/data/projectImages";
import { getProductHeroImage } from "../utils/productImages";
import ProductImage from "./ProductImage.astro";

interface Props {
  productKey: ProductKey;
  currentProductKey?: ProductKey;
}

const { productKey, currentProductKey } = Astro.props;

const product = products[productKey];
const productHeroImage = getProductHeroImage(
  product,
  getProjectImage(DEFAULT_PROJECT, "product"),
  productKey
);

const isCurrentProduct = currentProductKey === productKey;

const primaryLink = product
  ? getPrimaryAffiliateLink(product, projectConfig.affiliate ?? {})
  : null;
const hasAffiliate = primaryLink?.merchant === "amazon";

const buttonHref = primaryLink?.url || product.productUrl;

const buttonLabel = primaryLink?.label ?? "Zum Testbericht";

const showButton = hasAffiliate || !isCurrentProduct;

const score = getWeightedProductScore(productKey);
const scoreLabel = getScoreLabel(score);

const topHighlights = product.highlights?.slice(0, 4) ?? [];

const specs =
  product.specs ??
  [
    {
      label: "Kapazität",
      value: product.capacity
    },
    {
      label: "Erweiterbar",
      value: product.expandable
    }
  ].filter((item) => item.value);

---

{
  product && (
    <section class="product-box-v2 product-box-premium">
      <div class="product-box-media">
        <div class="product-box-badge-wrap">
          <Badge label={product.badge} />
        </div>

        <ProductImage
          image={productHeroImage}
          alt={product.name}
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="product-box-content">
        <div class="product-box-eyebrow">
          {product.brand}
        </div>

        <div class="product-box-title-row">
          <div>
            <h2>
              {product.name}
            </h2>

            <p class="product-box-text">
              {product.recommendation}
            </p>
          </div>

          <div class="product-box-score">
            <strong>{score}</strong>
            <span>{scoreLabel}</span>
          </div>
        </div>

        <div class="product-box-rating">
          <span aria-hidden="true">★★★★★</span>
          <strong>{product.rating} / 5</strong>
          <small>Unsere Bewertung</small>
        </div>

        {
          topHighlights.length > 0 && (
            <div class="product-box-highlights">
              {topHighlights.map((item) => (
                <div>
                  <span aria-hidden="true">✓</span>
                  {stripLeadingIcon(item)}
                </div>
              ))}
            </div>
          )
        }

        {
          specs.length > 0 && (
            <div class="product-box-specs">
              {specs.slice(0, 4).map((spec) => (
                <div>
                  <strong>{spec.label}</strong>
                  <span>{spec.value}</span>
                </div>
              ))}
            </div>
          )
        }

        <div class="product-box-action-row">
          <div class="product-box-price-hint">
            <span>Preis</span>
            <strong>Aktuell beim Anbieter prüfen</strong>
          </div>

          {showButton && (
            <a
              href={buttonHref}
              class="product-box-button"
              rel={primaryLink?.rel}
              target={primaryLink?.target}
            >
              {buttonLabel}
            </a>
          )}
        </div>
      </div>
    </section>
  )
}
