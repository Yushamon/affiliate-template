---
import { siteMeta } from "@app/project.config";

interface Props {
  author?: {
    name: string;
    role?: string;
  };

  publishedAt?: string;

  updatedAt?: string;

  readingTimeMinutes?: number;
}

const {
  author,
  publishedAt,
  updatedAt,
  readingTimeMinutes
} = Astro.props;

const formatDate = (date?: string) => {
  if (!date) return "";

  return new Intl.DateTimeFormat("de-DE", {
    day: "2-digit",
    month: "long",
    year: "numeric"
  }).format(new Date(date));
};

const visibleAuthor =
  author ??
  siteMeta.defaultAuthor;
---

<div class="article-meta">

  <div class="article-meta-author">

    <strong>
      {visibleAuthor.name}
    </strong>

    {
      visibleAuthor.role && (
        <span>
          {visibleAuthor.role}
        </span>
      )
    }

  </div>

  <div class="article-meta-dates">

    {
      publishedAt && (
        <span>
          <strong>Veröffentlicht:</strong>
          {" "}{formatDate(publishedAt)}
        </span>
      )
    }

    {
      updatedAt && (
        <span>
          <strong>Zuletzt aktualisiert:</strong>
          {" "}{formatDate(updatedAt)}
        </span>
      )
    }

    {
      readingTimeMinutes && (
        <span>
          <strong>Lesezeit:</strong>
          {" "}{readingTimeMinutes} Min.
        </span>
      )
    }

  </div>

</div>
