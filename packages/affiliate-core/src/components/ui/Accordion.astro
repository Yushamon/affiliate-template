---
interface Item {
  question: string;
  answer: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="ui-accordion">
  {items.map((item) => (
    <details class="ui-accordion-item">
      <summary>{item.question}</summary>
      <p>{item.answer}</p>
    </details>
  ))}
</div>