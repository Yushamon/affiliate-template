---
import Card from "./ui/Card.astro";
import Grid from "./ui/Grid.astro";
import Section from "./ui/Section.astro";

interface Page {
  data: {
    title: string;
    description: string;
    slug: string;
    categoryLabel: string;
  };
}

interface Props {
  pages: Page[];
}

const { pages } = Astro.props;
---

{pages.length > 0 && (
  <Section
    eyebrow="Nächster Schritt"
    title="Sinnvolle Ratgeber zu diesem Thema"
  >
    <Grid columns={2}>
      {pages.map((page) => (
        <Card
          href={`/${page.data.slug}`}
          label={page.data.categoryLabel}
          title={page.data.title}
          text={page.data.description}
          cta="Jetzt ansehen"
        />
      ))}
    </Grid>
  </Section>
)}