---
import type { HomepageModel } from "../../home/model";
import HomeHero from "./HomeHero.astro";
import HomeSection from "./HomeSection.astro";
import HomeNavigation from "./HomeNavigation.astro";
import HomeBrandStatement from "./HomeBrandStatement.astro";
import HomeStats from "./HomeStats.astro";
import HomeUseCases from "./HomeUseCases.astro";
import HomeFaq from "./HomeFaq.astro";
import "./home.css";

type Props = {
  model: HomepageModel;
};

const { model } = Astro.props as Props;
---

<div class="home3 home5">
  <HomeHero hero={model.hero} />

  <HomeNavigation
    mode="comparison-decision"
    decisionCards={model.decisionComparisons}
  />

  <HomeSection
    kind="products"
    eyebrow="Aktuelle Produktempfehlungen"
    title="Starke Optionen für konkrete Anforderungen"
    text="Keine pauschale Bestenliste. Die Empfehlungen unterscheiden sich nach Futterart, Tierzahl, Bedienung und gewünschter Kontrolle."
    items={model.products}
  />

  <HomeSection
    kind="editorial"
    id="ratgeber"
    eyebrow="Neu im Ratgeber"
    title="Fundierte Antworten auf konkrete Fragen"
    text="Gesundheitliche Warnzeichen, Fütterung und Haustiertechnik verständlich und ohne unnötige Dramatisierung erklärt."
    items={model.guides}
  />

  <HomeNavigation
    mode="method"
    methods={model.methods}
    methodologyAction={model.methodologyAction}
  />

  <HomeUseCases items={model.useCases} />

  <HomeStats stats={model.hero.stats} />

  <HomeSection
    kind="editorial"
    eyebrow="Aktuell geprüft"
    title="Zuletzt überarbeitete Inhalte"
    text="Diese Seiten wurden zuletzt fachlich, redaktionell oder strukturell aktualisiert."
    items={model.recentlyUpdated}
  />

  <HomeFaq items={model.faq} />

  <HomeNavigation
    mode="topics"
    groups={model.topicGroups}
  />

  <HomeBrandStatement />
</div>
