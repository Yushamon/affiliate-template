---
import type {
  HomeLink,
  HomepageModel
} from "../../home/model";

type Props = {
  mode: "decision" | "method" | "topics";
  links?: HomeLink[];
  methods?: HomepageModel["methods"];
  methodologyAction?: HomeLink;
  groups?: HomepageModel["topicGroups"];
};

const {
  mode,
  links = [],
  methods = [],
  methodologyAction,
  groups = []
} = Astro.props as Props;
---

{mode === "decision" && links.length > 0 && (
  <nav class="home3-decision" aria-labelledby="home3-decision-title">
    <div>
      <p class="home3-eyebrow">Schnelle Orientierung</p>
      <h2 id="home3-decision-title">Ich suche gerade …</h2>
    </div>
    <ul>
      {links.map((link) => (
        <li>
          <a href={link.href}>
            <span>{link.label}</span>
            <strong aria-hidden="true">→</strong>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

{mode === "method" && methods.length > 0 && methodologyAction && (
  <section class="home3-method" aria-labelledby="home3-method-title">
    <div class="home3-method__intro">
      <p class="home3-eyebrow home3-eyebrow--light">So arbeiten wir</p>
      <h2 id="home3-method-title">
        Empfehlungen brauchen eine überprüfbare Grundlage
      </h2>
      <p>
        Wir trennen technische Produktdaten, dokumentierte Erfahrungen und redaktionelle Einordnung. Unklare Angaben werden nicht geraten.
      </p>
      <a href={methodologyAction.href}>{methodologyAction.label}</a>
    </div>

    <ol>
      {methods.map((step) => (
        <li>
          <span>{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </li>
      ))}
    </ol>
  </section>
)}

{mode === "topics" && groups.length > 0 && (
  <nav class="home3-topics" aria-labelledby="home3-topics-title">
    <div>
      <p class="home3-eyebrow">Themenübersicht</p>
      <h2 id="home3-topics-title">
        Weiter nach Tier, Produkt oder Problem
      </h2>
    </div>

    <div class="home3-topic-groups">
      {groups.map((group) => (
        <section>
          <h3>{group.title}</h3>
          <ul>
            {group.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </nav>
)}
