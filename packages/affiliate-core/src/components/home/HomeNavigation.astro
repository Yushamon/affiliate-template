---
import OptimizedImage from "../OptimizedImage.astro";
import type {
  HomeDecisionCard,
  HomeLink,
  HomepageModel
} from "../../home/model";

type Props = {
  mode: "decision" | "comparison-decision" | "method" | "topics";
  links?: HomeLink[];
  decisionCards?: HomeDecisionCard[];
  methods?: HomepageModel["methods"];
  methodologyAction?: HomeLink;
  groups?: HomepageModel["topicGroups"];
};

const {
  mode,
  links = [],
  decisionCards = [],
  methods = [],
  methodologyAction,
  groups = []
} = Astro.props as Props;

const decisionLinks = links.slice(0, 4);

const getDecisionIcon = (label: string) => {
  const normalized = label.toLocaleLowerCase("de");

  if (
    normalized.includes("futter") ||
    normalized.includes("automat")
  ) {
    return "bowl";
  }

  if (
    normalized.includes("gps") ||
    normalized.includes("tracker") ||
    normalized.includes("ortung")
  ) {
    return "location";
  }

  if (
    normalized.includes("trink") ||
    normalized.includes("wasser")
  ) {
    return "drop";
  }

  if (
    normalized.includes("ratgeber") ||
    normalized.includes("wissen")
  ) {
    return "guide";
  }

  return "star";
};

const getDecisionIconSvg = (type: string) => {
  if (type === "location") {
    return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2.2"/></svg>`;
  }

  if (type === "drop") {
    return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3s6 6.2 6 11a6 6 0 0 1-12 0c0-4.8 6-11 6-11Z"/><path d="M9.5 15.2c.7 1.1 1.6 1.6 2.8 1.6"/></svg>`;
  }

  if (type === "bowl") {
    return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 10h16l-1.6 8H5.6L4 10Z"/><path d="M7 10c.3-2.5 2.1-4 5-4s4.7 1.5 5 4"/><path d="M9 14h6"/></svg>`;
  }

  if (type === "guide") {
    return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h6a3 3 0 0 1 3 3v13a3 3 0 0 0-3-3H5V4Z"/><path d="M19 4h-3a3 3 0 0 0-3 3v13a3 3 0 0 1 3-3h3V4Z"/></svg>`;
  }

  return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 2.2 5.2 5.6.5-4.3 3.7 1.3 5.5L12 15l-4.8 2.9 1.3-5.5-4.3-3.7 5.6-.5L12 3Z"/></svg>`;
};

---

{mode === "comparison-decision" && decisionCards.length > 0 && (
  <section
    class="home41-decision"
    aria-labelledby="home41-decision-title"
  >
    <header class="home41-decision__header">
      <div>
        <p class="home3-eyebrow">Schnelle Orientierung</p>
        <h2 id="home41-decision-title">
          Direkt zum passenden Vergleich
        </h2>
      </div>
      <p>
        Starte mit unseren redaktionell gepflegten Vergleichen. Modelle werden nach denselben Kriterien eingeordnet und fehlende Angaben nicht geschätzt.
      </p>
    </header>

    <div class="home41-decision__grid">
      {decisionCards.map((card) => (
        <a class="home41-decision__card" href={card.href}>
          <span
            class:list={[
              "home41-decision__quick-icon",
              `home41-decision__quick-icon--${getDecisionIcon(
                `${card.label} ${card.title}`
              )}`
            ]}
            aria-hidden="true"
            set:html={getDecisionIconSvg(
              getDecisionIcon(`${card.label} ${card.title}`)
            )}
          ></span>

          <div class="home41-decision__media">
            {card.image && (
              <OptimizedImage
                src={card.image.src}
                alt={card.image.alt ?? ""}
                width={720}
                height={480}
                layout="constrained"
              />
            )}
            <span>{card.label}</span>
          </div>

          <div class="home41-decision__content">
            <h3>{card.title}</h3>
            <p>{card.text}</p>

            <div class="home41-decision__meta">
              <strong>
                {card.itemCount}
                {" "}
                {card.itemCount === 1
                  ? "Modell"
                  : "Modelle"}
                {" "}
                verglichen
              </strong>
              {card.updatedLabel && (
                <small>{card.updatedLabel}</small>
              )}
            </div>

            <b><span class="home41-decision__cta-label">Vergleich ansehen</span></b>
          </div>

          <span class="home41-decision__arrow" aria-hidden="true">
            →
          </span>
        </a>
      ))}
    </div>
  </section>
)}

{mode === "method" && methods.length > 0 && methodologyAction && (
  <section
    class="home3-method"
    aria-labelledby="home3-method-title"
  >
    <div class="home3-method__intro">
      <p class="home3-eyebrow home3-eyebrow--light">
        So arbeiten wir
      </p>
      <h2 id="home3-method-title">
        Empfehlungen brauchen eine überprüfbare Grundlage
      </h2>
      <p>
        Wir trennen technische Produktdaten, dokumentierte Erfahrungen und redaktionelle Einordnung. Unklare Angaben werden nicht geraten.
      </p>
      <a href={methodologyAction.href}>
        {methodologyAction.label}
      </a>
    </div>

    <ol>
      {methods.map((step) => (
        <li>
          <span>{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </li>
      ))}
    </ol>
  </section>
)}

{mode === "topics" && groups.length > 0 && (
  <nav
    class="home3-topics"
    aria-labelledby="home3-topics-title"
  >
    <div>
      <p class="home3-eyebrow">Themenübersicht</p>
      <h2 id="home3-topics-title">
        Weiter nach Tier, Produkt oder Problem
      </h2>
    </div>

    <div class="home3-topic-groups">
      {groups.map((group) => (
        <section>
          <h3>{group.title}</h3>
          <ul>
            {group.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </nav>
)}
