---
import OptimizedImage from "../OptimizedImage.astro";
import type { HomeCard, HomeCategory, HomeProduct } from "../../home/model";

import { toEditorialScore } from "@affiliate-core/utils/editorialScore";
type Props = {
  kind: "categories" | "editorial" | "products";
  eyebrow: string;
  title: string;
  text: string;
  items: HomeCategory[] | HomeCard[] | HomeProduct[];
  id?: string;
};

const { kind, eyebrow, title, text, items, id } = Astro.props as Props;
---
{items.length > 0 && (
  <section id={id} class="home2-section" aria-labelledby={id ? `${id}-title` : undefined}>
    <header class="home2-section__header">
      <div>
        <p class="home2-eyebrow">{eyebrow}</p>
        <h2 id={id ? `${id}-title` : undefined}>{title}</h2>
      </div>
      <p>{text}</p>
    </header>

    {kind === "categories" && (
      <div class="home2-category-grid">
        {(items as HomeCategory[]).map((item) => (
          <a class="home2-category-card" href={item.href}>
            {item.image && <div class="home2-card-media"><OptimizedImage src={item.image.src} alt={item.image.alt ?? ""} width={720} height={480} layout="constrained" /></div>}
            <div class="home2-category-card__content">
              <span>{item.code}</span><h3>{item.title}</h3><p>{item.text}</p>
              <strong>{item.count} {item.count === 1 ? "Inhalt" : "Inhalte"} ansehen</strong>
            </div>
          </a>
        ))}
      </div>
    )}

    {kind === "editorial" && (
      <div class="home2-editorial-grid">
        {(items as HomeCard[]).map((item, index) => (
          <a class:list={["home2-editorial-card", index === 0 && "home2-editorial-card--featured"]} href={item.href}>
            <div class="home2-card-media">
              {item.image && <OptimizedImage src={item.image.src} alt={item.image.alt ?? ""} width={900} height={600} layout="constrained" />}
            </div>
            <div class="home2-card-content">
              <span>{item.label}</span><h3>{item.title}</h3><p>{item.text}</p>
              {item.meta && <small>{item.meta}</small>}<strong>{item.action}</strong>
            </div>
          </a>
        ))}
      </div>
    )}

    {kind === "products" && (
      <div class="home2-product-grid">
        {(items as HomeProduct[]).map((item) => (
          <a class="home2-product-card" href={item.href}>
            <div class="home2-product-media">
              <OptimizedImage src={item.image.src} alt={item.image.alt ?? item.title} width={480} height={360} layout="constrained" />
            </div>
            <div class="home2-card-content">
              <span>{item.manufacturer}</span><h3>{item.title}</h3><p>{item.recommendation}</p>
              <div class="home2-rating"><strong>{toEditorialScore(item.rating, 5)}</strong><small>PfotenTechnik-Score</small></div>
              <b>Produkttest lesen</b>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
)}
