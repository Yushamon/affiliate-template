---
import { projectConfig } from "@app/project.config";

const year = new Date().getFullYear();
const footerColumnStyle = `--footer-column-count: ${projectConfig.footer.columns.length}`;
---

<footer class="footer-v2">
  <div class="footer-inner-v2">
    <div class="footer-main-v2" style={footerColumnStyle}>
      <section class="footer-brand-v2" aria-labelledby="footer-brand-title">
        <strong id="footer-brand-title">{projectConfig.projectName}</strong>
        <p>{projectConfig.footer.description}</p>
      </section>

      {projectConfig.footer.columns.map((column, index) => {
        const headingId = `footer-column-${index}`;

        return (
          <nav class="footer-column-v2" aria-labelledby={headingId}>
            <h2 id={headingId}>{column.title}</h2>
            {column.links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </nav>
        );
      })}
    </div>

    <div class="footer-bottom-v2">
      <p class="footer-copyright-v2">
        © {year} {projectConfig.projectName}
      </p>

      <p class="footer-transparency-v2">
        {projectConfig.footer.transparency}
      </p>
    </div>
  </div>
</footer>
