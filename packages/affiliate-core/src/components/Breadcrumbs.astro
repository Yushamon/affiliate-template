---
import { projectConfig } from "@app/project.config";

interface Props {
  categoryLabel: string;
  title: string;
  categoryHref?: string;
}

const {
  categoryLabel,
  title,
  categoryHref = projectConfig.categoryPath ?? "/"
} = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <a href="/">Startseite</a>
  <span>›</span>
  <a href={categoryHref}>{categoryLabel}</a>
  <span>›</span>
  <span>{title}</span>
</nav>
