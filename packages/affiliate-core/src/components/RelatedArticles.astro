---
import Card from "./ui/Card.astro";
import Grid from "./ui/Grid.astro";
import Section from "./ui/Section.astro";

interface RelatedItem {
  href: string;
  label: string;
  title: string;
  text: string;
}

interface Props {
  items: RelatedItem[];
}

const { items = [] } = Astro.props as Partial<Props>;
---

{items.length > 0 && (
  <Section
    eyebrow="Weiterführende Inhalte"
    title="Das könnte dich auch interessieren"
  >
    <Grid columns={3}>
      {items.map((item) => (
        <Card
          href={item.href}
          label={item.label}
          title={item.title}
          text={item.text}
          cta="Weiterlesen"
        />
      ))}
    </Grid>
  </Section>
)}
