---
import Card from "./ui/Card.astro";
import Grid from "./ui/Grid.astro";
import Section from "./ui/Section.astro";

interface Page {
  data: {
    title: string;
    description: string;
    slug: string;
    categoryLabel: string;
  };
}

interface Props {
  pages: Page[];‚
}

const { pages } = Astro.props;
---

{pages.length > 0 && (
  <Section
    eyebrow="Weiterführende Inhalte"
    title="Das könnte dich auch interessieren"
  >
    <Grid columns={3}>
      {pages.map((page) => (
        <Card
          href={`/${page.data.slug}`}
          label={page.data.categoryLabel}
          title={page.data.title}
          text={page.data.description}
          cta="Weiterlesen"
        />
      ))}
    </Grid>
  </Section>
)}