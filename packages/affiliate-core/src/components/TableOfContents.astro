---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
}

const headings = Array.isArray(Astro.props.headings)
  ? Astro.props.headings
  : [];

const tocHeadings = headings.filter((heading) => heading.depth === 2);
const initiallyOpen = tocHeadings.length <= 6;
---

{
  tocHeadings.length > 0 && (
    <details class="toc" open={initiallyOpen}>
      <summary>
        <strong>Inhaltsverzeichnis</strong>
        <span>{tocHeadings.length} Abschnitte</span>
      </summary>

      <ol>
        {tocHeadings.map((heading) => (
          <li>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </details>
  )
}