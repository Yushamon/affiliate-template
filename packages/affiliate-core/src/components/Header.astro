---
interface Props {
  projectName: string;
  links: Array<{
    label: string;
    href: string;
  }>;
}

const {
  projectName,
  links
} = Astro.props as Props;
---

<header class="site-header-v2">
  <div class="header-container-v2">
    <a href="/" class="logo-v2">
      {projectName}
    </a>

    <input id="nav-toggle" class="nav-toggle" type="checkbox" />

    <label for="nav-toggle" class="nav-toggle-label">
      Menü
    </label>

    <nav class="main-nav-v2">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>
