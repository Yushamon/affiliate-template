---
import ProductImage from "../ProductImage.astro";

import type {
  AlternativeRecommendation
} from "./alternativeRecommendation.types";

interface Props {
  alternatives?: AlternativeRecommendation[];
}

const {
  alternatives = []
} = Astro.props as Props;
---

{
  alternatives.length > 0 ? (
    <div class="alternative-recommendation-grid">
      {
        alternatives.map((alternative) => (
          <article class="alternative-recommendation-card">
            <a
              class="alternative-recommendation-image"
              href={alternative.url}
              aria-label={`${alternative.name} Test öffnen`}
            >
              <ProductImage
                image={alternative.image}
                alt={alternative.name}
                loading="lazy"
              />
            </a>

            <div class="alternative-recommendation-content">
              <div class="alternative-recommendation-meta">
                <span>
                  Wann stattdessen?
                </span>

                <strong>
                  {alternative.score} / 100
                </strong>
              </div>

              <span
                class="alternative-recommendation-icon"
                aria-hidden="true"
              >
                {alternative.icon}
              </span>

              <p class="alternative-recommendation-headline">
                {alternative.headline}
              </p>

              <h3>
                <a href={alternative.url}>
                  {alternative.name}
                </a>
              </h3>

              <p class="alternative-recommendation-reason">
                {alternative.reason}
              </p>

              <div class="alternative-recommendation-difference">
                <strong>
                  Größter Unterschied
                </strong>

                <p>
                  {alternative.difference}
                </p>
              </div>

              {
                alternative.tags.length > 0 && (
                  <ul class="alternative-recommendation-tags">
                    {
                      alternative.tags.map((tag) => (
                        <li>
                          {tag}
                        </li>
                      ))
                    }
                  </ul>
                )
              }

              <div class="alternative-recommendation-footer">
                <span>
                  {alternative.rating} / 5
                </span>

                <a href={alternative.url}>
                  Zum vollständigen Test

                  <span aria-hidden="true">
                    →
                  </span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  ) : (
    <div class="alternative-recommendation-empty">
      <strong>
        Noch keine passende Alternative verfügbar
      </strong>

      <p>
        Für dieses Produkt ist derzeit noch kein ausreichend
        vergleichbares Modell vollständig bewertet.
      </p>
    </div>
  )
}

<style>
  .alternative-recommendation-grid {
    display: grid;
    grid-template-columns:
      repeat(
        3,
        minmax(0, 1fr)
      );
    gap: 1.25rem;
  }

  .alternative-recommendation-card {
    display: flex;
    min-width: 0;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid
      var(
        --product-border,
        #dce5e3
      );
    border-radius: 1.2rem;
    background:
      linear-gradient(
        145deg,
        rgba(24, 116, 59, 0.05),
        #ffffff 46%
      );
    box-shadow:
      0 12px 30px
        rgba(13, 48, 43, 0.06);
  }

  .alternative-recommendation-image {
    display: grid;
    min-height: 14rem;
    overflow: hidden;
    place-items: center;
    background:
      linear-gradient(
        145deg,
        #f5f7f6,
        #ffffff
      );
  }

  .alternative-recommendation-image :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 16rem;
    padding: 1.2rem;
    object-fit: contain;
    transition: transform 180ms ease;
  }

  .alternative-recommendation-image:hover :global(img) {
    transform: scale(1.025);
  }

  .alternative-recommendation-content {
    display: flex;
    min-width: 0;
    padding: 1.3rem;
    flex: 1;
    flex-direction: column;
  }

  .alternative-recommendation-meta {
    display: flex;
    margin-bottom: 0.9rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .alternative-recommendation-meta > span {
    color:
      var(
        --product-accent,
        #18743b
      );
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .alternative-recommendation-meta > strong {
    flex: 0 0 auto;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    background: rgba(24, 116, 59, 0.09);
    color:
      var(
        --product-accent-dark,
        #0f5a2b
      );
    font-size: 0.78rem;
  }

  .alternative-recommendation-icon {
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    margin-bottom: 0.8rem;
    place-items: center;
    border-radius: 0.8rem;
    background: rgba(24, 116, 59, 0.09);
    font-size: 1.25rem;
  }

  .alternative-recommendation-headline {
    margin: 0 0 0.75rem;
    color:
      var(
        --product-accent-dark,
        #0f5a2b
      );
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.45;
  }

  .alternative-recommendation-content h3 {
    margin: 0 0 0.75rem;
    font-size: 1.35rem;
    line-height: 1.18;
    letter-spacing: -0.025em;
  }

  .alternative-recommendation-content h3 a {
    color:
      var(
        --product-text,
        #0d302b
      );
    text-decoration: none;
  }

  .alternative-recommendation-content h3 a:hover {
    color:
      var(
        --product-accent,
        #18743b
      );
  }

  .alternative-recommendation-reason {
    margin: 0 0 1rem;
    color:
      var(
        --product-muted,
        #647579
      );
    line-height: 1.6;
  }

  .alternative-recommendation-difference {
    margin-bottom: 1rem;
    padding: 0.9rem;
    border-radius: 0.85rem;
    background: rgba(13, 48, 43, 0.04);
  }

  .alternative-recommendation-difference strong {
    display: block;
    margin-bottom: 0.35rem;
    color:
      var(
        --product-text,
        #0d302b
      );
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .alternative-recommendation-difference p {
    margin: 0;
    color:
      var(
        --product-muted,
        #647579
      );
    font-size: 0.88rem;
    line-height: 1.5;
  }

.alternative-recommendation-tags {
  display: flex;
  margin: 0 0 1rem;
  padding: 0;
  flex-wrap: wrap;
  gap: 0.55rem;
  list-style: none;
}

.alternative-recommendation-tags li {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 1.9rem;
  padding: 0.35rem 0.8rem;
  border: 1px solid
    color-mix(
      in srgb,
      var(--product-accent, #18743b) 14%,
      var(--product-border, #dce5e3)
    );
  border-radius: 999px;
  background: #fafcfb;
  color: var(--product-text, #0d302b);
  font-size: 0.73rem;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  transition:
    background-color 160ms ease,
    border-color 160ms ease;
}

.alternative-recommendation-tags li:hover {
  background: rgba(24, 116, 59, 0.05);
  border-color:
    color-mix(
      in srgb,
      var(--product-accent, #18743b) 30%,
      var(--product-border, #dce5e3)
    );
}

  .alternative-recommendation-footer {
    display: flex;
    margin-top: auto;
    padding-top: 1rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    border-top: 1px solid
      var(
        --product-border,
        #dce5e3
      );
  }

  .alternative-recommendation-footer > span {
    color:
      var(
        --product-text,
        #0d302b
      );
    font-size: 0.86rem;
    font-weight: 850;
  }

  .alternative-recommendation-footer a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color:
      var(
        --product-accent-dark,
        #0f5a2b
      );
    font-size: 0.87rem;
    font-weight: 850;
    text-decoration: none;
  }

  .alternative-recommendation-empty {
    padding: 1.5rem;
    border: 1px dashed
      var(
        --product-border,
        #dce5e3
      );
    border-radius: 1rem;
    background: #ffffff;
    text-align: center;
  }

  .alternative-recommendation-empty strong {
    display: block;
    margin-bottom: 0.4rem;
    color:
      var(
        --product-text,
        #0d302b
      );
  }

  .alternative-recommendation-empty p {
    margin: 0;
    color:
      var(
        --product-muted,
        #647579
      );
  }

  @media (max-width: 1050px) {
    .alternative-recommendation-grid {
      grid-template-columns: 1fr;
    }

    .alternative-recommendation-card {
      display: grid;
      grid-template-columns:
        minmax(12rem, 0.7fr)
        minmax(0, 1.3fr);
    }

    .alternative-recommendation-image {
      min-height: 100%;
    }
  }

  @media (max-width: 640px) {
    .alternative-recommendation-card {
      display: flex;
    }

    .alternative-recommendation-image {
      min-height: 13rem;
    }

    .alternative-recommendation-footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .alternative-recommendation-image :global(img) {
      transition: none;
    }

    .alternative-recommendation-image:hover :global(img) {
      transform: none;
    }
  }
</style>