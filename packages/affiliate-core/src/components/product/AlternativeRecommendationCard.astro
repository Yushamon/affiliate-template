---
import ProductImage from "../ProductImage.astro";

import type {
  AlternativeRecommendation
} from "./alternativeRecommendation.types";

interface Props {
  alternatives?: AlternativeRecommendation[];
}

const {
  alternatives = []
} = Astro.props as Props;

const cleanText = (value: string) =>
  value
    .replace(/^\s*(?:[✓✔☑✅✕✖×❌✗✘•\-–—]+\s*)+/u, "")
    .trim();

const formatHeadline = (value: string) =>
  cleanText(value)
    .replace(/\bapp-auswertung\b/giu, "App-Auswertung")
    .replace(/\bpremiumanspruch\b/giu, "Premiumanspruch")
    .replace(/\baufstellung\b/giu, "Aufstellung")
    .replace(/\bapp\b/giu, "App")
    .replace(/\buvc\b/giu, "UVC");

const iconType = (alternative: AlternativeRecommendation) => {
  const evidence = [
    alternative.icon,
    alternative.headline,
    alternative.reason,
    alternative.difference,
    ...alternative.tags
  ]
    .join(" ")
    .toLocaleLowerCase("de");

  if (/akku|kabellos|cordless|batterie/.test(evidence)) {
    return "battery";
  }

  if (/app|smart|auswertung|wlan|wifi/.test(evidence)) {
    return "app";
  }

  if (/premium|uvc|hygiene|filter/.test(evidence)) {
    return "shield";
  }

  if (/schloss|zugang|chip|mikrochip/.test(evidence)) {
    return "lock";
  }

  return "compare";
};

const iconSvg = (type: string) => {
  if (type === "battery") {
    return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 5h9a2 2 0 0 1 2 2v1h1a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Zm0 2v10h9V7H7Zm2 2h5v6H9V9Z"/></svg>`;
  }

  if (type === "app") {
    return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 2h8a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H8a3 3 0 0 1-3-3V5a3 3 0 0 1 3-3Zm0 2a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V5a1 1 0 0 0-1-1H8Zm3 13h2v2h-2v-2Z"/></svg>`;
  }

  if (type === "shield") {
    return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 2 8 3v6c0 5.1-3.4 9.6-8 11-4.6-1.4-8-5.9-8-11V5l8-3Zm0 2.2L6 6.4V11c0 3.9 2.4 7.4 6 8.7 3.6-1.3 6-4.8 6-8.7V6.4l-6-2.2Zm-1 4.3h2V11h2.5v2H13v2.5h-2V13H8.5v-2H11V8.5Z"/></svg>`;
  }

  if (type === "lock") {
    return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 10V7a5 5 0 0 1 10 0v3h1a2 2 0 0 1 2 2v8H4v-8a2 2 0 0 1 2-2h1Zm2 0h6V7a3 3 0 0 0-6 0v3Zm-3 2v6h12v-6H6Zm5 1h2v4h-2v-4Z"/></svg>`;
  }

  return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h10v2H7V3Zm-3 4h16v14H4V7Zm2 2v10h12V9H6Zm2 2h8v2H8v-2Zm0 4h5v2H8v-2Z"/></svg>`;
};
---

{
  alternatives.length > 0 ? (
    <div class="alternative-recommendation-grid">
      {
        alternatives.map((alternative) => (
          <article class="alternative-recommendation-card">
            <a
              class="alternative-recommendation-image"
              href={alternative.url}
              aria-label={`${alternative.name} Test öffnen`}
            >
              <ProductImage
                image={alternative.image}
                alt={alternative.name}
                loading="lazy"
              />
            </a>

            <div class="alternative-recommendation-content">
              <div class="alternative-recommendation-meta">
                <span>Wann stattdessen?</span>

                <strong>{alternative.score} / 100</strong>
              </div>

              <span
                class="alternative-recommendation-icon"
                aria-hidden="true"
                set:html={iconSvg(iconType(alternative))}
              />

              <p class="alternative-recommendation-headline">
                {formatHeadline(alternative.headline)}
              </p>

              <h3>
                <a href={alternative.url}>
                  {alternative.name}
                </a>
              </h3>

              <p class="alternative-recommendation-reason">
                {alternative.reason}
              </p>

              <div class="alternative-recommendation-difference">
                <strong>Größter Unterschied</strong>
                <p>{alternative.difference}</p>
              </div>

              {
                alternative.tags.length > 0 && (
                  <ul class="alternative-recommendation-tags">
                    {
                      alternative.tags.map((tag) => (
                        <li>{cleanText(tag)}</li>
                      ))
                    }
                  </ul>
                )
              }

              <div class="alternative-recommendation-footer">
                <span>{alternative.rating} / 5</span>

                <a href={alternative.url}>
                  Zum vollständigen Test
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  ) : (
    <div class="alternative-recommendation-empty">
      <strong>
        Noch keine passende Alternative verfügbar
      </strong>

      <p>
        Für dieses Produkt ist derzeit noch kein ausreichend
        vergleichbares Modell vollständig bewertet.
      </p>
    </div>
  )
}

<style>
  .alternative-recommendation-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .alternative-recommendation-card {
    display: flex;
    min-width: 0;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid var(--product-border, #dce5e3);
    border-radius: 1.2rem;
    background: #fff;
    box-shadow: 0 12px 30px rgba(13, 48, 43, 0.06);
  }

  .alternative-recommendation-image {
    display: grid;
    min-height: 14rem;
    overflow: hidden;
    place-items: center;
    background: linear-gradient(145deg, #f5f7f6, #ffffff);
  }

  .alternative-recommendation-image :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 16rem;
    padding: 1.2rem;
    object-fit: contain;
    transition: transform 180ms ease;
  }

  .alternative-recommendation-image:hover :global(img) {
    transform: scale(1.025);
  }

  .alternative-recommendation-content {
    display: flex;
    min-width: 0;
    padding: 1.3rem;
    flex: 1;
    flex-direction: column;
  }

  .alternative-recommendation-meta {
    display: flex;
    margin-bottom: 0.9rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .alternative-recommendation-meta > span {
    color: var(--product-accent, #18743b);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .alternative-recommendation-meta > strong {
    flex: 0 0 auto;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    background: rgba(24, 116, 59, 0.09);
    color: var(--product-accent-dark, #0f5a2b);
    font-size: 0.78rem;
  }

  .alternative-recommendation-icon {
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    margin-bottom: 0.8rem;
    place-items: center;
    border-radius: 0.8rem;
    background: rgba(24, 116, 59, 0.09);
    color: var(--product-accent, #18743b);
  }

  .alternative-recommendation-icon :global(svg) {
    width: 1.35rem;
    height: 1.35rem;
    fill: currentColor;
  }

  .alternative-recommendation-headline {
    margin: 0 0 0.75rem;
    color: var(--product-accent-dark, #0f5a2b);
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.45;
  }

  .alternative-recommendation-content h3 {
    margin: 0 0 0.75rem;
    font-size: 1.35rem;
    line-height: 1.18;
    letter-spacing: -0.025em;
  }

  .alternative-recommendation-content h3 a {
    color: var(--product-text, #0d302b);
    text-decoration: none;
  }

  .alternative-recommendation-reason {
    margin: 0 0 1rem;
    color: var(--product-muted, #647579);
    line-height: 1.6;
  }

  .alternative-recommendation-difference {
    margin-bottom: 1rem;
    padding: 0.9rem;
    border-radius: 0.85rem;
    background: rgba(13, 48, 43, 0.04);
  }

  .alternative-recommendation-difference strong {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--product-text, #0d302b);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .alternative-recommendation-difference p {
    margin: 0;
    color: var(--product-muted, #647579);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .alternative-recommendation-tags {
    display: flex;
    margin: 0 0 1rem;
    padding: 0 !important;
    flex-wrap: wrap;
    gap: 0.55rem;
    list-style: none !important;
  }

  .alternative-recommendation-tags li {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    padding: 0.35rem 0.8rem !important;
    border: 1px solid color-mix(
      in srgb,
      var(--product-accent, #18743b) 14%,
      var(--product-border, #dce5e3)
    );
    border-radius: 999px;
    background: #fafcfb;
    color: var(--product-text, #0d302b);
    font-size: 0.73rem;
    font-weight: 700;
    line-height: 1;
    list-style: none !important;
    white-space: nowrap;
  }

  .alternative-recommendation-tags li::before,
  .alternative-recommendation-tags li::after {
    content: none !important;
    display: none !important;
  }

  .alternative-recommendation-footer {
    display: flex;
    margin-top: auto;
    padding-top: 1rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    border-top: 1px solid var(--product-border, #dce5e3);
  }

  .alternative-recommendation-footer > span {
    color: var(--product-text, #0d302b);
    font-size: 0.86rem;
    font-weight: 850;
  }

  .alternative-recommendation-footer a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--product-accent-dark, #0f5a2b);
    font-size: 0.87rem;
    font-weight: 850;
    text-decoration: none;
  }

  .alternative-recommendation-empty {
    padding: 1.5rem;
    border: 1px dashed var(--product-border, #dce5e3);
    border-radius: 1rem;
    background: #ffffff;
    text-align: center;
  }

  @media (max-width: 1050px) {
    .alternative-recommendation-grid {
      grid-template-columns: 1fr;
    }

    .alternative-recommendation-card {
      display: grid;
      grid-template-columns: minmax(12rem, 0.7fr) minmax(0, 1.3fr);
    }

    .alternative-recommendation-image {
      min-height: 100%;
    }
  }

  @media (max-width: 640px) {
    .alternative-recommendation-card {
      display: flex;
    }

    .alternative-recommendation-image {
      min-height: 13rem;
    }

    .alternative-recommendation-footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .alternative-recommendation-image :global(img) {
      transition: none;
    }
  }
</style>
