---
import ProductImage from "../ProductImage.astro";

import {
  products,
  type ProductKey
} from "@app/data/products";

import {
  getWeightedProductScore
} from "@app/data/productScoring";

import {
  DEFAULT_PROJECT,
  getProjectImage
} from "@app/data/projectImages";

import {
  stripLeadingIcon
} from "../../utils/content";

import {
  getProductHeroImage
} from "../../utils/productImages";

interface Props {
  currentProductKey: ProductKey;
  limit?: number;
}

type AlternativeInsight = {
  kind: string;
  icon: string;
  headline: string;
  reason: string;
  difference: string;
};

type AlternativeItem = {
  productKey: ProductKey;
  insight: AlternativeInsight;
};

const {
  currentProductKey,
  limit = 3
} = Astro.props as Props;

const currentProduct =
  products[currentProductKey];

const productKeys =
  Object.keys(
    products
  ) as ProductKey[];

const normalizeText = (
  value: unknown
) =>
  String(
    value ?? ""
  )
    .toLowerCase()
    .replace(
      /ä/g,
      "ae"
    )
    .replace(
      /ö/g,
      "oe"
    )
    .replace(
      /ü/g,
      "ue"
    )
    .replace(
      /ß/g,
      "ss"
    )
    .replace(
      /[^a-z0-9]+/g,
      " "
    )
    .trim();

const getArrayText = (
  value: unknown
) =>
  Array.isArray(
    value
  )
    ? value
        .map(
          (item) =>
            stripLeadingIcon(
              String(item)
            )
        )
        .join(" ")
    : "";

const getSpecsText = (
  value: unknown
) => {
  if (
    !Array.isArray(
      value
    )
  ) {
    return "";
  }

  return value
    .map(
      (spec) => {
        if (
          !spec ||
          typeof spec !==
            "object"
        ) {
          return "";
        }

        const record =
          spec as Record<
            string,
            unknown
          >;

        return [
          record.label,
          record.value
        ]
          .filter(Boolean)
          .join(" ");
      }
    )
    .join(" ");
};

const getProductSearchText = (
  productKey: ProductKey
) => {
  const product =
    products[productKey];

  return normalizeText(
    [
      product.name,
      product.category,
      product.useCase,
      product.recommendation,
      product.review?.summary,
      product.review?.verdict,
      getArrayText(
        product.bestFor
      ),
      getArrayText(
        product.notFor
      ),
      getArrayText(
        product.pros
      ),
      getArrayText(
        product.cons
      ),
      getSpecsText(
        product.specs
      )
    ]
      .filter(Boolean)
      .join(" ")
  );
};

const includesAny = (
  text: string,
  terms: string[]
) =>
  terms.some(
    (term) =>
      text.includes(
        normalizeText(
          term
        )
      )
  );

const getUsefulBestFor = (
  productKey: ProductKey
) => {
  const product =
    products[productKey];

  if (
    !Array.isArray(
      product.bestFor
    )
  ) {
    return [];
  }

  const ignoredTerms =
    new Set([
      "katze",
      "katzen",
      "hund",
      "hunde",
      "haustier",
      "haustiere",
      "tierhalter",
      "haushalte"
    ]);

  return product.bestFor
    .map(
      (item) =>
        stripLeadingIcon(
          String(item)
        ).trim()
    )
    .filter(Boolean)
    .filter(
      (item) =>
        !ignoredTerms.has(
          normalizeText(
            item
          )
        )
    )
    .slice(
      0,
      3
    );
};

const currentSearchText =
  currentProduct
    ? getProductSearchText(
        currentProductKey
      )
    : "";

const getAlternativeInsight = (
  alternativeKey: ProductKey
): AlternativeInsight => {
  const alternative =
    products[
      alternativeKey
    ];

  const alternativeText =
    getProductSearchText(
      alternativeKey
    );

  const currentHasWetFood =
    includesAny(
      currentSearchText,
      [
        "nassfutter",
        "wet food",
        "wetfood",
        "kuehlung",
        "gekuehlt"
      ]
    );

  const alternativeHasWetFood =
    includesAny(
      alternativeText,
      [
        "nassfutter",
        "wet food",
        "wetfood",
        "kuehlung",
        "gekuehlt"
      ]
    );

  if (
    alternativeHasWetFood &&
    !currentHasWetFood
  ) {
    return {
      kind: "wet-food",
      icon: "🥣",
      headline:
        "Wenn du überwiegend Nassfutter fütterst",
      reason:
        "Dieses Modell ist die passendere Wahl für frische oder gekühlte Mahlzeiten.",
      difference:
        "Der größte Unterschied liegt in der Ausrichtung auf Nassfutter statt auf klassische Trockenfutterportionen."
    };
  }

  const currentHasAccessControl =
    includesAny(
      currentSearchText,
      [
        "rfid",
        "mikrochip",
        "microchip",
        "zugangskontrolle",
        "futterneid"
      ]
    );

  const alternativeHasAccessControl =
    includesAny(
      alternativeText,
      [
        "rfid",
        "mikrochip",
        "microchip",
        "zugangskontrolle",
        "futterneid"
      ]
    );

  if (
    alternativeHasAccessControl &&
    !currentHasAccessControl
  ) {
    return {
      kind: "access-control",
      icon: "🔐",
      headline:
        "Wenn mehrere Tiere getrennt gefüttert werden sollen",
      reason:
        "Dieses Modell ist besser geeignet, wenn jedes Tier nur auf seine eigene Portion zugreifen soll.",
      difference:
        "Die Zugangskontrolle per RFID oder Mikrochip schützt Futter vor anderen Tieren im Haushalt."
    };
  }

  const currentHasCamera =
    includesAny(
      currentSearchText,
      [
        "kamera",
        "camera",
        "video",
        "live bild"
      ]
    );

  const alternativeHasCamera =
    includesAny(
      alternativeText,
      [
        "kamera",
        "camera",
        "video",
        "live bild"
      ]
    );

  if (
    alternativeHasCamera &&
    !currentHasCamera
  ) {
    return {
      kind: "camera",
      icon: "📷",
      headline:
        "Wenn du dein Tier auch aus der Ferne sehen möchtest",
      reason:
        "Dieses Modell bietet zusätzliche Kontrolle durch eine integrierte Kamera.",
      difference:
        "Neben der Fütterung kannst du Mahlzeiten und Verhalten per Video überprüfen."
    };
  }

  const currentHasApp =
    includesAny(
      currentSearchText,
      [
        "app",
        "wlan",
        "wifi",
        "wi fi",
        "smartphone"
      ]
    );

  const alternativeHasApp =
    includesAny(
      alternativeText,
      [
        "app",
        "wlan",
        "wifi",
        "wi fi",
        "smartphone"
      ]
    );

  if (
    alternativeHasApp &&
    !currentHasApp
  ) {
    return {
      kind: "app",
      icon: "📱",
      headline:
        "Wenn dir App-Steuerung besonders wichtig ist",
      reason:
        "Dieses Modell eignet sich besser für flexible Fütterungspläne und Steuerung aus der Ferne.",
      difference:
        "Zeitpläne, Portionen und Statusmeldungen lassen sich direkt über das Smartphone verwalten."
    };
  }

  const alternativeHasMultiPet =
    includesAny(
      alternativeText,
      [
        "mehrere katzen",
        "mehrkatzen",
        "mehrtier",
        "mehrere tiere",
        "dual",
        "doppeln",
        "zwei naepfe",
        "2 naepfe"
      ]
    );

  const currentHasMultiPet =
    includesAny(
      currentSearchText,
      [
        "mehrere katzen",
        "mehrkatzen",
        "mehrtier",
        "mehrere tiere",
        "dual",
        "doppeln",
        "zwei naepfe",
        "2 naepfe"
      ]
    );

  if (
    alternativeHasMultiPet &&
    !currentHasMultiPet
  ) {
    return {
      kind: "multi-pet",
      icon: "🐾",
      headline:
        "Wenn du mehrere Tiere versorgen möchtest",
      reason:
        "Dieses Modell ist stärker auf Haushalte mit mehreren Katzen oder Hunden ausgerichtet.",
      difference:
        "Die Fütterung lässt sich besser auf mehrere Tiere, getrennte Portionen oder mehrere Näpfe abstimmen."
    };
  }

  const alternativeHasLargeCapacity =
    includesAny(
      alternativeText,
      [
        "gross",
        "großer",
        "vorrat",
        "liter",
        "kapazitaet",
        "lange abwesenheit"
      ]
    );

  const currentHasLargeCapacity =
    includesAny(
      currentSearchText,
      [
        "gross",
        "großer",
        "vorrat",
        "liter",
        "kapazitaet",
        "lange abwesenheit"
      ]
    );

  if (
    alternativeHasLargeCapacity &&
    !currentHasLargeCapacity
  ) {
    return {
      kind: "capacity",
      icon: "📦",
      headline:
        "Wenn du einen größeren Futtervorrat benötigst",
      reason:
        "Dieses Modell ist für längere Zeiträume ohne häufiges Nachfüllen interessanter.",
      difference:
        "Der größere Behälter reduziert den Aufwand bei längerer Abwesenheit oder mehreren täglichen Portionen."
    };
  }

  const alternativeHasCompactFocus =
    includesAny(
      alternativeText,
      [
        "kompakt",
        "klein",
        "platzsparend",
        "kleine wohnung"
      ]
    );

  const currentHasCompactFocus =
    includesAny(
      currentSearchText,
      [
        "kompakt",
        "klein",
        "platzsparend",
        "kleine wohnung"
      ]
    );

  if (
    alternativeHasCompactFocus &&
    !currentHasCompactFocus
  ) {
    return {
      kind: "compact",
      icon: "↘",
      headline:
        "Wenn du möglichst wenig Platz zur Verfügung hast",
      reason:
        "Dieses Modell ist kompakter und lässt sich leichter in kleinen Wohnbereichen aufstellen.",
      difference:
        "Der Schwerpunkt liegt stärker auf einer platzsparenden Bauform als auf maximalem Funktionsumfang."
    };
  }

  const alternativeHasValueFocus =
    includesAny(
      alternativeText,
      [
        "preis leistung",
        "preisleistung",
        "guenstig",
        "budget",
        "einsteiger"
      ]
    );

  if (
    alternativeHasValueFocus
  ) {
    return {
      kind: "value",
      icon: "💰",
      headline:
        "Wenn dir ein gutes Preis-Leistungs-Verhältnis wichtiger ist",
      reason:
        "Dieses Modell konzentriert sich stärker auf die wichtigsten Funktionen ohne unnötige Extras.",
      difference:
        "Du erhältst eine solide Grundausstattung, verzichtest aber möglicherweise auf einzelne Premiumfunktionen."
    };
  }

  const usefulBestFor =
    getUsefulBestFor(
      alternativeKey
    );

  if (
    usefulBestFor.length >
      0
  ) {
    return {
      kind:
        `best-for-${normalizeText(
          usefulBestFor[0]
        )}`,
      icon: "🎯",
      headline:
        `Wenn ${usefulBestFor[0].toLowerCase()} für dich im Mittelpunkt steht`,
      reason:
        alternative.recommendation,
      difference:
        "Diese Alternative setzt andere Prioritäten als das aktuell betrachtete Modell."
    };
  }

  return {
    kind: "general",
    icon: "↔",
    headline:
      "Wenn du ein anderes Gesamtpaket suchst",
    reason:
      alternative.recommendation,
    difference:
      "Dieses Modell bietet eine andere Kombination aus Ausstattung, Bedienung und Preis-Leistung."
  };
};

const candidateItems =
  currentProduct
    ? productKeys
        .filter(
          (
            candidateKey
          ) => {
            const candidate =
              products[
                candidateKey
              ];

            return (
              candidateKey !==
                currentProductKey &&
              candidate.category ===
                currentProduct.category
            );
          }
        )
        .sort(
          (
            a,
            b
          ) =>
            getWeightedProductScore(
              b
            ) -
            getWeightedProductScore(
              a
            )
        )
        .map(
          (
            productKey
          ): AlternativeItem => ({
            productKey,
            insight:
              getAlternativeInsight(
                productKey
              )
          })
        )
    : [];

const selectedAlternatives: AlternativeItem[] =
  [];

const selectedKinds =
  new Set<string>();

for (
  const candidate
  of candidateItems
) {
  if (
    selectedAlternatives.length >=
      limit
  ) {
    break;
  }

  if (
    !selectedKinds.has(
      candidate.insight.kind
    )
  ) {
    selectedAlternatives.push(
      candidate
    );

    selectedKinds.add(
      candidate.insight.kind
    );
  }
}

if (
  selectedAlternatives.length <
    limit
) {
  for (
    const candidate
    of candidateItems
  ) {
    if (
      selectedAlternatives.length >=
        limit
    ) {
      break;
    }

    const alreadySelected =
      selectedAlternatives.some(
        (
          selected
        ) =>
          selected.productKey ===
          candidate.productKey
      );

    if (
      !alreadySelected
    ) {
      selectedAlternatives.push(
        candidate
      );
    }
  }
}
---

{
  selectedAlternatives.length >
    0 ? (
    <div class="alternative-recommendation-grid">
      {
        selectedAlternatives.map(
          (
            item
          ) => {
            const alternative =
              products[
                item.productKey
              ];

            const alternativeImage =
              getProductHeroImage(
                alternative,
                getProjectImage(
                  DEFAULT_PROJECT,
                  "product"
                ),
                item.productKey
              );

            const alternativeScore =
              getWeightedProductScore(
                item.productKey
              );

            const usefulBestFor =
              getUsefulBestFor(
                item.productKey
              );

            return (
              <article class="alternative-recommendation-card">
                <a
                  class="alternative-recommendation-image"
                  href={
                    alternative.productUrl
                  }
                  aria-label={`${alternative.name} Test öffnen`}
                >
                  <ProductImage
                    image={
                      alternativeImage
                    }
                    alt={
                      alternative.name
                    }
                    loading="lazy"
                  />
                </a>

                <div class="alternative-recommendation-content">
                  <div class="alternative-recommendation-meta">
                    <span>
                      Wann stattdessen?
                    </span>

                    <strong>
                      {
                        alternativeScore
                      }
                      {" / 100"}
                    </strong>
                  </div>

                  <span
                    class="alternative-recommendation-icon"
                    aria-hidden="true"
                  >
                    {
                      item.insight
                        .icon
                    }
                  </span>

                  <p class="alternative-recommendation-headline">
                    {
                      item.insight
                        .headline
                    }
                  </p>

                  <h3>
                    <a
                      href={
                        alternative.productUrl
                      }
                    >
                      {
                        alternative.name
                      }
                    </a>
                  </h3>

                  <p class="alternative-recommendation-reason">
                    {
                      item.insight
                        .reason
                    }
                  </p>

                  <div class="alternative-recommendation-difference">
                    <strong>
                      Größter Unterschied
                    </strong>

                    <p>
                      {
                        item.insight
                          .difference
                      }
                    </p>
                  </div>

                  {
                    usefulBestFor.length >
                      0 && (
                      <ul class="alternative-recommendation-tags">
                        {
                          usefulBestFor.map(
                            (
                              tag
                            ) => (
                              <li>
                                {
                                  tag
                                }
                              </li>
                            )
                          )
                        }
                      </ul>
                    )
                  }

                  <div class="alternative-recommendation-footer">
                    <span>
                      {
                        alternative.rating
                      }
                      {" / 5"}
                    </span>

                    <a
                      href={
                        alternative.productUrl
                      }
                    >
                      Zum vollständigen Test

                      <span
                        aria-hidden="true"
                      >
                        →
                      </span>
                    </a>
                  </div>
                </div>
              </article>
            );
          }
        )
      }
    </div>
  ) : (
    <div class="alternative-recommendation-empty">
      <strong>
        Noch keine passende Alternative verfügbar
      </strong>

      <p>
        Für dieses Produkt ist derzeit noch kein ausreichend
        vergleichbares Modell vollständig bewertet.
      </p>
    </div>
  )
}

<style>
  .alternative-recommendation-grid {
    display: grid;
    grid-template-columns:
      repeat(
        3,
        minmax(0, 1fr)
      );
    gap: 1.25rem;
  }

  .alternative-recommendation-card {
    display: flex;
    min-width: 0;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid
      var(
        --product-border,
        #dce5e3
      );
    border-radius: 1.2rem;
    background:
      linear-gradient(
        145deg,
        rgba(
          24,
          116,
          59,
          0.05
        ),
        #ffffff 46%
      );
    box-shadow:
      0 12px 30px
        rgba(
          13,
          48,
          43,
          0.06
        );
  }

  .alternative-recommendation-image {
    display: grid;
    min-height: 14rem;
    overflow: hidden;
    place-items: center;
    background:
      linear-gradient(
        145deg,
        #f5f7f6,
        #ffffff
      );
  }

  .alternative-recommendation-image
    :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 16rem;
    padding: 1.2rem;
    object-fit: contain;
    transition:
      transform
      180ms
      ease;
  }

  .alternative-recommendation-image:hover
    :global(img) {
    transform:
      scale(
        1.025
      );
  }

  .alternative-recommendation-content {
    display: flex;
    min-width: 0;
    padding: 1.3rem;
    flex: 1;
    flex-direction: column;
  }

  .alternative-recommendation-meta {
    display: flex;
    margin-bottom: 0.9rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .alternative-recommendation-meta
    > span {
    color:
      var(
        --product-accent,
        #18743b
      );
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .alternative-recommendation-meta
    > strong {
    flex: 0 0 auto;
    padding:
      0.35rem
      0.55rem;
    border-radius: 999px;
    background:
      rgba(
        24,
        116,
        59,
        0.09
      );
    color:
      var(
        --product-accent-dark,
        #0f5a2b
      );
    font-size: 0.78rem;
  }

  .alternative-recommendation-icon {
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    margin-bottom: 0.8rem;
    place-items: center;
    border-radius: 0.8rem;
    background:
      rgba(
        24,
        116,
        59,
        0.09
      );
    font-size: 1.25rem;
  }

  .alternative-recommendation-headline {
    margin:
      0
      0
      0.75rem;
    color:
      var(
        --product-accent-dark,
        #0f5a2b
      );
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.45;
  }

  .alternative-recommendation-content
    h3 {
    margin:
      0
      0
      0.75rem;
    font-size: 1.35rem;
    line-height: 1.18;
    letter-spacing: -0.025em;
  }

  .alternative-recommendation-content
    h3
    a {
    color:
      var(
        --product-text,
        #0d302b
      );
    text-decoration: none;
  }

  .alternative-recommendation-content
    h3
    a:hover {
    color:
      var(
        --product-accent,
        #18743b
      );
  }

  .alternative-recommendation-reason {
    margin:
      0
      0
      1rem;
    color:
      var(
        --product-muted,
        #647579
      );
    line-height: 1.6;
  }

  .alternative-recommendation-difference {
    margin-bottom: 1rem;
    padding: 0.9rem;
    border-radius: 0.85rem;
    background:
      rgba(
        13,
        48,
        43,
        0.04
      );
  }

  .alternative-recommendation-difference
    strong {
    display: block;
    margin-bottom: 0.35rem;
    color:
      var(
        --product-text,
        #0d302b
      );
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .alternative-recommendation-difference
    p {
    margin: 0;
    color:
      var(
        --product-muted,
        #647579
      );
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .alternative-recommendation-tags {
    display: flex;
    margin:
      0
      0
      1rem;
    padding: 0;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
  }

  .alternative-recommendation-tags
    li {
    padding:
      0.35rem
      0.55rem;
    border: 1px solid
      var(
        --product-border,
        #dce5e3
      );
    border-radius: 999px;
    background: #ffffff;
    color:
      var(
        --product-text,
        #0d302b
      );
    font-size: 0.76rem;
    font-weight: 750;
  }

  .alternative-recommendation-footer {
    display: flex;
    margin-top: auto;
    padding-top: 1rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    border-top: 1px solid
      var(
        --product-border,
        #dce5e3
      );
  }

  .alternative-recommendation-footer
    > span {
    color:
      var(
        --product-text,
        #0d302b
      );
    font-size: 0.86rem;
    font-weight: 850;
  }

  .alternative-recommendation-footer
    a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color:
      var(
        --product-accent-dark,
        #0f5a2b
      );
    font-size: 0.87rem;
    font-weight: 850;
    text-decoration: none;
  }

  .alternative-recommendation-empty {
    padding: 1.5rem;
    border: 1px dashed
      var(
        --product-border,
        #dce5e3
      );
    border-radius: 1rem;
    background: #ffffff;
    text-align: center;
  }

  .alternative-recommendation-empty
    strong {
    display: block;
    margin-bottom: 0.4rem;
    color:
