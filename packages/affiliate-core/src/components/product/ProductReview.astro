---
import AlternativeRecommendationCard from "./AlternativeRecommendationCard.astro";
import OptimizedImage from "../OptimizedImage.astro";
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import type {
  AlternativeRecommendation
} from "./alternativeRecommendation.types";
import {
  stripLeadingIcon
} from "../../utils/content";

type ProductReviewData = {
  name: string;
  manufacturerLabel: string;
  category: string;
  recommendation: string;
  rating: number;
  score: number;
  capacity?: string;
  expandable?: string | boolean;
  useCase?: string;
  pros: string[];
  cons: string[];
  bestFor: string[];
  notFor: string[];
  ratings: Record<string, number>;
  specs: Array<{
    label: string;
    value: string | number | boolean;
  }>;
  review: {
    summary: string;
    verdict: string;
  };
  images: {
    hero: {
      src: ImageMetadata;
      alt: string;
    };
    gallery: Array<{
      src: ImageMetadata;
      alt: string;
    }>;
  };
  affiliate?: {
    url: string;
    label: string;
    rel: string;
    target: "_blank" | "_self";
  };
};

interface Props {
  product: ProductReviewData;
  alternativeRecommendations?: AlternativeRecommendation[];
  relatedContent?: unknown[];
}

const {
  product,
  alternativeRecommendations = []
} = Astro.props as Props;

const productHeroImage = product.images.hero;
const galleryImages = [
  productHeroImage,
  ...(product.images.gallery ?? [])
];

const optimizedGallery = await Promise.all(
  galleryImages.map(async (image) => {
    const main = await getImage({
      src: image.src,
      widths: [480, 768, 1024, 1200],
      sizes: "(max-width: 760px) 100vw, 46vw",
      quality: "high"
    });

    return {
      image,
      main
    };
  })
);

const [optimizedHero, ...optimizedProductGallery] =
  optimizedGallery;

const ratingLabels: Record<string, string> = {
  app: "App",
  portionierung: "Portionierung",
  reinigung: "Reinigung",
  zuverlaessigkeit: "Zuverlässigkeit",
  sicherheit: "Sicherheit",
  preisleistung: "Preis-Leistung",
  installation: "Installation",
  flexibility: "Flexibilität",
  pricePerformance: "Preis-Leistung",
  expandability: "Erweiterbarkeit",
  battery: "Akku",
  cleaning: "Reinigung",
  noise: "Lautstärke",
  safety: "Sicherheit"
};

const getRatingLabel = (key: string) =>
  ratingLabels[key] ??
  key
    .replace(/([a-z0-9])([A-Z])/g, "$1 $2")
    .replace(/[-_]+/g, " ")
    .replace(/\b\w/g, (character) =>
      character.toUpperCase()
    );

const ratingEntries = Object
  .entries(product.ratings ?? {})
  .filter(([, value]) => Number.isFinite(value));

const topMetrics = ratingEntries.slice(0, 3);

const specValue = (label: string) =>
  product.specs.find(
    (item) =>
      item.label.toLowerCase() === label.toLowerCase()
  )?.value;

const quickFacts = [
  {
    label: "Kapazität",
    value: product.capacity ?? specValue("Kapazität")
  },
  {
    label: "Steuerung",
    value:
      specValue("App-Steuerung") === "Ja"
        ? "WLAN & App"
        : specValue("App-Steuerung") ?? "Ohne App"
  },
  {
    label: "Portionen",
    value:
      specValue("Portionierung") ??
      specValue("Mahlzeiten")
  }
].filter((item) => item.value);

const scoreLabel =
  product.score >= 90
    ? "Hervorragend"
    : product.score >= 80
      ? "Sehr gut"
      : product.score >= 70
        ? "Gut"
        : product.score >= 60
          ? "Solide"
          : "Mit Einschränkungen";

const bestForItems = (product.bestFor ?? [])
  .map((item) => stripLeadingIcon(item).trim())
  .filter(Boolean);

const attentionItems = (product.notFor?.length
  ? product.notFor
  : product.cons
).map((item) => stripLeadingIcon(item).trim());

const displayHighlights = [
  ...product.pros,
  ...bestForItems
]
  .map((item) => stripLeadingIcon(item).trim())
  .filter(Boolean)
  .filter(
    (item, index, items) =>
      items.indexOf(item) === index
  )
  .slice(0, 5);
---

{
  product && (
    <article class="product-review-v4">
      <section class="product-hero-v4">
        <div
          class="product-hero-v4__media"
          data-product-gallery
        >
          <div class="product-hero-v4__image">
            <img
              src={optimizedHero.main.src}
              srcset={optimizedHero.main.srcSet.attribute}
              sizes="(max-width: 760px) 100vw, 46vw"
              width={productHeroImage.src.width}
              height={productHeroImage.src.height}
              alt={productHeroImage.alt || product.name}
              loading="eager"
              decoding="sync"
              fetchpriority="high"
            />

            <span class="product-hero-v4__badge">
              Unsere Empfehlung
            </span>
          </div>

          {
            optimizedProductGallery.length > 0 && (
              <div
                class="product-hero-v4__thumbs"
                aria-label={`Weitere Bilder von ${product.name}`}
              >
                <button
                  type="button"
                  class="product-hero-v4__thumb is-active"
                  aria-label="Hauptbild anzeigen"
                  aria-pressed="true"
                  data-product-gallery-src={
                    optimizedHero.main.src
                  }
                  data-product-gallery-srcset={
                    optimizedHero.main.srcSet.attribute
                  }
                >
                  <OptimizedImage
                    src={productHeroImage.src}
                    alt={`${product.name} Hauptbild`}
                    width={144}
                    height={108}
                    layout="fixed"
                  />
                </button>

                {
                  optimizedProductGallery.map(
                    ({ image, main }, index) => (
                      <button
                        type="button"
                        class="product-hero-v4__thumb"
                        aria-label={`Produktbild ${index + 2} anzeigen`}
                        aria-pressed="false"
                        data-product-gallery-src={main.src}
                        data-product-gallery-srcset={
                          main.srcSet.attribute
                        }
                      >
                        <OptimizedImage
                          src={image.src}
                          alt={
                            image.alt ||
                            `${product.name} Produktbild ${index + 2}`
                          }
                          width={144}
                          height={108}
                          layout="fixed"
                        />
                      </button>
                    )
                  )
                }
              </div>
            )
          }
        </div>

        <div class="product-hero-v4__content">
          <span class="product-hero-v4__eyebrow">
            Unsere Einschätzung
          </span>

          <h1>{product.name}</h1>

          <p class="product-hero-v4__summary">
            {product.review.summary}
          </p>

          <div class="product-hero-v4__tags">
            {
              [
                product.capacity,
                product.useCase,
                product.category
              ]
                .filter(Boolean)
                .slice(0, 3)
                .map((item) => <span>{item}</span>)
            }
          </div>

          <section
            class="product-verdict-v4"
            aria-label="Gesamtbewertung"
          >
            <div class="product-verdict-v4__top">
              <div>
                <span>Unsere Einschätzung</span>
                <h2>{scoreLabel}</h2>
              </div>

              <strong>
                {product.rating.toFixed(1).replace(".", ",")} / 5
              </strong>
            </div>

            <div
              class="product-verdict-v4__stars"
              aria-label={`${product.rating} von 5 Sternen`}
            >
              ★★★★★
            </div>

            <p>{product.review.verdict}</p>
          </section>

          {
            topMetrics.length > 0 && (
              <dl class="product-metrics-v4">
                {
                  topMetrics.map(([key, value]) => (
                    <div>
                      <dt>{getRatingLabel(key)}</dt>
                      <dd>
                        {Number(value)
                          .toFixed(1)
                          .replace(".", ",")} / 5
                      </dd>
                    </div>
                  ))
                }
              </dl>
            )
          }

          {
            product.affiliate?.url && (
              <>
                <a
                  class="product-cta-v4"
                  href={product.affiliate.url}
                  rel={product.affiliate.rel}
                  target={product.affiliate.target}
                >
                  <span>{product.affiliate.label}</span>
                  <span aria-hidden="true">→</span>
                </a>

                <p class="product-cta-v4__note">
                  Preise und Verfügbarkeit können sich ändern.
                </p>
              </>
            )
          }

          {
            displayHighlights.length > 0 && (
              <section class="product-highlights-v4">
                <h2>Das Wichtigste in Kürze</h2>

                <ul>
                  {
                    displayHighlights.map((item) => (
                      <li>
                        <span aria-hidden="true">✓</span>
                        <p>{item}</p>
                      </li>
                    ))
                  }
                </ul>
              </section>
            )
          }

          {
            quickFacts.length > 0 && (
              <dl class="product-facts-v4">
                {
                  quickFacts.map((item) => (
                    <div>
                      <dt>{item.label}</dt>
                      <dd>{String(item.value)}</dd>
                    </div>
                  ))
                }
              </dl>
            )
          }
        </div>
      </section>

      <section class="product-decision-v4">
        <header>
          <span>Entscheidungshilfe</span>
          <h2>Passt {product.name} zu mir?</h2>
          <p>
            Die wichtigsten Gründe für und gegen dieses
            Modell, ohne die Bewertung erneut zu wiederholen.
          </p>
        </header>

        <div class="product-decision-v4__grid">
          <article class="product-decision-v4__positive">
            <h3>Besonders geeignet</h3>
            <ul>
              {
                bestForItems.map((item) => (
                  <li>{item}</li>
                ))
              }
            </ul>
          </article>

          <article class="product-decision-v4__attention">
            <h3>Darauf solltest du achten</h3>
            <ul>
              {
                attentionItems.map((item) => (
                  <li>{item}</li>
                ))
              }
            </ul>
          </article>
        </div>
      </section>

      {
        ratingEntries.length > 0 && (
          <section class="product-ratings-v4">
            <header>
              <span>Detailbewertung</span>
              <h2>Wie gut ist {product.name}?</h2>
            </header>

            <div class="product-ratings-v4__grid">
              {
                ratingEntries.map(([key, value]) => (
                  <article>
                    <strong>{getRatingLabel(key)}</strong>
                    <span>
                      {Number(value)
                        .toFixed(1)
                        .replace(".", ",")} / 5
                    </span>
                  </article>
                ))
              }
            </div>
          </section>
        )
      }

      <section class="product-strengths-v4">
        <header>
          <span>Unsere Einordnung</span>
          <h2>Stärken und Schwächen</h2>
        </header>

        <div class="product-strengths-v4__grid">
          <article class="product-strengths-v4__positive">
            <h3>Stärken</h3>
            <ul>
              {
                product.pros.map((item) => (
                  <li>{stripLeadingIcon(item)}</li>
                ))
              }
            </ul>
          </article>

          <article class="product-strengths-v4__neutral">
            <h3>Schwächen</h3>
            <ul>
              {
                product.cons.map((item) => (
                  <li>{stripLeadingIcon(item)}</li>
                ))
              }
            </ul>
          </article>
        </div>
      </section>

      {
        alternativeRecommendations.length > 0 && (
          <section class="product-alternatives-v4">
            <header>
              <span>Alternativen</span>
              <h2>Welche Alternative passt besser?</h2>
            </header>

            <AlternativeRecommendationCard
              alternatives={alternativeRecommendations}
            />
          </section>
        )
      }

      <section class="product-specs-v4">
        <header>
          <span>Details</span>
          <h2>Technische Daten</h2>
        </header>

        <dl>
          {
            product.specs.map((spec) => (
              <div>
                <dt>{spec.label}</dt>
                <dd>{String(spec.value)}</dd>
              </div>
            ))
          }
        </dl>
      </section>
    </article>
  )
}

<script>
  document
    .querySelectorAll("[data-product-gallery]")
    .forEach((gallery) => {
      const image = gallery.querySelector(
        ".product-hero-v4__image img"
      );

      const buttons = gallery.querySelectorAll(
        "[data-product-gallery-src]"
      );

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(image instanceof HTMLImageElement)) {
            return;
          }

          const src =
            button.getAttribute(
              "data-product-gallery-src"
            );

          const srcset =
            button.getAttribute(
              "data-product-gallery-srcset"
            );

          if (src) image.src = src;
          if (srcset) image.srcset = srcset;

          buttons.forEach((item) => {
            item.classList.remove("is-active");
            item.setAttribute(
              "aria-pressed",
              "false"
            );
          });

          button.classList.add("is-active");
          button.setAttribute(
            "aria-pressed",
            "true"
          );
        });
      });
    });
</script>

<style>
  .product-review-v4 {
    --v4-ink: #0d3b35;
    --v4-text: #29403c;
    --v4-muted: #6a7d79;
    --v4-green: #0f765b;
    --v4-green-dark: #075944;
    --v4-border: #dce7e3;
    --v4-surface: #ffffff;
    --v4-soft: #f1f7f4;
    --v4-warm: #fff8ee;

    display: grid;
    gap: clamp(48px, 7vw, 88px);
    color: var(--v4-text);
  }

  .product-hero-v4 {
    overflow: hidden;
    border: 1px solid var(--v4-border);
    border-radius: 26px;
    background: var(--v4-surface);
    box-shadow: 0 16px 42px rgb(16 63 54 / 8%);
  }

  .product-hero-v4__image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #edf2ef;
  }

  .product-hero-v4__image > img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-hero-v4__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 10px 14px;
    border-radius: 12px;
    color: #fff;
    background: rgb(9 93 69 / 94%);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: 0 8px 22px rgb(0 0 0 / 16%);
  }

  .product-hero-v4__thumbs {
    display: flex;
    gap: 9px;
    padding: 12px;
    overflow-x: auto;
    border-top: 1px solid var(--v4-border);
  }

  .product-hero-v4__thumb {
    flex: 0 0 70px;
    height: 54px;
    overflow: hidden;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 10px;
    background: #fff;
    cursor: pointer;
  }

  .product-hero-v4__thumb.is-active {
    border-color: var(--v4-green);
  }

  .product-hero-v4__thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-hero-v4__content {
    padding: clamp(22px, 5vw, 46px);
  }

  .product-hero-v4__eyebrow,
  .product-decision-v4 header > span,
  .product-ratings-v4 header > span,
  .product-strengths-v4 header > span,
  .product-alternatives-v4 header > span,
  .product-specs-v4 header > span {
    display: block;
    margin-bottom: 8px;
    color: var(--v4-green);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .product-hero-v4 h1 {
    max-width: 17ch;
    margin: 0;
    color: var(--v4-ink);
    font-size: clamp(2.05rem, 8vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.048em;
    text-wrap: balance;
  }

  .product-hero-v4__summary {
    max-width: 44rem;
    margin: 18px 0 0;
    font-size: clamp(1.04rem, 3.7vw, 1.28rem);
    line-height: 1.6;
  }

  .product-hero-v4__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .product-hero-v4__tags span {
    padding: 8px 12px;
    border: 1px solid var(--v4-border);
    border-radius: 999px;
    color: var(--v4-text);
    background: #fff;
    font-size: 0.82rem;
    font-weight: 650;
  }

  .product-verdict-v4 {
    margin-top: 28px;
    padding: clamp(20px, 5vw, 28px);
    border-radius: 18px;
    color: #fff;
    background:
      radial-gradient(circle at 100% 0, rgb(255 255 255 / 13%), transparent 42%),
      linear-gradient(145deg, #147a5e, #075a46);
    box-shadow: 0 14px 30px rgb(8 90 69 / 18%);
  }

  .product-verdict-v4__top {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
  }

  .product-verdict-v4__top span {
    display: block;
    margin-bottom: 5px;
    color: rgb(255 255 255 / 75%);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-verdict-v4 h2 {
    margin: 0;
    font-size: clamp(1.75rem, 6vw, 2.55rem);
    line-height: 1;
  }

  .product-verdict-v4__stars {
    margin-top: 13px;
    color: #f5b720;
    font-size: 1.35rem;
    letter-spacing: 0.06em;
  }

  .product-verdict-v4 > p {
    margin: 13px 0 0;
    color: rgb(255 255 255 / 90%);
    line-height: 1.55;
  }

  .product-metrics-v4,
  .product-facts-v4 {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 12px 0 0;
    overflow: hidden;
    border: 1px solid var(--v4-border);
    border-radius: 14px;
    background: #fff;
  }

  .product-metrics-v4 div,
  .product-facts-v4 div {
    min-width: 0;
    padding: 14px 7px;
    text-align: center;
  }

  .product-metrics-v4 div + div,
  .product-facts-v4 div + div {
    border-left: 1px solid var(--v4-border);
  }

  .product-metrics-v4 dt,
  .product-facts-v4 dt {
    color: var(--v4-muted);
    font-size: 0.69rem;
  }

  .product-metrics-v4 dd,
  .product-facts-v4 dd {
    margin: 5px 0 0;
    color: var(--v4-ink);
    font-size: clamp(0.8rem, 3.3vw, 0.96rem);
    font-weight: 800;
    overflow-wrap: anywhere;
  }

  .product-cta-v4 {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    min-height: 54px;
    margin-top: 20px;
    padding: 14px 20px;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(
      135deg,
      var(--v4-green),
      var(--v4-green-dark)
    );
    font-weight: 800;
    text-align: center;
    text-decoration: none;
    box-shadow: 0 10px 24px rgb(15 118 91 / 20%);
  }

  .product-cta-v4__note {
    margin: 8px 0 0;
    color: var(--v4-muted);
    font-size: 0.75rem;
    text-align: center;
  }

  .product-highlights-v4 {
    margin-top: 31px;
  }

  .product-highlights-v4 h2 {
    margin: 0 0 15px;
    color: var(--v4-ink);
    font-size: 1.35rem;
  }

  .product-highlights-v4 ul {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-highlights-v4 li {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 11px;
    align-items: start;
  }

  .product-highlights-v4 li > span {
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    color: #fff;
    background: var(--v4-green);
    font-size: 0.76rem;
    font-weight: 900;
  }

  .product-highlights-v4 p {
    margin: 0;
    line-height: 1.48;
  }

  .product-facts-v4 {
    margin-top: 27px;
  }

  .product-decision-v4,
  .product-ratings-v4,
  .product-strengths-v4,
  .product-alternatives-v4,
  .product-specs-v4 {
    width: min(100%, 920px);
    margin-inline: auto;
  }

  .product-decision-v4 header,
  .product-ratings-v4 header,
  .product-strengths-v4 header,
  .product-alternatives-v4 header,
  .product-specs-v4 header {
    margin-bottom: 22px;
  }

  .product-decision-v4 h2,
  .product-ratings-v4 h2,
  .product-strengths-v4 h2,
  .product-alternatives-v4 h2,
  .product-specs-v4 h2 {
    margin: 0;
    color: var(--v4-ink);
    font-size: clamp(1.75rem, 5vw, 2.55rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
  }

  .product-decision-v4 header p {
    max-width: 45rem;
    margin: 12px 0 0;
    line-height: 1.6;
  }

  .product-decision-v4__grid,
  .product-strengths-v4__grid {
    display: grid;
    gap: 14px;
  }

  .product-decision-v4__grid article,
  .product-strengths-v4__grid article {
    padding: 22px;
    border: 1px solid var(--v4-border);
    border-radius: 18px;
  }

  .product-decision-v4__positive,
  .product-strengths-v4__positive {
    background: var(--v4-soft);
  }

  .product-decision-v4__attention,
  .product-strengths-v4__neutral {
    background: var(--v4-warm);
  }

  .product-decision-v4 h3,
  .product-strengths-v4 h3 {
    margin: 0 0 13px;
    color: var(--v4-ink);
  }

  .product-decision-v4 ul,
  .product-strengths-v4 ul {
    display: grid;
    gap: 9px;
    margin: 0;
    padding-left: 19px;
  }

  .product-ratings-v4__grid {
    display: grid;
    grid-template-columns: repeat(
      auto-fit,
      minmax(145px, 1fr)
    );
    gap: 10px;
  }

  .product-ratings-v4__grid article {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 15px 17px;
    border-bottom: 1px solid var(--v4-border);
  }

  .product-ratings-v4__grid article strong {
