---
import AlternativeRecommendationCard from "./AlternativeRecommendationCard.astro";
import ProductImage from "../ProductImage.astro";
import type {
  AlternativeRecommendation
} from "./alternativeRecommendation.types";

import {
  stripLeadingIcon
} from "../../utils/content";

type ProductReviewData = {
  name: string;
  manufacturerLabel: string;
  category: string;
  recommendation: string;
  rating: number;
  score: number;
  capacity?: string;
  expandable?: string | boolean;
  useCase?: string;
  pros: string[];
  cons: string[];
  bestFor: string[];
  notFor: string[];
  ratings: Record<string, number>;
  specs: Array<{
    label: string;
    value: string | number | boolean;
  }>;
  review: {
    summary: string;
    verdict: string;
  };
  images: {
    hero: {
      src: string;
      alt: string;
    };
    gallery: Array<{
      src: string;
      alt: string;
    }>;
  };
  affiliate?: {
    url: string;
    label: string;
    rel: string;
    target: "_blank" | "_self";
  };
};

interface Props {
  product: ProductReviewData;
  alternativeRecommendations?: AlternativeRecommendation[];
  relatedContent?: unknown[];
}

const {
  product,
  alternativeRecommendations = []
} = Astro.props as Props;

const productHeroImage =
  product.images.hero;

const productGallery =
  product.images.gallery.map(
    (image) => image.src
  );

const score = product.score;

const scoreLabel =
  score >= 90
    ? "Hervorragend"
    : score >= 80
      ? "Sehr gut"
      : score >= 70
        ? "Gut"
        : score >= 60
          ? "Solide"
          : "Mit Einschränkungen";

const primaryLink =
  product.affiliate ?? null;

const review = {
  summary: product.review.summary,
  verdict: product.review.verdict,
  pros: product.pros,
  cons: product.cons,
  bestFor: product.bestFor,
  notFor: product.notFor,
  ratings: product.ratings
};

const legacySpecs = [
      {
        label: "Hersteller",
        value:
          product.manufacturerLabel
      },
      {
        label: "Kategorie",
        value:
          product.category
      },
      {
        label: "Kapazität",
        value:
          product.capacity
      },
      {
        label: "Erweiterbar",
        value:
          product.expandable
      },
      {
        label: "Einsatzbereich",
        value:
          product.useCase
      },
      {
        label: "Bewertung",
        value:
          `${product.rating} / 5`
      }
    ];

const specs =
  product?.specs?.length
    ? product.specs
    : legacySpecs;

const ratingLabels:
  Record<string, string> = {
    installation:
      "Installation",

    app:
      "App",

    flexibility:
      "Flexibilität",

    pricePerformance:
      "Preis-Leistung",

    expandability:
      "Erweiterbarkeit",

    battery:
      "Akku",

    cleaning:
      "Reinigung",

    noise:
      "Lautstärke",

    safety:
      "Sicherheit",

    portionierung:
      "Portionierung",

    reinigung:
      "Reinigung",

    zuverlaessigkeit:
      "Zuverlässigkeit",

    preisleistung:
      "Preis-Leistung"
  };

const getRatingLabel = (
  key: string
) => {
  if (ratingLabels[key]) {
    return ratingLabels[key];
  }

  return key
    .replace(
      /([a-z0-9])([A-Z])/g,
      "$1 $2"
    )
    .replace(
      /[-_]+/g,
      " "
    )
    .trim()
    .replace(
      /\b\w/g,
      (character) =>
        character.toUpperCase()
    );
};

const ratingEntries =
  review?.ratings &&
  typeof review.ratings === "object" &&
  !Array.isArray(
    review.ratings
  )
    ? Object
        .entries(
          review.ratings
        )
        .filter(
          ([, rating]) =>
            Number.isFinite(
              rating
            )
        )
    : [];

const normalizedCons =
  Array.isArray(
    review?.cons
  )
    ? review.cons.map(
        (item) =>
          stripLeadingIcon(item)
            .trim()
            .toLowerCase()
      )
    : [];

const uniqueNotFor =
  Array.isArray(
    review?.notFor
  )
    ? review.notFor.filter(
        (item) => {
          const normalizedItem =
            stripLeadingIcon(
              item
            )
              .trim()
              .toLowerCase();

          return (
            normalizedItem.length >
              0 &&
            !normalizedCons.includes(
              normalizedItem
            )
          );
        }
      )
    : [];

const bestForItems =
  Array.isArray(
    review?.bestFor
  )
    ? review.bestFor
        .map(
          (item) =>
            stripLeadingIcon(
              item
            ).trim()
        )
        .filter(Boolean)
    : product?.useCase
      ? [
          product.useCase
        ]
      : [];

const attentionItems =
  uniqueNotFor.length > 0
    ? uniqueNotFor
    : Array.isArray(
          review?.cons
        )
      ? review.cons.slice(
          0,
          4
        )
      : [];



const stars = (
  rating: number
) => {
  const normalizedRating =
    Math.max(
      0,
      Math.min(
        5,
        Math.round(rating)
      )
    );

  return (
    "★".repeat(
      normalizedRating
    ) +
    "☆".repeat(
      5 -
        normalizedRating
    )
  );
};
---

{
  product &&
  review && (
    <article class="product-review-v3">
      <section class="product-review-hero-v3">
        <div class="product-review-hero-copy">
          <span class="product-review-eyebrow">
            Unsere Einschätzung
          </span>

          <h1>
            {product.name}
          </h1>

          <p class="product-review-hero-summary">
            {review.summary}
          </p>
<div class="product-review-hero-verdict">

  <span>
    Kurzfazit
  </span>

  <strong>
    {product.recommendation}
  </strong>

  <p>
    {review.verdict}
  </p>

</div>
          <div class="product-review-hero-rating">
            <div>
              <span
                class="product-review-stars"
                aria-hidden="true"
              >
                {stars(
                  product.rating
                )}
              </span>

              <strong>
                {product.rating}
                {" / 5"}
              </strong>
            </div>

            <small>
              Redaktionelle
              Produktbewertung
            </small>
          </div>

          <div class="product-review-hero-score">
            <div>
              <strong>
                {score}
              </strong>

              <span>
                von 100
              </span>
            </div>

            <p>
              {scoreLabel}
            </p>
          </div>

          {
            primaryLink &&
            primaryLink.url && (
              <a
                class="product-review-affiliate-cta"
                href={
                  primaryLink.url
                }
                rel={
                  primaryLink.rel
                }
                target={
                  primaryLink.target
                }
              >
                {
                  primaryLink.label
                }

                <span
                  aria-hidden="true"
                >
                  →
                </span>
              </a>
            )
          }
        </div>

        <div
          class="product-review-hero-image"
          data-product-gallery
        >
          <div class="product-review-gallery-main">
            <ProductImage
              image={
                productHeroImage
              }
              alt={
                product.name
              }
              loading="eager"
            />
          </div>

          {
            productGallery.length >
              0 && (
              <div
                class="product-review-gallery-thumbnails"
                aria-label={`Weitere Bilder von ${product.name}`}
              >
                <button
                  class="product-review-gallery-thumbnail is-active"
                  type="button"
                  aria-label="Hauptbild anzeigen"
                  aria-pressed="true"
                  data-product-gallery-src={
                    productHeroImage.src
                  }
                >
                  <ProductImage
                    image={
                      productHeroImage
                    }
                    alt={`${product.name} Hauptbild`}
                  />
                </button>

                {
                  productGallery.map(
                    (
                      image,
                      index
                    ) => (
                      <button
                        class="product-review-gallery-thumbnail"
                        type="button"
                        aria-label={`Produktbild ${index + 2} anzeigen`}
                        aria-pressed="false"
                        data-product-gallery-src={
                          image
                        }
                      >
                        <img
                          src={
                            image
                          }
                          alt={`${product.name} Produktbild ${index + 2}`}
                          loading="lazy"
                          decoding="async"
                          onerror="this.closest('button')?.remove()"
                        />
                      </button>
                    )
                  )
                }
              </div>
            )
          }
        </div>
      </section>

      <div
        class="product-review-divider"
        aria-hidden="true"
      >
        <span></span>

        <strong>
          🐾
        </strong>

        <span></span>
      </div>



      <section class="product-review-decision-v3">
        <div class="product-review-section-heading-v3">
          <span>
            Entscheidungshilfe
          </span>

          <h2>
            Passt {
              product.name
            } zu mir?
          </h2>

          <p>
            Die wichtigsten Punkte
            für eine schnelle
            Einschätzung vor dem
            Kauf.
          </p>
        </div>

        <div class="product-review-grid-v3">
          <div class="product-review-card-v3 product-review-card-positive-v3">
            <div class="product-review-card-heading-v3">
              <span
                aria-hidden="true"
              >
                ✓
              </span>

              <h3>
                Besonders geeignet
              </h3>
            </div>

            {
              bestForItems.length >
                0 ? (
                <ul>
                  {
                    bestForItems.map(
                      (
                        item
                      ) => (
                        <li class="product-review-list-item product-review-list-item-positive">
                          {
                            item
                          }
                        </li>
                      )
                    )
                  }
                </ul>
              ) : (
                <p>
                  {
                    product.useCase
                  }
                </p>
              )
            }
          </div>

          <div class="product-review-card-v3 product-review-card-neutral-v3">
            <div class="product-review-card-heading-v3">
              <span
                aria-hidden="true"
              >
                !
              </span>

              <h3>
                Darauf solltest
                du achten
              </h3>
            </div>

            <ul>
              {
                attentionItems.map(
                  (
                    item
                  ) => (
                    <li class="product-review-list-item product-review-list-item-negative">
                      {
                        stripLeadingIcon(
                          item
                        )
                      }
                    </li>
                  )
                )
              }
            </ul>
          </div>
        </div>
      </section>

      {
        ratingEntries.length >
          0 && (
          <section class="product-review-rating-section-v3">
            <div class="product-review-section-heading-v3">
              <span>
                Detailbewertung
              </span>

              <h2>
                Wie gut ist {
                  product.name
                }?
              </h2>
            </div>

            <div class="product-score-grid-v3">
              {
                ratingEntries.map(
                  (
                    [
                      key,
                      rating
                    ]
                  ) => (
                    <div class="product-score-card-v3">
                      <strong>
                        {
                          getRatingLabel(
                            key
                          )
                        }
                      </strong>

                      <span
                        aria-label={`${rating} von 5`}
                      >
                        {
                          stars(
                            rating
                          )
                        }
                      </span>

                      <small>
                        {
                          Number(
                            rating
                          ).toFixed(
                            1
                          )
                        }
                        {" / 5"}
                      </small>
                    </div>
                  )
                )
              }
            </div>
          </section>
        )
      }

      <section class="product-review-strengths-v3">
        <div class="product-review-section-heading-v3">
          <span>
            Unsere Einordnung
          </span>

          <h2>
            Stärken und
            Schwächen
          </h2>
        </div>

        <div class="product-review-grid-v3">
          <div class="product-review-card-v3 product-review-card-positive-v3">
            <div class="product-review-card-heading-v3">
              <span
                aria-hidden="true"
              >
                +
              </span>

              <h3>
                Stärken
              </h3>
            </div>

            <ul>
              {
                review.pros.map(
                  (
                    item
                  ) => (
                    <li class="product-review-list-item product-review-list-item-positive">
                      {
                        stripLeadingIcon(
                          item
                        )
                      }
                    </li>
                  )
                )
              }
            </ul>
          </div>

          <div class="product-review-card-v3 product-review-card-neutral-v3">
            <div class="product-review-card-heading-v3">
              <span
                aria-hidden="true"
              >
                !
              </span>

              <h3>
                Schwächen
              </h3>
            </div>

            <ul>
              {
                review.cons.map(
                  (
                    item
                  ) => (
                    <li class="product-review-list-item product-review-list-item-negative">
                      {
                        stripLeadingIcon(
                          item
                        )
                      }
                    </li>
                  )
                )
              }
            </ul>
          </div>
        </div>
      </section>

   <section class="product-review-experience-v3">

  <div class="product-review-section-heading-v3">

    <span>
      Alltag und Nutzung
    </span>

    <h2>
      Erfahrungen aus der Praxis
    </h2>

    <p>
      Unsere Einschätzung basiert auf Herstellerinformationen,
      Fachtests und wiederkehrenden Erfahrungen aus dem Alltag.
      Einzelne Bewertungen werden dabei nicht ungeprüft übernommen,
      sondern in den Gesamtkontext eingeordnet.
    </p>

  </div>

  <div class="product-review-experience-grid-v3">

    <div class="product-review-experience-card-v3 product-review-experience-summary-v3">

      <span
        class="product-review-experience-icon-v3"
        aria-hidden="true"
      >
        ⭐
      </span>

      <h3>
        Unsere Praxiseinschätzung
      </h3>

      <p>
        {review.verdict}
      </p>

    </div>

    <div class="product-review-experience-card-v3 product-review-experience-method-v3">

      <span
        class="product-review-experience-icon-v3"
        aria-hidden="true"
      >
        🔎
      </span>

      <h3>
        So bewerten wir Produkte
      </h3>

      <p>
        Unsere Bewertung kombiniert technische Eigenschaften,
        Praxiserfahrungen, Herstellerinformationen und
        wiederkehrende Rückmeldungen aus der Nutzung.
        Einzelne Kundenmeinungen werden nicht ungeprüft
        übernommen.
      </p>

    </div>

  </div>

</section>
<section class="product-review-alternatives-v3">
  <div class="product-review-section-heading-v3">
    <span>
      Alternativen
    </span>

    <h2>
      Welche Alternative passt besser?
    </h2>

    <p>
      Ein anderes Modell kann sinnvoller sein, wenn du
      andere Anforderungen an Futterart, App, Kamera,
      Zugangskontrolle oder Preis-Leistung hast.
    </p>
  </div>

<AlternativeRecommendationCard
  alternatives={alternativeRecommendations}
/>
  
</section>
      <section class="product-review-spec-section-v3">
        <div class="product-review-section-heading-v3">
          <span>
            Details
          </span>

          <h2>
            Technische Daten
          </h2>
        </div>

        <div class="product-review-specs-v3">
          {
            specs.map(
              (
                spec
              ) => (
                <div>
                  <strong>
                    {
                      spec.label
                    }
                  </strong>

                  <span>
                    {
                      spec.value
                    }
                  </span>
                </div>
              )
            )
          }
        </div>
      </section>

      <section class="product-review-final-verdict-v3">
        <span class="product-review-section-eyebrow">
          Unser Urteil
        </span>

        <h2>
          Lohnt sich {
            product.name
          }?
        </h2>

        <p>
          {review.verdict}
        </p>

        {
          primaryLink &&
          primaryLink.url && (
            <a
              class="product-review-affiliate-cta"
              href={
                primaryLink.url
              }
              rel={
                primaryLink.rel
              }
              target={
                primaryLink.target
              }
            >
              {
                primaryLink.label
              }

              <span
                aria-hidden="true"
              >
                →
              </span>
            </a>
          )
        }
      </section>

     
    </article>
  )
}

<script>
  const initializeProductGalleries =
    () => {
      document
        .querySelectorAll<HTMLElement>(
          "[data-product-gallery]"
        )
        .forEach(
          (
            gallery
          ) => {
            if (
              gallery
                .dataset
                .initialized ===
              "true"
            ) {
              return;
            }

            const mainImage =
              gallery.querySelector<HTMLImageElement>(
                ".product-review-gallery-main img"
              );

            const thumbnails =
              Array.from(
                gallery.querySelectorAll<HTMLButtonElement>(
                  ".product-review-gallery-thumbnail"
                )
              );

            if (
              !mainImage ||
              thumbnails.length ===
                0
            ) {
              return;
            }

            thumbnails.forEach(
              (
                thumbnail
              ) => {
                thumbnail.addEventListener(
                  "click",
                  () => {
                    const nextImage =
                      thumbnail
                        .dataset
                        .productGallerySrc;

                    if (
                      !nextImage
                    ) {
                      return;
                    }

                    mainImage.src =
                      nextImage;

                    mainImage.alt =
                      thumbnail.querySelector(
                        "img"
                      )?.alt ??
                      mainImage.alt;

                    thumbnails.forEach(
                      (
                        item
                      ) => {
                        const isActive =
                          item ===
                          thumbnail;

                        item.classList.toggle(
                          "is-active",
                          isActive
                        );

                        item.setAttribute(
                          "aria-pressed",
                          String(
                            isActive
                          )
                        );
                      }
                    );
                  }
                );
              }
            );

            gallery.dataset.initialized =
              "true";
          }
        );
    };

  initializeProductGalleries();

  document.addEventListener(
    "astro:page-load",
    initializeProductGalleries
  );
</script>

<style>
  .product-review-v3 {
    --product-accent: #18743b;
    --product-accent-dark: #0f5a2b;
    --product-accent-soft: rgba(24, 116, 59, 0.09);
    --product-warning-soft: rgba(196, 132, 31, 0.09);
    --product-text: #0d302b;
    --product-muted: #647579;
    --product-border: #dce5e3;

    color: var(--product-text);
  }

  .product-review-v3 *,
  .product-review-v3 *::before,
  .product-review-v3 *::after {
    box-sizing: border-box;
  }

  .product-review-hero-v3 {
    display: grid;
    grid-template-columns:
      minmax(0, 0.95fr)
      minmax(0, 1.05fr);
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid var(--product-border);
    border-radius: 1.75rem;
    background:
      linear-gradient(
        135deg,
        #ffffff,
        #f7faf8 55%,
        #f4eee7
      );
    box-shadow:
      0 22px 55px rgba(13, 48, 43, 0.1);
  }

  .product-review-hero-copy {
    display: flex;
    min-width: 0;
    padding:
      clamp(
        2rem,
        4vw,
        4rem
      );
    flex-direction: column;
    justify-content: center;
  }

  .product-review-eyebrow,
  .product-review-section-eyebrow {
    display: inline-block;
    width: fit-content;
    margin-bottom: 0.75rem;
    color: var(--product-accent);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .product-review-hero-copy h1 {
    margin: 0;
    color: var(--product-text);
    font-size:
      clamp(
        2.8rem,
        5vw,
        5.5rem
      );
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .product-review-hero-summary {
    max-width: 58ch;
    margin:
      1.5rem
      0
      0;
    color: var(--product-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

.product-review-hero-verdict {
  margin-top: 2rem;
  padding: 1.25rem;
  border-radius: 1rem;
  background:
    linear-gradient(
      145deg,
      rgba(24,116,59,.08),
      #fff
    );
  border: 1px solid var(--product-border);
}

.product-review-hero-verdict span {
  display: inline-block;
  margin-bottom: .5rem;
  color: var(--product-accent);
  font-size: .78rem;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.product-review-hero-verdict strong {
  display: block;
  margin-bottom: .75rem;
  color: var(--product-text);
  font-size: 1.35rem;
  line-height: 1.3;
}

.product-review-hero-verdict p {
  margin: 0;
  color: var(--product-muted);
  line-height: 1.7;
}
  
  .product-review-hero-rating {
    display: flex;
    margin-top: 1.5rem;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.85rem;
  }

  .product-review-hero-rating > div {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .product-review-stars {
    color: var(--product-accent);
    font-size: 1.12rem;
    letter-spacing: 0.08em;
  }

  .product-review-hero-rating strong {
    font-size: 1.05rem;
  }

  .product-review-hero-rating small {
    color: var(--product-muted);
  }

  .product-review-hero-score {
    display: flex;
    width: fit-content;
    margin-top: 1rem;
    padding:
      0.8rem
      1rem;
    align-items: center;
    gap: 1rem;
    border: 1px solid var(--product-border);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.82);
  }

  .product-review-hero-score > div {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .product-review-hero-score strong {
    font-size: 1.45rem;
  }

  .product-review-hero-score span,
  .product-review-hero-score p {
    color: var(--product-muted);
    font-size: 0.85rem;
  }

  .product-review-hero-score p {
    margin: 0;
    font-weight: 800;
  }

  .product-review-affiliate-cta {
    display: inline-flex;
    width: fit-content;
    min-height: 3.4rem;
    margin-top: 1.5rem;
    padding:
      0.85rem
      1.25rem;
    align-items: center;
    justify-content: center;
