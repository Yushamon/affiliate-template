---
import ProductBox from "../ProductBox.astro";
import { products, type ProductKey } from "@app/data/products";
import { productReviews } from "@app/data/productReviews";
import { stripLeadingIcon } from "../../utils/content";
import { getScoreLabel, getWeightedProductScore } from "@app/data/productScoring";
import { getPrimaryAffiliateLink } from "../../affiliate/affiliateEngine";
import { projectConfig } from "@app/project.config";
import { DEFAULT_PROJECT, getProjectImage } from "@app/data/projectImages";
import {
  getProductGallery,
  getProductHeroImage
} from "../../utils/productImages";
import ProductImage from "../ProductImage.astro";

interface Props {
  productKey: ProductKey;
}

const { productKey } = Astro.props;

const product = products[productKey];
const productHeroImage = product

  ? getProductHeroImage(

      product,

      getProjectImage(DEFAULT_PROJECT, "product"),

      productKey

    )

  : getProductHeroImage(

      {},

      getProjectImage(DEFAULT_PROJECT, "product")

    );

const productGallery = product

  ? getProductGallery(product, productKey)

  : [];
const score = product ? getWeightedProductScore(productKey) : 0;
const scoreLabel = getScoreLabel(score);
const primaryLink = product
  ? getPrimaryAffiliateLink(product, projectConfig.affiliate ?? {})
  : null;
const review = productReviews[productKey] ?? (product
  ? {
      summary: product.review.summary,
      verdict: product.review.verdict,
      pros: product.pros,
      cons: product.cons,
      bestFor: product.bestFor,
      notFor: product.notFor,
      ratings: product.ratings
    }
  : null);

const legacySpecs = product
  ? [
      { label: "Hersteller", value: product.manufacturerLabel },
      { label: "Kategorie", value: product.category },
      { label: "Kapazität", value: product.capacity },
      { label: "Erweiterbar", value: product.expandable },
      { label: "Einsatzbereich", value: product.useCase },
      { label: "Bewertung", value: `${product.rating} / 5` }
    ]
  : [];

const specs = product?.specs?.length ? product.specs : legacySpecs;

const ratingLabels: Record<string, string> = {
  installation: "Installation",
  app: "App",
  flexibility: "Flexibilität",
  pricePerformance: "Preis-Leistung",
  expandability: "Erweiterbarkeit",
  battery: "Akku",
  cleaning: "Reinigung",
  noise: "Lautstärke",
  safety: "Sicherheit",
  portionierung: "Portionierung",
  reinigung: "Reinigung",
  zuverlaessigkeit: "Zuverlässigkeit",
  preisleistung: "Preis-Leistung"
};

const getRatingLabel = (key: string) => {
  if (ratingLabels[key]) {
    return ratingLabels[key];
  }

  return key
    .replace(/([a-z0-9])([A-Z])/g, "$1 $2")
    .replace(/[-_]+/g, " ")
    .trim()
    .replace(/\b\w/g, (character) => character.toUpperCase());
};

const ratingEntries =
  review?.ratings &&
  typeof review.ratings === "object" &&
  !Array.isArray(review.ratings)
    ? Object.entries(review.ratings).filter(([, rating]) =>
        Number.isFinite(rating)
      )
    : [];
const normalizedCons = Array.isArray(review?.cons)
  ? review.cons.map((item) =>
      stripLeadingIcon(item).trim().toLowerCase()
    )
  : [];

const uniqueNotFor = Array.isArray(review?.notFor)
  ? review.notFor.filter((item) => {
      const normalizedItem = stripLeadingIcon(item)
        .trim()
        .toLowerCase();

      return (
        normalizedItem.length > 0 &&
        !normalizedCons.includes(normalizedItem)
      );
    })
  : [];
const stars = (rating: number) => {
  const normalizedRating = Math.max(0, Math.min(5, Math.round(rating)));

  return "★".repeat(normalizedRating) + "☆".repeat(5 - normalizedRating);
};

---

{product && review && (
  <article class="product-review-v3">
    <section class="product-review-hero-v3">
      <div class="product-review-hero-copy">
        <div class="article-category">
          Testbericht
        </div>

        <h1>
          {product.name}
        </h1>

        <p>
          {review.summary}
        </p>

        <div class="product-review-hero-meta">
          <div class="product-review-rating">
            <strong>
              {product.rating} / 5
            </strong>

            <span>
              Unsere Bewertung
            </span>
          </div>

          <div class="product-review-score">
            <strong>{score}</strong>
            <span>{scoreLabel}</span>
          </div>
        </div>

        {primaryLink && primaryLink.url && (
          <a
            class="product-review-affiliate-cta"
            href={primaryLink.url}
            rel={primaryLink.rel}
            target={primaryLink.target}
          >
            {primaryLink.label}
          </a>
        )}
      </div>

      <div class="product-review-hero-image" data-product-gallery>
  <div class="product-review-gallery-main">
    <ProductImage
      image={productHeroImage}
      alt={product.name}
      loading="eager"
    />
  </div>

  {productGallery.length > 0 && (
    <div
      class="product-review-gallery-thumbnails"
      aria-label={`Weitere Bilder von ${product.name}`}
    >
      <button
        class="product-review-gallery-thumbnail is-active"
        type="button"
        aria-label="Hauptbild anzeigen"
        aria-pressed="true"
        data-product-gallery-src={productHeroImage.src}
      >
        <ProductImage
          image={productHeroImage}
          alt={`${product.name} Hauptbild`}
        />
      </button>

      {productGallery.map((image, index) => (
        <button
          class="product-review-gallery-thumbnail"
          type="button"
          aria-label={`Produktbild ${index + 2} anzeigen`}
          aria-pressed="false"
          data-product-gallery-src={image}
        >
          <img
            src={image}
            alt={`${product.name} Produktbild ${index + 2}`}
            loading="lazy"
            decoding="async"
            onerror="this.closest('button')?.remove()"
          />
        </button>
      ))}
    </div>
  )}
</div>
    </section>

    <section class="product-verdict-v3">
      <span>
        Kurzfazit
      </span>

      <h2>
        {product.recommendation}
      </h2>

      <p>
        {review.verdict}
      </p>
    </section>

    {ratingEntries.length > 0 && (
      <section class="product-score-grid-v3">
        {ratingEntries.map(([key, rating]) => (
          <div>
            <strong>{getRatingLabel(key)}</strong>
            <span>{stars(rating)}</span>
          </div>
        ))}
      </section>
    )}

    <section class="product-review-grid-v3">
      <div class="product-review-card-v3">
        <h2>
          Vorteile
        </h2>

        <ul>
          {review.pros.map((item) => (
            <li class="product-review-list-item product-review-list-item-positive">
              {stripLeadingIcon(item)}
            </li>
          ))}
        </ul>
      </div>

      <div class="product-review-card-v3">
        <h2>
          Nachteile
        </h2>

        <ul>
          {review.cons.map((item) => (
            <li class="product-review-list-item product-review-list-item-negative">
              {stripLeadingIcon(item)}
            </li>
          ))}
        </ul>
      </div>
    </section>

       <section class="product-review-grid-v3">
      <div class="product-review-card-v3">
        <h2>Für wen geeignet</h2>

        <p>{product.useCase}</p>
      </div>

      {uniqueNotFor.length > 0 && (
        <div class="product-review-card-v3">
          <h2>
            Weniger geeignet für
          </h2>

          <ul>
            {uniqueNotFor.map((item) => (
              <li class="product-review-list-item product-review-list-item-negative">
                {stripLeadingIcon(item)}
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <section class="product-review-card-v3">
      <h2>
        Technische Daten
      </h2>

      <div class="product-review-specs-v3">
        {specs.map((spec) => (
          <div>
            <strong>{spec.label}</strong>
            <span>{spec.value}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="product-verdict-v3">
      <span>
        Unser Urteil
      </span>

      <h2>
        Lohnt sich {product.name}?
      </h2>

      <p>
        {review.verdict}
      </p>
    </section>

    <ProductBox
      productKey={productKey}
      currentProductKey={productKey}
    />
  </article>
)}
<script>
  const initializeProductGalleries = () => {
    document
      .querySelectorAll<HTMLElement>("[data-product-gallery]")
      .forEach((gallery) => {
        if (gallery.dataset.initialized === "true") {
          return;
        }

        const mainImage = gallery.querySelector<HTMLImageElement>(
          ".product-review-gallery-main img"
        );

        const thumbnails = Array.from(
          gallery.querySelectorAll<HTMLButtonElement>(
            ".product-review-gallery-thumbnail"
          )
        );

        if (!mainImage || thumbnails.length === 0) {
          return;
        }

        thumbnails.forEach((thumbnail) => {
          thumbnail.addEventListener("click", () => {
            const nextImage =
              thumbnail.dataset.productGallerySrc;

            if (!nextImage) {
              return;
            }

            mainImage.src = nextImage;
            mainImage.alt =
              thumbnail.querySelector("img")?.alt ??
              mainImage.alt;

            thumbnails.forEach((item) => {
              const isActive = item === thumbnail;

              item.classList.toggle(
                "is-active",
                isActive
              );

              item.setAttribute(
                "aria-pressed",
                String(isActive)
              );
            });
          });
        });

        gallery.dataset.initialized = "true";
      });
  };

  initializeProductGalleries();

  document.addEventListener(
    "astro:page-load",
    initializeProductGalleries
  );
</script>

<style>
  .product-review-gallery-main {
    display: grid;
    place-items: center;
  }

  .product-review-gallery-main :global(img) {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .product-review-gallery-thumbnails {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .product-review-gallery-thumbnail {
    padding: 0.35rem;
    border: 1px solid var(--border-color, #d9dee7);
    border-radius: 0.75rem;
    background: #fff;
    cursor: pointer;
  }

  .product-review-gallery-thumbnail.is-active {
    border-color: currentColor;
    box-shadow: 0 0 0 1px currentColor;
  }

  .product-review-gallery-thumbnail :global(img) {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: contain;
  }

  @media (max-width: 640px) {
    .product-review-gallery-thumbnails {
      gap: 0.5rem;
    }
  }
</style>