---
import type {
  ComparisonProduct,
  ComparisonRow
} from "../../comparison/model";

type Props = {
  products: ComparisonProduct[];
  rows: ComparisonRow[];
  initialVisibleProducts?: number;
};

const {
  products,
  rows,
  initialVisibleProducts = 5
} = Astro.props as Props;
---

<div class="comparison-desktop-table">
  <div class="comparison-section__head">
    <div>
      <span class="comparison-eyebrow">Merkmale gegenübergestellt</span>
      <h2>Direkter Vergleich</h2>
    </div>
    <p class="comparison-section__note">
      Standardmäßig werden die ersten {initialVisibleProducts} Modelle gezeigt.
    </p>
  </div>

  <div
    class="comparison-table-wrap"
    tabindex="0"
    aria-label="Horizontal scrollbarer Produktvergleich"
  >
    <table class="comparison-table">
      <caption class="sr-only">Direkter Produktvergleich</caption>
      <thead>
        <tr>
          <th scope="col">Kriterium</th>
          {products.map((product) => (
            <th
              scope="col"
              data-product-column={product.slug}
            >
              <a href={product.href}>{product.title}</a>
            </th>
          ))}
        </tr>
      </thead>

      <tbody>
        {rows.map((row) => (
          <tr
            data-comparison-row
            data-has-differences={String(row.hasDifferences)}
          >
            <th scope="row">
              <strong>{row.criterion.label}</strong>
              {row.criterion.description && (
                <small>{row.criterion.description}</small>
              )}
            </th>

            {products.map((product) => {
              const cell = row.cells.find(
                (entry) => entry.productSlug === product.slug
              );

              const value =
                cell?.value && cell.value !== "–"
                  ? cell.value
                  : "Keine Angabe";

              return (
                <td
                  data-label={product.title}
                  data-product-column={product.slug}
                >
                  {value}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
