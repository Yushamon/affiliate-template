---
import type {
  ComparisonProduct,
  ComparisonRow
} from "../../comparison/model";

type Props = {
  products: ComparisonProduct[];
  rows: ComparisonRow[];
};

const { products, rows } = Astro.props as Props;
---

{rows.length > 0 && (
  <section id="direktvergleich" class="comparison-section" aria-labelledby="comparison-table-title">
    <div class="comparison-section__head">
      <div>
        <span class="comparison-eyebrow">Merkmale gegenübergestellt</span>
        <h2 id="comparison-table-title">Direkter Vergleich</h2>
      </div>
      <p class="comparison-section__note">
        Fehlende Angaben werden nicht geschätzt.
      </p>
    </div>

    <div
      class="comparison-table-wrap"
      tabindex="0"
      aria-label="Horizontal scrollbarer Produktvergleich"
    >
      <table class="comparison-table">
        <caption class="sr-only">Direkter Produktvergleich</caption>
        <thead>
          <tr>
            <th scope="col">Kriterium</th>
            {products.map((product) => (
              <th scope="col">
                <a href={product.href}>{product.title}</a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th scope="row">
                <strong>{row.criterion.label}</strong>
                {row.criterion.description && (
                  <small>{row.criterion.description}</small>
                )}
              </th>

              {products.map((product) => {
                const cell = row.cells.find(
                  (entry) => entry.productSlug === product.slug
                );

                const value =
                  cell?.value && cell.value !== "–"
                    ? cell.value
                    : "Keine Angabe";

                return (
                  <td data-label={product.title}>{value}</td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}
