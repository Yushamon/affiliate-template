---
import type { ComparisonProduct } from "../../comparison/model";
import { getPriceDisplay } from "../../comparison/price";

type Props = {
  title: string;
  text: string;
  winner?: ComparisonProduct;
  alternative?: ComparisonProduct;
};

const {
  title,
  text,
  winner,
  alternative
} = Astro.props as Props;
---

<section class="comparison-verdict" aria-labelledby="comparison-verdict-title">
  <div class="comparison-verdict__copy">
    <span class="comparison-eyebrow">Redaktionelles Fazit</span>
    <h2 id="comparison-verdict-title">{title}</h2>
    <p>{text}</p>
  </div>

  {(winner || alternative) && (
    <div class="comparison-verdict__choices">
      {winner && (() => {
        const price = getPriceDisplay(winner.price);

        return (
          <article>
            <span>Unsere Empfehlung</span>
            <h3>{winner.title}</h3>
            {winner.recommendation && <p>{winner.recommendation}</p>}
            <div>
              <a
                href={winner.href}
                class="comparison-button comparison-button--secondary"
              >
                Test lesen
              </a>

              {price.url && (
                <a
                  href={price.url}
                  class="comparison-button"
                  rel={price.rel}
                  target={price.target}
                  data-affiliate-link
                >
                  {price.label}
                </a>
              )}
            </div>
          </article>
        );
      })()}

      {alternative && (
        <article>
          <span>Gute Alternative</span>
          <h3>{alternative.title}</h3>
          {alternative.recommendation && (
            <p>{alternative.recommendation}</p>
          )}
          <a href={alternative.href} class="comparison-text-link">
            Alternative ansehen
          </a>
        </article>
      )}
    </div>
  )}
</section>
