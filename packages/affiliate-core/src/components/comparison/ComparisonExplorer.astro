---
import type {
  ComparisonFilter,
  ComparisonProduct,
  ComparisonRow
} from "../../comparison/model";
import ComparisonFilterBar from "./ComparisonFilterBar.astro";
import ComparisonTable from "./ComparisonTable.astro";
import ComparisonMobileCards from "./ComparisonMobileCards.astro";

type Props = {
  products: ComparisonProduct[];
  rows: ComparisonRow[];
  filters: ComparisonFilter[];
  initialVisibleProducts?: number;
};

const {
  products,
  rows,
  filters,
  initialVisibleProducts = 5
} = Astro.props as Props;
---

<section
  id="direktvergleich"
  class="comparison-explorer"
  data-comparison-explorer
  data-initial-limit={initialVisibleProducts}
>
  <ComparisonFilterBar
    filters={filters}
    products={products}
  />

  <div class="comparison-explorer__toolbar">
    <label class="comparison-toggle">
      <input
        type="checkbox"
        data-differences-only
      />
      <span class="comparison-control-box" aria-hidden="true"></span>
      <span class="comparison-toggle__copy">
        <strong>Nur Unterschiede anzeigen</strong>
        <small>Identische Merkmale vorübergehend ausblenden</small>
      </span>
    </label>

    {products.length > initialVisibleProducts && (
      <button
        type="button"
        class="comparison-show-all"
        data-show-all-products
        aria-pressed="false"
      >
        Alle {products.length} Modelle anzeigen
      </button>
    )}
  </div>

  <ComparisonTable
    products={products}
    rows={rows}
    initialVisibleProducts={initialVisibleProducts}
  />

  <ComparisonMobileCards
    products={products}
    rows={rows}
    initialVisibleProducts={initialVisibleProducts}
  />

  <div
    class="comparison-empty-state"
    hidden
    data-comparison-empty
  >
    <h2>Keine passende Kombination gefunden</h2>
    <p>
      Entferne einen Filter, damit wieder Modelle erscheinen.
    </p>
  </div>
</section>

<script>
  document
    .querySelectorAll("[data-comparison-explorer]")
    .forEach((explorer) => {
      if (!(explorer instanceof HTMLElement)) return;

      const filterRoot = explorer.querySelector(
        "[data-comparison-filters]"
      );

      const productData = filterRoot instanceof HTMLElement &&
        filterRoot.dataset.products
        ? JSON.parse(filterRoot.dataset.products)
        : {};

      const inputs = Array.from(
        explorer.querySelectorAll(
          "input[data-filter-key]"
        )
      );

      const differencesToggle = explorer.querySelector(
        "[data-differences-only]"
      );

      const showAllButton = explorer.querySelector(
        "[data-show-all-products]"
      );

      const count = explorer.querySelector(
        "[data-comparison-result-count]"
      );

      const resetButton = explorer.querySelector(
        "[data-comparison-filter-reset]"
      );

      const emptyState = explorer.querySelector(
        "[data-comparison-empty]"
      );

      const initialLimit = Number(
        explorer.dataset.initialLimit ?? "5"
      );

      let showAll = false;

      const getSelected = () => {
        const selected = new Map();

        inputs.forEach((input) => {
          if (
            !(input instanceof HTMLInputElement) ||
            !input.checked
          ) {
            return;
          }

          const key = input.dataset.filterKey;
          if (!key) return;

          const current = selected.get(key) ?? [];
          selected.set(key, [...current, input.value]);
        });

        return selected;
      };

      const applyUrlFilters = () => {
        const params = new URLSearchParams(window.location.search);

        inputs.forEach((input) => {
          if (!(input instanceof HTMLInputElement)) return;
          const key = input.dataset.filterKey;
          if (!key) return;

          const values = [
            ...params.getAll(`filter-${key}`),
            ...params.getAll(key)
          ]
            .flatMap((value) => value.split(","))
            .map((value) => value.trim())
            .filter(Boolean);

          if (values.includes(input.value)) input.checked = true;
        });
      };

      const applyState = () => {
        const selected = getSelected();

        const matchingSlugs = Object.entries(productData)
          .filter(([, values]) =>
            Array.from(selected.entries()).every(
              ([key, selectedValues]) => {
                const productValues = values[key] ?? [];

                return selectedValues.some((value) =>
                  productValues.includes(value)
                );
              }
            )
          )
          .map(([slug]) => slug);

        const visibleSlugs = showAll
          ? matchingSlugs
          : matchingSlugs.slice(0, initialLimit);

        explorer
          .querySelectorAll("[data-product-column]")
          .forEach((element) => {
            if (!(element instanceof HTMLElement)) return;

            const slug = element.dataset.productColumn;
            element.hidden = !slug || !visibleSlugs.includes(slug);
          });

        explorer
          .querySelectorAll("[data-mobile-product]")
          .forEach((element) => {
            if (!(element instanceof HTMLElement)) return;

            const slug = element.dataset.mobileProduct;
            element.hidden = !slug || !visibleSlugs.includes(slug);
          });

        const differencesOnly =
          differencesToggle instanceof HTMLInputElement &&
          differencesToggle.checked;

        explorer
          .querySelectorAll("[data-comparison-row]")
          .forEach((row) => {
            if (!(row instanceof HTMLElement)) return;

            row.hidden =
              differencesOnly &&
              row.dataset.hasDifferences !== "true";
          });

        explorer
          .querySelectorAll("[data-mobile-criterion]")
          .forEach((criterion) => {
            if (!(criterion instanceof HTMLElement)) return;

            criterion.hidden =
              differencesOnly &&
              criterion.dataset.hasDifferences !== "true";
          });

        if (count) {
          count.textContent = String(matchingSlugs.length);
        }

        if (emptyState instanceof HTMLElement) {
          emptyState.hidden = matchingSlugs.length !== 0;
        }

        if (showAllButton instanceof HTMLButtonElement) {
          const hasMore = matchingSlugs.length > initialLimit;
          showAllButton.hidden = !hasMore;
          showAllButton.textContent = showAll
            ? `Nur Top ${initialLimit} anzeigen`
            : `Alle ${matchingSlugs.length} Modelle anzeigen`;
          showAllButton.setAttribute(
            "aria-pressed",
            String(showAll)
          );
        }
      };

      inputs.forEach((input) => {
        input.addEventListener("change", () => {
          showAll = false;
          applyState();
        });
      });

      differencesToggle?.addEventListener(
        "change",
        applyState
      );

      showAllButton?.addEventListener("click", () => {
        showAll = !showAll;
        applyState();
      });

      resetButton?.addEventListener("click", () => {
        inputs.forEach((input) => {
          if (input instanceof HTMLInputElement) {
            input.checked = false;
          }
        });

        showAll = false;
        applyState();
      });

      applyUrlFilters();
      applyState();
    });
</script>
