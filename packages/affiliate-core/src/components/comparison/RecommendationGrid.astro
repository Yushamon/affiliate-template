---
import OptimizedImage from "../OptimizedImage.astro";
import type { ComparisonProductView } from "./types";

type Props = {
  products: ComparisonProductView[];
  title?: string;
};

const {
  products,
  title = "Unsere Empfehlungen in Kürze"
} = Astro.props as Props;
---

<section class="comparison-section" aria-labelledby="comparison-recommendations-title">
  <div class="comparison-section__head">
    <div>
      <span class="comparison-eyebrow">Schnelle Orientierung</span>
      <h2 id="comparison-recommendations-title">{title}</h2>
    </div>
    <a href="#direktvergleich" class="comparison-text-link">Direkt vergleichen</a>
  </div>

  <div class="recommendation-grid">
    {products.map((product) => (
      <article class="recommendation-card">
        {product.badge && <span class="recommendation-card__badge">{product.badge}</span>}

        <a href={product.href} class="recommendation-card__image-link" tabindex="-1" aria-hidden="true">
          {product.image ? (
            <OptimizedImage
              src={product.image.src}
              alt={product.image.alt ?? product.title}
              class="recommendation-card__image"
              width={420}
              height={320}
              layout="constrained"
            />
          ) : (
            <div class="comparison-placeholder comparison-placeholder--product">
              <span aria-hidden="true">□</span>
            </div>
          )}
        </a>

        <div class="recommendation-card__content">
          {product.manufacturer && <span class="recommendation-card__manufacturer">{product.manufacturer}</span>}
          <h3><a href={product.href}>{product.title}</a></h3>
          {product.recommendation && <p>{product.recommendation}</p>}
          {typeof product.rating === "number" && (
            <strong class="recommendation-card__rating">
              {product.rating.toFixed(1)} / 5
              <span>Redaktionelle Bewertung</span>
            </strong>
          )}
        </div>

        <div class="recommendation-card__actions">
          <a href={product.href} class="comparison-button comparison-button--secondary">
            Test lesen
          </a>
          {product.affiliate && (
            <a
              href={product.affiliate.url}
              class="comparison-button"
              rel={product.affiliate.rel ?? "sponsored nofollow noopener"}
              target={product.affiliate.target ?? "_blank"}
              data-affiliate-link
            >
              {product.affiliate.label}
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>
