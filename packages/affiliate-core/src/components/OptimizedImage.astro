---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata | string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  layout?: "constrained" | "full-width" | "fixed" | "none";
  fit?: "cover" | "contain" | "fill" | "inside" | "outside";
  position?: string;
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
  priority?: boolean;
}

const {
  src,
  alt,
  class: className,
  width,
  height,
  widths,
  sizes,
  layout = "constrained",
  fit = "cover",
  position = "center",
  loading = "lazy",
  decoding = "async",
  priority = false
} = Astro.props;

const isLocalAsset = typeof src !== "string";
---

{
  isLocalAsset ? (
    <Image
      src={src as ImageMetadata}
      alt={alt}
      class={className}
      width={width}
      height={height}
      widths={widths}
      sizes={sizes}
      layout={layout}
      fit={fit}
      position={position}
      loading={priority ? undefined : loading}
      decoding={priority ? undefined : decoding}
      priority={priority}
    />
  ) : (
    <img
      src={src as string}
      alt={alt}
      class={className}
      width={width}
      height={height}
      loading={priority ? "eager" : loading}
      decoding={priority ? "sync" : decoding}
      fetchpriority={priority ? "high" : undefined}
    />
  )
}

