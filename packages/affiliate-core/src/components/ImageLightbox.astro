---
interface Props {
  selectors?: string[];
  excludeSelectors?: string[];
  hint?: string;
}

const {
  selectors = [
    ".article img",
    ".product-content img",
    ".comparison-content img",
    ".manufacturer-content img",
    "[data-lightbox-gallery] img",
  ],
  excludeSelectors = [
    ".article-hero-image",
    "a img",
    "button img",
    "dialog img",
    "[data-no-lightbox]",
  ],
  hint = "Zum Vergrößern öffnen",
} = Astro.props;

const selectorValue = selectors.join(",");
const excludeValue = excludeSelectors.join(",");
---

<dialog
  class="image-lightbox-v2"
  data-image-lightbox-v2
  data-selectors={selectorValue}
  data-excludes={excludeValue}
  aria-label="Bildanzeige"
>
  <div class="image-lightbox-v2__surface">
    <header class="image-lightbox-v2__toolbar">
      <p class="image-lightbox-v2__counter" data-lightbox-counter></p>

      <div class="image-lightbox-v2__actions">
        <button
          type="button"
          class="image-lightbox-v2__action"
          data-lightbox-reset
          aria-label="Zoom zurücksetzen"
          title="Zoom zurücksetzen"
        >
          1:1
        </button>

        <button
          type="button"
          class="image-lightbox-v2__action image-lightbox-v2__close"
          data-lightbox-close
          aria-label="Bildanzeige schließen"
          title="Schließen"
        >
          ×
        </button>
      </div>
    </header>

    <button
      type="button"
      class="image-lightbox-v2__nav image-lightbox-v2__nav--previous"
      data-lightbox-previous
      aria-label="Vorheriges Bild"
    >
      ‹
    </button>

    <div class="image-lightbox-v2__viewport" data-lightbox-viewport>
      <img
        class="image-lightbox-v2__image"
        data-lightbox-image
        alt=""
        decoding="async"
        draggable="false"
      />
    </div>

    <button
      type="button"
      class="image-lightbox-v2__nav image-lightbox-v2__nav--next"
      data-lightbox-next
      aria-label="Nächstes Bild"
    >
      ›
    </button>

    <footer class="image-lightbox-v2__footer">
      <p class="image-lightbox-v2__caption" data-lightbox-caption hidden></p>
      <p class="image-lightbox-v2__help">
        Pfeiltasten oder Wischen zum Wechseln · Doppeltippen zum Zoomen · Esc zum Schließen
      </p>
    </footer>
  </div>
</dialog>

<script define:vars={{ hint }}>
  const LIGHTBOX_READY = "imageLightboxV2Ready";

  const setupImageLightboxV2 = () => {
    const dialog = document.querySelector("[data-image-lightbox-v2]");

    if (!(dialog instanceof HTMLDialogElement)) {
      return;
    }

    const selector = dialog.dataset.selectors || "";
    const excludeSelector = dialog.dataset.excludes || "";
    const viewport = dialog.querySelector("[data-lightbox-viewport]");
    const preview = dialog.querySelector("[data-lightbox-image]");
    const caption = dialog.querySelector("[data-lightbox-caption]");
    const counter = dialog.querySelector("[data-lightbox-counter]");
    const previousButton = dialog.querySelector("[data-lightbox-previous]");
    const nextButton = dialog.querySelector("[data-lightbox-next]");
    const closeButton = dialog.querySelector("[data-lightbox-close]");
    const resetButton = dialog.querySelector("[data-lightbox-reset]");

    if (
      !(viewport instanceof HTMLElement) ||
      !(preview instanceof HTMLImageElement) ||
      !(caption instanceof HTMLElement) ||
      !(counter instanceof HTMLElement) ||
      !(previousButton instanceof HTMLButtonElement) ||
      !(nextButton instanceof HTMLButtonElement) ||
      !(closeButton instanceof HTMLButtonElement) ||
      !(resetButton instanceof HTMLButtonElement)
    ) {
      return;
    }

    let gallery = [];
    let activeIndex = -1;
    let activeTrigger = null;
    let scale = 1;
    let translateX = 0;
    let translateY = 0;
    let pointerStartX = 0;
    let pointerStartY = 0;
    let pointerLastX = 0;
    let pointerLastY = 0;
    let pointerMoved = false;

    const matchesExclude = (image) =>
      excludeSelector
        .split(",")
        .map((value) => value.trim())
        .filter(Boolean)
        .some((value) => {
          try {
            return image.matches(value) || Boolean(image.closest(value));
          } catch {
            return false;
          }
        });

    const collectGallery = () => {
      if (!selector) {
        return [];
      }

      return Array.from(document.querySelectorAll(selector)).filter(
        (node) =>
          node instanceof HTMLImageElement &&
          !matchesExclude(node) &&
          Boolean(node.currentSrc || node.src),
      );
    };

    const applyTransform = () => {
      preview.style.transform =
        `translate3d(${translateX}px, ${translateY}px, 0) scale(${scale})`;
      preview.classList.toggle("is-zoomed", scale > 1);
      resetButton.disabled = scale === 1;
    };

    const resetTransform = () => {
      scale = 1;
      translateX = 0;
      translateY = 0;
      applyTransform();
    };

    const preloadAdjacent = () => {
      if (gallery.length < 2 || activeIndex < 0) {
        return;
      }

      [-1, 1].forEach((offset) => {
        const index = (activeIndex + offset + gallery.length) % gallery.length;
        const source = gallery[index]?.currentSrc || gallery[index]?.src;

        if (source) {
          const image = new Image();
          image.src = source;
        }
      });
    };

    const renderActiveImage = () => {
      const sourceImage = gallery[activeIndex];

      if (!(sourceImage instanceof HTMLImageElement)) {
        return;
      }

      const source = sourceImage.currentSrc || sourceImage.src;
      const figureCaption = sourceImage
        .closest("figure")
        ?.querySelector("figcaption")
        ?.textContent
        ?.trim();
      const captionText = figureCaption || sourceImage.alt?.trim() || "";

      resetTransform();
      preview.src = source;
      preview.alt = sourceImage.alt || "";
      caption.textContent = captionText;
      caption.hidden = captionText.length === 0;
      counter.textContent =
        gallery.length > 1 ? `${activeIndex + 1} / ${gallery.length}` : "";
      previousButton.hidden = gallery.length < 2;
      nextButton.hidden = gallery.length < 2;
      preloadAdjacent();
    };

    const showAt = (index) => {
      if (!gallery.length) {
        return;
      }

      activeIndex = (index + gallery.length) % gallery.length;
      renderActiveImage();
    };

    const close = () => {
      if (dialog.open) {
        dialog.close();
      }
    };

    const open = (image) => {
      gallery = collectGallery();
      activeIndex = gallery.indexOf(image);

      if (activeIndex < 0) {
        return;
      }

      activeTrigger = image;
      renderActiveImage();
      dialog.showModal();
      document.documentElement.classList.add("has-image-lightbox-v2");
      closeButton.focus();
    };

    const markImages = () => {
      collectGallery().forEach((image) => {
        if (image.dataset.lightboxV2Ready === "true") {
          return;
        }

        image.dataset.lightboxV2Ready = "true";
        image.classList.add("image-lightbox-v2-trigger");
        image.tabIndex = image.tabIndex >= 0 ? image.tabIndex : 0;
        image.setAttribute("role", "button");
        image.setAttribute(
          "aria-label",
          `${image.alt || "Bild"}. ${hint}`,
        );
        image.setAttribute("title", hint);
      });
    };

    markImages();

    if (document.documentElement.dataset[LIGHTBOX_READY] === "true") {
      return;
    }

    document.documentElement.dataset[LIGHTBOX_READY] = "true";

    document.addEventListener("click", (event) => {
      const target = event.target;

      if (
        target instanceof HTMLImageElement &&
        target.classList.contains("image-lightbox-v2-trigger")
      ) {
        open(target);
      }
    });

    document.addEventListener("keydown", (event) => {
      const target = event.target;

      if (
        !dialog.open &&
        target instanceof HTMLImageElement &&
        target.classList.contains("image-lightbox-v2-trigger") &&
        (event.key === "Enter" || event.key === " ")
      ) {
        event.preventDefault();
        open(target);
        return;
      }

      if (!dialog.open) {
        return;
      }

      if (event.key === "ArrowLeft") {
        event.preventDefault();
        showAt(activeIndex - 1);
      } else if (event.key === "ArrowRight") {
        event.preventDefault();
        showAt(activeIndex + 1);
      } else if (event.key === "Escape") {
        close();
      }
    });

    previousButton.addEventListener("click", () => showAt(activeIndex - 1));
    nextButton.addEventListener("click", () => showAt(activeIndex + 1));
    closeButton.addEventListener("click", close);
    resetButton.addEventListener("click", resetTransform);

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) {
        close();
      }
    });

    preview.addEventListener("dblclick", () => {
      if (scale > 1) {
        resetTransform();
      } else {
        scale = 2;
        applyTransform();
      }
    });

    viewport.addEventListener("pointerdown", (event) => {
      pointerStartX = event.clientX;
      pointerStartY = event.clientY;
      pointerLastX = event.clientX;
      pointerLastY = event.clientY;
      pointerMoved = false;
      viewport.setPointerCapture(event.pointerId);
    });

    viewport.addEventListener("pointermove", (event) => {
      if (!viewport.hasPointerCapture(event.pointerId)) {
        return;
      }

      const deltaX = event.clientX - pointerLastX;
      const deltaY = event.clientY - pointerLastY;
      pointerLastX = event.clientX;
      pointerLastY = event.clientY;

      if (
        Math.abs(event.clientX - pointerStartX) > 6 ||
        Math.abs(event.clientY - pointerStartY) > 6
      ) {
        pointerMoved = true;
      }

      if (scale > 1) {
        translateX += deltaX;
        translateY += deltaY;
        applyTransform();
      }
    });

    viewport.addEventListener("pointerup", (event) => {
      if (viewport.hasPointerCapture(event.pointerId)) {
        viewport.releasePointerCapture(event.pointerId);
      }

      if (!pointerMoved || scale > 1) {
        return;
      }

      const deltaX = event.clientX - pointerStartX;
      const deltaY = event.clientY - pointerStartY;

      if (Math.abs(deltaY) > 110 && Math.abs(deltaY) > Math.abs(deltaX)) {
        close();
      } else if (Math.abs(deltaX) > 70 && gallery.length > 1) {
        showAt(activeIndex + (deltaX < 0 ? 1 : -1));
      }
    });

    dialog.addEventListener("close", () => {
      document.documentElement.classList.remove("has-image-lightbox-v2");
      preview.removeAttribute("src");
      preview.alt = "";
      caption.textContent = "";
      caption.hidden = true;
      counter.textContent = "";
      resetTransform();

      if (activeTrigger instanceof HTMLElement) {
        activeTrigger.focus();
      }

      activeTrigger = null;
      gallery = [];
      activeIndex = -1;
    });

    const observer = new MutationObserver(() => markImages());
    observer.observe(document.body, { childList: true, subtree: true });
  };

  setupImageLightboxV2();
  document.addEventListener("astro:page-load", setupImageLightboxV2);
</script>

<style is:global>
  .image-lightbox-v2-trigger {
    cursor: zoom-in;
    outline-offset: 5px;
  }

  .image-lightbox-v2-trigger:focus-visible {
    outline: 3px solid var(--primary-dark, #166534);
  }

  .has-image-lightbox-v2 {
    overflow: hidden;
  }

  .image-lightbox-v2 {
    width: 100%;
    max-width: none;
    height: 100%;
    max-height: none;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    overflow: hidden;
  }

  .image-lightbox-v2::backdrop {
    background: rgba(5, 10, 8, 0.92);
    backdrop-filter: blur(10px);
  }

  .image-lightbox-v2__surface {
    position: relative;
    display: grid;
    width: 100%;
    height: 100%;
    grid-template-rows: auto minmax(0, 1fr) auto;
    grid-template-columns: minmax(52px, 7vw) minmax(0, 1fr) minmax(52px, 7vw);
    color: white;
  }

  .image-lightbox-v2__toolbar {
    z-index: 3;
    display: flex;
    grid-column: 1 / -1;
    align-items: center;
    justify-content: space-between;
    min-height: 68px;
    padding: 10px clamp(12px, 3vw, 32px);
  }

  .image-lightbox-v2__counter {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 14px;
    font-weight: 700;
  }

  .image-lightbox-v2__actions {
    display: flex;
    gap: 8px;
  }

  .image-lightbox-v2__action,
  .image-lightbox-v2__nav {
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.24);
    color: white;
    background: rgba(7, 15, 11, 0.76);
    font: inherit;
    cursor: pointer;
    transition:
      background 160ms ease,
      transform 160ms ease,
      opacity 160ms ease;
  }

  .image-lightbox-v2__action {
    min-width: 44px;
    height: 44px;
    padding: 0 12px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 800;
  }

  .image-lightbox-v2__close {
    font-size: 30px;
    font-weight: 400;
    line-height: 1;
  }

  .image-lightbox-v2__action:hover,
  .image-lightbox-v2__nav:hover {
    background: rgba(255, 255, 255, 0.16);
  }

  .image-lightbox-v2__action:focus-visible,
  .image-lightbox-v2__nav:focus-visible {
    outline: 3px solid white;
    outline-offset: 3px;
  }

  .image-lightbox-v2__action:disabled {
    opacity: 0.45;
    cursor: default;
  }

  .image-lightbox-v2__viewport {
    position: relative;
    display: grid;
    min-width: 0;
    min-height: 0;
    grid-column: 2;
    place-items: center;
    overflow: hidden;
    touch-action: none;
    user-select: none;
  }

  .image-lightbox-v2__image {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 100%;
    object-fit: contain;
    border-radius: 16px;
    background: white;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.34);
    transform-origin: center center;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
    user-select: none;
    -webkit-user-drag: none;
  }

  .image-lightbox-v2__image.is-zoomed {
    cursor: grab;
    transition: none;
  }

  .image-lightbox-v2__nav {
    z-index: 2;
    align-self: center;
    width: 48px;
    height: 48px;
    border-radius: 999px;
    font-size: 38px;
    line-height: 1;
  }

  .image-lightbox-v2__nav--previous {
    grid-column: 1;
    justify-self: center;
  }

  .image-lightbox-v2__nav--next {
    grid-column: 3;
    justify-self: center;
  }

  .image-lightbox-v2__footer {
    z-index: 2;
    grid-column: 1 / -1;
    min-height: 78px;
    padding: 12px clamp(16px, 4vw, 48px) 18px;
    text-align: center;
  }

  .image-lightbox-v2__caption {
    max-width: 900px;
    margin: 0 auto 6px;
    color: white;
    font-size: 15px;
    line-height: 1.5;
  }

  .image-lightbox-v2__help {
    margin: 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: 12px;
    line-height: 1.4;
  }

  @media (max-width: 760px) {
    .image-lightbox-v2__surface {
      grid-template-columns: 46px minmax(0, 1fr) 46px;
    }

    .image-lightbox-v2__toolbar {
      min-height: 58px;
      padding: 8px 10px;
    }

    .image-lightbox-v2__action {
      min-width: 42px;
      height: 42px;
    }

    .image-lightbox-v2__viewport {
      grid-column: 1 / -1;
      padding: 0 8px;
    }

    .image-lightbox-v2__image {
      max-width: calc(100vw - 16px);
      max-height: calc(100dvh - 146px);
      border-radius: 12px;
    }

    .image-lightbox-v2__nav {
      position: absolute;
      bottom: 88px;
      width: 42px;
      height: 42px;
      font-size: 32px;
    }

    .image-lightbox-v2__nav--previous {
      left: 10px;
    }

    .image-lightbox-v2__nav--next {
      right: 10px;
    }

    .image-lightbox-v2__footer {
      min-height: 80px;
      padding: 10px 54px 16px;
    }

    .image-lightbox-v2__help {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .image-lightbox-v2__action,
    .image-lightbox-v2__nav,
    .image-lightbox-v2__image {
      transition: none;
    }
  }
</style>
