---
import type { ResolvedProductImage } from "../utils/productImages";
import type { ImageMetadata } from "astro";
import OptimizedImage from "./OptimizedImage.astro";

type CollectionImage = {
  src: ImageMetadata;
  alt?: string;
};

interface Props {
  image: ResolvedProductImage | CollectionImage;
  alt: string;
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
}

const {
  image,
  alt,
  loading = "lazy",
  decoding = "async"
} = Astro.props;

const isCollectionImage = typeof image.src !== "string";
const serializedFallbacks = JSON.stringify(
  "fallbacks" in image ? image.fallbacks : []
);
---

{
  isCollectionImage ? (
    <OptimizedImage
      src={image.src as ImageMetadata}
      alt={alt}
      loading={loading}
      decoding={decoding}
      layout="constrained"
    />
  ) : (
    <img
      src={image.src as string}
      alt={alt}
      loading={loading}
      decoding={decoding}
      data-product-image-fallbacks={serializedFallbacks}
      onerror="const candidates=JSON.parse(this.dataset.productImageFallbacks||'[]');const next=candidates.shift();this.dataset.productImageFallbacks=JSON.stringify(candidates);if(next){this.src=next}else{this.onerror=null}"
    />
  )
}
