diff --git a/packages/affiliate-core/src/components/ArticleImageLightbox.astro b/packages/affiliate-core/src/components/ArticleImageLightbox.astro
new file mode 100644
index 0000000..6e61174
--- /dev/null
+++ b/packages/affiliate-core/src/components/ArticleImageLightbox.astro
@@ -0,0 +1,197 @@
+---
+interface Props {
+  selector?: string;
+  hint?: string;
+}
+
+const {
+  selector = ".article-content img, .premium-v3-image img",
+  hint = "Zum Vergrößern antippen",
+} = Astro.props;
+
+const dialogId = "article-image-lightbox";
+---
+
+<dialog id={dialogId} class="article-image-lightbox" aria-label="Vergrößerte Infografik">
+  <div class="article-image-lightbox__surface">
+    <button class="article-image-lightbox__close" type="button" aria-label="Vergrößerte Ansicht schließen">
+      <span aria-hidden="true">×</span>
+    </button>
+    <div class="article-image-lightbox__viewport">
+      <img class="article-image-lightbox__image" src="" alt="" decoding="async" />
+    </div>
+    <p class="article-image-lightbox__caption" hidden></p>
+    <p class="article-image-lightbox__help">Mit zwei Fingern zoomen · Zum Schließen außerhalb des Bildes tippen</p>
+  </div>
+</dialog>
+
+<script define:vars={{ selector, dialogId, hint }}>
+  const enhanceArticleImages = () => {
+    const dialog = document.getElementById(dialogId);
+    if (!(dialog instanceof HTMLDialogElement)) return;
+
+    const lightboxImage = dialog.querySelector(".article-image-lightbox__image");
+    const caption = dialog.querySelector(".article-image-lightbox__caption");
+    const closeButton = dialog.querySelector(".article-image-lightbox__close");
+
+    if (!(lightboxImage instanceof HTMLImageElement) || !(caption instanceof HTMLParagraphElement) || !(closeButton instanceof HTMLButtonElement)) return;
+
+    let activeTrigger = null;
+    const closeDialog = () => dialog.open && dialog.close();
+    const openDialog = (image) => {
+      activeTrigger = image;
+      lightboxImage.src = image.currentSrc || image.src;
+      lightboxImage.alt = image.alt || "";
+      const figcaption = image.closest("figure")?.querySelector("figcaption");
+      const captionText = figcaption?.textContent?.trim() || image.alt?.trim() || "";
+      caption.textContent = captionText;
+      caption.hidden = !captionText;
+      dialog.showModal();
+      document.documentElement.classList.add("has-image-lightbox");
+      closeButton.focus();
+    };
+
+    document.querySelectorAll(selector).forEach((element) => {
+      if (!(element instanceof HTMLImageElement)) return;
+      if (element.dataset.lightboxReady === "true" || element.dataset.noLightbox === "true" || element.closest("a, button, dialog")) return;
+
+      element.dataset.lightboxReady = "true";
+      element.classList.add("zoomable-article-image");
+      element.tabIndex = 0;
+      element.setAttribute("role", "button");
+      element.setAttribute("aria-label", `${element.alt || "Infografik"}. ${hint}`);
+      element.setAttribute("title", hint);
+      element.addEventListener("click", () => openDialog(element));
+      element.addEventListener("keydown", (event) => {
+        if (event.key === "Enter" || event.key === " ") {
+          event.preventDefault();
+          openDialog(element);
+        }
+      });
+    });
+
+    if (dialog.dataset.listenersReady !== "true") {
+      dialog.dataset.listenersReady = "true";
+      closeButton.addEventListener("click", closeDialog);
+      dialog.addEventListener("click", (event) => event.target === dialog && closeDialog());
+      dialog.addEventListener("close", () => {
+        document.documentElement.classList.remove("has-image-lightbox");
+        lightboxImage.removeAttribute("src");
+        lightboxImage.alt = "";
+        caption.textContent = "";
+        caption.hidden = true;
+        if (activeTrigger instanceof HTMLElement) activeTrigger.focus();
+        activeTrigger = null;
+      });
+    }
+  };
+
+  enhanceArticleImages();
+  document.addEventListener("astro:page-load", enhanceArticleImages);
+</script>
+
+<style is:global>
+  .zoomable-article-image { cursor: zoom-in; outline-offset: 5px; }
+  .zoomable-article-image:focus-visible { outline: 3px solid var(--primary, #2e7d32); }
+  .article-content p:has(> .zoomable-article-image)::after,
+  .premium-v3-image:has(.zoomable-article-image)::after {
+    content: "Zum Vergrößern antippen";
+    display: block;
+    margin-top: 8px;
+    color: var(--muted);
+    font-size: 13px;
+    font-weight: 700;
+    line-height: 1.4;
+    text-align: center;
+    pointer-events: none;
+  }
+  .has-image-lightbox { overflow: hidden; }
+  .article-image-lightbox {
+    width: 100%;
+    max-width: none;
+    height: 100%;
+    max-height: none;
+    margin: 0;
+    padding: clamp(16px, 3vw, 32px);
+    border: 0;
+    background: transparent;
+    overflow: hidden;
+  }
+  .article-image-lightbox::backdrop {
+    background: rgba(8, 15, 12, 0.88);
+    backdrop-filter: blur(8px);
+  }
+  .article-image-lightbox__surface {
+    position: relative;
+    display: flex;
+    width: 100%;
+    height: 100%;
+    flex-direction: column;
+    align-items: center;
+    justify-content: center;
+  }
+  .article-image-lightbox__viewport {
+    display: flex;
+    width: 100%;
+    min-height: 0;
+    flex: 1;
+    align-items: center;
+    justify-content: center;
+    overflow: auto;
+    overscroll-behavior: contain;
+    -webkit-overflow-scrolling: touch;
+  }
+  .article-image-lightbox__image {
+    display: block;
+    width: auto;
+    max-width: 100%;
+    height: auto;
+    max-height: calc(100dvh - 150px);
+    object-fit: contain;
+    border-radius: 16px;
+    background: white;
+    touch-action: pinch-zoom;
+    user-select: none;
+    -webkit-user-drag: none;
+  }
+  .article-image-lightbox__close {
+    position: absolute;
+    z-index: 2;
+    top: 0;
+    right: 0;
+    display: grid;
+    width: 48px;
+    height: 48px;
+    place-items: center;
+    border: 1px solid rgba(255,255,255,.25);
+    border-radius: 999px;
+    color: white;
+    background: rgba(8,15,12,.82);
+    font: inherit;
+    font-size: 32px;
+    line-height: 1;
+    cursor: pointer;
+  }
+  .article-image-lightbox__close:focus-visible { outline: 3px solid white; outline-offset: 3px; }
+  .article-image-lightbox__caption {
+    max-width: 820px;
+    margin: 14px auto 0;
+    color: white;
+    font-size: 15px;
+    line-height: 1.5;
+    text-align: center;
+  }
+  .article-image-lightbox__help {
+    margin: 6px auto 0;
+    color: rgba(255,255,255,.7);
+    font-size: 12px;
+    line-height: 1.4;
+    text-align: center;
+  }
+  @media (max-width: 760px) {
+    .article-image-lightbox { padding: 12px; }
+    .article-image-lightbox__image { max-height: calc(100dvh - 130px); border-radius: 12px; }
+    .article-image-lightbox__close { top: 4px; right: 4px; width: 44px; height: 44px; }
+    .article-image-lightbox__help { font-size: 11px; }
+  }
+</style>
