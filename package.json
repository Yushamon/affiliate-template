{
  "name": "affiliate-sites-monorepo",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:balkonspeicher": "npm --workspace apps/balkonspeicher run dev",
    "build:balkonspeicher": "npm --workspace apps/balkonspeicher run build",
    "preview:balkonspeicher": "npm --workspace apps/balkonspeicher run preview",
    "dev:pfotentechnik": "npm --workspace apps/pfotentechnik run dev",
    "build:pfotentechnik": "npm --workspace apps/pfotentechnik run build",
    "preview:pfotentechnik": "npm --workspace apps/pfotentechnik run preview",
    "test:affiliate": "npm --workspace packages/affiliate-core test",
    "build": "npm run build:balkonspeicher && npm run build:pfotentechnik",
    "seo:audit": "node tools/seo-platform/audit.mjs",
    "seo:audit:strict": "node tools/seo-platform/audit.mjs --strict",
    "build:content-graph": "npm --workspace apps/pfotentechnik run build:content-graph",
    "audit:content-graph": "npm --workspace apps/pfotentechnik run audit:content-graph",
    "lint:content": "npm --workspace apps/pfotentechnik run lint:content",
    "lint:content:strict": "npm --workspace apps/pfotentechnik run lint:content:strict",
    "indexnow:pfotentechnik": "npm --workspace apps/pfotentechnik run indexnow:submit",
    "indexnow:pfotentechnik:all": "npm --workspace apps/pfotentechnik run indexnow:submit:all",
    "indexnow:status": "npm --workspace apps/pfotentechnik run indexnow:status",
    "gsc:setup": "npm --workspace apps/pfotentechnik run gsc:setup --",
    "gsc:test": "npm --workspace apps/pfotentechnik run gsc:test",
    "gsc:audit": "npm --workspace apps/pfotentechnik run gsc:audit",
    "gsc:report": "npm --workspace apps/pfotentechnik run gsc:report",
    "ratings:fix": "node apps/pfotentechnik/scripts/normalize-product-ratings.mjs",
    "ratings:check": "node apps/pfotentechnik/scripts/normalize-product-ratings.mjs --check",
    "gsc:sync": "npm --workspace apps/pfotentechnik run gsc:sync",
    "seo:sync": "npm --workspace apps/pfotentechnik run seo:sync"
  }
}
