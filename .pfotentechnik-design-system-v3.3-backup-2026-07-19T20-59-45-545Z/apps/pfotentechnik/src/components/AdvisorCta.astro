---
interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Noch unsicher, welcher Futterautomat passt?",
  text = "Der kostenlose Berater grenzt anhand von Tier, Futterart, Portionsgröße und gewünschten Funktionen die passende Gerätekategorie ein."
} = Astro.props;
---

<aside class="pt-advisor-cta" aria-labelledby="pt-advisor-cta-title">
  <div>
    <span>Interaktive Auswahlhilfe</span>
    <h2 id="pt-advisor-cta-title">{title}</h2>
    <p>{text}</p>
  </div>
  <a href="/berater/futterautomat/">Berater starten</a>
</aside>

<style>
  .pt-advisor-cta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    margin: 40px 0;
    padding: clamp(22px, 4vw, 34px);
    border: 1px solid var(--pt-theme-border, var(--border));
    border-radius: 24px;
    background: var(--pt-theme-surface-2, var(--surface-soft));
    color: var(--pt-theme-text-soft, var(--text));
  }

  .pt-advisor-cta div {
    max-width: 720px;
  }

  .pt-advisor-cta span {
    color: var(--pt-theme-accent, var(--primary));
    font-size: .78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .07em;
  }

  .pt-advisor-cta h2 {
    margin: 7px 0 9px;
    color: var(--pt-theme-text, var(--text));
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  .pt-advisor-cta p {
    margin: 0;
    color: var(--pt-theme-text-soft, var(--text));
    line-height: 1.6;
  }

  .pt-advisor-cta a {
    flex: 0 0 auto;
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    padding: 12px 19px;
    border-radius: 999px;
    background: var(--pt-theme-accent, var(--primary));
    color: var(--pt-theme-text-inverse, #fff);
    font-weight: 800;
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .pt-advisor-cta {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
