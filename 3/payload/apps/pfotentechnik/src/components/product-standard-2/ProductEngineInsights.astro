---
interface Props {
  benefits?: string[];
  warnings?: string[];
  targetGroups?: string[];
}

const {
  benefits = [],
  warnings = [],
  targetGroups = []
} = Astro.props;

const visibleBenefits = benefits.slice(0, 4);
const visibleWarnings = warnings.slice(0, 4);
const visibleGroups = targetGroups.slice(0, 5);

const hasContent =
  visibleBenefits.length ||
  visibleWarnings.length ||
  visibleGroups.length;
---

{hasContent > 0 && (
  <section class="engine-insights" aria-labelledby="engine-insights-title">
    <div class="engine-insights__heading">
      <span class="engine-insights__eyebrow">Automatisch eingeordnet</span>
      <h2 id="engine-insights-title">Was die Produktdaten für den Alltag bedeuten</h2>
    </div>

    <div class="engine-insights__grid">
      {visibleGroups.length > 0 && (
        <article class="engine-insights__card">
          <h3>Passende Zielgruppen</h3>
          <ul>
            {visibleGroups.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      )}

      {visibleBenefits.length > 0 && (
        <article class="engine-insights__card engine-insights__card--positive">
          <h3>Erkannte Stärken</h3>
          <ul>
            {visibleBenefits.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      )}

      {visibleWarnings.length > 0 && (
        <article class="engine-insights__card engine-insights__card--attention">
          <h3>Worauf du achten solltest</h3>
          <ul>
            {visibleWarnings.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      )}
    </div>
  </section>
)}

<style>
  .engine-insights {
    margin-block: clamp(22px, 4vw, 34px);
    padding: clamp(18px, 3vw, 28px);
    border: 1px solid var(--color-border, rgba(15, 23, 42, .12));
    border-radius: 22px;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--color-surface, #fff) 96%, #16a34a 4%),
        var(--color-surface, #fff)
      );
    box-shadow: 0 18px 45px rgba(15, 23, 42, .06);
  }

  .engine-insights__heading {
    display: grid;
    gap: 6px;
    margin-bottom: 18px;
  }

  .engine-insights__eyebrow {
    color: var(--color-success, #15803d);
    font-size: .78rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .engine-insights h2,
  .engine-insights h3 {
    margin: 0;
    color: var(--color-text, #111827);
  }

  .engine-insights h2 {
    font-size: clamp(1.25rem, 3vw, 1.65rem);
    line-height: 1.18;
  }

  .engine-insights h3 {
    font-size: 1rem;
  }

  .engine-insights__grid {
    display: grid;
    gap: 14px;
  }

  .engine-insights__card {
    padding: 16px;
    border: 1px solid var(--color-border, rgba(15, 23, 42, .12));
    border-radius: 16px;
    background: var(--color-surface-elevated, rgba(255, 255, 255, .72));
  }

  .engine-insights__card--positive {
    border-color: color-mix(in srgb, var(--color-success, #16a34a) 30%, transparent);
  }

  .engine-insights__card--attention {
    border-color: color-mix(in srgb, var(--color-warning, #f59e0b) 34%, transparent);
  }

  .engine-insights ul {
    display: grid;
    gap: 9px;
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
  }

  .engine-insights li {
    position: relative;
    padding-left: 22px;
    color: var(--color-text-muted, #475569);
    line-height: 1.5;
  }

  .engine-insights li::before {
    content: "•";
    position: absolute;
    left: 7px;
    color: var(--color-success, #16a34a);
    font-weight: 900;
  }

  @media (min-width: 760px) {
    .engine-insights__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  :global(html[data-theme="dark"]) .engine-insights,
  :global(.dark) .engine-insights {
    background:
      linear-gradient(
        145deg,
        rgba(22, 163, 74, .08),
        rgba(15, 23, 42, .62)
      );
    box-shadow: none;
  }

  :global(html[data-theme="dark"]) .engine-insights__card,
  :global(.dark) .engine-insights__card {
    background: rgba(15, 23, 42, .7);
  }
</style>
