---
import ProductReview from "@affiliate-core/components/product/ProductReview.astro";
import { normalizeProduct } from "../../lib/product-engine/normalizeProduct";

import ProductEngineInsights from "./ProductEngineInsights.astro";
import SuitabilityMatrix from "./SuitabilityMatrix.astro";
import ContextSpecs from "./ContextSpecs.astro";

interface Props {
  product: any;
  reviewProduct: any;
  alternativeRecommendations?: any[];
  debug?: boolean;
}

const {
  product,
  reviewProduct,
  alternativeRecommendations = [],
  debug = false
} = Astro.props;

const normalized = normalizeProduct(product);

const hasSuitability =
  normalized.suitability &&
  Object.keys(normalized.suitability).length > 0;

const hasContextSpecs =
  Array.isArray(normalized.contextSpecs) &&
  normalized.contextSpecs.length > 0;

const showDebug =
  debug === true &&
  import.meta.env.PUBLIC_PRODUCT_ENGINE_DEBUG === "true";
---

<div
  class="product-renderer"
  data-product-standard="2.3"
  data-product-source={normalized.source}
>
  <ProductReview
    product={reviewProduct}
    alternativeRecommendations={alternativeRecommendations}
  />

  <div class="product-renderer__engine-layer">
    <ProductEngineInsights
      benefits={normalized.intelligence.inferredBenefits}
      warnings={normalized.intelligence.inferredWarnings}
      targetGroups={normalized.intelligence.inferredTargetGroups}
    />

    {hasSuitability && (
      <SuitabilityMatrix suitability={normalized.suitability} />
    )}

    {hasContextSpecs && (
      <ContextSpecs specs={normalized.contextSpecs} />
    )}
  </div>

  {showDebug && (
    <details class="product-renderer-debug">
      <summary>Product Engine Debug</summary>
      <pre>{JSON.stringify(normalized, null, 2)}</pre>
    </details>
  )}
</div>

<style>
  .product-renderer {
    display: contents;
  }

  .product-renderer__engine-layer {
    display: grid;
    gap: 20px;
    margin-block: 24px;
  }

  .product-renderer-debug {
    margin-block: 24px;
    padding: 14px;
    border: 1px dashed currentColor;
    border-radius: 12px;
    opacity: .82;
  }

  .product-renderer-debug pre {
    overflow: auto;
    max-height: 420px;
    font-size: .72rem;
  }
</style>
