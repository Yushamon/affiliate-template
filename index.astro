---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import ProjectLayout from "../layouts/ProjectLayout.astro";
import HomePage from "@affiliate-core/components/home/HomePage.astro";
import petTechHeroImage from "../assets/images/project/pfotentechnik/pet-tech-hero.webp";
import { projectConfig } from "../project.config";
import { buildHomepageModel } from "../domain/home/buildHomepageModel";

const [products, comparisons, pages, manufacturers] = await Promise.all([
  getCollection("products"),
  getCollection("comparisons"),
  getCollection("pages"),
  getCollection("manufacturers")
]);

const model = buildHomepageModel({
  home: projectConfig.home,
  products,
  comparisons,
  pages,
  manufacturers
});

const optimizedOgImage = await getImage({
  src: petTechHeroImage,
  width: 1200,
  quality: "high"
});
---
<ProjectLayout
  title={projectConfig.home.seo.title}
  description={projectConfig.home.seo.description}
  canonical="/"
  ogImage={optimizedOgImage.src}
  schemaType="website"
  includeBreadcrumbSchema={false}
>
  <HomePage model={model} />
</ProjectLayout>
