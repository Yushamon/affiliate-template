---
import AffiliateLayout from "@affiliate-core/layouts/AffiliateLayout.astro";
import "../styles/pfotentechnik.css";
import "../styles/pfotentechnik-brand-system.css";
import { getNavigationItems } from "@app/domain/content";
import ImageLightbox from "@affiliate-core/components/ImageLightbox.astro";

const props = Astro.props;
const headerLinks = await getNavigationItems();
const webAnalyticsToken = import.meta.env.CLOUDFLARE_WEB_ANALYTICS_TOKEN?.trim();
const requestedCanonical = props.canonical ?? "/";
const canonical =
  requestedCanonical === "/" || requestedCanonical.endsWith("/")
    ? requestedCanonical
    : `${requestedCanonical}/`;
---

<AffiliateLayout
  {...props}
  canonical={canonical}
  webAnalyticsToken={webAnalyticsToken}
  headerLinks={headerLinks}
>
  <slot />
  <ImageLightbox />
</AffiliateLayout>
