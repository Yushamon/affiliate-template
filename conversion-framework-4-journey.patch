diff --git a/apps/pfotentechnik/src/components/ConversionJourney.astro b/apps/pfotentechnik/src/components/ConversionJourney.astro
new file mode 100644
index 0000000..cf40001
--- /dev/null
+++ b/apps/pfotentechnik/src/components/ConversionJourney.astro
@@ -0,0 +1,193 @@
+---
+type JourneyItem = {
+  href: string;
+  label: string;
+  title: string;
+  text?: string;
+};
+
+interface Props {
+  eyebrow?: string;
+  title?: string;
+  text?: string;
+  items: JourneyItem[];
+}
+
+const {
+  eyebrow = "Nächster Schritt",
+  title = "So gehst du sinnvoll weiter",
+  text =
+    "Vertiefe nur den Schritt, der für deine Entscheidung noch fehlt.",
+  items
+} = Astro.props as Props;
+
+const visibleItems = items
+  .filter(
+    (item, index, allItems) =>
+      item.href &&
+      allItems.findIndex(
+        (candidate) =>
+          candidate.href === item.href
+      ) === index
+  )
+  .slice(0, 3);
+---
+
+{visibleItems.length > 0 && (
+  <nav
+    class="pt-conversion-journey"
+    aria-label="Empfohlene nächste Schritte"
+  >
+    <header>
+      <span>{eyebrow}</span>
+      <h2>{title}</h2>
+      <p>{text}</p>
+    </header>
+
+    <ol>
+      {visibleItems.map((item, index) => (
+        <li>
+          <a href={item.href}>
+            <span
+              class="pt-conversion-journey__number"
+              aria-hidden="true"
+            >
+              {index + 1}
+            </span>
+            <span class="pt-conversion-journey__content">
+              <small>{item.label}</small>
+              <strong>{item.title}</strong>
+              {item.text && <p>{item.text}</p>}
+            </span>
+            <span
+              class="pt-conversion-journey__arrow"
+              aria-hidden="true"
+            >
+              →
+            </span>
+          </a>
+        </li>
+      ))}
+    </ol>
+  </nav>
+)}
+
+<style>
+  .pt-conversion-journey {
+    margin: 56px auto;
+    padding: clamp(24px, 4vw, 42px);
+    border-radius: 28px;
+    background:
+      linear-gradient(
+        135deg,
+        rgba(46, 125, 50, 0.08),
+        rgba(79, 70, 229, 0.06)
+      );
+  }
+
+  .pt-conversion-journey header {
+    max-width: 760px;
+    margin-bottom: 24px;
+  }
+
+  .pt-conversion-journey header > span {
+    display: block;
+    margin-bottom: 8px;
+    font-size: 0.78rem;
+    font-weight: 800;
+    letter-spacing: 0.08em;
+    text-transform: uppercase;
+    color: #2e7d32;
+  }
+
+  .pt-conversion-journey h2 {
+    margin: 0 0 10px;
+    font-size: clamp(1.65rem, 3vw, 2.4rem);
+    line-height: 1.12;
+  }
+
+  .pt-conversion-journey header p {
+    margin: 0;
+    color: #475569;
+    line-height: 1.65;
+  }
+
+  .pt-conversion-journey ol {
+    margin: 0;
+    padding: 0;
+    list-style: none;
+    display: grid;
+    gap: 12px;
+  }
+
+  .pt-conversion-journey a {
+    display: grid;
+    grid-template-columns: auto 1fr auto;
+    gap: 16px;
+    align-items: center;
+    padding: 18px;
+    border: 1px solid rgba(15, 23, 42, 0.1);
+    border-radius: 18px;
+    background: #ffffff;
+    color: inherit;
+    text-decoration: none;
+    transition:
+      transform 160ms ease,
+      border-color 160ms ease,
+      box-shadow 160ms ease;
+  }
+
+  .pt-conversion-journey a:hover,
+  .pt-conversion-journey a:focus-visible {
+    transform: translateY(-2px);
+    border-color: rgba(46, 125, 50, 0.35);
+    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.08);
+  }
+
+  .pt-conversion-journey__number {
+    width: 36px;
+    height: 36px;
+    display: grid;
+    place-items: center;
+    border-radius: 999px;
+    background: #2e7d32;
+    color: #ffffff;
+    font-weight: 800;
+  }
+
+  .pt-conversion-journey__content {
+    min-width: 0;
+    display: grid;
+    gap: 3px;
+  }
+
+  .pt-conversion-journey small {
+    color: #64748b;
+    font-weight: 700;
+  }
+
+  .pt-conversion-journey strong {
+    font-size: 1.04rem;
+  }
+
+  .pt-conversion-journey__content p {
+    margin: 2px 0 0;
+    color: #475569;
+    line-height: 1.5;
+  }
+
+  .pt-conversion-journey__arrow {
+    font-size: 1.4rem;
+    color: #2e7d32;
+  }
+
+  @media (max-width: 640px) {
+    .pt-conversion-journey a {
+      grid-template-columns: auto 1fr;
+    }
+
+    .pt-conversion-journey__arrow {
+      display: none;
+    }
+  }
+</style>
