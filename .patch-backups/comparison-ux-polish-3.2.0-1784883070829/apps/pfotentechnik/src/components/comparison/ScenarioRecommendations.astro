---
import type { ComparisonViewModel } from "@affiliate-core/comparison/model";

type Props = {
  scenarios: NonNullable<ComparisonViewModel["scenarioRecommendations"]>;
};

const { scenarios } = Astro.props;
---

{scenarios.length > 0 && (
  <section class="scenario-recommendations" aria-labelledby="scenario-title">
    <div class="scenario-heading">
      <span>Automatisch eingeordnet</span>
      <h2 id="scenario-title">Empfehlungen nach Einsatzzweck</h2>
      <p>Die Auswahl berücksichtigt die gepflegten Produktdaten und die Anforderungen des jeweiligen Szenarios.</p>
    </div>

    <div class="scenario-grid">
      {scenarios.map((scenario) => (
        <article class="scenario-card">
          <p class="scenario-label">{scenario.label}</p>
          <h3>
            <a href={scenario.winner.href}>{scenario.winner.title}</a>
          </h3>
          <p>{scenario.reason}</p>
          <div class="scenario-meta">
            <span>Score {Math.round(scenario.score)}</span>
            {scenario.alternative && (
              <a href={scenario.alternative.href}>
                Alternative: {scenario.alternative.title}
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .scenario-recommendations {
    width: min(100%, 1180px);
    margin: clamp(2.5rem, 6vw, 5rem) auto;
    padding-inline: clamp(1rem, 3vw, 1.5rem);
  }
  .scenario-heading {
    max-width: 760px;
    margin-bottom: 1.5rem;
  }
  .scenario-heading > span,
  .scenario-label {
    font-size: .78rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--color-primary, #2e7d32);
  }
  .scenario-heading h2 {
    margin: .35rem 0 .6rem;
  }
  .scenario-heading p,
  .scenario-card p {
    color: var(--color-text-muted, #5f6368);
  }
  .scenario-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
    gap: 1rem;
  }
  .scenario-card {
    padding: 1.25rem;
    border: 1px solid var(--color-border, rgba(127, 127, 127, .25));
    border-radius: 1rem;
    background: var(--color-surface, #fff);
    box-shadow: 0 10px 30px rgba(0, 0, 0, .05);
  }
  .scenario-card h3 {
    margin: .3rem 0 .65rem;
    font-size: 1.08rem;
  }
  .scenario-card h3 a,
  .scenario-meta a {
    color: inherit;
  }
  .scenario-meta {
    display: flex;
    flex-wrap: wrap;
    gap: .55rem 1rem;
    margin-top: 1rem;
    font-size: .86rem;
    font-weight: 700;
  }
</style>
