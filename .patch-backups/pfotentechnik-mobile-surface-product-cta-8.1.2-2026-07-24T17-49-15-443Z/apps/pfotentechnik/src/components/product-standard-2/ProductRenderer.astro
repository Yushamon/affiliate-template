---
interface Props {
  product: any;
  reviewProduct: any;
  alternativeRecommendations?: any[];
  debug?: boolean;
}

const {
  product,
  reviewProduct,
  alternativeRecommendations = []
} = Astro.props;

const source = product?.data ?? product ?? {};
const value = reviewProduct ?? {};

const list = <T,>(input: T[] | null | undefined): T[] =>
  Array.isArray(input) ? input : [];

const asText = (input: unknown, fallback = ""): string => {
  if (typeof input === "string") return input.trim();
  if (typeof input === "number") return String(input);
  if (input && typeof input === "object") {
    const candidate =
      (input as any).label ??
      (input as any).name ??
      (input as any).title ??
      (input as any).value;
    return candidate == null ? fallback : String(candidate).trim();
  }
  return fallback;
};

const imageUrl = (input: any): string => {
  if (!input) return "";
  if (typeof input === "string") return input;
  if (typeof input.src === "string") return input.src;
  if (input.src && typeof input.src.src === "string") return input.src.src;
  if (typeof input.url === "string") return input.url;
  return "";
};

const name = asText(value.name ?? source.title, "Produkt");
const manufacturer = asText(
  value.manufacturerLabel ??
  source.manufacturer?.name ??
  source.manufacturer
);
const manufacturerSlug = asText(
  source.manufacturer?.slug ??
  source.manufacturer?.key
);
const manufacturerHref = manufacturerSlug
  ? `/hersteller/${manufacturerSlug}/`
  : "";

const category = asText(
  value.category ??
  source.category?.label ??
  source.category
);

const categoryHref = asText(
  value.categoryHref ??
  source.category?.path
);
const recommendation = asText(
  value.recommendation ??
  source.recommendation ??
  source.description
);
const description = asText(source.description ?? recommendation);

const rating = Number(value.rating ?? source.rating ?? 0);
const rawEditorialScore = Number(value.score ?? source.score ?? 0);
const editorialScore =
  rawEditorialScore > 0 && rawEditorialScore <= 10
    ? Math.round(rawEditorialScore * 10)
    : Math.max(0, Math.min(100, Math.round(rawEditorialScore)));
const ratingCount = Number(
  source.ratingCount ??
  source.reviewCount ??
  source.ratingsCount ??
  0
);

const rawHero =
  value.images?.hero ??
  source.images?.hero ??
  source.heroImage ??
  source.image;

const galleryEntries = [
  rawHero,
  ...list<any>(value.images?.gallery ?? source.images?.gallery)
];

const gallery = galleryEntries
  .map((entry: any, index: number) => ({
    src: imageUrl(entry),
    alt:
      asText(entry?.alt) ||
      (index === 0 ? name : `${name} – Ansicht ${index + 1}`),
    caption: asText(entry?.caption)
  }))
  .filter((entry: any, index: number, entries: any[]) =>
    entry.src &&
    entries.findIndex((candidate) => candidate.src === entry.src) === index
  );

const hero = gallery[0];

const pros = list<string>(
  value.pros ??
  source.strengths ??
  source.pros
).filter(Boolean);

const cons = list<string>(
  value.cons ??
  source.weaknesses ??
  source.cons
).filter(Boolean);

const bestFor = list<string>(
  value.bestFor ??
  source.decision?.bestFor ??
  source.decision?.goodFor
).filter(Boolean);

const notFor = list<string>(
  value.notFor ??
  source.decision?.attention ??
  source.decision?.notFor
).filter(Boolean);

const rawSpecs =
  value.specs ??
  source.specs ??
  source.specifications ??
  {};

const specEntries = Array.isArray(rawSpecs)
  ? rawSpecs
      .map((item: any) => ({
        label: asText(item?.label ?? item?.name ?? item?.title),
        value: asText(item?.value ?? item?.text ?? item?.description)
      }))
      .filter((item: any) => item.label && item.value)
  : Object.entries(rawSpecs ?? {})
      .map(([label, specValue]) => ({
        label,
        value: asText(specValue)
      }))
      .filter((item) => item.value);

const explicitQuickFacts = list<any>(
  source.productStandard2?.quickFacts ??
  source.quickFacts ??
  source.highlights
);

const quickFacts = (
  explicitQuickFacts.length
    ? explicitQuickFacts.map((fact: any) => ({
        label: asText(fact?.label ?? fact?.title ?? fact?.name, "Merkmal"),
        value: asText(fact?.value ?? fact?.text ?? fact?.description ?? fact),
        note: asText(fact?.note)
      }))
    : [
        value.capacity
          ? { label: "Kapazität", value: asText(value.capacity), note: "" }
          : null,
        value.useCase
          ? { label: "Einsatz", value: asText(value.useCase), note: "" }
          : null,
        ...specEntries.slice(0, 6)
      ]
).filter(Boolean).filter((fact: any) => fact.label && fact.value).slice(0, 8);

const review = value.review ?? source.review ?? {};
const reviewText = asText(
  review?.summary ??
  review?.verdict ??
  review?.text ??
  review?.body ??
  recommendation
);

const packageContents = list<any>(
  source.packageContents ??
  source.included ??
  source.scopeOfDelivery ??
  source.delivery
)
  .map((item) => asText(item))
  .filter(Boolean);

const faq = list<any>(
  source.productStandard2?.faq ??
  source.faq ??
  review?.faq
)
  .map((item: any) => ({
    question: asText(item?.question ?? item?.title),
    answer: asText(item?.answer ?? item?.text)
  }))
  .filter((item: any) => item.question && item.answer);

const affiliate = value.affiliate ?? source.affiliate ?? {};
const conversion = value.conversion ?? source.conversion ?? {};

const affiliateUrl = asText(
  affiliate.url ??
  conversion.url ??
  conversion.primaryUrl ??
  source.productUrl
);

const ctaLabel = asText(
  affiliate.label ??
  conversion.label ??
  conversion.ctaLabel ??
  conversion.primaryLabel,
  "Preis prüfen"
);

const price = asText(
  conversion.price ??
  conversion.currentPrice ??
  affiliate.price ??
  source.price
);

const priceNote = asText(
  conversion.priceNote ??
  conversion.note ??
  affiliate.note,
  "Preis und Verfügbarkeit können sich ändern."
);

const trust = source.editorial ?? source.trust ?? {};
const updatedAt = asText(
  trust.lastVerifiedAt ??
  source.updatedAt ??
  source.publishedAt
);

const testStatus = asText(
  source.testStatus ??
  trust.assessmentType ??
  trust.testStatus,
  "Redaktionelle Einordnung"
);

const alternatives = list<any>(alternativeRecommendations)
  .map((item: any) => {
    const entry = item?.product?.data ?? item?.data ?? item?.product ?? item;
    const slug =
      asText(entry?.slug ?? item?.slug);
    return {
      title: asText(entry?.title ?? entry?.name ?? item?.title, "Alternative"),
      href: asText(
        item?.href ??
        item?.url ??
        entry?.productUrl,
        slug ? `/produkt/${slug}/` : "#"
      ),
      image: imageUrl(
        entry?.images?.thumbnail ??
        entry?.images?.hero ??
        entry?.image ??
        item?.image
      ),
      reason: asText(
        item?.reason ??
        item?.description ??
        entry?.recommendation ??
        entry?.description
      ),
      score: Number(entry?.score ?? item?.score ?? 0)
    };
  })
  .filter((item: any) => item.title)
  .slice(0, 3);

const scoreLabel =
  editorialScore >= 90 ? "Hervorragend" :
  editorialScore >= 80 ? "Sehr gut" :
  editorialScore >= 70 ? "Gut" :
  editorialScore > 0 ? "Solide" :
  "Redaktionell eingeordnet";

const normalizeLabel = (input: unknown) =>
  asText(input)
    .toLocaleLowerCase("de-DE")
    .replace(/[-_]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const primaryQuickFactLabels = new Set([
  "geeignet für",
  "einsatz",
  "kapazität"
]);

const quickFactIcon = (label: unknown) => {
  const normalized = normalizeLabel(label);

  if (normalized.includes("geeignet")) return "users";
  if (normalized.includes("einsatz")) return "home";
  if (normalized.includes("kapazität") || normalized.includes("volumen")) return "capacity";
  if (normalized.includes("modell")) return "cube";
  if (normalized.includes("futterart")) return "bowl";
  if (normalized.includes("kroketten")) return "kibble";
  if (normalized.includes("portionseinheit")) return "portion";
  if (normalized.includes("portionszahl") || normalized.includes("mahlzeit")) return "calendar";
  if (normalized.includes("gewicht")) return "weight";
  if (normalized.includes("app") || normalized.includes("steuerung")) return "phone";
  if (normalized.includes("strom") || normalized.includes("akku")) return "power";
  if (normalized.includes("kamera")) return "camera";
  if (normalized.includes("wlan") || normalized.includes("wifi")) return "wifi";

  return "diamond";
};

const safeQuickFacts = quickFacts
  .filter((fact: any) => normalizeLabel(fact.value) !== "editorial-review")
  .filter((fact: any) => normalizeLabel(fact.label) !== "status")
  .slice(0, 10);

const primaryQuickFacts = safeQuickFacts.filter((fact: any) =>
  primaryQuickFactLabels.has(normalizeLabel(fact.label))
);

const secondaryQuickFacts = safeQuickFacts.filter((fact: any) =>
  !primaryQuickFactLabels.has(normalizeLabel(fact.label))
);
---

<section class="native-product" data-product-engine="4.1-premium">
  <header class="native-product__intro">
    <div class="native-product__badges">
      {category && (
        categoryHref
          ? (
              <a
                class="native-product__badge native-product__badge--category"
                href={categoryHref}
                aria-label={`Zum Vergleich und Ratgeberbereich ${category}`}
              >
                {category}
              </a>
            )
          : <span class="native-product__badge">{category}</span>
      )}
      {manufacturer && (
        manufacturerHref
          ? <a class="native-product__badge native-product__badge--soft native-product__badge--manufacturer" href={manufacturerHref} aria-label={`Alle Inhalte und Produkte von ${manufacturer}`}>{manufacturer}</a>
          : <span class="native-product__badge native-product__badge--soft">{manufacturer}</span>
      )}
    </div>

    <h1>{name}</h1>

    {description && <p class="native-product__lead">{description}</p>}

    {editorialScore > 0 && (
      <div class="native-product__ratings" aria-label={`Redaktionelle Bewertung ${editorialScore} von 100`}>
        <span class="native-product__score">
          <strong>{editorialScore.toLocaleString("de-DE")}</strong>
          <small>/100</small>
        </span>
        <span class="native-product__score-label">{scoreLabel}</span>
        {ratingCount > 0 && (
          <span class="native-product__rating-count">
            {ratingCount.toLocaleString("de-DE")} Bewertungen
          </span>
        )}
      </div>
    )}
  </header>

  <div class="native-product__commerce">
    <section class="native-gallery" data-native-gallery>
      {hero ? (
        <>
          <div class="native-gallery__stage">
            {gallery.map((image: any, index: number) => (
              <figure
                class:list={[
                  "native-gallery__slide",
                  { "is-active": index === 0 }
                ]}
                data-gallery-slide={index}
              >
                <img
                  src={image.src}
                  alt={image.alt}
                  width="1200"
                  height="900"
                  loading={index === 0 ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                />
                {image.caption && <figcaption>{image.caption}</figcaption>}
              </figure>
            ))}

            {gallery.length > 1 && (
              <>
                <button class="native-gallery__nav native-gallery__nav--prev" type="button" data-gallery-prev aria-label="Vorheriges Bild">‹</button>
                <button class="native-gallery__nav native-gallery__nav--next" type="button" data-gallery-next aria-label="Nächstes Bild">›</button>
                <span class="native-gallery__counter" data-gallery-counter>1/{gallery.length}</span>
              </>
            )}
          </div>

          {gallery.length > 1 && (
            <div class="native-gallery__thumbs" aria-label="Produktbilder">
              {gallery.map((image: any, index: number) => (
                <button
                  class:list={[
                    "native-gallery__thumb",
                    { "is-active": index === 0 }
                  ]}
                  type="button"
                  data-gallery-thumb={index}
                  aria-label={`Bild ${index + 1} anzeigen`}
                >
                  <img src={image.src} alt="" width="160" height="120" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </>
      ) : (
        <div class="native-gallery__fallback">
          <span>Produktbild folgt</span>
        </div>
      )}
    </section>

    <aside class="native-buybox" aria-label="Kaufoptionen">
      {editorialScore > 0 && (
        <div class="native-buybox__score">
          <strong>{editorialScore.toLocaleString("de-DE")}</strong>
          <span>/100</span>
          <small>{scoreLabel}</small>
        </div>
      )}

      {price && (
        <div class="native-buybox__price">
          <span>Aktueller Preis</span>
          <strong>{price}</strong>
        </div>
      )}

      {affiliateUrl ? (
        <a class="native-buybox__primary" href={affiliateUrl} rel="nofollow sponsored noopener" target="_blank">
          {ctaLabel}
          <span aria-hidden="true">→</span>
        </a>
      ) : (
        <span class="native-buybox__primary native-buybox__primary--disabled">Preis derzeit nicht verlinkt</span>
      )}

      <a class="native-buybox__secondary" href="#alternativen">
        Alternativen vergleichen
      </a>

      <p class="native-buybox__note">{priceNote}</p>

      <dl class="native-buybox__meta">
        {manufacturer && <div><dt>Hersteller</dt><dd>{manufacturer}</dd></div>}
        {category && <div><dt>Kategorie</dt><dd>{category}</dd></div>}
        {testStatus && <div><dt>Status</dt><dd>{testStatus}</dd></div>}
        {updatedAt && <div><dt>Aktualisiert</dt><dd>{updatedAt}</dd></div>}
      </dl>
    </aside>
  </div>

  {safeQuickFacts.length > 0 && (
    <section class="native-panel native-quickfacts" aria-labelledby="native-quickfacts-title">
      <header class="native-quickfacts__header">
        <div>
          <span>Produktüberblick</span>
          <h2 id="native-quickfacts-title">Das Wichtigste in Kürze</h2>
        </div>
        <p>Die wichtigsten Angaben vollständig und ohne abgeschnittene Inhalte.</p>
      </header>

      {primaryQuickFacts.length > 0 && (
        <div class="native-quickfacts__primary">
          {primaryQuickFacts.map((fact: any) => (
            <article class="native-quickfacts__card native-quickfacts__card--primary">
              <span class="native-quickfacts__icon" aria-hidden="true">
                {quickFactIcon(fact.label) === "users" && <svg viewBox="0 0 24 24"><path d="M8.5 11.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Zm7 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM2.5 20c0-3.1 2.7-5.5 6-5.5s6 2.4 6 5.5m0 0c0-2.5 2.1-4.5 4.8-4.5 1 0 1.8.2 2.7.7"/></svg>}
                {quickFactIcon(fact.label) === "home" && <svg viewBox="0 0 24 24"><path d="M4 10.5 12 4l8 6.5V20H4v-9.5Zm5 9.5v-6h6v6"/></svg>}
                {quickFactIcon(fact.label) === "capacity" && <svg viewBox="0 0 24 24"><path d="M7 4h10l1 4v11H6V8l1-4Zm-1 4h12M9 4V2h6v2"/></svg>}
                {quickFactIcon(fact.label) === "cube" && <svg viewBox="0 0 24 24"><path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Zm0 0v18m8-13.5-8 4.5-8-4.5"/></svg>}
                {quickFactIcon(fact.label) === "bowl" && <svg viewBox="0 0 24 24"><path d="M4 15c0 3 3.6 5 8 5s8-2 8-5H4Zm1-3h14l1 3H4l1-3Zm4-3c0-1 .8-2 1.8-2 .8 0 1.2.4 1.7 1 .5-.8 1.1-1.5 2.2-1.5 1.3 0 2.3 1 2.3 2.5"/></svg>}
                {quickFactIcon(fact.label) === "kibble" && <svg viewBox="0 0 24 24"><circle cx="7" cy="7" r="2"/><circle cx="15.5" cy="6.5" r="1.5"/><circle cx="11.5" cy="13" r="2.5"/><circle cx="18" cy="16.5" r="2"/><circle cx="5" cy="17" r="1.5"/></svg>}
                {quickFactIcon(fact.label) === "portion" && <svg viewBox="0 0 24 24"><path d="M5 4h11l2 5-2 11H7L5 4Zm11 2h3v5h-2M8 8h6M9 12h4"/></svg>}
                {quickFactIcon(fact.label) === "calendar" && <svg viewBox="0 0 24 24"><path d="M6 5h12v15H6V5Zm3-2v4m6-4v4M6 9h12M9 13h2m2 0h2m-6 3h2m2 0h2"/></svg>}
                {quickFactIcon(fact.label) === "weight" && <svg viewBox="0 0 24 24"><path d="M6 20h12L16.5 9h-9L6 20Zm3-11a3 3 0 0 1 6 0m-5 5h4"/></svg>}
                {quickFactIcon(fact.label) === "phone" && <svg viewBox="0 0 24 24"><path d="M7 3h10v18H7V3Zm3 3h4m-3 12h2"/></svg>}
                {quickFactIcon(fact.label) === "power" && <svg viewBox="0 0 24 24"><path d="M13 2 5 14h6l-1 8 9-13h-6V2Z"/></svg>}
                {quickFactIcon(fact.label) === "camera" && <svg viewBox="0 0 24 24"><path d="M4 7h4l1.5-2h5L16 7h4v12H4V7Zm8 9a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"/></svg>}
                {quickFactIcon(fact.label) === "wifi" && <svg viewBox="0 0 24 24"><path d="M4 9a12 12 0 0 1 16 0M7 12.5a7.5 7.5 0 0 1 10 0M10 16a3 3 0 0 1 4 0M12 20h.01"/></svg>}
                {quickFactIcon(fact.label) === "diamond" && <svg viewBox="0 0 24 24"><path d="m12 4 8 8-8 8-8-8 8-8Z"/></svg>}
              </span>
              <div>
                <small>{fact.label}</small>
                <strong>{fact.value}</strong>
                {fact.note && <span>{fact.note}</span>}
              </div>
            </article>
          ))}
        </div>
      )}

      {secondaryQuickFacts.length > 0 && (
        <div class="native-quickfacts__secondary">
          {secondaryQuickFacts.map((fact: any) => (
            <article class="native-quickfacts__card">
              <span class="native-quickfacts__icon" aria-hidden="true">
                {quickFactIcon(fact.label) === "users" && <svg viewBox="0 0 24 24"><path d="M8.5 11.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Zm7 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM2.5 20c0-3.1 2.7-5.5 6-5.5s6 2.4 6 5.5m0 0c0-2.5 2.1-4.5 4.8-4.5 1 0 1.8.2 2.7.7"/></svg>}
                {quickFactIcon(fact.label) === "home" && <svg viewBox="0 0 24 24"><path d="M4 10.5 12 4l8 6.5V20H4v-9.5Zm5 9.5v-6h6v6"/></svg>}
                {quickFactIcon(fact.label) === "capacity" && <svg viewBox="0 0 24 24"><path d="M7 4h10l1 4v11H6V8l1-4Zm-1 4h12M9 4V2h6v2"/></svg>}
                {quickFactIcon(fact.label) === "cube" && <svg viewBox="0 0 24 24"><path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Zm0 0v18m8-13.5-8 4.5-8-4.5"/></svg>}
                {quickFactIcon(fact.label) === "bowl" && <svg viewBox="0 0 24 24"><path d="M4 15c0 3 3.6 5 8 5s8-2 8-5H4Zm1-3h14l1 3H4l1-3Zm4-3c0-1 .8-2 1.8-2 .8 0 1.2.4 1.7 1 .5-.8 1.1-1.5 2.2-1.5 1.3 0 2.3 1 2.3 2.5"/></svg>}
                {quickFactIcon(fact.label) === "kibble" && <svg viewBox="0 0 24 24"><circle cx="7" cy="7" r="2"/><circle cx="15.5" cy="6.5" r="1.5"/><circle cx="11.5" cy="13" r="2.5"/><circle cx="18" cy="16.5" r="2"/><circle cx="5" cy="17" r="1.5"/></svg>}
                {quickFactIcon(fact.label) === "portion" && <svg viewBox="0 0 24 24"><path d="M5 4h11l2 5-2 11H7L5 4Zm11 2h3v5h-2M8 8h6M9 12h4"/></svg>}
                {quickFactIcon(fact.label) === "calendar" && <svg viewBox="0 0 24 24"><path d="M6 5h12v15H6V5Zm3-2v4m6-4v4M6 9h12M9 13h2m2 0h2m-6 3h2m2 0h2"/></svg>}
                {quickFactIcon(fact.label) === "weight" && <svg viewBox="0 0 24 24"><path d="M6 20h12L16.5 9h-9L6 20Zm3-11a3 3 0 0 1 6 0m-5 5h4"/></svg>}
                {quickFactIcon(fact.label) === "phone" && <svg viewBox="0 0 24 24"><path d="M7 3h10v18H7V3Zm3 3h4m-3 12h2"/></svg>}
                {quickFactIcon(fact.label) === "power" && <svg viewBox="0 0 24 24"><path d="M13 2 5 14h6l-1 8 9-13h-6V2Z"/></svg>}
                {quickFactIcon(fact.label) === "camera" && <svg viewBox="0 0 24 24"><path d="M4 7h4l1.5-2h5L16 7h4v12H4V7Zm8 9a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"/></svg>}
                {quickFactIcon(fact.label) === "wifi" && <svg viewBox="0 0 24 24"><path d="M4 9a12 12 0 0 1 16 0M7 12.5a7.5 7.5 0 0 1 10 0M10 16a3 3 0 0 1 4 0M12 20h.01"/></svg>}
                {quickFactIcon(fact.label) === "diamond" && <svg viewBox="0 0 24 24"><path d="m12 4 8 8-8 8-8-8 8-8Z"/></svg>}
              </span>
              <div>
                <small>{fact.label}</small>
                <strong>{fact.value}</strong>
                {fact.note && <span>{fact.note}</span>}
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  )}

  {(bestFor.length > 0 || notFor.length > 0) && (
    <section class="native-panel native-decision" aria-labelledby="native-decision-title">
      <h2 id="native-decision-title">Passt {name} zu dir?</h2>
      <div class="native-decision__grid">
        {bestFor.length > 0 && (
          <article class="native-decision__card native-decision__card--yes">
            <h3>Passt gut, wenn …</h3>
            <ul>
              {bestFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        )}

        {notFor.length > 0 && (
          <article class="native-decision__card native-decision__card--no">
            <h3>Weniger geeignet, wenn …</h3>
            <ul>
              {notFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        )}
      </div>
    </section>
  )}

  <section class="native-summary-grid">
    {pros.length > 0 && (
      <article class="native-panel native-list-card native-list-card--positive">
        <h2>Vorteile</h2>
        <ul>{pros.map((item) => <li>{item}</li>)}</ul>
      </article>
    )}

    {cons.length > 0 && (
      <article class="native-panel native-list-card native-list-card--negative">
        <h2>Nachteile</h2>
        <ul>{cons.map((item) => <li>{item}</li>)}</ul>
      </article>
    )}

    {(reviewText || recommendation) && (
      <article class="native-panel native-recommendation">
        <span>Unsere Empfehlung</span>
        <h2>Redaktionelles Urteil</h2>
        <p>{reviewText || recommendation}</p>
        {recommendation && reviewText !== recommendation && (
          <strong>{recommendation}</strong>
        )}
      </article>
    )}
  </section>

  {(specEntries.length > 0 || packageContents.length > 0) && (
