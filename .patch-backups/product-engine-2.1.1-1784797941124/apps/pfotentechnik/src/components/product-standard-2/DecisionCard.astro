---
const { decision } = Astro.props;
const goodFor = Array.isArray(decision?.goodFor) ? decision.goodFor : [];
const notFor = Array.isArray(decision?.notFor) ? decision.notFor : [];
---

<section class="decision-card" aria-labelledby="product-fit-title">
  <h2 id="product-fit-title">{decision?.title ?? "Passt dieses Produkt zu dir?"}</h2>
  <div class="decision-grid">
    {goodFor.length > 0 && (
      <div class="decision-panel decision-panel--positive">
        <h3>Passt zu dir, wenn …</h3>
        <ul>{goodFor.map((item) => <li><span aria-hidden="true">✓</span>{item}</li>)}</ul>
      </div>
    )}
    {notFor.length > 0 && (
      <div class="decision-panel decision-panel--negative">
        <h3>Weniger geeignet, wenn …</h3>
        <ul>{notFor.map((item) => <li><span aria-hidden="true">×</span>{item}</li>)}</ul>
      </div>
    )}
  </div>
</section>

<style>
  .decision-card {
    padding: clamp(18px, 3vw, 28px);
    border: 1px solid var(--ps2-border, #dce5e0);
    border-radius: 18px;
    background: var(--ps2-surface, #fff);
    color: var(--ps2-text, #15211b);
  }
  .decision-card h2 { margin: 0 0 18px; font-size: clamp(1.2rem, 2vw, 1.5rem); }
  .decision-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 14px; }
  .decision-panel { padding: 18px; border-radius: 14px; border: 1px solid transparent; }
  .decision-panel--positive { background: color-mix(in srgb, #2e7d32 10%, var(--ps2-surface, #fff)); border-color: color-mix(in srgb, #2e7d32 26%, transparent); }
  .decision-panel--negative { background: color-mix(in srgb, #dc2626 9%, var(--ps2-surface, #fff)); border-color: color-mix(in srgb, #dc2626 24%, transparent); }
  .decision-panel h3 { margin: 0 0 12px; font-size: 1rem; }
  .decision-panel ul { display: grid; gap: 9px; margin: 0; padding: 0; list-style: none; }
  .decision-panel li { display: grid; grid-template-columns: 22px 1fr; gap: 8px; align-items: start; }
  .decision-panel--positive li span { color: #2e7d32; font-weight: 800; }
  .decision-panel--negative li span { color: #dc2626; font-weight: 800; }
  @media (max-width: 720px) { .decision-grid { grid-template-columns: 1fr; } }
  :global([data-theme="dark"]) .decision-card,
  :global(.dark) .decision-card {
    --ps2-surface: #171f1b;
    --ps2-border: #2c3932;
    --ps2-text: #eff6f2;
  }
</style>
