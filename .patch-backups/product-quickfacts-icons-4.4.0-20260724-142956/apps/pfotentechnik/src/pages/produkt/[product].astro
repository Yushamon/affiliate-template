---
import {
  getCollection,
  getEntry
} from "astro:content";
import { getImage } from "astro:assets";

import ProjectLayout from "../../layouts/ProjectLayout.astro";

import Breadcrumbs from "@affiliate-core/components/Breadcrumbs.astro";

import ProductRenderer from "../../components/product-standard-2/ProductRenderer.astro";
import AutoLinkContent from "@affiliate-core/components/AutoLinkContent.astro";
import RelatedArticles from "@affiliate-core/components/RelatedArticles.astro";
import DecisionNextSteps from "../../components/DecisionNextSteps.astro";
import { addAmazonTrackingId } from "@affiliate-core/affiliate";
import { projectConfig, site } from "../../project.config";

import {
  getAlternativeRecommendations
} from "@app/domain/productAlternatives";
import {
  getProductBreadcrumbs,
  getRelatedContent
} from "@app/domain/content";
import {
  getInternalLinkDefinitions,
  getSourceContexts
} from "../../domain/content/internalLinks";
import { buildProductNextSteps } from "../../domain/recommendationLinks";

type PageProps = {
  contentProductId: string;
};

export async function getStaticPaths() {
  const contentProducts =
    await getCollection(
      "products"
    );

  return contentProducts.map(
    (entry) => ({
      params: {
        product: entry.data.slug
      },
      props: {
        contentProductId: entry.id
      } satisfies PageProps
    })
  );
}

const { contentProductId } =
  Astro.props as PageProps;

const contentEntry =
  await getEntry(
    "products",
    contentProductId
  );

if (!contentEntry) {
  throw new Error(
    `Das Content-Produkt "${contentProductId}" wurde nicht gefunden.`
  );
}

const contentProduct =
  contentEntry.data;

const breadcrumbs =
  getProductBreadcrumbs(contentEntry);

const [allProducts, pages, comparisons, manufacturers] =
  await Promise.all([
    getCollection("products"),
    getCollection("pages"),
    getCollection("comparisons"),
    getCollection("manufacturers")
  ]);

const internalLinkDefinitions = getInternalLinkDefinitions({
  pages,
  products: allProducts,
  comparisons,
  manufacturers
});
const sourceContexts = getSourceContexts(contentProduct);

const alternativeRecommendations =
  getAlternativeRecommendations(
    contentEntry,
    allProducts,
    3
  );

const relatedEntries = await getRelatedContent({
  currentSlug: contentProduct.slug,
  tags: contentProduct.related?.tags.length
    ? contentProduct.related.tags
    : contentProduct.tags,
  sections: contentProduct.hub?.sections ?? [],
  type: "product",
  exclude: contentProduct.related?.exclude ?? [],
  limit: contentProduct.related?.limit ?? 4
});

const relatedItems = relatedEntries.map((entry) => ({
  href: entry.href,
  label: entry.type === "product"
    ? "Produkt"
    : entry.type === "manufacturer"
      ? "Hersteller"
      : entry.type === "comparison"
        ? "Vergleich"
        : "Ratgeber",
  title: entry.hubTitle,
  text: entry.hubDescription
}));

const productNextSteps = buildProductNextSteps({
  product: contentProduct,
  pages,
  comparisons
});

const pageTitle =
  contentProduct.title;

const pageDescription =
  contentProduct.description;

const seoTitle =
  contentProduct.seo?.title ??
  `${contentProduct.title} im Test und Vergleich`;

const seoDescription =
  contentProduct.seo?.description ??
  contentProduct.description;

const canonical =
  contentProduct.seo?.canonical ??
  contentProduct.productUrl ??
  `/produkt/${contentProduct.slug}/`;

const heroImage =
  contentProduct.images.hero.src;

const heroImageAlt =
  contentProduct.images.hero.alt ??
  pageTitle;

const productScoreRaw = Number(contentProduct.score ?? contentProduct.rating ?? 0);
const productScore100 =
  productScoreRaw > 0 && productScoreRaw <= 10
    ? Math.round(productScoreRaw * 10)
    : Math.max(0, Math.min(100, Math.round(productScoreRaw)));

const productSuitabilityLabels = Array.from(new Set([
  ...(Array.isArray(contentProduct.decision?.bestFor)
    ? contentProduct.decision.bestFor
    : []),
  ...(Array.isArray(contentProduct.petSize)
    ? contentProduct.petSize
    : contentProduct.petSize
      ? [contentProduct.petSize]
      : []),
  ...(contentProduct.animal
    ? [contentProduct.animal]
    : [])
]))
  .map((value) => String(value).trim())
  .filter(Boolean)
  .slice(0, 4);

const compactProductSpecs = (() => {
  const source = contentProduct.specs ?? {};
  const entries = Array.isArray(source)
    ? source
    : Object.entries(source).map(([label, value]) => ({
        label,
        value:
          value && typeof value === "object"
            ? value.value ?? value.label ?? value.text ?? ""
            : value
      }));

  const blocked = new Set([
    "status",
    "prüfstatus",
    "teststatus",
    "bewertungsstatus"
  ]);

  const normalized = entries
    .map((item) => ({
      ...item,
      label: String(item?.label ?? item?.title ?? item?.name ?? "").trim(),
      value: String(item?.value ?? item?.text ?? item?.description ?? "").trim()
    }))
    .filter((item) =>
      item.label &&
      item.value &&
      !blocked.has(item.label.toLowerCase()) &&
      item.value.toLowerCase() !== "editorial-review"
    )
    .slice(0, 8);

  if (productSuitabilityLabels.length) {
    normalized.unshift({
      label: "Geeignet für",
      value: productSuitabilityLabels.join(", ")
    });
  }

  return normalized.slice(0, 8);
})();

// Product Renderer 4.1 Premium: bestehende Datenlogik bleibt unverändert.
const reviewProduct = {
        name: contentProduct.title,
        manufacturerLabel:
          contentProduct.manufacturer.name,
        category:
          contentProduct.category.label,
        recommendation:
          contentProduct.recommendation,
        rating: undefined,
        score: productScore100,
        capacity:
          contentProduct.capacity,
        expandable:
          contentProduct.expandable,
        useCase:
          contentProduct.useCase,
        pros:
          contentProduct.strengths,
        cons:
          contentProduct.weaknesses,
        bestFor:
          contentProduct.decision.bestFor,
        notFor:
          contentProduct.decision.attention,
        ratings:
          contentProduct.ratings,
        specs: compactProductSpecs,
        review:
          contentProduct.review,
        images: {
          hero: {
            src: heroImage,
            alt: heroImageAlt
          },
          gallery:
            contentProduct.images.gallery
        },
        conversion:
          contentProduct.conversion,
        affiliate:
          contentProduct.affiliate
            ? {
                ...contentProduct.affiliate,
                url: addAmazonTrackingId(
                  contentProduct.affiliate.url,
                  projectConfig.affiliate.amazon.trackingId
                )
              }
            : undefined
      };

const optimizedOgImage = await getImage({
  src: heroImage,
  width: 1200,
  quality: "high"
});

const categoryLabel =
  contentProduct.category.label;

const categoryHref =
  contentProduct.category.path ??
  "/smarte-futterautomaten/";

const author =
  contentProduct.author ?? {
    name:
      "PfotenTechnik Redaktion",

    role:
      "Redaktion"
  };

const publishedAt = contentProduct.publishedAt;
const updatedAt =
  contentProduct.updatedAt ??
  publishedAt;


const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: contentProduct.title,
  description: seoDescription,
  url: new URL(canonical, site.domain).toString(),
  image: [
    new URL(optimizedOgImage.src, site.domain).toString()
  ],
  sku: contentProduct.slug,
  category: contentProduct.category.label,
  brand: {
    "@type": "Brand",
    name: contentProduct.manufacturer.name
  },
  review: {
    "@type": "Review",
    name: `${contentProduct.title} – redaktionelle Einordnung`,
    reviewBody: contentProduct.recommendation,
    author: {
      "@type": "Organization",
      name: "PfotenTechnik Redaktion"
    },
    reviewRating: {
      "@type": "Rating",
      ratingValue: contentProduct.rating,
      bestRating: 5,
      worstRating: 1
    }
  }
};

const productSearchValues = [
  contentProduct.useCase,
  ...contentProduct.tags,
  ...contentProduct.features,
  ...contentProduct.decision.bestFor,
  ...contentProduct.decision.attention
]
  .filter(Boolean)
  .join(" ")
  .toLowerCase();

const hasApp =
  (contentProduct.ratings.app ?? 0) > 1 ||
  productSearchValues.includes("app");

const supportsWetFood =
  [
        "nassfutter",
        "wetfood",
        "wet food",
        "kühlung",
        "gekühlt"
      ].some(
        (term) =>
          productSearchValues.includes(
            term
          )
      );

const hasCamera =
  [
        "kamera",
        "camera",
        "video"
      ].some(
        (term) =>
          productSearchValues.includes(
            term
          )
      );

const brandLabel =
  contentProduct.manufacturer.name;

const everydayCriteria = [
  {
    title:
      "App",

    text: hasApp
      ? `Die App-Funktionen von ${brandLabel} werden nach Zeitplanung, Statusmeldungen und Verständlichkeit eingeordnet. Entscheidend bleibt, ob gespeicherte Abläufe auch bei kurzen Verbindungsproblemen sinnvoll weiterlaufen.`
      : "Dieses Modell arbeitet ohne App. Das reduziert Fernfunktionen, macht die Bedienung aber unabhängig von WLAN, Konto und Cloud-Diensten."
  },
  {
    title:
      "Portionierung",

    text: supportsWetFood
      ? "Die Portionen werden vorab auf getrennte Fächer verteilt. Dadurch ist die Menge direkt kontrollierbar. Kühlung und Standzeit müssen trotzdem passend geplant werden."
      : "Förderschritte entsprechen nicht automatisch einem festen Grammgewicht. Die Ausgabe sollte mit dem verwendeten Futter mehrfach nachgewogen und anschließend passend eingestellt werden."
  },
  {
    title:
      "Reinigung",

    text: supportsWetFood
      ? "Bei Nassfutter sind herausnehmbare Schalen und die Reinigung nach jeder Nutzung besonders wichtig. Auch Deckelränder und Kontaktflächen müssen frei von Resten bleiben."
      : "Napf, Vorratsbehälter und erreichbare Teile des Futterwegs sollten regelmäßig von Krümeln und Futterfett befreit werden."
  },
  {
    title:
      "Zuverlässigkeit",

    text:
      "Bewertet werden Stromreserve, lokal gespeicherte Zeitpläne und die konstruktive Eignung für die angegebene Futterart. Eine verantwortliche Person sollte die Funktion dennoch regelmäßig kontrollieren."
  },
  {
    title:
      "Sicherheit",

    text:
      "Deckel, Futterauslass und Stand müssen zum Tier passen. Vor längerer Abwesenheit sollte geprüft werden, ob das Tier das Gerät verschieben, öffnen oder blockieren kann."
  },
  {
    title:
      "Lautstärke",

    text: supportsWetFood
      ? "Der drehende Deckel ist nur kurz aktiv, kann sensible Tiere anfangs aber irritieren. Eine schrittweise Gewöhnung am vertrauten Futterplatz ist sinnvoll."
      : `Der Motor ist bei jeder Ausgabe kurz hörbar${hasCamera ? "; zusätzliche Kamera- oder Audiofunktionen sollten behutsam eingeführt werden" : ""}. Empfindliche Tiere sollten zunächst bei einzelnen Ausgaben beobachtet werden.`
  }
];

---

<ProjectLayout
  title={`${pageTitle} Testbericht`}
  seoTitle={seoTitle}
  description={pageDescription}
  seoDescription={seoDescription}
  canonical={canonical}
  noindex={contentProduct.seo?.noindex ?? false}
  ogImage={optimizedOgImage.src}
  author={author}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  categoryLabel={categoryLabel}
  breadcrumbs={breadcrumbs}
  schemaType="webpage"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(productSchema)}
  />

  <Breadcrumbs items={breadcrumbs} />

  <main class="product-detail pt-product-detail" data-product-page>
    <AutoLinkContent
      definitions={internalLinkDefinitions}
      sourcePath={canonical}
      sourceGroup="product"
      sourceContexts={sourceContexts}
      maxLinksPerPage={5}
    >
      <ProductRenderer
        product={{
          slug: contentEntry.slug,
          data: contentProduct
        }}
        reviewProduct={reviewProduct}
        alternativeRecommendations={alternativeRecommendations}
      />
    </AutoLinkContent>
<section
      class="pt-everyday-review"
      aria-labelledby="pt-everyday-review-title"
    >
      <header>
        <span>
          Alltagstest
        </span>

        <h2 id="pt-everyday-review-title">
          Die wichtigsten Kriterien im Alltag
        </h2>

        <p>
          Diese Punkte zeigen, worauf es bei Einrichtung,
          Fütterung und laufender Kontrolle ankommt.
        </p>
      </header>

      <div class="pt-everyday-review-grid">
        {
          everydayCriteria.map(
            (criterion) => (
              <article>
                <h3>
                  {
                    criterion.title
                  }
                </h3>

                <p>
                  {
                    criterion.text
                  }
                </p>
              </article>
            )
          )
        }
      </div>
    </section>

    <aside
      class="pt-product-health"
      aria-labelledby="pt-product-health-title"
    >
      <span>
        Gesundheitshinweis
      </span>

      <div>
        <h2 id="pt-product-health-title">
          Routinen unterstützen, Veränderungen beobachten
        </h2>

        <p>
          Ein Futterautomat unterstützt Routinen, ersetzt
          aber keine tierärztliche Einschätzung. Auffällige
          Veränderungen bei Futteraufnahme, Verhalten oder
          Wohlbefinden müssen persönlich geprüft und
          gegebenenfalls fachlich abgeklärt werden.
        </p>
      </div>
    </aside>

    <DecisionNextSteps
      title="Passend weiterentscheiden"
      intro="Öffne den passenden Vergleich oder die Kaufberatung für diesen Anwendungsfall."
      items={productNextSteps}
    />

    <RelatedArticles items={relatedItems} />
  </main>

<script is:inline data-pt-editorial-status-cleanup>
  (() => {
    const root = document.querySelector('[data-product-page]');
    if (!root) return;

    const hiddenLabels = new Set([
      'editorial review',
      'editorial-review',
      'redaktionelle bewertung',
      'redaktionell bewertet'
    ]);

    root.querySelectorAll(
      '[data-test-status], [data-review-status], [class*="test-status"], [class*="review-status"], [class*="status"]'
    ).forEach((element) => {
      const value = (
        element.getAttribute('data-test-status') ||
        element.getAttribute('data-review-status') ||
        element.textContent ||
        ''
      ).trim().toLocaleLowerCase('de');

      if (hiddenLabels.has(value)) {
        element.remove();
      }
    });
  })();
</script>


<style is:global>
  /* PT PRODUCT DARK + MOBILE FIX 4.2 START */

  /* Produktseite zuverlässig im verfügbaren Layout zentrieren. */
  [data-product-page].pt-product-detail {
    width: min(100%, 1280px);
    max-width: 1280px;
    min-width: 0;
    margin-inline: auto;
    padding-inline: 0;
    overflow: clip;
  }

  [data-product-page].pt-product-detail,
  [data-product-page].pt-product-detail > *,
  [data-product-page].pt-product-detail [data-product-engine],
  [data-product-page].pt-product-detail .native-product,
  [data-product-page].pt-product-detail .native-product > *,
  [data-product-page].pt-product-detail .native-product__commerce,
  [data-product-page].pt-product-detail .native-gallery,
  [data-product-page].pt-product-detail .native-buybox,
  [data-product-page].pt-product-detail .native-panel {
    min-width: 0;
    max-width: 100%;
  }

  /* Verhindert, dass lange Titel, Chips oder Metadaten die Seite verbreitern. */
  [data-product-page] h1,
  [data-product-page] h2,
  [data-product-page] h3,
  [data-product-page] p,
  [data-product-page] a,
  [data-product-page] span,
  [data-product-page] dd,
  [data-product-page] dt {
    overflow-wrap: anywhere;
  }

  [data-product-page] img,
  [data-product-page] video,
  [data-product-page] svg {
    max-width: 100%;
  }

  /* Dark Mode für Renderer und nachgelagerte Produktblöcke. */
  :is(
    html[data-theme='dark'],
    html.dark,
    body[data-theme='dark'],
    body.dark,
    [data-theme='dark']
  ) [data-product-page] {
    color-scheme: dark;
    --np-page: #07111d;
    --np-surface: #0d1a28;
    --np-surface-raised: #102131;
    --np-surface-soft: #132536;
    --np-surface-muted: #172d41;
    --np-text: #f7fafc;
    --np-text-soft: #d9e2ec;
    --np-muted: #aebdca;
    --np-border: #294054;
    --np-border-strong: #36526a;
    --np-green: #54d989;
    --np-green-strong: #75e5a3;
    --np-green-soft: rgba(84, 217, 137, .12);
    --np-red: #ff7b7b;
    --np-red-soft: rgba(255, 123, 123, .10);
  }

  :is(
    html[data-theme='dark'],
    html.dark,
    body[data-theme='dark'],
    body.dark,
    [data-theme='dark']
  ) [data-product-page] :is(
    .native-product__intro,
    .native-gallery__stage,
    .native-gallery__fallback,
    .native-buybox,
    .native-panel,
    .pt-everyday-review,
    .pt-everyday-review article,
    .pt-product-health
  ) {
    border-color: var(--np-border, #294054) !important;
    background-color: var(--np-surface, #0d1a28) !important;
    color: var(--np-text, #f7fafc) !important;
    box-shadow: 0 18px 42px rgba(0, 0, 0, .28) !important;
  }

  :is(
    html[data-theme='dark'],
    html.dark,
    body[data-theme='dark'],
    body.dark,
    [data-theme='dark']
  ) [data-product-page] .native-product__intro {
    background:
      radial-gradient(circle at 88% 10%, rgba(84, 217, 137, .12), transparent 34%),
      linear-gradient(145deg, #102131, #0d1a28) !important;
  }

  :is(
    html[data-theme='dark'],
    html.dark,
    body[data-theme='dark'],
    body.dark,
    [data-theme='dark']
  ) [data-product-page] .native-gallery__stage {
    background: linear-gradient(145deg, #102131, #132536) !important;
  }

  :is(
    html[data-theme='dark'],
    html.dark,
    body[data-theme='dark'],
    body.dark,
    [data-theme='dark']
  ) [data-product-page] :is(h1, h2, h3, strong, dt) {
    color: var(--np-text, #f7fafc) !important;
  }

  :is(
    html[data-theme='dark'],
    html.dark,
    body[data-theme='dark'],
    body.dark,
    [data-theme='dark']
  ) [data-product-page] :is(p, dd, small, .native-product__lead, .native-product__score-label, .native-product__rating-count) {
    color: var(--np-text-soft, #d9e2ec) !important;
  }

  :is(
    html[data-theme='dark'],
    html.dark,
    body[data-theme='dark'],
    body.dark,
    [data-theme='dark']
  ) [data-product-page] .native-gallery__thumb {
    border-color: var(--np-border, #294054);
    background: var(--np-surface-soft, #132536);
  }

  :is(
    html[data-theme='dark'],
    html.dark,
    body[data-theme='dark'],
    body.dark,
    [data-theme='dark']
  ) [data-product-page] .native-buybox__secondary {
    border-color: var(--np-border-strong, #36526a);
    background: var(--np-surface-soft, #132536);
    color: var(--np-text, #f7fafc);
  }

  @media (max-width: 767px) {
    /* Kompensiert äußere Container-Paddings und hält alles mittig. */
    [data-product-page].pt-product-detail {
      width: 100%;
      max-width: 100%;
      margin-inline: auto;
      padding-inline: 0;
      overflow-x: clip;
    }

    [data-product-page] .native-product {
      width: 100%;
      gap: 16px;
    }

    [data-product-page] .native-product__intro {
      width: 100%;
      padding: 20px 16px;
      border-radius: 18px;
      text-align: left;
    }

    [data-product-page] .native-product__badges,
    [data-product-page] .native-product__ratings {
      max-width: 100%;
      justify-content: flex-start;
    }

    [data-product-page] .native-product h1 {
      max-width: 100%;
      font-size: clamp(2rem, 10.5vw, 3rem);
      line-height: 1.04;
      letter-spacing: -.04em;
    }

    [data-product-page] .native-gallery__stage,
    [data-product-page] .native-gallery__fallback,
    [data-product-page] .native-buybox,
    [data-product-page] .native-panel,
    [data-product-page] .pt-everyday-review,
    [data-product-page] .pt-product-health {
      width: 100%;
      max-width: 100%;
      margin-inline: auto;
      border-radius: 18px;
    }

    [data-product-page] .native-gallery__stage,
    [data-product-page] .native-gallery__fallback {
      min-height: 0;
    }

    [data-product-page] .native-gallery__slide img {
      width: 100%;
      height: auto;
      max-height: 70vh;
      padding: 10px;
      object-fit: contain;
    }

    [data-product-page] .native-gallery__thumbs {
      width: 100%;
      max-width: 100%;
      padding-inline: 0;
      scroll-padding-inline: 0;
    }

    [data-product-page] .native-buybox,
    [data-product-page] .native-panel,
    [data-product-page] .pt-everyday-review,
    [data-product-page] .pt-product-health {
      padding-inline: 16px;
    }

    [data-product-page] .native-buybox__meta div {
      grid-template-columns: minmax(0, 1fr);
      gap: 4px;
    }
  }

  @supports not (overflow: clip) {
    [data-product-page].pt-product-detail {
      overflow-x: hidden;
    }
  }

  /* PT PRODUCT DARK + MOBILE FIX 4.2 END */
</style>
<style is:global>
/* PT mobile product breadcrumb 4.2.0 */
@media(max-width:720px){
  body:has([data-product-page]) :is(nav[aria-label="Breadcrumb"],nav[aria-label="Breadcrumbs"],.breadcrumbs,.breadcrumb,.product-breadcrumbs,[class*="breadcrumb"]){ display:none!important; }
  body:has([data-product-page]) main[data-product-page],body:has([data-product-page]) .product-detail{ padding-top:clamp(.9rem,4vw,1.3rem); }
}
/* End PT mobile product breadcrumb 4.2.0 */
</style>

</ProjectLayout>
